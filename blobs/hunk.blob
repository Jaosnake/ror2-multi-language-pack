				SkinDef item = Skins.NewSkinDef(gameObject, "ROB_HUNK_BODY_DEFAULT_SKIN_NAME", HunkAssets.mainAssetBundle.LoadAsset<Sprite>("texMainSkin"), baseRendererInfos);
