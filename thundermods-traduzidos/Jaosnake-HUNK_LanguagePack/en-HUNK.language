{
    "en": {
        "ROB_HUNK_BODY_NAME": "HUNK",
        "ROB_HUNK_BODY_DESCRIPTION": "HUNK is an elite infiltrator who carries a large arsenal of weapons obtained via OSP (On-Site Procurement).<color=#CCD3E0>\n\n< ! > Use your Combat Knife on weaker enemies to conserve ammo.\n\n< ! > Obtaining the G-Virus Sample will give you a keycard, allowing access to weapon cases on each Stage.\n\n< ! > Use Quickstep near an enemy or projectile attack to perform a Perfect Dodge, then counterattack with your Primary.\n\n< ! > Ammo is scarce, but can be found in opened chests. Secondary stock and cooldown reduction also affect ammo.\n\n< ! > This is war. Survival is your responsibility. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SUBTITLE": "The Reaper",
        "ROB_HUNK_BODY_OUTRO_FLAVOR": "..and so he departed, all good.",
        "ROB_HUNK_BODY_OUTRO_FAILURE": "..and so he vanished, human unit now neutralized.",
        "ROB_HUNK_BODY_DEFAULT_SKIN_NAME": "Default",
        "ROB_HUNK_BODY_CLASSIC_SKIN_NAME": "RE2make",
        "ROB_HUNK_BODY_TOFU_SKIN_NAME": "Tofu",
        "ROB_HUNK_BODY_SUPER_SKIN_NAME": "<color=#FFFF00>Early Supporter</color>",
        "ROB_HUNK_BODY_LIGHTWEIGHT_SKIN_NAME": "Lightweight",
        "ROB_HUNK_BODY_GUERRILLA_SKIN_NAME": "Trooper",
        "ROB_HUNK_BODY_ROOKIE_SKIN_NAME": "Rookie",
        "ROB_HUNK_BODY_SWAT_SKIN_NAME": "Peacekeeper",
        "ROB_HUNK_BODY_LEON_SKIN_NAME": "Specialist",
        "ROB_HUNK_BODY_LEONSHIRT_SKIN_NAME": "Specialist EX",
        "ROB_HUNK_BODY_ENFORCER_SKIN_NAME": "Bulldozer",
        "ROB_HUNK_BODY_WESKER_SKIN_NAME": "Mastermind",
        "ROB_HUNK_BODY_DOOM_SKIN_NAME": "Slayer",
        "ROB_HUNK_BODY_COMMANDO_SKIN_NAME": "Commando",
        "ROB_HUNK_BODY_JACKET_SKIN_NAME": "Jacket",
        "ROB_HUNK_BODY_PPASSIVE_NAME": "OSP (On-Site Procurement)",
        "ROB_HUNK_BODY_PPASSIVE_DESCRIPTION": "HUNK can collect <color=#FFFF00>U.C. Keycards</color> to open <style=cIsDamage>weapon cases</style> and expand his arsenal. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_PPASSIVE2_NAME": "Forgotten Soldier",
        "ROB_HUNK_BODY_PPASSIVE2_DESCRIPTION": "The first <style=cIsHealth>boss</style> to die on each Stage drops a <style=cIsDamage>supply package</style> containing a weapon or accessory. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_PASSIVE_NAME": "Shadow Fight",
        "ROB_HUNK_BODY_PASSIVE_DESCRIPTION": "Start with a <style=cIsDamage>LE 5</style> and a <style=cIsDamage>secondary weapon</style>. You can <style=cIsDamage>scavenge</style> <style=cIsUtility>chests</style> for ammo. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_PASSIVE2_NAME": "Impending Dread",
        "ROB_HUNK_BODY_PASSIVE2_DESCRIPTION": "Start with a <style=cIsDamage>full arsenal</style>, <style=cIsHealth>BUT</style> you can no longer <style=cIsHealth>obtain additional ammo</style>. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_RANDOMPASSIVE_NAME": "New Game+",
        "ROB_HUNK_BODY_RANDOMPASSIVE_DESCRIPTION": "Start with a <style=cIsDamage>LE 5</style> and a <style=cIsDamage>secondary weapon</style>. You can <style=cIsDamage>scavenge</style> <style=cIsUtility>chests</style> for ammo. <style=cIsHealth>All weapon case contents are random.</style> <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SHOTGUNPASSIVE_NAME": "Supreme Authority",
        "ROB_HUNK_BODY_SHOTGUNPASSIVE_DESCRIPTION": "Start with a <style=cIsDamage>W-870</style> and a <style=cIsDamage>secondary weapon</style>. You can <style=cIsDamage>scavenge</style> <style=cIsUtility>chests</style> for ammo. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SMGPASSIVE_NAME": "Supreme Mercenary",
        "ROB_HUNK_BODY_SMGPASSIVE_DESCRIPTION": "Start <style=cIsHealth>ONLY</style> with a <style=cIsDamage>fully upgraded LE 5</style>. You can <style=cIsDamage>scavenge</style> <style=cIsUtility>chests</style> for ammo. The <style=cIsDamage>Special</style> is replaced by <color=#C80202>Chaos Mode</color>. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_WPASSIVE_NAME": "Complete Global Saturation",
        "ROB_HUNK_BODY_WPASSIVE_DESCRIPTION": "Start <style=cIsHealth>ONLY</style> with a <style=cIsDamage>secondary weapon</style>. You can <style=cIsDamage>scavenge</style> <style=cIsUtility>chests</style> for ammo. The <style=cIsDamage>Utility</style> is replaced by <color=#C80202>Uroboros</color>. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_FLAMERPASSIVE_NAME": "Pyromania",
        "ROB_HUNK_BODY_FLAMERPASSIVE_DESCRIPTION": "Start <style=cIsHealth>ONLY</style> with a <style=cIsDamage>Chemical Flamethrower</style>. You can <style=cIsDamage>scavenge</style> <style=cIsUtility>chests</style> for ammo. <style=cIsHealth>Only ONE weapon case spawns per Stage.</style> <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_PRIMARY_KNIFE_NAME": "Combat Knife",
        "ROB_HUNK_BODY_PRIMARY_KNIFE_DESCRIPTION": "<style=cIsUtility>Draw.</style> <style=cIsDamage>Cut</style> nearby combatants for <style=cIsDamage>200% damage</style>, inflicting <style=cIsHealth>Mangled</style>. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_PRIMARY_CQC_NAME": "CQC (Close Quarters Combat)",
        "ROB_HUNK_BODY_PRIMARY_CQC_DESCRIPTION": "<style=cIsUtility>Draw.</style> <style=cIsDamage>Kick twice</style> for <style=cIsDamage>200% and 250% damage</style>. If the <style=cIsUtility>second kick</style> connects, follow up with a <style=cIsDamage>Counterattack</style>. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_PRIMARY_RELOAD_NAME": "Reload",
        "ROB_HUNK_BODY_RELOAD_DESCRIPTION": "Reload your current weapon. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SECONDARY_AIM_NAME": "Aim Steadily",
        "ROB_HUNK_BODY_SECONDARY_AIM_DESCRIPTION": "Aim, <style=cIsUtility>exposing enemy weak points</style>. <style=cIsDamage>Using primary while aiming fires your equipped weapon.</style> <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_UTILITY_DODGE_NAME": "Quickstep",
        "ROB_HUNK_BODY_UTILITY_DODGE_DESCRIPTION": "<style=cIsUtility>Advance</style> a short distance. If used preemptively to <style=cIsUtility>avoid an attack</style>, perform a <style=cIsDamage>Perfect Dodge</style>. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_UTILITY_DODGE_SCEPTER_NAME": "Uroboros",
        "ROB_HUNK_BODY_UTILITY_DODGE_SCEPTER_DESCRIPTION": "<style=cIsUtility>Advance</style> a short distance. If used preemptively to <style=cIsUtility>avoid an attack</style>, perform a <style=cIsDamage>Perfect Dodge</style>. The power of Uroboros flows through you. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_UTILITY_PARRY_NAME": "Parry",
        "ROB_HUNK_BODY_UTILITY_PARRY_DESCRIPTION": "<style=cIsUtility>Block</style> an attack, <style=cIsDamage>nullifying</style> the damage and <style=cIsUtility>refunding the cooldown</style>. If used preemptively, perform a <style=cIsDamage>Perfect Parry</style>. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_UTILITY_BASH_NAME": "Shoulder Bash",
        "ROB_HUNK_BODY_UTILITY_BASH_DESCRIPTION": "<style=cIsUtility>Hit</style> nearby enemies with your shoulder, <style=cIsUtility>stunning them</style> for <style=cIsDamage>400% damage</style>. If used preemptively to <style=cIsUtility>cancel an attack</style>, perform a <style=cIsDamage>Perfect Deflection</style>. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SPECIAL_SWAP_NAME": "Legion",
        "ROB_HUNK_BODY_SPECIAL_SWAP_DESCRIPTION": "<style=cIsUtility>Swap</style> to a <style=cIsDamage>different weapon</style>. Tap to swap to your <style=cIsUtility>last used weapon</style>. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SPECIAL_MAYHEM_NAME": "Chaos Mode",
        "ROB_HUNK_BODY_SPECIAL_MAYHEM_DESCRIPTION": "Enter <style=cIsDamage>Chaos Mode</style>, drastically increasing weapon performance. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_CONFIRM_NAME": "Confirm",
        "ROB_HUNK_BODY_CONFIRM_DESCRIPTION": "Proceed with current ability. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_CANCEL_NAME": "Cancel",
        "ROB_HUNK_BODY_CANCEL_DESCRIPTION": "Cancel current ability. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_KNIFE_DEFAULT_NAME": "Combat Knife",
        "ROB_HUNK_BODY_KNIFE_DEFAULT_DESCRIPTION": "A standard military knife. Certainly useful in tight spots. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_KNIFE_INFINITE_NAME": "Combat Knife EX",
        "ROB_HUNK_BODY_KNIFE_INFINITE_DESCRIPTION": "A specially treated military knife hardened to an unbelievable degree. Said to be made to truly last. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_KNIFE_HIDDEN_NAME": "Hidden Blade",
        "ROB_HUNK_BODY_KNIFE_HIDDEN_DESCRIPTION": "A low-profile retractable blade hidden in the sleeve. Ideal for stealth operations. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_KNIFE_WESKER_NAME": "Custom Knife",
        "ROB_HUNK_BODY_KNIFE_WESKER_DESCRIPTION": "A cruel blade with a serrated edge to help tear apart your opponents. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_KNIFE_MACHETE_NAME": "Machete",
        "ROB_HUNK_BODY_KNIFE_MACHETE_DESCRIPTION": "An enormous blade primarily intended for guerrilla tactics. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_KNIFE_RE4_NAME": "Primary Knife",
        "ROB_HUNK_BODY_KNIFE_RE4_DESCRIPTION": "A knife forged with infinite possibilities. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_KNIFE_BLOODY_NAME": "Bloody Blade",
        "ROB_HUNK_BODY_KNIFE_BLOODY_DESCRIPTION": "A bloodied blade with a serrated edge that has already torn apart many opponents. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_KNIFE_HOTDOGGER_NAME": "HOT DOGGER",
        "ROB_HUNK_BODY_KNIFE_HOTDOGGER_DESCRIPTION": "As the name indicates, this anti-bioweapon knife developed by Umbrella is used by those who like to show off. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_KNIFE_STUNROD_NAME": "Stun Rod",
        "ROB_HUNK_BODY_KNIFE_STUNROD_DESCRIPTION": "WARNING: Does not actually stun. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_KNIFE_KITCHEN_NAME": "Kitchen Knife",
        "ROB_HUNK_BODY_KNIFE_KITCHEN_DESCRIPTION": "A knife made for cooking. Its blade chips easily. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SHOOT_SMG_NAME": "Fire",
        "ROB_HUNK_BODY_SHOOT_SMG_DESCRIPTION": "Fires for <style=cIsDamage>110% damage</style>. <style=cIsUtility>25% headshot bonus.</style> <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SHOOT_M19_NAME": "Fire",
        "ROB_HUNK_BODY_SHOOT_M19_DESCRIPTION": "Fires for <style=cIsDamage>500% damage</style>. <style=cIsUtility>100% headshot bonus.</style> <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SHOOT_SG09_NAME": "Fire",
        "ROB_HUNK_BODY_SHOOT_SG09_DESCRIPTION": "Fires for <style=cIsDamage>500% damage</style>. <style=cIsUtility>50% headshot bonus.</style> <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SHOOT_BROOMHC_NAME": "Fire",
        "ROB_HUNK_BODY_SHOOT_BROOMHC_DESCRIPTION": "Fires for <style=cIsDamage>180% damage</style>. <style=cIsUtility>25% headshot bonus.</style> <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SHOOT_MAGNUM_NAME": "Fire",
        "ROB_HUNK_BODY_SHOOT_MAGNUM_DESCRIPTION": "Fires for <style=cIsDamage>1,200% damage</style>. <style=cIsUtility>50% headshot bonus.</style> <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SHOOT_GOLDGUN_NAME": "Fire",
        "ROB_HUNK_BODY_SHOOT_GOLDGUN_DESCRIPTION": "Fires for <style=cIsDamage>99,999% damage</style>. <style=cIsUtility>50% headshot bonus.</style> <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SHOOT_MUP_NAME": "Fire",
        "ROB_HUNK_BODY_SHOOT_MUP_DESCRIPTION": "Fires for <style=cIsDamage>320% damage</style>. <style=cIsUtility>25% headshot bonus.</style> <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SHOOT_REVOLVER_NAME": "Fire",
        "ROB_HUNK_BODY_SHOOT_REVOLVER_DESCRIPTION": "Fires for <style=cIsDamage>1,200% damage</style>. <style=cIsUtility>50% headshot bonus.</style> <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SHOOT_COLT_NAME": "Fire",
        "ROB_HUNK_BODY_SHOOT_COLT_DESCRIPTION": "Fires for <style=cIsDamage>2,000% damage</style>. <style=cIsUtility>50% headshot bonus.</style> <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SHOOT_SPARKSHOT_NAME": "Fire",
        "ROB_HUNK_BODY_SHOOT_SPARKSHOT_DESCRIPTION": "Fires an electrified needle for <style=cIsDamage>1,000% damage</style>. <style=cIsUtility>Bounces to up to 3 enemies for <style=cIsDamage>2,000% damage</style>.</style> <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SHOOT_BLUEROSE_NAME": "Fire",
        "ROB_HUNK_BODY_SHOOT_BLUEROSE_DESCRIPTION": "Fires for <style=cIsDamage>2x3,800% damage</style>. <style=cIsUtility>50% headshot bonus.</style> <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SHOOT_SHOTGUN_NAME": "Fire",
        "ROB_HUNK_BODY_SHOOT_SHOTGUN_DESCRIPTION": "Fires for <style=cIsDamage>14x150% damage</style>. <style=cIsUtility>50% headshot bonus.</style> <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SHOOT_M3_NAME": "Fire",
        "ROB_HUNK_BODY_SHOOT_M3_DESCRIPTION": "Fires for <style=cIsDamage>10x130% damage</style>. <style=cIsUtility>50% headshot bonus.</style> <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SHOOT_SSG_NAME": "Fire",
        "ROB_HUNK_BODY_SHOOT_SSG_DESCRIPTION": "Fires for <style=cIsDamage>16x200% damage</style>. <style=cIsUtility>50% headshot bonus.</style> <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SHOOT_STREETSWEEPER_NAME": "Fire",
        "ROB_HUNK_BODY_SHOOT_STREETSWEEPER_DESCRIPTION": "Fires for <style=cIsDamage>14x24% damage</style>. <style=cIsUtility>25% headshot bonus.</style> <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SHOOT_SLUGGER_NAME": "Fire",
        "ROB_HUNK_BODY_SHOOT_SLUGGER_DESCRIPTION": "Fires for <style=cIsDamage>3,000% damage</style>. <style=cIsUtility>50% headshot bonus.</style> <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SHOOT_AR_NAME": "Fire",
        "ROB_HUNK_BODY_SHOOT_AR_DESCRIPTION": "Fires for <style=cIsDamage>385% damage</style>. <style=cIsUtility>50% headshot bonus.</style> <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SHOOT_MINIGUN_NAME": "Fire",
        "ROB_HUNK_BODY_SHOOT_MINIGUN_DESCRIPTION": "Fires for <style=cIsDamage>2x250% damage</style>. <style=cIsUtility>Damage scales with attack speed.</style> <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SHOOT_ATM_NAME": "Fire",
        "ROB_HUNK_BODY_SHOOT_ATM_DESCRIPTION": "Fires for <style=cIsDamage>8,000% damage</style>. <style=cIsUtility>Deals more damage on direct hits.</style> <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SHOOT_ATM2_NAME": "Fire",
        "ROB_HUNK_BODY_SHOOT_ATM2_DESCRIPTION": "Fires for <style=cIsDamage>8,000% damage</style>. <style=cIsUtility>Deals more damage on direct hits.</style> <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SHOOT_RPG_NAME": "Fire",
        "ROB_HUNK_BODY_SHOOT_RPG_DESCRIPTION": "Fires for <style=cIsDamage>8,000% damage</style>. <style=cIsUtility>Deals more damage on direct hits.</style> <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SHOOT_ROCKETLAUNCHER_NAME": "Fire",
        "ROB_HUNK_BODY_SHOOT_ROCKETLAUNCHER_DESCRIPTION": "Fires for <style=cIsDamage>12,000% damage</style>. <style=cIsDamage>Incendiary.</style> <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SHOOT_GRENADELAUNCHER_NAME": "Fire",
        "ROB_HUNK_BODY_SHOOT_GRENADELAUNCHER_DESCRIPTION": "Fires for <style=cIsDamage>3,200% damage</style>. <style=cIsDamage>Incendiary.</style> <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SHOOT_MGL_NAME": "Fire",
        "ROB_HUNK_BODY_SHOOT_MGL_DESCRIPTION": "Fires for <style=cIsDamage>2,400% damage</style>. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SHOOT_RAILGUN_NAME": "Fire",
        "ROB_HUNK_BODY_SHOOT_RAILGUN_DESCRIPTION": "Fires for <style=cIsDamage>20,000% damage</style>. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SHOOT_FLAMETHROWER_NAME": "Fire",
        "ROB_HUNK_BODY_SHOOT_FLAMETHROWER_DESCRIPTION": "Fires a jet of flames for <style=cIsDamage>tons of damage</style>. <style=cIsUtility>Ignites.</style> <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SHOOT_SCANNER_NAME": "Scan",
        "ROB_HUNK_BODY_SHOOT_SCANNER_DESCRIPTION": "Scans for <style=cIsUtility>unopened weapon cases</style>. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_BODY_SHOOT_HOOKSHOT_NAME": "Hookshot",
        "ROB_HUNK_BODY_SHOOT_HOOKSHOT_DESCRIPTION": "Fire a hook to a <style=cIsUtility>distant point</style>, then <style=cIsUtility>pull yourself to it</style>. <style=cIsDamage>You can counterattack after landing.</style> <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_HUNK_KEYWORD_MANGLED": "Mangled",
        "ROB_HUNK_KEYWORD_COUNTER": "Counterattack",
        "ROB_HUNK_KEYWORD_PERFECTDODGE": "Perfect Dodge",
        "ROB_HUNK_KEYWORD_PERFECTBASH": "Perfect Deflection",
        "ROB_HUNK_KEYWORD_PERFECTPARRY": "Perfect Parry",
        "ROB_HUNK_KEYWORD_CVIRUS": "C-Virus",
        "ROB_HUNK_KEYWORD_GVIRUS": "G-Virus",
        "ROB_HUNK_KEYWORD_TVIRUS": "T-Virus",
        "ROB_HUNK_KEYWORD_VIRUS": "Virus",
        "ROB_HUNK_KEYWORD_LOOTING": "Looting",
        "ROB_HUNK_JETPACK_NAME": "Experimental Jump Pack",
        "ROB_HUNK_JETPACK_DESC": "A tool made by Umbrella that allows you to propel yourself in any direction by pressing jump in the air.",
        "ROB_HUNK_SURVIVALKIT_NAME": "Emergency Survival Kit",
        "ROB_HUNK_SURVIVALKIT_DESC": "A survival kit that increases both your ability to scavenge for ammo and the effectiveness of your knife.",
        "ROB_HUNK_TRANSCEIVER_NAME": "Worn Transceiver",
        "ROB_HUNK_TRANSCEIVER_DESC": "Calls a squadmate to assist in your operation.",
        "ROB_HUNK_INFROCKET_NAME": "ATM-4",
        "ROB_HUNK_INFROCKET_DESC": "A rocket launcher with <style=cIsHealing>infinite ammo</style>. Reward for the <color=#FFFF00>Early Supporter</color> achievement.",
        "ROB_HUNK_TYPEWRITER_NAME": "Typewriter",
        "ROB_HUNK_TYPEWRITER_DESC": "Grants <style=cIsUtility>2</style> additional <color=#C80202>Umbrella weapon cases</color> per Stage.",
        "ROB_HUNK_CRYSTALSKULL_NAME": "Crystal Skull",
        "ROB_HUNK_CRYSTALSKULL_DESC": "A rare treasure. Can be traded at any <style=cIsUtility>Cauldron</style> to receive an item.",
        "ROB_HUNK_WRISTBAND_NAME": "Identification Wristband",
        "ROB_HUNK_WRISTBAND_DESC": "An electronic key for use at <color=#C80202>Umbrella Corporation</color> facilities. Used to open a <style=cIsUtility>special weapon case</style>.",
        "ROB_HUNK_SPADE_KEYCARD_NAME": "U.C. Keycard (Spades)",
        "ROB_HUNK_CLUB_KEYCARD_NAME": "U.C. Keycard (Clubs)",
        "ROB_HUNK_HEART_KEYCARD_NAME": "U.C. Keycard (Hearts)",
        "ROB_HUNK_DIAMOND_KEYCARD_NAME": "U.C. Keycard (Diamonds)",
        "ROB_HUNK_GOLD_KEYCARD_NAME": "U.C. Keycard (Star)",
        "ROB_HUNK_MASTER_KEYCARD_NAME": "U.C. Keycard (Master)",
        "ROB_HUNK_KEYCARD_DESC": "Used to open <color=#C80202>weapon cases</color> from the <style=cIsUtility>Umbrella Corporation</style>.",
        "ROB_HUNK_KEYCARD_MASTER_DESC": "Used to open <color=#C80202>weapon cases</color> from the <style=cIsUtility>Umbrella Corporation</style>. Opens <style=cIsHealing>all cases</style> and turns other keycards into <style=cIsUtility>scrap</style>.",
        "ROB_HUNK_STARSBADGE_NAME": "S.T.A.R.S. Badge",
        "ROB_HUNK_STARSBADGE_DESC": "A special badge from the R.P.D. special forces division, <color=#F20443>S.T.A.R.S.</color> <style=cIsHealth>Maybe picking this up was a bad idea?</style>",
        "ROB_HUNK_STARSBADGE_DESCFULL": "Each Stage, a special <color=#F20443>S.T.A.R.S.</color> case spawns that can only be opened using this badge. However, the <style=cIsHealth>Nemesis T-Type</style> will hunt you relentlessly.",
        "ROB_HUNK_STARSBADGE2_NAME": "USB Dongle Key",
        "ROB_HUNK_STARSBADGE2_DESC": "Used to access a <style=cIsUtility>special chest</style> on each Stage.",
        "ROB_HUNK_STARSBADGE2_DESCFULL": "Each Stage, a special <color=#F20443>S.T.A.R.S.</color> case spawns that can only be opened using this badge. However, the <style=cIsHealth>Nemesis T-Type</style> will hunt you relentlessly.",
        "ROB_HUNK_HEARTCHEST_NAME": "Heart Chest",
        "ROB_HUNK_NEMICASE_NAME": "Nemi Case",
        "ROB_HUNK_NEMICASE_DESC": "A mysterious case.",
