		private void CreatePowerupItem()
		{
			//IL_015c: Unknown result type (might be due to invalid IL or missing references)
			//IL_017b: Unknown result type (might be due to invalid IL or missing references)
			//IL_0185: Expected O, but got Unknown
			Aetherium.Language.Language.Add("HIDDEN_ITEM_" + ItemLangTokenName + "_LIMITER_RELEASE_NAME", "Weighted Anklet Limiter Release");
			Aetherium.Language.Language.Add("HIDDEN_ITEM_" + ItemLangTokenName + "_LIMITER_RELEASE_PICKUP", "You feel much lighter, and your senses keener.");
			Aetherium.Language.Language.Add("HIDDEN_ITEM_" + ItemLangTokenName + "_LIMITER_RELEASE_DESCRIPTION", $"You gain <style=cIsUtility>{MovementSpeedGainedPerLimiterRelease}</style> movement speed <style=cStack>(+{MovementSpeedGainedPerLimiterRelease} per stack)</style>, <style=cIsUtility>{AttackSpeedGainedPerLimiterRelease}</style> attack speed <style=cStack>(+{AttackSpeedGainedPerLimiterRelease} per stack)</style>, and <style=cIsDamage>{MathHelpers.FloatToPercentageString(DamagePercentageGainedPerLimiterRelease)}</style> damage bonus <style=cStack>(+{MathHelpers.FloatToPercentageString(DamagePercentageGainedPerLimiterRelease)} per stack)</style>.");
			LimiterReleaseItemDef = ScriptableObject.CreateInstance<ItemDef>();
			((Object)LimiterReleaseItemDef).name = "HIDDEN_ITEM_WEIGHTED_ANKLET_LIMITER_RELEASE";
			LimiterReleaseItemDef.nameToken = "HIDDEN_ITEM_" + ItemLangTokenName + "_LIMITER_RELEASE_NAME";
			LimiterReleaseItemDef.pickupToken = "HIDDEN_ITEM_" + ItemLangTokenName + "_LIMITER_RELEASE_PICKUP";
			LimiterReleaseItemDef.descriptionToken = "HIDDEN_ITEM_" + ItemLangTokenName + "_LIMITER_RELEASE_DESCRIPTION";
			LimiterReleaseItemDef.loreToken = "";
			LimiterReleaseItemDef.canRemove = false;
			LimiterReleaseItemDef.hidden = true;
			LimiterReleaseItemDef.deprecatedTier = (ItemTier)5;
			LimiterReleaseItemDef.requiredExpansion = AetheriumPlugin.AetheriumExpansionDef;
			ItemAPI.Add(new CustomItem(LimiterReleaseItemDef, CreateLimiterItemDisplayRules()));
		}

		public override void Hooks()
		{
			//IL_0008: Unknown result type (might be due to invalid IL or missing references)
			//IL_0012: Expected O, but got Unknown
			//IL_001a: Unknown result type (might be due to invalid IL or missing references)
			//IL_0024: Expected O, but got Unknown
			//IL_002c: Unknown result type (might be due to invalid IL or missing references)
			//IL_0036: Expected O, but got Unknown
			//IL_003e: Unknown result type (might be due to invalid IL or missing references)
			//IL_0048: Expected O, but got Unknown
			//IL_0050: Unknown result type (might be due to invalid IL or missing references)
			//IL_005a: Expected O, but got Unknown
			CharacterBody.OnInventoryChanged += new hook_OnInventoryChanged(RemoveWeightedAnkletAndLimitersFromDeployables);
			RecalculateStatsAPI.GetStatCoefficients += new StatHookEventHandler(ManageBonusesAndPenalties);
			CharacterMaster.OnInventoryChanged += new hook_OnInventoryChanged(ManageLimiter);
			CharacterBody.FixedUpdate += new hook_FixedUpdate(ManageLimiterBuff);
			HealthComponent.TakeDamage += new hook_TakeDamage(ReduceKnockback);
		}

		private void RemoveWeightedAnkletAndLimitersFromDeployables(orig_OnInventoryChanged orig, CharacterBody self)
		{
			//IL_002e: Unknown result type (might be due to invalid IL or missing references)
			//IL_0034: Invalid comparison between Unknown and I4
			orig.Invoke(self);
			int count = GetCount(self);
			if (count > 0 && Object.op_Implicit((Object)(object)self.master) && (int)self.master.teamIndex == 1 && !self.isPlayerControlled)
			{
				self.inventory.RemoveItem(ItemDef, count);
				int countSpecific = GetCountSpecific(self, LimiterReleaseItemDef);
				self.inventory.RemoveItem(LimiterReleaseItemDef, countSpecific);
			}
		}

		private void ManageBonusesAndPenalties(CharacterBody sender, StatHookEventArgs args)
		{
			int count = GetCount(sender);
			if (count > 0)
			{
				args.moveSpeedMultAdd -= Mathf.Min((float)count * (float)BaseMovementSpeedReductionPercentage, (float)MovementSpeedReductionPercentageCap);
				args.attackSpeedMultAdd -= Mathf.Min((float)count * (float)BaseAttackSpeedReductionPercentage, (float)AttackSpeedReductionPercentageCap);
			}
			int countSpecific = GetCountSpecific(sender, LimiterReleaseItemDef);
			if (countSpecific > 0)
			{
				args.baseAttackSpeedAdd += (float)countSpecific * (float)AttackSpeedGainedPerLimiterRelease;
				args.baseMoveSpeedAdd += (float)countSpecific * (float)MovementSpeedGainedPerLimiterRelease;
				args.damageMultAdd += (float)countSpecific * (float)DamagePercentageGainedPerLimiterRelease;
			}
		}

		private void ManageLimiter(orig_OnInventoryChanged orig, CharacterMaster self)
		{
			orig.Invoke(self);
			AnkletTracker ankletTracker = ((Component)self).GetComponent<AnkletTracker>();
			if (!Object.op_Implicit((Object)(object)ankletTracker))
			{
				ankletTracker = ((Component)self).gameObject.AddComponent<AnkletTracker>();
			}
			int count = GetCount(self);
			if (count > ankletTracker.AnkletStacks)
			{
				ankletTracker.AnkletStacks = count;
			}
			else if (count < ankletTracker.AnkletStacks)
			{
				int num = ankletTracker.AnkletStacks - count;
				ankletTracker.AnkletStacks = count;
				self.inventory.GiveItem(LimiterReleaseItemDef, num);
			}
		}

		private void ManageLimiterBuff(orig_FixedUpdate orig, CharacterBody self)
		{
			orig.Invoke(self);
			if (!Object.op_Implicit((Object)(object)self.inventory))
			{
				return;
			}
			int itemCount = self.inventory.GetItemCount(LimiterReleaseItemDef);
			int buffCount = self.GetBuffCount(LimiterReleaseBuffDef);
			if (buffCount < itemCount)
			{
				int num = itemCount - buffCount;
				for (int i = 1; i <= num; i++)
				{
					self.AddBuff(LimiterReleaseBuffDef);
				}
			}
			else if (buffCount > itemCount)
			{
				int num2 = buffCount - itemCount;
				for (int j = 1; j <= num2; j++)
				{
					self.RemoveBuff(LimiterReleaseBuffDef);
				}
			}
		}

		private void ReduceKnockback(orig_TakeDamage orig, HealthComponent self, DamageInfo damageInfo)
		{
			//IL_003c: Unknown result type (might be due to invalid IL or missing references)
			//IL_0042: Unknown result type (might be due to invalid IL or missing references)
			//IL_0047: Unknown result type (might be due to invalid IL or missing references)
			int count = GetCount(self.body);
			if (count > 0)
			{
				float num = Mathf.Clamp(1f - (float)count * (float)BaseKnockbackReductionPercentage, 0f, 1f);
				damageInfo.force *= num;
			}
			orig.Invoke(self, damageInfo);
		}
	}
	public class ZenithAccelerator : ItemBase<ZenithAccelerator>
	{
		public class ZenithAcceleratorManager : MonoBehaviour
		{
			public ItemDisplay ItemDisplay;

			public Animator Animator;

			public ParticleSystem[] ParticleSystem;

			public List<ZenithFirePlumeController> Plumes = new List<ZenithFirePlumeController>();

			public List<ZenithGlowController> GlowControllers = new List<ZenithGlowController>();

			public CharacterMaster OwnerMaster;

			public CharacterBody OwnerBody;

			public float CalculateWindUp()
			{
				int buffCount = OwnerBody.GetBuffCount(ZenithAccelerationBuff);
				int itemCount = OwnerBody.inventory.GetItemCount(ItemBase<ZenithAccelerator>.instance.ItemDef);
				float num = Mathf.Pow(0.5f, (float)itemCount);
				float num2 = 0.1f;
				float num3 = 3f + (float)(itemCount - 1) * 1f;
				return Mathf.Min(num2 * (float)buffCount / (num3 - num), 1f);
			}

			public void OnDestroy()
			{
				ParticleSystem[] particleSystem = ParticleSystem;
				foreach (ParticleSystem val in particleSystem)
				{
					Object.Destroy((Object)(object)val);
				}
				foreach (ZenithFirePlumeController plume in Plumes)
				{
					Object.Destroy((Object)(object)plume.Plume);
				}
			}

			public void FixedUpdate()
			{
				//IL_02b2: Unknown result type (might be due to invalid IL or missing references)
				//IL_02b8: Invalid comparison between Unknown and I4
				//IL_02df: Unknown result type (might be due to invalid IL or missing references)
				//IL_02e5: Invalid comparison between Unknown and I4
				if (!Object.op_Implicit((Object)(object)OwnerMaster) || !Object.op_Implicit((Object)(object)ItemDisplay) || !ParticleSystem.Any() || !Plumes.Any() || !Object.op_Implicit((Object)(object)Animator) || !GlowControllers.Any())
				{
					ItemDisplay = ((Component)this).GetComponentInParent<ItemDisplay>();
					if (Object.op_Implicit((Object)(object)ItemDisplay))
					{
						Animator = ((Component)this).GetComponentInChildren<Animator>();
						ParticleSystem = (from x in ((Component)this).GetComponentsInChildren<ParticleSystem>()
							where !((Object)((Component)x).gameObject).name.Contains("FirePlume")
							select x).ToArray();
						CharacterModel componentInParent = ((Component)ItemDisplay).GetComponentInParent<CharacterModel>();
						if (Object.op_Implicit((Object)(object)componentInParent))
						{
							CharacterBody body = componentInParent.body;
							if (Object.op_Implicit((Object)(object)body))
							{
								OwnerMaster = body.master;
							}
						}
						ParticleSystem[] array = (from x in ((Component)this).GetComponentsInChildren<ParticleSystem>()
							where ((Object)((Component)x).gameObject).name.Contains("FirePlume")
							select x).ToArray();
						ParticleSystem[] array2 = array;
						foreach (ParticleSystem plume in array2)
						{
							Plumes.Add(new ZenithFirePlumeController(plume, 0f));
						}
						MeshRenderer[] array3 = (from x in ((Component)this).GetComponentsInChildren<MeshRenderer>()
							where ((Object)((Renderer)x).material.shader).name.Contains("Hopoo")
							select x).ToArray();
						MeshRenderer[] array4 = array3;
						for (int j = 0; j < array4.Length; j++)
						{
							Renderer renderer = (Renderer)(object)array4[j];
							GlowControllers.Add(new ZenithGlowController(this, renderer));
						}
					}
				}
				if (Object.op_Implicit((Object)(object)OwnerMaster) && !Object.op_Implicit((Object)(object)OwnerBody))
				{
					CharacterBody body2 = OwnerMaster.GetBody();
					if (Object.op_Implicit((Object)(object)body2))
					{
						OwnerBody = body2;
					}
					if (!Object.op_Implicit((Object)(object)body2))
					{
						Object.Destroy((Object)(object)this);
					}
				}
				if (Object.op_Implicit((Object)(object)OwnerBody))
				{
					ParticleSystem[] particleSystem = ParticleSystem;
					foreach (ParticleSystem val in particleSystem)
					{
						if (OwnerBody.inventory.GetItemCount(ItemBase<ZenithAccelerator>.instance.ItemDef) > 0 && ItemBase<ZenithAccelerator>.instance.CalculateMaxBuffStacks(OwnerBody) == OwnerBody.GetBuffCount(ZenithAccelerationBuff))
						{
							if (!val.isPlaying && (int)ItemDisplay.visibilityLevel > 0)
							{
								val.Play();
							}
							else if (val.isPlaying && (int)ItemDisplay.visibilityLevel == 0)
							{
								val.Stop();
								val.Clear();
							}
						}
						else if (val.isPlaying)
						{
							val.Stop();
						}
					}
					foreach (ZenithFirePlumeController plume2 in Plumes)
					{
						plume2.Update();
					}
				}
				if (Object.op_Implicit((Object)(object)OwnerBody) && Object.op_Implicit((Object)(object)Animator))
				{
					Animator.speed = ItemBase<ZenithAccelerator>.instance.CalculateSpeedMult(OwnerBody);
				}
			}

			public void Update()
			{
				if (!Object.op_Implicit((Object)(object)OwnerBody))
				{
					return;
				}
				foreach (ZenithGlowController glowController in GlowControllers)
				{
					glowController.Update();
				}
			}
		}

		public class ZenithGlowController
		{
			public ZenithAcceleratorManager ManagerComponent;

			public Renderer Renderer;

			public float NoiseOffset;

			public float GlowCounter;

			public ZenithGlowController(ZenithAcceleratorManager managerComponent, Renderer renderer)
			{
				ManagerComponent = managerComponent;
				Renderer = renderer;
				NoiseOffset = Random.Range(0, 1000);
			}

			public void Update()
			{
				float num = Time.time / 1f + NoiseOffset;
				float num2 = Mathf.Sin(num * 7f) * Mathf.Sin(num * 13f) * Mathf.Sin(num * 43f) * Mathf.Sin(num * 71f) * Mathf.Sin(num * 101f) * 0.5f + 0.5f;
				float num3 = 0.5f;
				float value = Mathf.Clamp01(ManagerComponent.CalculateWindUp() - num3) / (1f - num3);
				Renderer.materials[0].SetFloat("_EmPower", EasingFunction.EaseInOutQuad(0f, 10f - num2 * 7f, value));
			}
		}

		public class ZenithFirePlumeController
		{
			public ParticleSystem Plume;

			public float Stopwatch;

			public ZenithFirePlumeController(ParticleSystem plume, float stopwatch)
			{
				Plume = plume;
				Stopwatch = stopwatch;
			}

			public void Update()
			{
				//IL_0057: Unknown result type (might be due to invalid IL or missing references)
				//IL_005c: Unknown result type (might be due to invalid IL or missing references)
				Stopwatch -= Time.fixedDeltaTime;
				if (Stopwatch <= 0f)
				{
					Stopwatch += Random.Range(1, 10);
					if (!Plume.IsAlive())
					{
						MainModule main = Plume.main;
						((MainModule)(ref main)).duration = Random.Range(1, 3);
						Plume.Play();
					}
				}
			}
		}

		public ConfigOption<float> ExponentialBaseMultiplier;

		public ConfigOption<float> PercentageIncreasePerHit;

		public ConfigOption<float> BaseMaximumPercentageCap;

		public ConfigOption<float> AdditionalMaximumPercentageCap;

		public ConfigOption<float> DurationOfTimedBuffPerStack;

		public static GameObject ItemBodyModelPrefab;

		public static BuffDef ZenithAccelerationBuff;

		public override string ItemName => "Zenith Accelerator";

		public override string ItemLangTokenName => "ZENITH_ACCELERATOR";

		public override string ItemPickupDesc => "Hits increase your attack speed... <style=cDeath>BUT it's reduced by " + MathHelpers.FloatToPercentageString(ExponentialBaseMultiplier) + " initially.</style>";

		public override string ItemFullDescription => "<style=cIsDamage>Hitting enemies</style> grants you a <style=cIsDamage>temporary attack speed buff</style> that increases attack speed <style=cIsDamage>" + MathHelpers.FloatToPercentageString(PercentageIncreasePerHit) + "</style> per buff stack linearly up to <style=cIsDamage>+" + MathHelpers.FloatToPercentageString(BaseMaximumPercentageCap) + "</style> <style=cStack>(+" + MathHelpers.FloatToPercentageString(AdditionalMaximumPercentageCap) + " per item stack linearly)</style>, but you lose up to <style=cDeath>" + MathHelpers.FloatToPercentageString(ExponentialBaseMultiplier) + " attack speed</style> <style=cStack>(+" + MathHelpers.FloatToPercentageString(ExponentialBaseMultiplier) + " per item stack exponentially)</style> the closer you are to <style=cDeath>0</style> stacks of the buff.";

		public override string ItemLore => "The others are not the masters of this universe, brother. They create clocks to count the time, we create clocks to create our own time. Watch.\n\nWe create an axle for stability, power, and to release the energies trapped within. A rounded center is key to its purpose.\n\nThe exhausts send the energies spiraling out. This, we harness with a simple bit of stone. We require less of the essence if we create smaller portions here, and here.\n\nNow it is complete. The hotter it burns, the more time we have created. This time allows us a quickening.\n\nI do not need to remind you of the importance of the quickening. Remember brother.\n\nFuel is Blood.\n\nSpeed is War.";

		public override ItemTier Tier => (ItemTier)3;

		public override bool AIBlacklisted => true;

		public override GameObject ItemModel => AetheriumPlugin.MainAssets.LoadAsset<GameObject>("PickupZenithAccelerator.prefab");

		public override Sprite ItemIcon => AetheriumPlugin.MainAssets.LoadAsset<Sprite>("ZenithAcceleratorIcon.png");

		public override void Init(ConfigFile config)
		{
			CreateConfig(config);
			CreateLang();
			CreateBuff();
			CreateItem();
			Hooks();
		}

		private void CreateConfig(ConfigFile config)
		{
			ExponentialBaseMultiplier = config.ActiveBind("Item: " + ItemName, "Exponential Base Multiplier", 0.5f, "How far down should we reduce attack speed by at 0 stacks of the Zenith Acceleration Buff? (0.5f results in reducing attack speed by half, an additional pickup of the item reduces it twice as much as the first.)");
			PercentageIncreasePerHit = config.ActiveBind("Item: " + ItemName, "Percentage Increase per Hit", 0.1f, "How much bonus in percentage towards our cap should we get per hit?");
			BaseMaximumPercentageCap = config.ActiveBind("Item: " + ItemName, "Base Percentage Max of Zenith Acceleration Attack Speed Bonus", 3f, "What should be our base cap for the attack speed bonus granted to us at full Zenith Acceleration stacks?");
			AdditionalMaximumPercentageCap = config.ActiveBind("Item: " + ItemName, "Additional Percentage Cap per Additional Stack", 1f, "How much higher should our base percentage cap go with additional Zenith Accelerator stacks?");
			DurationOfTimedBuffPerStack = config.ActiveBind("Item: " + ItemName, "Duration of Zenith Acceleration Stack", 3f, "How long should the base Zenith Acceleration stack be?");
		}

		private void CreateBuff()
		{
			//IL_0034: Unknown result type (might be due to invalid IL or missing references)
			//IL_0039: Unknown result type (might be due to invalid IL or missing references)
			ZenithAccelerationBuff = ScriptableObject.CreateInstance<BuffDef>();
			((Object)ZenithAccelerationBuff).name = "Aetherium: Zenith Acceleration";
			ZenithAccelerationBuff.buffColor = new Color(195f, 61f, 100f, 255f);
			ZenithAccelerationBuff.canStack = true;
			ZenithAccelerationBuff.isDebuff = false;
			ZenithAccelerationBuff.iconSprite = AetheriumPlugin.MainAssets.LoadAsset<Sprite>("ZenithAccelerationBuffIcon.png");
			ContentAddition.AddBuffDef(ZenithAccelerationBuff);
		}

