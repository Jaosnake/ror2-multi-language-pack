        "SS2_EXECUTIONER2_IONCHARGE_DESC": "按住开始充能,最多<style=cIsUtility>5层</style>,并替换你的<style=cIsDamage>主要技能</style>。<style=cIsUtility>击败敌人也会增加充能。</style>",
        "SS2_NEMESIS_MERCENARY_SECONDARY_SLASH_NAME": "割喉",
        "SS2_ACHIEVEMENT_EXECUTIONER_MASTERY_NAME": "Executioner: Mastery",
        "SS2_DRONE_CLONE_INTERACTABLE_CONTEXT": "修复复制无人机",
        "SS2_EQUIP_MIDAS_DESC": "牺牲<style=cIsHealth>50%</style>的<style=cIsHealth>当前生命</style>。获得等同于<style=cIsHealth>损失生命值</style>数目或一个普通宝箱价格的<style=cIsUtility>金钱</style>,具体取决于哪一个数据更高。",
        "SS2_INTERACTABLE_DROPPOD_CONTEXT": "打开舱门?",
        "SS2_EXECUTIONER2_BLOODLETTING_DESC": "消耗<style=cIsHealth>25%</style>生命值,使附近敌人陷入<style=cIsUtility>恐惧</style>并获得3点<color=#29e5f2>离子充能</color>。",
        "SS2_ARTIFACT_ADVERSITY_NAME": "逆境神器",
        "SS2_ITEM_ARMEDBACKPACK_DESC": "受伤时有几率发射一枚导弹,造成<style=cIsDamage>{0}%</style><style=cStack>(每层+{0}%)</style>伤害。所受伤害越高发射导弹的几率就越高。",
