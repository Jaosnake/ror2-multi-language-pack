			}
		}

		public override void OnEnter()
		{
			((GenericCharacterDeath)this).OnEnter();
			WormHealthTracker component = ((EntityState)this).GetComponent<WormHealthTracker>();
			specialSlot = component.specialSlot;
			cancelSkillDef = component.cancelSkillDef;
			wormSkill = component.wormSkill;
			UnsetOverride();
			WormBodyPositions2 component2 = ((EntityState)this).GetComponent<WormBodyPositions2>();
			WormBodyPositionsDriver component3 = ((EntityState)this).GetComponent<WormBodyPositionsDriver>();
			if (Object.op_Implicit((Object)(object)component2))
			{
				component3.yDamperConstant = 0f;
				component3.ySpringConstant = 0f;
				component3.maxTurnSpeed = 0f;
				component2.meatballCount = 0;
				Util.PlaySound(deathSoundString, ((Component)component2.bones[0]).gameObject);
			}
			Transform modelTransform = ((EntityState)this).GetModelTransform();
			if (!Object.op_Implicit((Object)(object)modelTransform))
			{
				return;
			}
			PrintController val = ((Component)modelTransform).gameObject.AddComponent<PrintController>();
			val.printTime = duration;
			((Behaviour)val).enabled = true;
			val.startingPrintHeight = 99999f;
			val.maxPrintHeight = 99999f;
			val.startingPrintBias = 1f;
			val.maxPrintBias = 3.5f;
			val.animateFlowmapPower = true;
			val.startingFlowmapPower = 1.14f;
			val.maxFlowmapPower = 30f;
			val.disableWhenFinished = false;
			val.printCurve = AnimationCurve.EaseInOut(0f, 0f, 1f, 1f);
			ParticleSystem[] componentsInChildren = ((Component)modelTransform).GetComponentsInChildren<ParticleSystem>();
			for (int i = 0; i < componentsInChildren.Length; i++)
			{
				componentsInChildren[i].Stop();
			}
			ChildLocator component4 = ((Component)modelTransform).GetComponent<ChildLocator>();
			if (Object.op_Implicit((Object)(object)component4))
			{
				Transform val2 = component4.FindChild("PP");
				if (Object.op_Implicit((Object)(object)val2))
				{
					PostProcessDuration component5 = ((Component)val2).GetComponent<PostProcessDuration>();
					if (Object.op_Implicit((Object)(object)component5))
					{
						((Behaviour)component5).enabled = true;
						component5.maxDuration = duration;
					}
				}
			}
			if (NetworkServer.active)
			{
				EffectManager.SimpleMuzzleFlash(initialDeathExplosionEffect, ((EntityState)this).gameObject, "HeadCenter", true);
			}
		}

		public override void FixedUpdate()
		{
			stopwatch += Time.fixedDeltaTime;
			if (NetworkServer.active && stopwatch > duration)
			{
				EntityState.Destroy((Object)(object)((EntityState)this).gameObject);
			}
		}
	}
