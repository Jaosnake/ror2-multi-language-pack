	internal class AncientAce : BaseCardSkill
	{
		private int result = 7;

		private static float buffDuration = 40f;

		public override void OnEnter()
		{
			cardTypeActivationVFX = Assets.PositiveCardActivation;
			cardSweepVFX = Assets.CardSweepPositive;
			base.OnEnter();
			if (((EntityState)this).isAuthority)
			{
				result = passiveManager.random.Next(4);
				passiveManager.roulleteAmmo = new int[6] { 7, 7, 7, 7, 7, 7 };
				if (((EntityState)this).characterBody.isPlayerControlled)
				{
					HouseHUDManager.instance.UpdateAmmo(passiveManager.roulletePriorityShot, passiveManager.roulleteAmmo);
				}
			}
			if (result != 3)
			{
				cardActivationVFX = Assets.VFXcardAncientAce;
				cardActivationSFX = "HouseCard_Spades";
			}
			else
			{
				cardActivationVFX = Assets.VFXcardAncientAce;
				cardActivationSFX = "HouseCard_Jackpot";
			}
		}

		public override void OnActivate()
		{
			base.OnActivate();
			switch (result)
			{
			case 0:
				Deuces();
				break;
			case 1:
				Flush();
				break;
			case 2:
				Draw();
				break;
			case 3:
				Deuces();
				Flush();
				Draw();
				break;
			}
		}

		private void Deuces()
		{
			//IL_000c: Unknown result type (might be due to invalid IL or missing references)
			((EntityState)this).characterBody.AddTimedBuffAuthority(Buffs.Deuces.buffIndex, buffDuration);
		}

		private void Flush()
		{
			//IL_000c: Unknown result type (might be due to invalid IL or missing references)
			((EntityState)this).characterBody.AddTimedBuffAuthority(Buffs.Flush.buffIndex, buffDuration);
		}

		private void Draw()
		{
			//IL_000c: Unknown result type (might be due to invalid IL or missing references)
			((EntityState)this).characterBody.AddTimedBuffAuthority(Buffs.CupsBuff.buffIndex, buffDuration);
		}

		public override void OnSerialize(NetworkWriter writer)
		{
			base.OnSerialize(writer);
			writer.Write(result);
		}

		public override void OnDeserialize(NetworkReader reader)
		{
			base.OnDeserialize(reader);
			result = reader.ReadInt32();
		}
	}
