namespace InterrogatorMod
{
	[NetworkCompatibility(/*Could not decode attribute arguments.*/)]
	[BepInPlugin("com.kenko.Interrogator", "Interrogator", "1.0.0")]
	[BepInDependency(/*Could not decode attribute arguments.*/)]
	[BepInDependency(/*Could not decode attribute arguments.*/)]
	[BepInDependency(/*Could not decode attribute arguments.*/)]
	public class InterrogatorPlugin : BaseUnityPlugin
	{
		public const string MODUID = "com.kenko.Interrogator";

		public const string MODNAME = "Interrogator";

		public const string MODVERSION = "1.0.0";

		public const string DEVELOPER_PREFIX = "KENKO";

		public static InterrogatorPlugin instance;

		public static bool emotesInstalled => Chainloader.PluginInfos.ContainsKey("com.weliveinasociety.CustomEmotesAPI");

		public static bool scepterInstalled => Chainloader.PluginInfos.ContainsKey("com.DestroyedClone.AncientScepter");

		private void Awake()
		{
			instance = this;
			NetworkingAPI.RegisterMessageType<SyncBloodExplosion>();
			NetworkingAPI.RegisterMessageType<SyncSelfDamage>();
			NetworkingAPI.RegisterMessageType<SyncSword>();
			Log.Init(((BaseUnityPlugin)this).Logger);
			Language.Init();
			new InterrogatorSurvivor().Initialize();
			new ContentPacks().Initialize();
		}
	}
	internal static class Log
