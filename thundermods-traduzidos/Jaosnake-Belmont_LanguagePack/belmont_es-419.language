 	 "ROB_BELMONT_BODY_SLIDEKICK_NAME": "Rush",
 	 "ROB_BELMONT_BODY_SLIDEKICK_DESCRIPTION": "<style=cIsUtility>Stunning.</style> Slide forward for <style=cIsDamage>350% damage</style>, launching yourself off the first foe hit.",

