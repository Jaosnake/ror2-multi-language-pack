		internal static class Tokens
		{
			internal static void AddTokens()
			{
				string text = "The Driver is literally me.<color=#CCD3E0>" + Environment.NewLine + Environment.NewLine;
				text = text + "< ! > Each weapon has its own unique strengths and weaknesses so be sure to pick the right tool for the job." + Environment.NewLine + Environment.NewLine;
				text = text + "< ! > Focus greatly increases your damage output, but be careful not to get flanked while aiming." + Environment.NewLine + Environment.NewLine;
				text = text + "< ! > Combat Slide while shooting to make sure your damage has no downtime." + Environment.NewLine + Environment.NewLine;
				text = text + "< ! > Flashbang can be used to make a clean getaway in a pinch." + Environment.NewLine + Environment.NewLine;
				string text2 = "..and so he left, still the same as he was when he began.";
				string text3 = "..and so he vanished, never to become a real human being.";
				string text4 = "Back against the wall and odds" + Environment.NewLine;
				text4 = text4 + "With the strength of a will and a cause" + Environment.NewLine;
				text4 = text4 + "Your pursuits are called outstanding" + Environment.NewLine;
				text4 = text4 + "You’re emotionally complex" + Environment.NewLine + Environment.NewLine;
				text4 = text4 + "Against the grain of dystopic claims" + Environment.NewLine;
				text4 = text4 + "Not the thoughts your actions entertain" + Environment.NewLine;
				text4 = text4 + "And you have proved to be" + Environment.NewLine + Environment.NewLine + Environment.NewLine;
				text4 = text4 + "A real human being and a real hero" + Environment.NewLine + Environment.NewLine;
				text4 = text4 + "\"So, what do you do?\"" + Environment.NewLine + Environment.NewLine;
				text4 += "\"I drive.\"";
				LanguageAPI.Add("ROB_DRIVER_BODY_" + "NAME", "Driver");
				LanguageAPI.Add("ROB_DRIVER_BODY_" + "DESCRIPTION", text);
				LanguageAPI.Add("ROB_DRIVER_BODY_" + "SUBTITLE", "Driver? I hardly know 'er!");
				LanguageAPI.Add("ROB_DRIVER_BODY_" + "LORE", text4);
				LanguageAPI.Add("ROB_DRIVER_BODY_" + "OUTRO_FLAVOR", text2);
				LanguageAPI.Add("ROB_DRIVER_BODY_" + "OUTRO_FAILURE", text3);
				LanguageAPI.Add("ROB_DRIVER_BODY_" + "DEFAULT_SKIN_NAME", "Default");
				LanguageAPI.Add("ROB_DRIVER_BODY_" + "MONSOON_SKIN_NAME", "Jacket");
				LanguageAPI.Add("ROB_DRIVER_BODY_" + "TYPHOON_SKIN_NAME", "Slugger");
