					}
				}
			}

			private void ForceWeaponSwap()
			{
				aiSwapCooldown = 2f;
				int num = 0;
				HunkWeaponData[] weaponData = weaponTracker.weaponData;
				for (int i = 0; i < weaponData.Length; i++)
				{
					HunkWeaponData hunkWeaponData = weaponData[i];
					num++;
					if (hunkWeaponData.totalAmmo > 0 && (Object)(object)hunkWeaponData.weaponDef != (Object)(object)BaseWeapon<ScanGun>.instance.weaponDef)
					{
						if (NetworkServer.active)
						{
							weaponStateMachine.SetNextState((EntityState)(object)new Swap
							{
								index = num
							});
							weaponTracker.nextWeapon = num;
						}
						break;
					}
				}
			}

