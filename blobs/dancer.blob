	public class EnterDirectionalAttack : BaseInputEvaluation
	{
		public override void FixedUpdate()
		{
			base.FixedUpdate();
			if (!((EntityState)this).isAuthority)
			{
				return;
			}
			EvaluateInput();
			if (inputVector.y < -0.5f)
			{
				nextState = (EntityState)(object)new AttackLeft();
			}
			else if (inputVector.y > 0.5f)
			{
				nextState = (EntityState)(object)new AttackRight();
			}
			else if (inputVector.x < -0.5f)
			{
				if (!((BaseState)this).isGrounded)
				{
					nextState = (EntityState)(object)new AttackDown();
				}
				else
				{
					nextState = (EntityState)(object)new AttackBackwards();
				}
			}
			else if (inputVector.x > 0.5f)
			{
				nextState = (EntityState)(object)new AttackForward();
			}
			SetNextState();
		}

		public override InterruptPriority GetMinimumInterruptPriority()
		{
			//IL_0002: Unknown result type (might be due to invalid IL or missing references)
			//IL_0005: Unknown result type (might be due to invalid IL or missing references)
			return (InterruptPriority)1;
		}
	}
