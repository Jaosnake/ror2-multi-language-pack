			if (Input.GetKeyDown((KeyCode)103) && ((Component)self).TryGetComponent<DriverController>(ref val))
			{
				val.PickUpWeapon(DriverWeaponCatalog.GetWeaponFromIndex((int)chronoGunIndex), -1f, false);
			}
