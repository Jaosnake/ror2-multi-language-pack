        "ROB_HUNK_CONTAMINATION_ACHIEVEMENT_DESC": "向Umbrella Corporation交付一个病毒样本。",
        "ROB_HUNK_PURSUER_UNLOCKABLE_NAME": "Nemesis被击倒",
        "ROB_HUNK_PURSUER_ACHIEVEMENT_NAME": "Nemesis被击倒",
        "ROB_HUNK_PURSUER_ACHIEVEMENT_DESC": "击败Nemesis T-Type。",
