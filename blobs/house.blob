			component.passiveSkill.enabled = true;
			component.passiveSkill.skillNameToken = "JAVANGLE_HOUSE_PASSIVE_NAME";
			component.passiveSkill.skillDescriptionToken = "JAVANGLE_HOUSE_PASSIVE_DESCRIPTION";
			component.passiveSkill.keywordToken = "JAVANGLE_HOUSE_PASSIVE_KEYWORD";
			component.passiveSkill.icon = Assets.mainAssetBundle.LoadAsset<Sprite>("PassiveTheGame");
			component.primary = targetPrefab.AddComponent<GenericSkill>();
			SkillFamily val = ScriptableObject.CreateInstance<SkillFamily>();
			((Object)val).name = ((Object)targetPrefab).name + "PrimaryFamily";
			val.variants = (Variant[])(object)new Variant[0];
