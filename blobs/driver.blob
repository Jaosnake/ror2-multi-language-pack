			((EntityState)this).skillLocator.primary?.SetWeaponSkill(primarySkillDef, (SkillOverridePriority)4);
			effectMuzzleInstance = Object.Instantiate<GameObject>(SetupAirstrike.effectMuzzlePrefab, ((BaseState)this).FindModelChild("PistolMuzzle"));
			crosshairOverrideRequest = CrosshairUtils.RequestOverrideForBody(((EntityState)this).characterBody, SetupAirstrike.crosshairOverridePrefab, (OverridePriority)1);
			Util.PlaySound("Play_captain_shift_start", ((EntityState)this).gameObject);
			Util.PlaySound("Play_captain_shift_active_loop", ((EntityState)this).gameObject);
		}

		public override void FixedUpdate()
		{
