        "JAVANGLE_HOUSE_BODY_FULLHOUSE_DESCRIPTION": "Fire multiple shots from the revolver at once.",
        "JAVANGLE_HOUSE_BODY_DIVINATION_NAME": "Divination",
        "JAVANGLE_HOUSE_BODY_DIVINATION_DESCRIPTION": "Predict the next card from the deck to gain an advantage.",
