	public class ChronoCharacterMain : GenericCharacterMain
	{
		private GenericSkill passiveSkill;

		public override void OnEnter()
		{
			((GenericCharacterMain)this).OnEnter();
			passiveSkill = ((EntityState)this).skillLocator.FindSkill("LOADOUT_SKILL_PASSIVE");
		}

		public override void HandleMovements()
		{
			//IL_005e: Unknown result type (might be due to invalid IL or missing references)
			bool flag = passiveSkill.CanExecute();
			if (!flag)
			{
				base.sprintInputReceived = false;
			}
			((GenericCharacterMain)this).HandleMovements();
			if (base.sprintInputReceived && flag && ((EntityState)this).isAuthority)
			{
				SkillDef skillDef = passiveSkill.skillDef;
				passiveSkill.hasExecutedSuccessfully = true;
				passiveSkill.stateMachine.SetInterruptState(skillDef.InstantiateNextState(passiveSkill), skillDef.interruptPriority);
				GenericSkill obj = passiveSkill;
				obj.stock -= skillDef.stockToConsume;
			}
		}
	}
