					{
						ConvertMaterial(val);
					}
				}
			}

			public static void ConvertMaterial(Material material)
			{
				Texture val = null;
				if (material.HasProperty("_BumpMap"))
				{
					val = material.GetTexture("_BumpMap");
				}
				material.shader = hotpoo;
				if ((Object)(object)val != (Object)null)
				{
					material.SetTexture("_NormalTex", val);
					material.SetFloat("_NormalStrength", 1f);
				}
			}

