			component.baseNameToken = "HABIBI_TESLA_TOWER_SCEPTER_NAME";
			component.portraitIcon = assetBundle.LoadAsset<Texture>("texIconTeslaTower");
			EntityStateMachine val = EntityStateMachine.FindByCustomName(bodyPrefab, "Body");
			val.initialStateType = new SerializableEntityStateType(typeof(TowerSpawnStateScepter));
			val.mainStateType = new SerializableEntityStateType(typeof(TowerIdleSearchScepter));
			Content.AddCharacterBodyPrefab(bodyPrefab);
			prefabCharacterModel = bodyPrefab.GetComponentInChildren<CharacterModel>();
			characterModelObject = ((Component)prefabCharacterModel).gameObject;
		}

