			if (!AkSoundEngine.GetIDFromString(voiceEvent).Equals(0u) && RobomandoConfig.CinematicMode.Value && canPlayVoice)
			{
				VoiceChain voiceChain = new VoiceChain(new List<string> { voiceEvent });
				if (voiceEvent.Equals("Play_Robo_Voice_Gold_Number"))
				{
					voiceChain = ConstructGoldVoiceChain(voiceChain);
				}
				else if (voiceEvent.Equals("Play_Robo_Voice_Survival_Time"))
				{
					voiceChain = ConstructSurvivalTimeVoiceChain(voiceChain);
				}
				else if (voiceEvent.Equals("Play_Robo_Voice_Spawn_Stage"))
				{
