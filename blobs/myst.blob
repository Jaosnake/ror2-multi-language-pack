			string text11 = "MP Cost: " + Flamebolt.MPCost + Environment.NewLine;
			text11 = text11 + "Damage: " + Flamebolt.Damage * 100f + "%" + Environment.NewLine;
			text11 = text11 + Environment.NewLine + "A guiding light of ruin, the power to burn our enemies... But who are the enemies?... Why are we fighting?";
			LanguageAPI.Add(text2 + "FIREBALL_INFO", text11);
			LanguageAPI.Add(text2 + "CONEOFFROST_NAME", "Cone of Frost");
