        "ROB_DRIVER_BODY_SECONDARY_HEAVY_MACHINEGUN_NAME": "Granada",
        "ROB_DRIVER_BODY_SECONDARY_HEAVY_MACHINEGUN_DESCRIPTION": "Lanza una granada que <style=cIsUtility> aturde a los enemigos </style> y les inflige un 800 % de daño.</i>",
        "ROB_DRIVER_BODY_SECONDARY_ROCKETLAUNCHER_NAME": "Tormenta",
        "ROB_DRIVER_BODY_SECONDARY_ROCKETLAUNCHER_DESCRIPTION": "Dispara una rápida ráfaga de cohetes que infligen un 300 % de daño cada uno.</i>",
        "ROB_DRIVER_BODY_SECONDARY_ROCKETLAUNCHER_ALT_NAME": "Tormenta",
        "ROB_DRIVER_BODY_SECONDARY_ROCKETLAUNCHER_ALT_DESCRIPTION": "Dispara una rápida ráfaga de cohetes que infligen un 250 % de daño cada uno.</i>",
        "ROB_DRIVER_BODY_SECONDARY_PLASMACANNON_NAME": "Aniquilar",
        "ROB_DRIVER_BODY_SECONDARY_PLASMACANNON_DESCRIPTION": "Dispara una andanada de ráfagas de plasma que infligen un 1000% de daño cada una.</i>",
        "ROB_DRIVER_BODY_SECONDARY_SNIPER_NAME": "Enfocar",
        "ROB_DRIVER_BODY_SECONDARY_SNIPER_DESCRIPTION": "Apunta a través de tu mira, <style=cIsDamage>exponiendo puntos débiles</style> y dispara un tiro devastador que inflige un 600% de daño.</i>",
        "ROB_DRIVER_BODY_SECONDARY_BANDITREVOLVER_NAME": "Luces apagadas",
        "ROB_DRIVER_BODY_SECONDARY_BANDITREVOLVER_DESCRIPTION": "Apunta y dispara un tiro devastador que inflige un 1500 % de daño. <style=cIsHealth>Actualiza los tiempos de reutilización y la munición al matar, pero consume el arma.</style></i>",
        "ROB_DRIVER_BODY_SECONDARY_GOLDENGUN_NAME": "Forajido",
        "ROB_DRIVER_BODY_SECONDARY_GOLDENGUN_DESCRIPTION": "Apunta y dispara un tiro devastador que inflige un 1500 % de daño. <style=cIsHealth>Consume el arma en uso.</style></i>",
        "ROB_DRIVER_BODY_SECONDARY_LUNARHAMMER_NAME": "Fragmentos",
        "ROB_DRIVER_BODY_SECONDARY_LUNARHAMMER_DESCRIPTION": "<style=cIsUtility>Ágil</style>. Dispara una salva de fragmentos lunares que infligen un 180 % de daño cada uno.</i>",
        "ROB_DRIVER_BODY_SECONDARY_MANDO_SMG_NAME": "Fuego supresor",
        "ROB_DRIVER_BODY_SECONDARY_MANDO_SMG_DESCRIPTION": "<style=cIsDamage>Aturdidor.</style> Dispara repetidamente para causar 6x250% de daño. El número de disparos aumenta con la velocidad de ataque.</i>",
        "ROB_DRIVER_BODY_SECONDARY_NEMMANDO_NAME": "Envío",
        "ROB_DRIVER_BODY_SECONDARY_NEMMANDO_DESCRIPTION": "<style=cIsDamage>Impresionante</style>. Dispara repetidamente para causar 6x250% de daño por disparo. El número de disparos aumenta con la velocidad de ataque.</i>",
        "ROB_DRIVER_BODY_SECONDARY_NEMMERC_NAME": "Intento",
        "ROB_DRIVER_BODY_SECONDARY_NEMMERC_DESCRIPTION": "<style=cIsDamage>Aturde</style> y <style=cIsUtility>empuja</style> a los enemigos cercanos para causar un 250 % de daño.</i>",
        "ROB_DRIVER_BODY_SECONDARY_RAV_PUNCH_NAME": "Puñetazo",
        "ROB_DRIVER_BODY_SECONDARY_RAV_PUNCH_DESCRIPTION": "Corre hacia adelante y <style=cIsUtility>golpea</style>, causando un 400 % de daño con una <style=cIsUtility>onda de choque</style> que causa el mismo daño.</i>",
        "ROB_DRIVER_BODY_SECONDARY_ARTI_GAUNTLET_NAME": "Nanobomba",
        "ROB_DRIVER_BODY_SECONDARY_ARTI_GAUNTLET_DESCRIPTION": "<style=cIsDamage>Impresionante</style>. Carga una nanobomba explosiva que inflige entre un 600 % y un 2000 % de daño.</i>",
        "ROB_DRIVER_BODY_UTILITY_SLIDE_NAME": "Diapositiva de combate",
        "ROB_DRIVER_BODY_UTILITY_SLIDE_DESCRIPTION": "<style=cIsUtility>Desliza</style> por el suelo una distancia corta. Puedes <style=cIsDamage>disparar mientras te deslizas.</style></i>",
        "ROB_DRIVER_BODY_UTILITY_DASH_NAME": "Esquivar",
        "ROB_DRIVER_BODY_UTILITY_DASH_DESCRIPTION": "<style=cIsUtility>Dash</style> una distancia corta. Puedes <style=cIsUtility>tener hasta 2 cargas.</style></i>",
        "ROB_DRIVER_BODY_UTILITY_SKATEBOARD_NAME": "Monopatín",
        "ROB_DRIVER_BODY_UTILITY_SKATEBOARD_DESCRIPTION": "Montar un monopatín <style=cIsUtility></style>.</i>",
        "ROB_DRIVER_BODY_UTILITY_SKATEBOARD2_DESCRIPTION": "Desmontar el <style=cIsUtility>skateboard</style>.</i>",
        "ROB_DRIVER_BODY_SPECIAL_GRENADE_NAME": "explosión explosiva",
        "ROB_DRIVER_BODY_SPECIAL_GRENADE_DESCRIPTION": "Lanza una granada que <style=cIsUtility> aturde a los enemigos </style> y les inflige un 500 % de daño. <style=cIsUtility>Los enemigos aturdidos apuntan en direcciones aleatorias durante 10 segundos.</style></i>",
        "ROB_DRIVER_BODY_SPECIAL_GRENADE_SCEPTER_NAME": "Cóctel Molotov",
        "ROB_DRIVER_BODY_SPECIAL_GRENADE_SCEPTER_DESCRIPTION": "Lanza una granada que <style=cIsUtility> aturde a los enemigos </style> y les inflige un 500 % de daño. <style=cIsUtility>Los enemigos aturdidos apuntan en direcciones aleatorias durante 10 segundos.</style>\n<style=cIsUtility>Cetro: lanza un cóctel molotov que explota en llamas.</style></i>",
        "ROB_DRIVER_BODY_SPECIAL_SUPPLY_DROP_NAME": "Caída de suministro",
        "ROB_DRIVER_BODY_SPECIAL_SUPPLY_DROP_DESCRIPTION": "Llame a una caja que contiene un <color=#00FF66>arma aleatoria</color>. <style=cIsHealth>El arma viene con solo media munición.</style></i>",
        "ROB_DRIVER_BODY_SPECIAL_SUPPLY_DROP_LEGACY_NAME": "Caída de suministros (heredado)",
        "ROB_DRIVER_BODY_SPECIAL_SUPPLY_DROP_LEGACY_DESCRIPTION": "Llame a una caja que contiene un <color=#FFFF00>Prototype Rocket Launcher</color>. <style=cIsUtility>Solo puedes llamar a uno por etapa.</style></i>",
        "ROB_DRIVER_BODY_SPECIAL_SUPPLY_DROP_SCEPTER_NAME": "Llamada nula",
        "ROB_DRIVER_BODY_SPECIAL_SUPPLY_DROP_SCEPTER_DESCRIPTION": "Llame a una caja que contiene un <color=#00FF66>arma aleatoria</color>. <style=cIsHealth>El arma viene con solo media munición.</style>\n<style=cIsUtility>Cetro: Invoca un arma vacía.</style></i>",
        "ROB_DRIVER_BODY_SPECIAL_SUPPLY_DROP_LEGACY_SCEPTER_NAME": "Llamada nula",
        "ROB_DRIVER_BODY_SPECIAL_SUPPLY_DROP_LEGACY_SCEPTER_DESCRIPTION": "Llame a una caja que contiene un <color=#FFFF00>Prototipo de lanzacohetes</color>.\n<style=cIsUtility>Scepter: Llame a un arma vacía.</style></i>",
        "ROB_DRIVER_BODY_SPECIAL_HEAL_NAME": "Cuidados personales",
        "ROB_DRIVER_BODY_SPECIAL_HEAL_DESCRIPTION": "Saca un <style=cIsUtility>Medkit</style> y cúrate gradualmente hasta alcanzar la máxima salud.</i>",
        "ROB_DRIVER_BODY_SPECIAL_KNIFE_NAME": "Cuchillo de combate",
        "ROB_DRIVER_BODY_SPECIAL_KNIFE_DESCRIPTION": "Corta a los enemigos cercanos con una hoja dentada, lo que les inflige un 470% de daño y <style=cIsHealth> los hiere</style>, <style=cIsDamage>reduce la armadura</style> durante <style=cIsUtility>4 segundos</style>.</i>",
        "ROB_DRIVER_BODY_SPECIAL_KNIFE_SCEPTER_NAME": "Cuchillo de combate (cetro)",
        "ROB_DRIVER_BODY_SPECIAL_KNIFE_SCEPTER_DESCRIPTION": "Corta a los enemigos cercanos con una hoja dentada, lo que les inflige un 470 % de daño y <style=cIsHealth> los hiere</style>, <style=cIsDamage> reduce la armadura</style> durante <style=cIsUtility>4 segundos</style>.\n<style=cIsUtility>Cetro: medio tiempo de reutilización y extra cargo.</style></i>",
        "ROB_DRIVER_BODY_SPECIAL_SYRINGE_NAME": "Jeringa experimental",
        "ROB_DRIVER_BODY_SPECIAL_SYRINGE_DESCRIPTION": "Inyéctese con una <style=cIsUtility>jeringa</style>, lo que otorga <style=cIsDamage>velocidad de ataque</style>, <style=cIsUtility>velocidad de movimiento</style> y <style=cIsHealing>regeneración de salud</style> para el próximo <style=cIsUtility>6 segundos</style>.</style>0__",
        "ROB_DRIVER_BODY_SPECIAL_SYRINGE_SCEPTER_NAME": "Jeringa mejorada",
        "ROB_DRIVER_BODY_SPECIAL_SYRINGE_SCEPTER_DESCRIPTION": "Inyéctate con una <style=cIsUtility>jeringa</style>, otorgando <style=cIsDamage>velocidad de ataque adicional</style> y <style=cIsHealing>regeneración de salud</style> durante los próximos <style=cIsUtility>6 segundos</style>.\n<style=cIsUtility>Cetro: aumenta el daño y el crítico. oportunidad y fortalece los beneficios.</style></style>0__",
        "ROB_DRIVER_BODY_SPECIAL_SYRINGELEGACY_NAME": "Jeringa sospechosa (heredada)",
