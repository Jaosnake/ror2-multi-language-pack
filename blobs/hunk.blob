				LanguageAPI.Add(string.Format(format2, "ROB_HUNK_TYPHOON_UNLOCKABLE_ACHIEVEMENT_ID"), "As HUNK, beat the game or obliterate on Typhoon or Eclipse.\n<color=#8888>(Counts any difficulty Typhoon or higher)</color>");
