        "HASTEREAPR_ASSASSIN_PRIMARY_CUTTER_DESCRIPTION": "<style=cIsUtility>Agile.</style>Lancez 1 dague pour <style=cIsDamage>30 % à 200 % de dégâts</style>.",
        "HASTEREAPR_ASSASSIN_SECONDARY_POISON_NAME": "Poison",
        "HASTEREAPR_ASSASSIN_SECONDARY_POISON_DESCRIPTION": "<style=cIsUtility>Agile.</style>Lancez une potion empoisonnée pour <style=cIsDamage>250 % de dégâts</style> plus un <style=cIsDamage>500 % de dégâts supplémentaires sur la durée.</style>",
        "HASTEREAPR_ASSASSIN_SECONDARY_POISON_DESCRIPTION_SCEPTER": "<style=cIsUtility>Agile.</style>Lancez une potion empoisonnée groupée pour <style=cIsDamage>250 % de dégâts</style> plus un <style=cIsDamage>500 % de dégâts supplémentaires sur la durée, chacun.</style> \n\n<style=cKeywordName>Sous l'influence de War Cry, lancez une potion groupée récursive, avec une puissance plus faible. enfants.</style>",
        "HASTEREAPR_ASSASSIN_SECONDARY_POISON_NAME_ALT": "Venin virulent",
        "HASTEREAPR_ASSASSIN_SECONDARY_POISON_DESCRIPTION_ALT": "<style=cIsUtility>Agile.</style>Lance une potion persistante pour <style=cIsDamage>500 % de dégâts.</style> <style=cIsUtility>Les toxines persistent pendant 5 secondes.</style> <style=cDeath>N'inflige pas de poison.</style>",
        "HASTEREAPR_ASSASSIN_SCEPTER_SECONDARY_POISON_DESCRIPTION_ALT": "<style=cIsUtility>Agile.</style>Lancez 2 potions persistantes dans un éventail libre pour <style=cIsDamage>500 % de dégâts.</style> <style=cIsUtility>Les toxines persistent pendant 5 secondes.</style> <style=cDeath>N'inflige pas de poison.</style>",
        "HASTEREAPR_ASSASSIN_UTILITY_CLOAK_NAME": "Téléportation",
        "HASTEREAPR_ASSASSIN_UTILITY_CLOAK_DESCRIPTION": "Lancez une potion vers votre curseur <style=cIsUtility> pour vous téléporter là où elle atterrit, </style> puis lancez une potion sur le sol, <style=cIsUtility> explosant dans un nuage de fumée, gagnant le buff Cloak Speed. </style>",
        "HASTEREAPR_ASSASSIN_UTILITY_ROLL_NAME": "Rouleau de camouflage",
