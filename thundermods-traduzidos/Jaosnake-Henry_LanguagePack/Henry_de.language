{
    "de": {
        "ROB_HENRY_BODY_NAME": "Heinrich",
        "ROB_HENRY_BODY_DESCRIPTION": "Henry ist ein geschickter Kämpfer, der ein breites Arsenal an Waffen einsetzt, um seine Feinde zu besiegen.<color=#CCD3E0>",
        "ROB_HENRY_BODY_SUBTITLE": "Der Auserwählte",
        "ROB_HENRY_BODY_LORE": "Beispielkunde",
        "ROB_HENRY_BODY_OUTRO_FLAVOR": "..und so ging er, auf der Suche nach einer neuen Identität.",
        "ROB_HENRY_BODY_OUTRO_FAILURE": "..und so verschwand er, für immer ein unbeschriebenes Blatt.",
        "ROB_HENRY_BODY_DEFAULT_SKIN_NAME": "Standard",
        "ROB_HENRY_BODY_MASTERY_SKIN_NAME": "Alternativ",
        "ROB_HENRY_BODY_TYPHOON_SKIN_NAME": "V1",
        "ROB_HENRY_BODY_DANTE_SKIN_NAME": "Dante",
        "ROB_HENRY_BODY_VERGIL_SKIN_NAME": "Vergil",
        "ROB_HENRY_BODY_SAMURAI_SKIN_NAME": "Samurai",
        "ROB_HENRY_BODY_SOLDIER_SKIN_NAME": "Champion",
        "ROB_HENRY_BODY_ZOMBIE_SKIN_NAME": "Zombie",
        "ROB_HENRY_BODY_SKELETON_SKIN_NAME": "Skelett",
        "ROB_HENRY_BODY_PASSIVE_NAME": "Henrys Passiv",
        "ROB_HENRY_BODY_PASSIVE_DESCRIPTION": "Beispieltext.",
        "ROB_HENRY_BODY_PRIMARY_SLASH_NAME": "Schwert",
        "ROB_HENRY_BODY_PRIMARY_SLASH_DESCRIPTION": "<style=cIsUtility>Agil.</style> Schwinge nach vorne für <style=cIsDamage>280% Schaden</style>.",
        "ROB_HENRY_BODY_PRIMARY_PUNCH_NAME": "Boxhandschuhe",
        "ROB_HENRY_BODY_PRIMARY_PUNCH_DESCRIPTION": "<style=cIsUtility>Agil.</style> Führe schnelle Faustschläge für <style=cIsDamage>240% Schaden</style> aus. <style=cIsUtility>Ignoriert Rüstung.</style>",
        "ROB_HENRY_BODY_PRIMARY_GUN_NAME": "Pistole",
        "ROB_HENRY_BODY_PRIMARY_GUN_DESCRIPTION": "<style=cIsUtility>Agil.</style> Feuere eine kleine Pistole für <style=cIsDamage>90% Schaden</style>.",
        "ROB_HENRY_BODY_SECONDARY_GUN_NAME": "Pistole",
        "ROB_HENRY_BODY_SECONDARY_GUN_DESCRIPTION": "<style=cIsUtility>Agil.</style> Feuere eine Pistole für <style=cIsDamage>420% Schaden</style>.",
        "ROB_HENRY_BODY_SECONDARY_STINGER_NAME": "Stinger",
        "ROB_HENRY_BODY_SECONDARY_STINGER_DESCRIPTION": "<style=cIsUtility>Agil.</style> Stürme auf einen Gegner zu und verursache <style=cIsDamage>450% Schaden</style>.",
        "ROB_HENRY_BODY_SECONDARY_UZI_NAME": "Uzi",
        "ROB_HENRY_BODY_SECONDARY_UZI_DESCRIPTION": "Feuere eine Uzi für <style=cIsDamage>75% Schaden</style>.",
        "ROB_HENRY_BODY_UTILITY_ROLL_NAME": "Rolle",
        "ROB_HENRY_BODY_UTILITY_ROLL_DESCRIPTION": "Rolle eine kurze Distanz und erhalte <style=cIsUtility>300 Rüstung</style>. <style=cIsUtility>Während der Rolle kannst du nicht getroffen werden.</style>",
        "ROB_HENRY_BODY_UTILITY_SHOTGUN_NAME": "Shotgun",
        "ROB_HENRY_BODY_UTILITY_SHOTGUN_DESCRIPTION": "Feuere eine <style=cIsUtility>Shotgun</style> für <style=cIsDamage>14x140% Schaden</style> und schleudere dich durch den Rückstoß zurück.",
        "ROB_HENRY_BODY_SPECIAL_BOMB_NAME": "Bombe",
        "ROB_HENRY_BODY_SPECIAL_BOMB_DESCRIPTION": "Wirf eine Bombe für <style=cIsDamage>1600% Schaden</style>.",
        "ROB_HENRY_BODY_SPECIAL_SCEPBOMB_NAME": "Mehr Bomben!",
        "ROB_HENRY_BODY_SPECIAL_SCEPBOMB_DESCRIPTION": "Wirf eine Bombe für <style=cIsDamage>1600% Schaden</style>.\n<color=#d299ff>SCEPTER: Halte bis zu 4 Bomben. Abklingzeit halbiert.</color>",
        "ROB_HENRY_BODY_SPECIAL_BAZOOKA_NAME": "Bazooka",
        "ROB_HENRY_BODY_SPECIAL_BAZOOKA_DESCRIPTION": "Lade und feuere Raketen für <style=cIsDamage>600%-1600% Schaden</style>.",
        "ROB_HENRY_BODY_PRIMARY_BAZOOKA_NAME": "Feuern",
        "ROB_HENRY_BODY_PRIMARY_BAZOOKA_DESCRIPTION": "Lade und feuere eine Rakete für <style=cIsDamage>600%-1600% Schaden</style>.",
        "ROB_HENRY_BODY_PRIMARY_BAZOOKAOUT_NAME": "Abbrechen",
        "ROB_HENRY_BODY_PRIMARY_BAZOOKAOUT_DESCRIPTION": "Lege deine <style=cIsDamage>Bazooka</style> weg.",
        "ROB_HENRY_BODY_SPECIAL_SCEPBAZOOKA_NAME": "Armageddon",
        "ROB_HENRY_BODY_SPECIAL_SCEPBAZOOKA_DESCRIPTION": "Lade und feuere Raketen für <style=cIsDamage>600%-1600% Schaden</style>.\n<color=#d299ff>SCEPTER: Halte zwei Bazookas gleichzeitig.</color>",
        "ROB_HENRY_BODY_PRIMARY_SCEPBAZOOKA_NAME": "Feuern",
        "ROB_HENRY_BODY_PRIMARY_SCEPBAZOOKA_DESCRIPTION": "Lade und feuere eine Rakete für <style=cIsDamage>600%-1600% Schaden</style>.\n<color=#d299ff>SCEPTER: Halte zwei Bazookas gleichzeitig.</color>",
        "ROB_HENRY_BODY_SPECIAL_FRENZY_NAME": "Rampage",
        "ROB_HENRY_BODY_SPECIAL_FRENZY_DESCRIPTION": "Baue bei Treffern <style=cIsHealth>Fury</style> auf. Nutze es bei voller Ladung, um für <style=cIsUtility>10 Sekunden</style> in einen <style=cIsDamage>Rausch</style> zu verfallen. <style=cIsHealth>Lädt bei niedriger Gesundheit schneller.</style>",
        "ROB_HENRY_BODY_SPECIAL_SCEPFRENZY_NAME": "Super Saiyan",
        "ROB_HENRY_BODY_SPECIAL_SCEPFRENZY_DESCRIPTION": "Baue bei Treffern <style=cIsHealth>Fury</style> auf. Nutze es bei voller Ladung, um für <style=cIsUtility>10 Sekunden</style> in einen <style=cIsDamage>Rausch</style> zu verfallen. <style=cIsHealth>Lädt bei niedriger Gesundheit schneller.</style>\n<color=#d299ff>SCEPTER: Attributsboni stark erhöht. Dauer erhöht.</color>",
        "ACHIEVEMENT_ROB_HENRY_BODY_UNLOCKABLE_ACHIEVEMENT_ID_NAME": "Prelude",
        "ACHIEVEMENT_ROB_HENRY_BODY_UNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "Betritt Titanic Plains.",
        "ACHIEVEMENT_ROB_HENRY_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_ID_NAME": "Henry: Mastery",
        "ACHIEVEMENT_ROB_HENRY_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "Schließe als Henry das Spiel ab oder obliteriere auf Monsoon.",
        "ACHIEVEMENT_ROB_HENRY_BODY_TYPHOONUNLOCKABLE_ACHIEVEMENT_ID_NAME": "Henry: Grand Mastery",
        "ACHIEVEMENT_ROB_HENRY_BODY_TYPHOONUNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "Schließe als Henry das Spiel ab oder obliteriere auf Typhoon oder Eclipse.\n<color=#8888>(Zählt jede Schwierigkeit Typhoon oder höher)</color>",
        "ROB_HENRY_BODY_DANTEUNLOCKABLE_ACHIEVEMENT_NAME": "Henry: Jackpot",
        "ROB_HENRY_BODY_DANTEUNLOCKABLE_ACHIEVEMENT_DESC": "As Henry, defeat a Twisted Scavenger on Monsoon.",
        "ROB_HENRY_BODY_DANTEUNLOCKABLE_UNLOCKABLE_NAME": "Henry: Jackpot",
        "ROB_HENRY_BODY_VERGILUNLOCKABLE_ACHIEVEMENT_NAME": "Henry: 200% Motivated",
        "ROB_HENRY_BODY_VERGILUNLOCKABLE_ACHIEVEMENT_DESC": "As Henry, defeat the King of Nothing with no items.",
        "ROB_HENRY_BODY_VERGILUNLOCKABLE_UNLOCKABLE_NAME": "Henry: 200% Motivated",
        "ACHIEVEMENT_ROB_HENRY_MASTERYACHIEVEMENT_NAME": "Henry: Mastery",
        "ACHIEVEMENT_ROB_HENRY_MASTERYACHIEVEMENT_DESCRIPTION": "Schlagen Sie als Henry das Spiel oder vernichten Sie Monsun.",
        "ROB_MRGREEN_BODY_NAME": "Mr. Green",
        "ROB_MRGREEN_BODY_DESCRIPTION": "Mr. Green<color=#CCD3E0>\n\n< ! > Schwert ist vielseitig, während Boxhandschuhe besser sind, um starke Gegner zu verprügeln.\n\n< ! > Pistole ist stark gegen Luftziele, mit kurzer Abklingzeit und hohem Schaden.\n\n< ! > Rolle verleiht länger anhaltende Rüstung und kann aggressiv genutzt werden.\n\n< ! > Bombe kann Gruppen mühelos auslöschen.</color>",
        "ROB_MRGREEN_BODY_SUBTITLE": "Der",
        "ROB_MRGREEN_BODY_LORE": "Beispiel-Lore Teil 2",
        "ROB_MRGREEN_BODY_OUTRO_FLAVOR": "..and so he left, bottom text.",
        "ROB_MRGREEN_BODY_DEFAULT_SKIN_NAME": "Standard",
        "ROB_MRGREEN_BODY_PASSIVE_NAME": "Mr. Greens Passiv",
        "ROB_MRGREEN_BODY_PASSIVE_DESCRIPTION": "Beispieltext.",
        "ROB_MRGREEN_BODY_PRIMARY_PUNCH_NAME": "Martial Arts",
        "ROB_MRGREEN_BODY_PRIMARY_PUNCH_DESCRIPTION": "Führe eine schnelle Kombination aus Schlägen und Tritten für <style=cIsDamage>90% Schaden</style> aus.",
        "ROB_MRGREEN_BODY_SECONDARY_CLONETHROW_NAME": "Klonwurf",
        "ROB_MRGREEN_BODY_SECONDARY_CLONETHROW_DESCRIPTION": "Beschwöre einen Klon und wirf ihn nach vorne. Er greift nahe Gegner und schleudert sie für <style=cIsDamage>420% Schaden</style> zu Boden.",
        "ROB_MRGREEN_BODY_UTILITY_DASH_NAME": "People's Elbow",
        "ROB_MRGREEN_BODY_UTILITY_DASH_DESCRIPTION": "Stürme eine kurze Strecke. Bei Kontakt mit einem <style=cIsUtility>Klon</style> springst du in die Luft und landest mit einem mächtigen <style=cIsUtility>Ellbogenschlag</style> für <style=cIsDamage>800% Schaden</style>.",
        "ROB_MRGREEN_BODY_SPECIAL_RES_NAME": "Resurrection",
        "ROB_MRGREEN_BODY_SPECIAL_RES_DESCRIPTION": "Belebe alle gefallenen Klone wieder.",
        "ROB_NEMRY_BODY_NAME": "Nemesis Henry",
        "ROB_NEMRY_BODY_DESCRIPTION": "Nemesis Henry ist ein instabiler Schwertkämpfer mit einer besonderen Klinge, die Energie speichert, um Angriffe zu verstärken. Er hat keine normalen Abklingzeiten, muss seine Energie aber gut verwalten.<color=#CCD3E0>\n\n< ! > Sword Mode baut Energie auf, während Gun Mode Energie für starke Angriffe verbraucht.\n\n< ! > Swordmaster kann für mehr Schaden aufgeladen werden.\n\n< ! > Flash Step ist ein starkes aggressives Werkzeug, das Energie aufbaut.\n\n< ! > Nutze Hydra Bite zum Überleben und Hyper Beam für massiven Schaden.</color>",
        "ROB_NEMRY_BODY_SUBTITLE": "Der Gefallene",
        "ROB_NEMRY_BODY_LORE": "Beispiel-Lore",
        "ROB_NEMRY_BODY_OUTRO_FLAVOR": "..and so he left, having blown up the moon for no discernible reason.",
        "ROB_NEMRY_BODY_OUTRO_FAILURE": "..he tried so hard, and got so far. But in the end it doesn't even matter.",
        "ROB_NEMRY_BODY_DEFAULT_SKIN_NAME": "Nemesis",
        "ROB_NEMRY_BODY_MASTERY_SKIN_NAME": "Captive #001",
        "ROB_NEMRY_BODY_TYPHOON_SKIN_NAME": "FLLFFL",
        "ROB_NEMRY_BODY_PASSIVE_NAME": "Säure-Gunblade",
        "ROB_NEMRY_BODY_PASSIVE_DESCRIPTION": "Nemesis Henry führt eine Spezialwaffe, die zwischen Sword Mode und Gun Mode wechseln kann. Seine Fertigkeiten haben keine normalen Abklingzeiten, sondern nutzen das <style=cIsHealing>Energie</style>-System seines Schwerts.",
        "ROB_NEMRY_BODY_PRIMARY_SPEAR_NAME": "Aufspießen",
        "ROB_NEMRY_BODY_PRIMARY_SPEAR_DESCRIPTION": "<style=cIsUtility>Agil.</style> Stich nach vorne für <style=cIsDamage>160% Schaden</style>. <style=cIsDamage>viel <style=cIsHealing>50%</style> Heilt 50% des verursachten Schadens.</style>.",
        "ROB_WEAPON_SWAP_SKILL": "Weapon Swap",
        "ROB_NEMRY_BODY_PRIMARY_SWORD_NAME": "Sword Mode",
        "ROB_NEMRY_BODY_PRIMARY_SWORD_DESCRIPTION": "Schwinge deine Klinge nach vorne für <style=cIsDamage>280% Schaden</style>. Erzeuge bei Treffern <style=cIsHealing>20% Energie</style>.",
        "ROB_NEMRY_BODY_PRIMARY_GUN_NAME": "Gun Mode",
        "ROB_NEMRY_BODY_PRIMARY_GUN_DESCRIPTION": "<style=cIsHealing>2,5% Energie.</style> Feuere einen durchdringenden <style=cIsHealing>Energie</style>schuss für <style=cIsDamage>240% Schaden</style>.",
        "ROB_NEMRY_BODY_PRIMARY_SWORDCSS_NAME": "Sword Mode / Gun Mode",
        "ROB_NEMRY_BODY_PRIMARY_SWORDCSS_DESCRIPTION": "Schwinge deine Klinge nach vorne für <style=cIsDamage>280% Schaden</style>. Erzeuge bei Treffern <style=cIsHealing>20% Energie</style>.\n<style=cIsHealing>2,5% Energie.</style> Feuere einen durchdringenden <style=cIsHealing>Energie</style>schuss für <style=cIsDamage>240% Schaden</style>.",
        "ROB_NEMRY_BODY_SECONDARY_BLAST_NAME": "Null Blast",
        "ROB_NEMRY_BODY_SECONDARY_BLAST_DESCRIPTION": "<style=cIsUtility>Agil.</style> Wirf eine Kugel aus geheimnisvoller Energie für <style=cIsDamage>200% Schaden</style>.",
        "ROB_NEMRY_BODY_SECONDARY_CHARGE_NAME": "Swordmaster",
        "ROB_NEMRY_BODY_SECONDARY_CHARGE_DESCRIPTION": "<style=cIsHealing>10% Energie.</style> Stürme zu einem nahen Gegner und verursache <style=cIsDamage>700% Schaden</style>.",
        "ROB_NEMRY_BODY_SECONDARY_TORRENT_NAME": "Gunslinger",
        "ROB_NEMRY_BODY_SECONDARY_TORRENT_DESCRIPTION": "<style=cIsHealing>5% Energie.</style> Feuere eine Salve von Energie.",
        "ROB_NEMRY_BODY_SECONDARY_CHARGECSS_NAME": "Swordmaster / Gunslinger",
        "ROB_NEMRY_BODY_SECONDARY_CHARGECSS_DESCRIPTION": "<style=cIsHealing>10% Energie.</style> Stürme zu einem nahen Gegner und verursache <style=cIsDamage>700% Schaden</style>.\n<style=cIsHealing>5% Energie.</style> Feuere eine Salve von Energie.",
        "ROB_NEMRY_BODY_UTILITY_DODGESLASH_NAME": "Schneller Schnitt",
        "ROB_NEMRY_BODY_UTILITY_DODGESLASH_DESCRIPTION": "Springe zurück und schlitze nahe Gegner für <style=cIsDamage>300% Schaden</style>.",
        "ROB_NEMRY_BODY_UTILITY_BLINK_NAME": "Flash Step",
        "ROB_NEMRY_BODY_UTILITY_BLINK_DESCRIPTION": "<style=cIsHealing>5% Energie.</style> Stürme zu einem nahen Gegner und verursache",
        "ROB_NEMRY_BODY_UTILITY_BURST_NAME": "Energieschub",
        "ROB_NEMRY_BODY_UTILITY_BURST_DESCRIPTION": "<style=cIsHealing>10% Energie.</style> Entlade Energie und schleudere dich durch Rückstoß für <style=cIsDamage>400% Schaden</style>.",
        "ROB_NEMRY_BODY_UTILITY_BLINKCSS_NAME": "Flash Step / Energieschub",
        "ROB_NEMRY_BODY_UTILITY_BLINKCSS_DESCRIPTION": "<style=cIsHealing>5% Energie.</style> Stürme zu einem nahen Gegner und verursache\n<style=cIsHealing>10% Energie.</style> Entlade Energie und schleudere dich durch Rückstoß für <style=cIsDamage>400% Schaden</style>.",
        "ROB_NEMRY_BODY_SPECIAL_STAB_NAME": "Hydra Bite",
        "ROB_NEMRY_BODY_SPECIAL_STAB_DESCRIPTION": "<style=cIsHealing>100% Energie.</style> Stoße deine Klinge in einen Gegner und verursache <style=cIsDamage>2800% Schaden</style>. <style=cIsHealing>Heilt 50% des verursachten Schadens.</style>",
        "ROB_NEMRY_BODY_SPECIAL_BEAM_NAME": "Hyper Beam",
        "ROB_NEMRY_BODY_SPECIAL_BEAM_DESCRIPTION": "<style=cIsHealing>100% Energie.</style> Lade einen mächtigen Laserhagel für <style=cIsDamage>10x540% Schaden</style>.",
        "ROB_NEMRY_BODY_SPECIAL_STABCSS_NAME": "Hydra Bite / Hyper Beam",
        "ROB_NEMRY_BODY_SPECIAL_STABCSS_DESCRIPTION": "<style=cIsHealing>100% Energie.</style> Stoße deine Klinge in einen Gegner und verursache <style=cIsDamage>2800% Schaden</style>. <style=cIsHealing>Heilt 50% des verursachten Schadens.</style>\n<style=cIsHealing>100% Energie.</style> Lade einen mächtigen Laserhagel für <style=cIsDamage>viel Schaden</style>.",
