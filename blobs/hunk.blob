				mutationBonusAirdash = NemesisMutationDef.CreateMutationDef("Air Dash Double", "Gain a second Air Dash.");
				mutationTendrilBarrageDevastator = NemesisMutationDef.CreateMutationDef("Tendril Barrage Devastator", "Use Special with full Biomass to consume it all for a devastating barrage of tendrils.", 9);
				mutationTentacleGrab = NemesisMutationDef.CreateMutationDef("Tentacle Grab", "Double tap Grab to instead perform a ranged grab with your Tentacle.", 12);
				mutationAdrenalineSurge = NemesisMutationDef.CreateMutationDef("Adrenaline Surge", "When Biomass is full, lethal damage will be survived.", 18);
				mutationConsumeBoost = NemesisMutationDef.CreateMutationDef("Consume Boost", "All enemies can now be consumed at full health.", 15);
			}

