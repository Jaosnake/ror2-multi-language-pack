        "SS2_PLAYER_DAMAGE_50_DECREASE_NAME_TOKEN": "-50% ai danni inflitti",
        "SS2_PLAYER_DAMAGE_50_DECREASE_BODY_TOKEN": "I giocatori infliggono il 50% dei danni.",
        "SS2_PLAYER_DAMAGE_75_DECREASE_NAME_TOKEN": "-75% danni inflitti",
        "SS2_PLAYER_DAMAGE_75_DECREASE_BODY_TOKEN": "I giocatori infliggono il 25% di danni.",
        "SS2_PLAYER_DAMAGE_90_DECREASE_NAME_TOKEN": "-90% danni inflitti",
        "SS2_PLAYER_DAMAGE_90_DECREASE_BODY_TOKEN": "I giocatori infliggono il 10% di danni.",
        "SS2_PLAYER_ARMOR_RULE_NAME": "Danni ricevuti dai giocatori",
        "SS2_PLAYER_ARMOR_DEFAULT_NAME_TOKEN": "Danno predefinito ricevuto",
        "SS2_PLAYER_ARMOR_DEFAULT_BODY_TOKEN": "I giocatori subiscono il 100% dei danni.",
        "SS2_PLAYER_ARMOR_25_INCREASE_NAME_TOKEN": "+25% danni ricevuti",
        "SS2_PLAYER_ARMOR_25_INCREASE_BODY_TOKEN": "I giocatori subiscono il 125% di danni.",
        "SS2_PLAYER_ARMOR_50_INCREASE_NAME_TOKEN": "+50% ai danni ricevuti",
        "SS2_PLAYER_ARMOR_50_INCREASE_BODY_TOKEN": "I giocatori subiscono il 150% di danni.",
        "SS2_PLAYER_ARMOR_75_INCREASE_NAME_TOKEN": "+75% danni ricevuti",
        "SS2_PLAYER_ARMOR_75_INCREASE_BODY_TOKEN": "I giocatori subiscono il 175% di danni.",
