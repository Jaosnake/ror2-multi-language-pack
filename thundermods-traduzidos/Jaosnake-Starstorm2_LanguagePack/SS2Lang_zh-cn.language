        "SS2_ITEM_BLEEDOUT_DESC": "受到<style=cIsHealth>致命伤害</style>时,改为以<style=cIsHealth>100%</style><style=cIsHealth>最大生命值</style>进入濒死。每<style=cIsUtility>4</style>分钟充能一次<style=cStack>(每层-20%)</style>。",
        "SS2_ITEM_CHUNGUS_NAME": "窃笑真菌",
        "SS2_ITEM_GUARDINGAMULET_DESC": "减少来自背后攻击的伤害<style=cIsDamage>{0}%</style><style=cStack>(每层+{0}%)</style>",
        "SS2_NEMESIS_MERCENARY_SECONDARY_KNIFE_NAME": "穿刺者",
        "SS2_NEMESIS_MERCENARY_SPECIAL_SCAN_DESCRIPTION": "在最多<style=cIsDamage>4</style>名附近敌人周围标记<style=cIsUtility>攻击矢量</style>。<style=cIsUtility>动到对应位置</style>后可突进,造成<style=cIsDamage>1200%伤害</style>。",
        "SS2_NEMCOMMANDO_SPECIAL_SCEPSUBMISSION_NAME": "制压连射",
        "SS2_CHIRR_DETONATE_NAME": "自然链接",
        "SS2_ITEM_GUARDINGAMULET_NAME": "守卫护符",
        "SS2_ITEM_WATCHMETRONOME_DESC": "不奔跑时,充能使<style=cIsUtility>奔跑速度</style>提升<style=cIsUtility>{0}%</style>。奔跑时,速度提升效果在<style=cIsUtility>{1}秒</style><style=cStack>(每层+{2}秒)</style>内逐渐衰减。",
        "SS2_NEMCOMMANDO_SECONDARY_BEAM_NAME": "远程斩击",
        "SS2_ITEM_RELICOFMASS_NAME": "质量遗物",
        "SS2_EXECUTIONER2_DASH_NAME": "人群疏散",
        "SS2_EQUIP_AFFIXVOID_PICKUP": "成为法令的门徒。",
        "SS2_DIFFICULTY_CYCLONE_DESC": "",
        "SS2_RUNSHROOM_BODY_NAME": "突袭菇",
