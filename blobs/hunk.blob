			private void HandleShield()
			{
				if (!Object.op_Implicit((Object)(object)characterBody) || !Object.op_Implicit((Object)(object)characterBody.healthComponent) || !Object.op_Implicit((Object)(object)shieldOverlay))
				{
					return;
				}
				if (!fancyShield)
				{
					shieldOverlay.SetActive(false);
					return;
				}
				if (characterBody.healthComponent.shield > 0f)
				{
					shieldOverlay.SetActive(fancyShield);
				}
				else
				{
					shieldOverlay.SetActive(false);
				}
				if (_shieldIsVoid != shieldIsVoid)
				{
					if (shieldIsVoid)
					{
						((Renderer)shieldOverlay.GetComponent<MeshRenderer>()).material = HunkAssets.voidShieldMat;
					}
					else
					{
						((Renderer)shieldOverlay.GetComponent<MeshRenderer>()).material = HunkAssets.shieldMat;
					}
				}
