				//IL_006f: Unknown result type (might be due to invalid IL or missing references)
				BarStyle result = vanishingBarStyle;
				result.sizeDelta = bar.style.cullBarStyle.sizeDelta;
				result.baseColor = Color.cyan;
				result.imageType = bar.style.cullBarStyle.imageType;
				result.sprite = bar.style.cullBarStyle.sprite;
				result.enabled = true;
				return result;
			}

			public override void UpdateInfo(ref BarInfo info, HealthBar healthBar)
			{
				base.UpdateInfo(ref info, healthBar);
				float num = (((Object)(object)healthBar.viewerBody != (Object)null && (Object)(object)healthBar.source != (Object)null && healthBar.source.body.isElite) ? healthBar.viewerBody.executeEliteHealthFraction : 0f);
				info.enabled = sickness > 0f;
				info.normalizedXMin = num;
				info.normalizedXMax = sickness + num;
			}

			public override void ApplyBar(ref BarInfo info, Image image, HealthComponent source, ref int i)
			{
				base.ApplyBar(ref info, image, source, ref i);
			}

