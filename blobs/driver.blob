			}
			GenericSkill primary = ((EntityState)this).skillLocator.primary;
			if (primary != null && primary.stock == 0)
			{
				timerSinceComplete += ((EntityState)this).GetDeltaTime();
				if (timerSinceComplete > SetupAirstrike.baseExitDuration / ((BaseState)this).attackSpeedStat)
				{
					((EntityState)this).outer.SetNextStateToMain();
				}
			}
		}

		public override void OnExit()
		{
			base.OnExit();
			((EntityState)this).skillLocator.primary?.UnsetWeaponSkill(primarySkillDef, (SkillOverridePriority)4);
			Util.PlaySound("Play_captain_shift_end", ((EntityState)this).gameObject);
			Util.PlaySound("Stop_captain_shift_active_loop", ((EntityState)this).gameObject);
			if (Object.op_Implicit((Object)(object)effectMuzzleInstance))
			{
				EntityState.Destroy((Object)(object)effectMuzzleInstance);
			}
			OverrideRequest obj = crosshairOverrideRequest;
			if (obj != null)
			{
				obj.Dispose();
			}
		}
	}
