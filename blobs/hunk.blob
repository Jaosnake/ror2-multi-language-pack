		public static bool HunkHasWeapon(HunkWeaponDef weaponDef)
		{
			HunkWeaponTracker[] array = Object.FindObjectsOfType<HunkWeaponTracker>();
			foreach (HunkWeaponTracker hunkWeaponTracker in array)
			{
				if (hunkWeaponTracker.ignoreFlag)
				{
					continue;
				}
				HunkWeaponData[] weaponData = hunkWeaponTracker.weaponData;
				for (int j = 0; j < weaponData.Length; j++)
				{
					HunkWeaponData hunkWeaponData = weaponData[j];
					if ((Object)(object)hunkWeaponData.weaponDef == (Object)(object)weaponDef)
					{
						return true;
					}
				}
			}
			return false;
		}

		public static bool HunkHasWeapon(ItemDef itemDef)
		{
			HunkWeaponTracker[] array = Object.FindObjectsOfType<HunkWeaponTracker>();
			foreach (HunkWeaponTracker hunkWeaponTracker in array)
			{
				if (!hunkWeaponTracker.ignoreFlag && ((Component)hunkWeaponTracker).GetComponent<Inventory>().GetItemCount(itemDef) > 0)
				{
					return true;
				}
			}
			return false;
		}

