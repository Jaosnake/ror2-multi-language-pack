							}
						}
						else if (!Object.op_Implicit((Object)(object)gunSkin.skinDef) && (Object)(object)gunSkin.weaponDef == (Object)(object)_weaponDef)
						{
							return gunSkin.modelPrefab;
						}
					}
				}
				return _weaponDef.modelPrefab;
			}

