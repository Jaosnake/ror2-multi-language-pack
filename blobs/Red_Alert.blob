			if ((Object)(object)bodyObject != (Object)null && bodyObject.TryGetComponent<TeslaTowerControllerController>(ref _ownerTowerController))
			{
				_ownerTowerController.addNotTower(((Component)this).gameObject);
			}
		}

		private void OnDestroy()
		{
