			private void Start()
			{
				HUD obj = targetHUD;
				object obj2;
				if (obj == null)
				{
					obj2 = null;
				}
				else
				{
					GameObject targetBodyObject = obj.targetBodyObject;
					obj2 = ((targetBodyObject != null) ? targetBodyObject.GetComponent<DriverController>() : null);
				}
