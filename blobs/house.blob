namespace HouseMod.SkillStates.House.Cards
{
	internal class Jackpot : BaseCardSkill
	{
		private BuffDef[] vanillaBuffs = (BuffDef[])(object)new BuffDef[34]
		{
			Buffs.AffixBlue,
			Buffs.AffixEcho,
			Buffs.AffixHaunted,
			Buffs.AffixHauntedRecipient,
			Buffs.AffixLunar,
			Buffs.AffixPoison,
			Buffs.AffixRed,
			Buffs.AffixWhite,
			Buffs.ArmorBoost,
			Buffs.AttackSpeedOnCrit,
			Buffs.BugWings,
			Buffs.Cloak,
			Buffs.CloakSpeed,
			Buffs.CrocoRegen,
			Buffs.ElementalRingsReady,
			Buffs.Energized,
			Buffs.EngiShield,
			Buffs.FullCrit,
			Buffs.HiddenInvincibility,
			Buffs.Immune,
			Buffs.Intangible,
			Buffs.LaserTurbineKillCharge,
			Buffs.LifeSteal,
			Buffs.MedkitHeal,
			Buffs.LunarShell,
			Buffs.NoCooldowns,
			Buffs.PowerBuff,
			Buffs.SmallArmorBoost,
			Buffs.TeamWarCry,
			Buffs.TeslaField,
			Buffs.TonicBuff,
			Buffs.Warbanner,
			Buffs.WarCryBuff,
			Buffs.WhipBoost
		};

		private int result = 7;

		private static float healFraction = 1f;

		private static float scaledGold = 30f;

		private static int numberOfBullets = 6;

		private static int numberOfbuffs = 3;

		private static int numberOfRolls = 7;

		private static float buffDuration = 20f;

		public override void OnEnter()
		{
			cardTypeActivationVFX = Assets.PositiveCardActivation;
			cardSweepVFX = Assets.CardSweepPositive;
			base.OnEnter();
			if (((EntityState)this).isAuthority)
			{
				if (Auspicious.IsAuspiciousEnabled)
				{
					result = (Auspicious.isLocalPlayerAuspicious ? 4 : passiveManager.random.Next(4));
				}
				else
				{
					result = passiveManager.random.Next(5);
				}
			}
			switch (result)
			{
			default:
				Debug.LogWarning((object)"[HouseError] Jackpot had no result for VFX");
				break;
			case 0:
				cardActivationVFX = Assets.VFXcardHearts;
				cardActivationSFX = "HouseCard_Heart";
				break;
			case 1:
				cardActivationVFX = Assets.VFXcardDiamonds;
				cardActivationSFX = "HouseCard_Diamond";
				break;
			case 2:
				cardActivationVFX = Assets.VFXcardClubs;
				cardActivationSFX = "HouseCard_Clubs";
				break;
			case 3:
				cardActivationVFX = Assets.VFXcardSpades;
				cardActivationSFX = "HouseCard_Spades";
				break;
			case 4:
				cardActivationVFX = Assets.VFXcardLucky7;
				cardActivationSFX = "HouseCard_Jackpot";
				break;
			}
			if (result == 2 || result == 4)
			{
				Clubs();
			}
		}

		public override void OnActivate()
		{
			//IL_0018: Unknown result type (might be due to invalid IL or missing references)
			//IL_001d: Unknown result type (might be due to invalid IL or missing references)
			//IL_0024: Unknown result type (might be due to invalid IL or missing references)
			//IL_002f: Unknown result type (might be due to invalid IL or missing references)
			//IL_0041: Unknown result type (might be due to invalid IL or missing references)
			//IL_004d: Unknown result type (might be due to invalid IL or missing references)
			//IL_0052: Unknown result type (might be due to invalid IL or missing references)
			//IL_0057: Unknown result type (might be due to invalid IL or missing references)
			//IL_0068: Expected O, but got Unknown
			base.OnActivate();
			if (((EntityState)this).isAuthority)
			{
				EffectManager.SpawnEffect(Assets.VFXcardJackpot, new EffectData
				{
					origin = ((EntityState)this).characterBody.footPosition,
					rootObject = ((Component)((EntityState)this).characterBody).gameObject,
					rotation = ((EntityState)this).characterDirection.targetTransform.rotation,
					scale = 1f
				}, true);
			}
			switch (result)
			{
			case 2:
				break;
			case 0:
				Hearts();
				break;
			case 1:
				Diamonds();
				break;
			case 3:
				Spades();
				break;
			case 4:
				Hearts();
				Diamonds();
				Spades();
				break;
			}
		}

		private void Hearts()
		{
			//IL_0018: Unknown result type (might be due to invalid IL or missing references)
			//IL_001e: Unknown result type (might be due to invalid IL or missing references)
			if (NetworkServer.active)
			{
				((EntityState)this).healthComponent.HealFraction(healFraction, default(ProcChainMask));
				((EntityState)this).healthComponent.AddBarrier(((EntityState)this).healthComponent.fullCombinedHealth * healFraction);
			}
		}

		private void Diamonds()
		{
			if (NetworkServer.active)
			{
				((EntityState)this).characterBody.master.GiveMoney((uint)((float)(int)scaledGold * passiveManager.costScaler));
			}
		}

		private void Clubs()
		{
			if (((EntityState)this).isAuthority)
			{
				passiveManager.roulletePriorityShot = 4;
				for (int num = numberOfBullets; num > 0; num--)
				{
					passiveManager.roulleteAmmo[passiveManager.roulleteOrder[num - 1]] = 7;
				}
				passiveManager.Shuffle(passiveManager.roulleteOrder);
				if (((EntityState)this).characterBody.isPlayerControlled)
				{
					HouseHUDManager.instance.UpdateAmmo(passiveManager.roulletePriorityShot, passiveManager.roulleteAmmo);
				}
			}
		}

		private void Spades()
		{
			Random random = new Random();
			BuffDef[] array = (Config.SpadesVanilla.Value ? vanillaBuffs : BuffCatalog.buffDefs);
			for (int num = numberOfbuffs; num > 0; num--)
			{
				BuffDef val = Buffs.Lucky7buff;
				for (int num2 = numberOfRolls; num2 > 0; num2--)
				{
					val = array[random.Next(array.Length)];
					if (!val.isDebuff)
					{
						bool flag = false;
						foreach (BuffDef filteredBuff in SevenOfSpades.filteredBuffs)
						{
							if ((Object)(object)filteredBuff == (Object)(object)val)
							{
								flag = true;
								Debug.Log((object)("[HouseMessage] Jackpot skipped: ''" + ((Object)val).name + "'' due to filters, and will reroll"));
							}
						}
						if (!flag)
						{
							num2 = 0;
						}
					}
				}
				if (val.isDebuff)
				{
					val = Buffs.Lucky7buff;
					Debug.Log((object)"[HouseMessage] Jackpot exceeded the maximum number of rerolls, and is defaulting to Lucky7s");
				}
				Debug.Log((object)("[HouseMessage] Jackpot is applying: ''" + ((Object)val).name + "''"));
				((EntityState)this).characterBody.AddTimedBuff(val, buffDuration);
			}
			((EntityState)this).characterBody.AddTimedBuff(Buffs.Spadesbuff, buffDuration);
		}

		public override void OnSerialize(NetworkWriter writer)
		{
			base.OnSerialize(writer);
			writer.Write(result);
		}

		public override void OnDeserialize(NetworkReader reader)
		{
			base.OnDeserialize(reader);
			result = reader.ReadInt32();
		}
	}
	internal class PickUp52 : BaseCardSkill
	{
		public override void OnEnter()
		{
			cardTypeActivationVFX = Assets.PositiveCardActivation;
			cardSweepVFX = Assets.CardSweepPositive;
			passiveManager = ((EntityState)this).GetComponent<HousePassiveManager>();
			if (((EntityState)this).isAuthority)
			{
				passiveManager.MissileInterval = 0f;
				passiveManager.MissileCount += passiveManager.gameDeck.Count + 3;
				passiveManager.DiscardHand();
				passiveManager.reshuffle();
				passiveManager.NextHand();
			}
			base.OnEnter();
			cardActivationVFX = null;
			cardActivationSFX = "House_Shuffle";
		}

		public override void drawHand()
		{
		}

		public override void OnActivate()
		{
			base.OnActivate();
		}
	}
