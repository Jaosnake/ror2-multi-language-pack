        "HASTEREAPR_ASSASSIN_SECONDARY_POISON_DESCRIPTION_SCEPTER": "<style=cIsUtility>Agile.</style>Lanza una poción venenosa agrupada para <style=cIsDamage>250% de daño</style> más un <style=cIsDamage>500% de daño adicional en el tiempo, cada uno.</style> \n\n<style=cKeywordName>Mientras estás bajo la influencia de War Cry, lanza una poción agrupada de forma recursiva, con efectos más débiles. niños.</style>",
        "HASTEREAPR_ASSASSIN_SECONDARY_POISON_NAME_ALT": "Veneno virulento",
        "HASTEREAPR_ASSASSIN_SECONDARY_POISON_DESCRIPTION_ALT": "<style=cIsUtility>Agile.</style>Lanza una poción persistente para <style=cIsDamage>500% de daño.</style> <style=cIsUtility>Las toxinas permanecen durante 5 segundos.</style> <style=cDeath>No inflige veneno.</style>",
        "HASTEREAPR_ASSASSIN_SCEPTER_SECONDARY_POISON_DESCRIPTION_ALT": "<style=cIsUtility>Agile.</style>Lanza 2 pociones restantes en un abanico suelto para <style=cIsDamage>500% de daño.</style> <style=cIsUtility>Las toxinas permanecen durante 5 segundos.</style> <style=cDeath>No inflige veneno.</style>",
        "HASTEREAPR_ASSASSIN_UTILITY_CLOAK_NAME": "Teletransportarse",
