		public static T CreatePrimarySkillDef<T>(SerializableEntityStateType state, bool hasCooldown, string stateMachine, string skillNameToken, string skillDescriptionToken, Sprite skillIcon, bool agile, string[] keywordTokens, bool canBeOverriden) where T : SkillDef
		{
			//IL_003f: Unknown result type (might be due to invalid IL or missing references)
			//IL_0040: Unknown result type (might be due to invalid IL or missing references)
			//IL_00c4: Unknown result type (might be due to invalid IL or missing references)
			//IL_017f: Unknown result type (might be due to invalid IL or missing references)
			T val = ScriptableObject.CreateInstance<T>();
			((SkillDef)val).skillName = skillNameToken;
			((SkillDef)val).skillNameToken = skillNameToken;
			((SkillDef)val).skillDescriptionToken = skillDescriptionToken;
			((SkillDef)val).icon = skillIcon;
			((SkillDef)val).activationState = state;
			((SkillDef)val).activationStateMachineName = stateMachine;
			((SkillDef)val).baseMaxStock = 1;
			((SkillDef)val).baseRechargeInterval = 0f;
			Debug.Log((object)("cooldown is " + ((SkillDef)val).baseRechargeInterval));
			((SkillDef)val).beginSkillCooldownOnSkillEnd = true;
			((SkillDef)val).canceledFromSprinting = false;
			((SkillDef)val).forceSprintDuringState = false;
			((SkillDef)val).fullRestockOnAssign = true;
			((SkillDef)val).interruptPriority = (InterruptPriority)0;
			((SkillDef)val).resetCooldownTimerOnUse = false;
			((SkillDef)val).isCombatSkill = true;
			((SkillDef)val).mustKeyPress = false;
			((SkillDef)val).cancelSprintingOnActivation = !agile;
			((SkillDef)val).rechargeStock = 1;
			((SkillDef)val).requiredStock = 0;
			((SkillDef)val).stockToConsume = 0;
			((SkillDef)val).keywordTokens = keywordTokens;
			if (hasCooldown)
			{
				((SkillDef)val).baseRechargeInterval = 0.25f;
				((SkillDef)val).stockToConsume = 1;
				((SkillDef)val).requiredStock = 1;
			}
			skillDefs.Add((SkillDef)(object)val);
			if (!canBeOverriden)
			{
				((SkillDef)val).interruptPriority = (InterruptPriority)0;
			}
			return val;
		}

