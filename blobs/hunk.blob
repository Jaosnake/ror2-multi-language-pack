			private static void CreateHitboxes(GameObject prefab)
			{
				ChildLocator componentInChildren = prefab.GetComponentInChildren<ChildLocator>();
				GameObject gameObject = ((Component)componentInChildren).gameObject;
				Transform val = componentInChildren.FindChild("ChargeHitbox");
				Prefabs.SetupHitbox(gameObject, (Transform[])(object)new Transform[1] { val }, "Charge");
				val = componentInChildren.FindChild("BasicMeleeHitbox");
				Prefabs.SetupHitbox(gameObject, (Transform[])(object)new Transform[1] { val }, "BasicMelee");
				val = componentInChildren.FindChild("SmallMeleeHitbox");
				Prefabs.SetupHitbox(gameObject, (Transform[])(object)new Transform[1] { val }, "SmallMelee");
			}

