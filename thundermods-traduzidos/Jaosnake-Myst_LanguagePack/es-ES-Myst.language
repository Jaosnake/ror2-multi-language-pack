{
    "es-ES": {
        "JAVANGLE_MYST_BODY_NAME": "misterio",
        "JAVANGLE_MYST_BODY_DESCRIPTION": "Myst es un sobreviviente versátil que usa <style=cIsUtility>Magic Power</style> para utilizar una variedad de habilidades sobrenaturales y <style=cIsUtility>Limit</style> para desatar poderosos súper movimientos.",
        "JAVANGLE_MYST_BODY_SUBTITLE": "El arcanista misterioso",
        "JAVANGLE_MYST_BODY_DEFAULT_SKIN_NAME": "Por defecto",
        "JAVANGLE_MYST_BODY_MASTERY_SKIN_NAME": "Maestría",
        "JAVANGLE_MYST_BODY_GRANDMASTERY_SKIN_NAME": "Gran Maestría",
        "JAVANGLE_MYST_BODY_BASEFORM_SLASH_NAME": "Tajo vorpal",
        "JAVANGLE_MYST_BODY_BASEFORM_SLASH_DESCRIPTION": "<style=cIsUtility>Ágil</style>. Corta a los enemigos frente a ti y les inflige <style=cIsDamage>165% de daño</style>.",
        "JAVANGLE_MYST_BODY_BASEFORM_DASH_NAME": "Correr",
        "JAVANGLE_MYST_BODY_BASEFORM_DASH_DESCRIPTION": "<style=cIsUtility>Ágil</style>. Deslice una distancia corta en cualquier dirección horizontal.",
        "JAVANGLE_MYST_BODY_BASEFORM_BLOCK_NAME": "Fantasma",
        "JAVANGLE_MYST_BODY_BASEFORM_BLOCK_DESCRIPTION": "<style=cIsUtility>Mantén presionado</style> para reducir drásticamente el daño frontal entrante, obteniendo <style=cIsUtility>Limit</style> según el daño bloqueado. Si <style=cIsUtility>se sincroniza correctamente</style>: anula el daño desde todas las direcciones, enfría la habilidad, restaura <style=cIsUtility>Magic Power</style> según el daño bloqueado, obtiene <style=cIsUtility>doble límite</style> y refleja hasta</style>0__3x el daño</style>1__ bloqueado a los enemigos cercanos.",
        "JAVANGLE_MYST_BODY_BASEFORM_LIMITMENU_NAME": "Menú límite",
        "JAVANGLE_MYST_BODY_BASEFORM_LIMITMENU_DESCRIPTION": "Abra el menú de límites, lo que le permitirá usar <style=cIsUtility>Limit Breaks</style> equipado.",
        "JAVANGLE_MYST_BODY_UI_MAGICNAME": "Menú mágico",
        "JAVANGLE_MYST_BODY_UI_MAGICDESCRIPTION": "Abre el Menú Mágico, que te permitirá usar hechizos equipados.",
        "JAVANGLE_MYST_BODY_UI_LIMITNAME": "Menú límite",
        "JAVANGLE_MYST_BODY_UI_LIMITDESCRIPTION": "Abre el menú de límites, que te permitirá usar límites de límite equipados.",
