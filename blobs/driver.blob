		public override void FixedUpdate()
		{
			((EntityState)this).FixedUpdate();
			if (((EntityState)this).fixedAge >= 0.5f * duration && !kill)
			{
				kill = true;
				if (Object.op_Implicit((Object)(object)iDrive))
				{
					if (iDrive.weaponTimer == 0.1f)
					{
						iDrive.weaponTimer = 0f;
						((EntityState)this).PlayAnimation("Gesture, Override", iDrive.weaponDef.equipAnimationString);
					}
					else
					{
						((EntityState)this).PlayAnimation("Gesture, Override", "RefreshPistol");
					}
				}
			}
			if (((EntityState)this).fixedAge >= duration && ((EntityState)this).isAuthority)
			{
				((EntityState)this).outer.SetNextStateToMain();
			}
		}

		public override void OnExit()
		{
			base.OnExit();
			OverrideRequest obj = crosshairOverrideRequest;
			if (obj != null)
			{
				obj.Dispose();
			}
		}

