					if (DriverPlugin.LitInstalled && DriverPlugin.IsItemGoldenGun(itemIndex))
					{
						ServerPickUpWeapon(DriverWeaponCatalog.GoldenGun);
					}
					if (DriverPlugin.ClassicItemsInstalled && DriverPlugin.IsItemGoldenGun2(itemIndex))
					{
						ServerPickUpWeapon(DriverWeaponCatalog.GoldenGun);
					}
					if (itemIndex == Items.Behemoth.itemIndex)
					{
						ServerPickUpWeapon(DriverWeaponCatalog.Behemoth);
					}
					if (itemIndex == Items.LunarPrimaryReplacement.itemIndex)
					{
						ServerPickUpWeapon(DriverWeaponCatalog.Needler);
					}
				}
			}

			public void ConsumeAmmo(float multiplier = 1f, bool scaleWithAttackSpeed = true)
			{
				if (maxWeaponTimer <= 0f || !Object.op_Implicit((Object)(object)characterBody) || !Object.op_Implicit((Object)(object)inventory) || characterBody.HasBuff(Buffs.NoCooldowns))
				{
					return;
				}
				if (scaleWithAttackSpeed)
				{
					int itemCountEffective = inventory.GetItemCountEffective(Items.AlienHead);
					itemCountEffective += inventory.GetItemCountEffective(Items.LunarBadLuck);
					if (itemCountEffective > 0)
					{
						for (int i = 0; i < itemCountEffective; i++)
						{
							multiplier = ((!DriverPlugin.GreenAlienHeadInstalled) ? (multiplier * 0.75f) : (multiplier * 0.85f));
						}
					}
					weaponTimer -= multiplier / characterBody.attackSpeed;
				}
				else
				{
					weaponTimer -= multiplier;
				}
				onConsumeAmmo?.Invoke();
			}

			public bool AddJamBuildup(bool jammed = false)
			{
				jamTimer += 3f;
				if (jamTimer >= 10f)
				{
					jamTimer = 0f;
					jammed = true;
				}
				return jammed;
			}

			private void FixedUpdate()
			{
				jamTimer = Mathf.Clamp(jamTimer - 2f * Time.fixedDeltaTime, 0f, float.PositiveInfinity);
				if (!(weaponTimer <= 0f) || !(maxWeaponTimer > 0f))
				{
					return;
				}
				if (HasSpecialBullets)
				{
					currentBulletDef = DriverBulletCatalog.Default;
					if (Object.op_Implicit((Object)(object)muzzleTrail))
					{
						Object.Destroy((Object)(object)muzzleTrail);
					}
				}
				if (IsHoldingWeapon)
				{
					PickUpWeapon(defaultWeaponDef);
				}
				else if (!needReload)
				{
					needReload = true;
					skillLocator.primary.SetWeaponSkill(Skills.pistolReloadSkillDef, (SkillOverridePriority)4);
				}
			}

			public void PickUpWeaponDrop(DriverWeaponDef newWeapon, DriverBulletDef newBullet, bool cutAmmo, bool isNewAmmoType)
			{
				if (passive.isDefault)
				{
					PickUpWeapon(newWeapon, cutAmmo);
					return;
				}
				if (passive.isPistolOnly)
				{
					SetBulletAmmo();
					return;
				}
				if (passive.isBullets || isNewAmmoType)
				{
					TryPickupNotification(newBullet);
					currentBulletDef = newBullet;
					SetBulletAmmo(cutAmmo);
					return;
				}
				float? ammo = null;
				if (HasSpecialBullets && (Object)(object)weaponDef != (Object)(object)newWeapon)
				{
					if (AmmoPercent > 0.2f)
					{
						ammo = newWeapon.shotCount;
						if (Config.backupMagExtendDuration.Value && Object.op_Implicit((Object)(object)inventory))
						{
							ammo += (float)inventory.GetItemCountEffective(Items.SecondarySkillMagazine);
						}
						ammo *= AmmoPercent;
					}
					else
					{
						currentBulletDef = DriverBulletCatalog.Default;
					}
				}
				PickUpWeapon(newWeapon, cutAmmo, ammo);
			}

			public void PickUpWeapon(DriverWeaponDef newWeapon, bool cutAmmo = false, float? ammo = null)
			{
				if ((Object)(object)weaponDef != (Object)(object)newWeapon)
				{
					onWeaponChanged?.Invoke(newWeapon);
				}
				skillLocator.UnsetWeaponSkills(weaponDef, (SkillOverridePriority)3);
				if ((Object)(object)newWeapon != (Object)(object)defaultWeaponDef && (Object)(object)newWeapon != (Object)(object)DriverWeaponCatalog.Pistol)
				{
					skillLocator.SetWeaponSkills(newWeapon, (SkillOverridePriority)3);
				}
				characterBody._defaultCrosshairPrefab = newWeapon.crosshairPrefab;
				weaponDef = newWeapon;
				SetSkinnedWeaponModel(newWeapon);
				SetBulletAmmo(cutAmmo, ammo);
			}

			public void SetBulletAmmo(bool cutAmmo = false, float? ammo = null)
			{
				//IL_007f: Unknown result type (might be due to invalid IL or missing references)
				//IL_0084: Unknown result type (might be due to invalid IL or missing references)
				//IL_008c: Unknown result type (might be due to invalid IL or missing references)
				//IL_0091: Unknown result type (might be due to invalid IL or missing references)
				//IL_009e: Unknown result type (might be due to invalid IL or missing references)
				//IL_00a4: Unknown result type (might be due to invalid IL or missing references)
				skillLocator.primary.UnsetWeaponSkill(Skills.pistolReloadSkillDef, (SkillOverridePriority)4);
				if (HasSpecialBullets)
				{
					Transform val = ((weaponDef.animationSet == DriverWeaponDef.AnimationSet.Default) ? childLocator.FindChild("PistolMuzzle") : childLocator.FindChild("ShotgunMuzzle"));
					if (!Object.op_Implicit((Object)(object)muzzleTrail))
					{
						muzzleTrail = Object.Instantiate<GameObject>(Assets.defaultMuzzleTrail, val);
					}
					Color val2 = ((Color)(ref currentBulletDef.trailColor)).RGBMultiplied(0.5f);
					Color val3 = ((Color)(ref val2)).AlphaMultiplied(0.5f);
					TrailRenderer component = muzzleTrail.GetComponent<TrailRenderer>();
					component.startColor = val3;
					component.endColor = val3;
				}
				else if (Object.op_Implicit((Object)(object)muzzleTrail))
				{
					Object.Destroy((Object)(object)muzzleTrail);
				}
				if (weaponDef.shotCount == 0 || (DriverWeaponCatalog.IsWeaponPistol(weaponDef) && !HasSpecialBullets))
				{
					weaponTimer = 0f;
					maxWeaponTimer = 0f;
				}
				else
				{
					maxWeaponTimer = weaponDef.shotCount;
					if (Config.backupMagExtendDuration.Value && Object.op_Implicit((Object)(object)inventory))
					{
						maxWeaponTimer += inventory.GetItemCountEffective(Items.SecondarySkillMagazine);
					}
					if (ammo.HasValue)
					{
						weaponTimer = ammo.Value;
					}
					else
					{
						weaponTimer = maxWeaponTimer;
						if (cutAmmo)
						{
							weaponTimer *= 0.5f;
						}
					}
				}
				needReload = false;
				isReloading = false;
				onWeaponUpdate?.Invoke();
				onConsumeAmmo?.Invoke();
			}

			public void SetSkinnedWeaponModel(DriverWeaponDef newWeapon)
			{
				DriverWeaponDef.ModelSwapInfo[] modelSwapInfoForWeapon = DriverWeaponSkinCatalog.GetModelSwapInfoForWeapon(skinController, newWeapon);
				for (int i = 0; i < modelSwapInfoForWeapon.Length; i++)
				{
