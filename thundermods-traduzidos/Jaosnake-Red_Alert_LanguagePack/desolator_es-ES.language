    "KEYWORD_RADIATION_PRIMARY" : "<style=cKeywordName>Irradiando</style><style=cSub>Inflige 3 acumulaciones de <style=cIsHealing>RadiaciÃ³n</style>, cada una infligiendo <style=cIsDamage>8.4% daÃ±o por segundo</style> por <style=cIsUtility>8 segundos</style>.</style>",
    "HABIBI_DESOLATOR_BODY_SECONDARY_BIGBEAM_NAME" : "Tierra Quemada",
