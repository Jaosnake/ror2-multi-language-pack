        "SS2_ITEM_NANOBOTS_NAME": "Nanobotlar",
        "SS2_EXECUTIONER_DESCRIPTION": "The Executioner is a high-risk, high-reward survivor that's all about racking up an endless kill count.",
        "SS2_SKIN_CAPTAIN_GRANDMASTERY": "Prestij",
        "SS2_PYRO_OUTRO_FAILURE": "..ve böylece ortadan kayboldu, alevler sonunda söndü.",
        "SS2_ACHIEVEMENT_EXECUTIONER_ELECTRO_NAME": "Executioner: Kuwabara, Kuwabara",
        "SS2_EXECUTIONER2_IONCHARGE_DESC": "<style=cIsUtility>10 yüke</style> kadar biriktirmek için basılı tut ve <style=cIsDamage>ana becerini</style> değiştir. <style=cIsUtility>Düşman öldürmek de yük ekler.</style>",
        "SS2_NEMBANDIT_SPECIAL_DESCRIPTION": "<style=cIsDamage>6x%100 hasar</style> için bir av tüfeği patlaması yapın. <style=cIsUtility>'yi öldürürseniz tüm bekleme sürelerinizi sıfırlar.</style>",
        "SS2_MULE_KEYWORD_OVERCLOCKING2": "<style=cKeywordName>Hız Aşırtma</style></style=cSub>Beceriyi daha fazla yüklemek için düğmeyi basılı tutun, ancak aynı zamanda becerinin bekleme süresini de uzatın.</sub>",
        "SS2_NEMESIS_MERCENARY_SECONDARY_SLASH_NAME": "Kıyasıya",
        "SS2_PYRO_UTILITY_NAME": "Kontak Kontrolü",
        "SS2_ACHIEVEMENT_EXECUTIONER_MASTERY_NAME": "Executioner: Mastery",
        "SS2_NEMEXECUTIONER_SPECIAL_ALT_NAME": "ürkütücü mod",
        "SS2_KNGIHT_PRIMARY_SWORD_UPRGADE_TOOLTIP": "<style=cKeywordName><color=#fa78f3>Egüçlendirilmiş</color></style><style=cSub>İleri atılıp <style=cIsDamage>3x%400 hasar için saldırı</style>.</style>",
        "SS2_DRONE_CLONE_INTERACTABLE_CONTEXT": "Kopyalayıcı Dronu Tamir Et",
        "SS2_ACHIEVEMENT_CYBORG_GRANDMASTERY_NAME": "Cyborg: Grand Mastery",
        "SS2_EQUIP_AFFIXSUPERICE_NAME": "Onun Kozmik İhtişamı",
        "SS2_MULE_CHARGE_DESC": "<style=cIsUtility>Kalibre ediliyor</style>. <style=cIsUtility>Şarj etmek için basılı tutun</style> ve <style=cIsUtility>'ye kadar bırakın<style=cIsDamage>(orta-yüksek hasar TBD)% hasar için dönerken<style=cIsUtility>ileriye doğru fırlatın</style></style>.",
        "SS2_EQUIP_MIDAS_DESC": "<style=cIsHealth>Mevcut canının</style> <style=cIsHealth>%{0}</style>'ını feda et, <style=cIsHealth>kaybedilen can</style> veya <style=cIsUtility>standart bir sandığın fiyatı</style> kadarını, hangisi daha yüksekse, <style=cIsUtility>altın</style> olarak kazan.",
        "SS2_INTERACTABLE_DROPPOD_CONTEXT": "Kapsülü aç?",
        "SS2_EXECUTIONER2_BLOODLETTING_DESC": "Yakındaki düşmanlarda <style=cIsUtility>korku</style> uyandırmak için sağlığınızın <style=cIsHealth>%25'i</style> tüketin ve</style> 3 <color=#29e5f2>Ion Yükü</color> kazanın.",
