{
    "de": {
        "ROB_DRIVER_BODY_NAME": "Driver",
        "ROB_DRIVER_BODY_DESCRIPTION": "Der Fahrer bin im wahrsten Sinne des Wortes ich.<color=#CCD3E0></i>",
        "ROB_DRIVER_BODY_SUBTITLE": "Treiber? Kenne sie kaum!",
        "ROB_DRIVER_BODY_LORE": "Zurück gegen die Wand und allen Widrigkeiten zum Trotz\nMit der Kraft eines Willens und einer Sache\nIhre Heldentaten werden als bemerkenswert bezeichnet\nDu bist emotional komplex\n\nGegen den Strom dystopischer Behauptungen\nNicht die Gedanken, die Ihre Handlungen hervorrufen\nUnd das hast du bewiesen\n\n\nEin wahrer Mensch und ein wahrer Held\n\n\"Also, was machst du?\"\n\n\"Ich fahre.\"",
        "ROB_DRIVER_BODY_OUTRO_FLAVOR": "..und dann ging er, immer noch derselbe wie am Anfang.",
        "ROB_DRIVER_BODY_OUTRO_FAILURE": "..und dann verschwand er und wurde nie ein echter Mensch.",
        "ROB_DRIVER_BODY_DEFAULT_SKIN_NAME": "Standard",
        "ROB_DRIVER_BODY_MONSOON_SKIN_NAME": "Jacke",
        "ROB_DRIVER_BODY_TYPHOON_SKIN_NAME": "Schläger",
        "ROB_DRIVER_BODY_SUIT_SKIN_NAME": "Hitman",
        "ROB_DRIVER_BODY_SUIT2_SKIN_NAME": "Hitman EX",
        "ROB_DRIVER_BODY_SPECIALFORCES_SKIN_NAME": "Spezialeinheiten",
        "ROB_DRIVER_BODY_GUERRILLA_SKIN_NAME": "Guerilla",
        "ROB_DRIVER_BODY_GREEN_SKIN_NAME": "Grün",
        "ROB_DRIVER_BODY_MINECRAFT_SKIN_NAME": "Minecraft",
        "ROB_DRIVER_BODY_PASSIVE_NAME": "Überlebenskünstler",
        "ROB_DRIVER_BODY_PASSIVE_DESCRIPTION": "Feinde haben die Chance, ein neues fallen zu lassen<style=cIsUtility>Waffe</style>. Diese gewähren<style=cIsDamage>mächtige Angriffe</style>für begrenzte Zeit!</i>",
        "ROB_DRIVER_BODY_PASSIVE2_NAME": "Schütze (Legacy)",
        "ROB_DRIVER_BODY_PASSIVE2_DESCRIPTION": "Ihr Vertrauter<style=cIsHealth>Pistole</style>ist alles was Sie brauchen.</i>",
        "ROB_DRIVER_BODY_PASSIVE3_NAME": "Leadfoot",
        "ROB_DRIVER_BODY_PASSIVE3_DESCRIPTION": "Es besteht die Möglichkeit, dass Feinde fallen gelassen werden<style=cIsHealth>Munition</style>. Diese gewähren Ihnen<style=cIsHealth>Waffe</style> <style=cIsDamage>mächtige Angriffe</style>für begrenzte Zeit!</i>",
        "ROB_DRIVER_BODY_PASSIVE4_NAME": "Götterling",
        "ROB_DRIVER_BODY_PASSIVE4_DESCRIPTION": "ICH<style=cIsHealth>fahren</style>.</i>",
        "ROB_DRIVER_BODY_CONFIRM_NAME": "Bestätigen",
        "ROB_DRIVER_BODY_CONFIRM_DESCRIPTION": "Fahren Sie mit der aktuellen Fähigkeit fort.</i>",
        "ROB_DRIVER_BODY_CANCEL_NAME": "Stornieren",
        "ROB_DRIVER_BODY_CANCEL_DESCRIPTION": "Brechen Sie die aktuelle Fähigkeit ab.</i>",
        "ROB_DRIVER_BODY_RELOAD_NAME": "Neu laden",
        "ROB_DRIVER_BODY_RELOAD_DESCRIPTION": "Laden Sie Ihre Waffe neu.</i>",
        "ROB_DRIVER_BODY_PRIMARY_PISTOL_NAME": "Feuer",
        "ROB_DRIVER_BODY_PRIMARY_PISTOL_DESCRIPTION": "Feuern Sie Ihre Pistole ab und verursachen Sie 220 % Schaden.<style=cIsDamage>Kritische Treffer werden zweimal abgefeuert.</style></i>",
        "ROB_DRIVER_BODY_PRIMARY_PYRITE_PISTOL_NAME": "Feuer",
        "ROB_DRIVER_BODY_PRIMARY_PYRITE_PISTOL_DESCRIPTION": "Feuern Sie Ihre Pistole ab und verursachen Sie 250 % Schaden.<style=cIsDamage>Kritische Treffer werden zweimal abgefeuert.</style></i>",
        "ROB_DRIVER_BODY_PRIMARY_BEETLESHIELD_NAME": "Feuer",
        "ROB_DRIVER_BODY_PRIMARY_BEETLESHIELD_DESCRIPTION": "Feuern Sie Ihre Pistole ab und verursachen Sie 250 % Schaden.<style=cIsDamage>Kritische Treffer werden zweimal abgefeuert.</style></i>",
        "ROB_DRIVER_BODY_PRIMARY_LUNAR_PISTOL_NAME": "Feuer",
        "ROB_DRIVER_BODY_PRIMARY_LUNAR_PISTOL_DESCRIPTION": "Feuern Sie Ihre Pistole ab und verursachen Sie 350 % Schaden.<style=cIsDamage>Kritische Treffer werden zweimal abgefeuert.</style></i>",
        "ROB_DRIVER_BODY_PRIMARY_VOID_PISTOL_NAME": "Feuer",
        "ROB_DRIVER_BODY_PRIMARY_VOID_PISTOL_DESCRIPTION": "Feuern Sie Ihre Pistole ab und verursachen Sie 350 % Schaden.<style=cIsDamage>Kritische Treffer werden zweimal abgefeuert.</style></i>",
        "ROB_DRIVER_BODY_PRIMARY_FALSE_PISTOL_NAME": "Feuer",
        "ROB_DRIVER_BODY_PRIMARY_FALSE_PISTOL_DESCRIPTION": "Feuern Sie Ihre Pistole ab und verursachen Sie 350 % Schaden.<style=cIsDamage>Kritische Treffer werden zweimal abgefeuert.</style>\n<style=cIsUtility>Kein Schadensabfall mit zunehmender Entfernung.</style></i>",
