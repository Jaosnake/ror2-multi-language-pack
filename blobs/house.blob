		public override void OnEnter()
		{
			cardTypeActivationVFX = Assets.RandomCardActivation;
			cardSweepVFX = Assets.CardSweepRandom;
			base.OnEnter();
			cardActivationVFX = Assets.VFXcardWildCard;
			cardActivationSFX = "HouseCard_Wildcard";
			if (((EntityState)this).isAuthority)
			{
				EffectTypeRoll = passiveManager.random.Next(3);
				EffectrollBottle = passiveManager.random.Next(4);
				if (Seasons.isAprilFools)
				{
					EffectTypeRoll = 2;
					EffectrollBottle = 0;
				}
			}
		}

		public override void OnActivate()
		{
			base.OnActivate();
			switch (EffectTypeRoll)
			{
			default:
				Debug.LogError((object)"[HouseError] Wildcard didn't roll for EffectType?");
				break;
			case 0:
				TrueRandom();
				break;
			case 1:
				HouseSpecific();
				break;
			case 2:
				BottledEffects();
				break;
			}
		}

		private void TrueRandom()
		{
			if (NetworkServer.active)
			{
				Random random = passiveManager.random;
				switch (random.Next(3))
				{
				default:
					Chat.AddMessage("WildMagicTrueRandomFailed");
					break;
				case 0:
					RandomTargetEffect(random);
					break;
				case 1:
					RandomSummonEffect(random);
					break;
				case 2:
					RandomTransformEffect(random);
					break;
				}
			}
		}

