			HealthComponent.TakeDamage_Pre += HealthComponent_TakeDamage_Pre;
			HealthComponent.TakeDamage_Post += HealthComponent_TakeDamage_Post;
			try
			{
				HealthComponent.TakeDamageProcess += new Manipulator(HealthComponent_TakeDamageIL);
				GenericCharacterDeath.OnEnter += new Manipulator(GenericCharacterDeath_OnEnter1);
			}
			catch (Exception ex)
