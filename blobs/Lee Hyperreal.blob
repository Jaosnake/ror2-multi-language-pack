	internal class WeaponModelHandler : MonoBehaviour
	{
		public enum WeaponState
		{
			SUBMACHINE,
			RIFLE,
			CANNON
		}

		private GameObject submachineModel;

		private GameObject submachine2Model;

		private GameObject guncaseModel;

		private GameObject guncaseRoot;

		private GameObject submachineRoot;

		private GameObject sniperRifleModel;

		private GameObject sniperRifleAlphaModel;

		private GameObject snipeRoot;

		private GameObject supercannonModel;

		private GameObject superCannonRoot;

		private ParticleSystem rifleFlashEffect;

		private GameObject rifleLaser;

		private ParticleSystem boxFlashEffect;

		private Animator superCannonAnimator;

		private GameObject superCannonEffect;

		private float disableCannonEffectTimer;

		private bool isCannonEnabled;

		private CharacterBody characterBody;

		private LeeHyperrealPassive passive;

		private WeaponState state;

		private ChildLocator childLocator;

		private bool isEmoting;

		private GameObject armModel;

		private GameObject torsoModel;

		private GameObject faceModel;

		private GameObject hairModel;

		private GameObject armourPlateModel;

		private GameObject eyeModel;

		private GameObject legModel;

		private GameObject chestBone;

		private GameObject jetpackObj;

		private GameObject bkm;

		private GameObject yibody;

		private GameObject yicoat;

		public void Awake()
		{
			state = WeaponState.SUBMACHINE;
		}

		public void Start()
		{
			characterBody = ((Component)this).GetComponent<CharacterBody>();
			passive = ((Component)this).GetComponent<LeeHyperrealPassive>();
			childLocator = ((Component)characterBody.modelLocator.modelTransform).GetComponent<ChildLocator>();
			if (Object.op_Implicit((Object)(object)childLocator))
			{
				submachineModel = ((Component)childLocator.FindChild("PistolModel")).gameObject;
				submachine2Model = ((Component)childLocator.FindChild("SubMachineGunModel")).gameObject;
				guncaseModel = ((Component)childLocator.FindChild("GunCaseModel")).gameObject;
				sniperRifleModel = ((Component)childLocator.FindChild("SuperRifleModel")).gameObject;
				sniperRifleAlphaModel = ((Component)childLocator.FindChild("SuperRifleModelAlphaBit")).gameObject;
				supercannonModel = ((Component)childLocator.FindChild("SuperCannonModel")).gameObject;
				superCannonAnimator = ((Component)childLocator.FindChild("CannonAnimator")).gameObject.GetComponent<Animator>();
				superCannonEffect = ((Component)childLocator.FindChild("CannonEffect")).gameObject;
				rifleFlashEffect = ((Component)childLocator.FindChild("RifleFlashEffect")).gameObject.GetComponent<ParticleSystem>();
				boxFlashEffect = ((Component)childLocator.FindChild("BoxFlashEffect")).gameObject.GetComponent<ParticleSystem>();
				rifleLaser = ((Component)childLocator.FindChild("RifleLaser")).gameObject;
				submachineRoot = ((Component)childLocator.FindChild("SubmachineMain")).gameObject;
				snipeRoot = ((Component)childLocator.FindChild("RifleMain")).gameObject;
				superCannonRoot = ((Component)superCannonAnimator).gameObject;
				guncaseRoot = ((Component)childLocator.FindChild("WeaponCase")).gameObject;
				armModel = ((Component)childLocator.FindChild("ArmModel")).gameObject;
				torsoModel = ((Component)childLocator.FindChild("TorsoModel")).gameObject;
				faceModel = ((Component)childLocator.FindChild("FaceModel")).gameObject;
				hairModel = ((Component)childLocator.FindChild("HairModel")).gameObject;
				armourPlateModel = ((Component)childLocator.FindChild("ArmourPlateModel")).gameObject;
				eyeModel = ((Component)childLocator.FindChild("EyeModel")).gameObject;
				legModel = ((Component)childLocator.FindChild("LegModel")).gameObject;
				chestBone = ((Component)childLocator.FindChild("Chest")).gameObject;
				bkm = ((Component)childLocator.FindChild("BKM")).gameObject;
				yibody = ((Component)childLocator.FindChild("YiBody")).gameObject;
				yicoat = ((Component)childLocator.FindChild("YiCoat")).gameObject;
			}
			ChangeLaserColour();
			ChangeFlashEffect();
			HandleBoneEnablement();
			SpawnChestJetpack();
			superCannonEffect.gameObject.SetActive(false);
			SetLaserState(state: false);
			TransitionState(WeaponState.SUBMACHINE);
			Hook();
		}

		private void SpawnChestJetpack()
		{
			if (LeeHyperreal.rorSkins.Contains((int)characterBody.skinIndex) && !Object.op_Implicit((Object)(object)jetpackObj))
			{
				jetpackObj = Object.Instantiate<GameObject>(ParticleAssets.RetrieveParticleEffectFromSkin("skinJetpack", characterBody), chestBone.transform);
			}
		}

		private void HandleBoneEnablement()
		{
			if (characterBody.skinIndex == 5 || characterBody.skinIndex == 6)
			{
				Transform val = childLocator.FindChild("Head");
				if (characterBody.skinIndex == 5)
				{
					((Component)val.Find("yiear1.l")).gameObject.SetActive(true);
					((Component)val.Find("yiear1.r")).gameObject.SetActive(true);
					((Component)val.Find("yiwhisker1.l")).gameObject.SetActive(true);
					((Component)val.Find("yiwhisker1.r")).gameObject.SetActive(true);
					((Component)val.Find("yiwhisker2.l")).gameObject.SetActive(true);
					((Component)val.Find("yiwhisker2.r")).gameObject.SetActive(true);
				}
				if (characterBody.skinIndex == 6)
				{
					((Component)val.Find("boykisserear1.l")).gameObject.SetActive(true);
					((Component)val.Find("boykisserear1.r")).gameObject.SetActive(true);
					((Component)val.Find("boykisserwhisker1")).gameObject.SetActive(true);
					((Component)val.Find("boykisserwhisker1.l")).gameObject.SetActive(true);
					((Component)val.Find("boykisserwhisker1.r")).gameObject.SetActive(true);
					((Component)val.Find("boykisserwhisker2")).gameObject.SetActive(true);
					((Component)val.Find("boykisserwhisker2.l")).gameObject.SetActive(true);
					((Component)val.Find("boykisserwhisker2.r")).gameObject.SetActive(true);
				}
			}
		}

		private void ChangeFlashEffect()
		{
			ParticleAssets.ParticleColorInfo particleColorInfo = ParticleAssets.LIGHTBLUE_PARTICLE;
			bool flag = true;
			if (Object.op_Implicit((Object)(object)passive))
			{
				if (passive.GetVFXPassive() != 0)
				{
					switch (passive.GetVFXPassive())
					{
					case LeeHyperrealPassive.VFXPassive.RED:
						particleColorInfo = ParticleAssets.RED_PARTICLE;
						flag = false;
						break;
					case LeeHyperrealPassive.VFXPassive.ORANGE:
						particleColorInfo = ParticleAssets.ORANGE_PARTICLE;
						flag = false;
						break;
					case LeeHyperrealPassive.VFXPassive.YELLOW:
						particleColorInfo = ParticleAssets.YELLOW_PARTICLE;
						flag = false;
						break;
					case LeeHyperrealPassive.VFXPassive.GREEN:
						particleColorInfo = ParticleAssets.GREEN_PARTICLE;
						flag = false;
						break;
					case LeeHyperrealPassive.VFXPassive.BLUE:
						flag = true;
						break;
					case LeeHyperrealPassive.VFXPassive.LIGHTBLUE:
						particleColorInfo = ParticleAssets.LIGHTBLUE_PARTICLE;
						flag = false;
						break;
					case LeeHyperrealPassive.VFXPassive.VIOLET:
						particleColorInfo = ParticleAssets.VIOLET_PARTICLE;
						flag = false;
						break;
					case LeeHyperrealPassive.VFXPassive.PINK:
						particleColorInfo = ParticleAssets.PINK_PARTICLE;
						flag = false;
						break;
					}
				}
				else
				{
					if (LeeHyperreal.orangeVFXSkins.Contains((int)characterBody.skinIndex))
					{
						particleColorInfo = ParticleAssets.ORANGE_PARTICLE;
						flag = false;
					}
					if (LeeHyperreal.lightBlueVFXSkins.Contains((int)characterBody.skinIndex))
					{
						particleColorInfo = ParticleAssets.LIGHTBLUE_PARTICLE;
						flag = false;
					}
					if (LeeHyperreal.redVFXSkins.Contains((int)characterBody.skinIndex))
					{
						particleColorInfo = ParticleAssets.RED_PARTICLE;
						flag = false;
					}
				}
			}
			if (flag)
			{
				return;
			}
			GameObject[] array = (GameObject[])(object)new GameObject[2]
			{
				((Component)boxFlashEffect).gameObject,
				((Component)rifleFlashEffect).gameObject
			};
			GameObject[] array2 = array;
			foreach (GameObject val in array2)
			{
				float vFXIntensity = ParticleAssets.GetVFXIntensity(passive.GetVFXPassive());
				Renderer[] componentsInChildren = val.GetComponentsInChildren<Renderer>();
				Renderer[] array3 = componentsInChildren;
				foreach (Renderer rend in array3)
				{
					ParticleAssets.ModifyXEffectOnRenderer(rend, particleColorInfo);
					ParticleAssets.ModifyNoBatchingRenderers(rend, particleColorInfo);
				}
				Light[] componentsInChildren2 = val.GetComponentsInChildren<Light>(true);
				Light[] array4 = componentsInChildren2;
				foreach (Light light in array4)
				{
					ParticleAssets.ModifyLights(light, particleColorInfo);
				}
				GPUParticlePlayer[] componentsInChildren3 = val.GetComponentsInChildren<GPUParticlePlayer>();
				GPUParticlePlayer[] array5 = componentsInChildren3;
				foreach (GPUParticlePlayer player in array5)
				{
					ParticleAssets.ModifyGPUParticles(player, particleColorInfo);
				}
			}
		}

		private void ChangeLaserColour()
		{
			Transform parent = rifleLaser.transform.parent;
			Object.Destroy((Object)(object)rifleLaser);
			rifleLaser = Object.Instantiate<GameObject>(ParticleAssets.RetrieveParticleEffectFromSkin("rifleLaser", characterBody), parent);
		}

		public void Hook()
		{
			if (Chainloader.PluginInfos.ContainsKey("com.weliveinasociety.CustomEmotesAPI"))
			{
				SetupEmoteHook();
			}
		}

		public void Unhook()
		{
			if (Chainloader.PluginInfos.ContainsKey("com.weliveinasociety.CustomEmotesAPI"))
			{
				UnsetEmoteHook();
			}
		}

		public void SetupEmoteHook()
		{
			//IL_0008: Unknown result type (might be due to invalid IL or missing references)
			//IL_0012: Expected O, but got Unknown
			CustomEmotesAPI.animChanged += new AnimationChanged(CustomEmotesAPI_animChanged);
		}

		public void UnsetEmoteHook()
		{
			//IL_0008: Unknown result type (might be due to invalid IL or missing references)
			//IL_0012: Expected O, but got Unknown
			CustomEmotesAPI.animChanged -= new AnimationChanged(CustomEmotesAPI_animChanged);
		}

		private void CustomEmotesAPI_animChanged(string newAnimation, BoneMapper mapper)
		{
			if ((Object)(object)mapper != (Object)(object)CustomEmotesAPI.localMapper)
			{
				isEmoting = false;
				TransitionState(state);
			}
			else if (newAnimation == "none")
			{
				isEmoting = false;
				TransitionState(state);
			}
			else
			{
				isEmoting = true;
			}
		}

		public void OnDestroy()
		{
			Unhook();
			Object.Destroy((Object)(object)jetpackObj);
		}

		public void Update()
		{
			if (isEmoting)
			{
				DisableAll();
			}
			if (isCannonEnabled)
			{
				disableCannonEffectTimer += Time.deltaTime;
				if (disableCannonEffectTimer >= 5f)
				{
					disableCannonEffectTimer = 0f;
					isCannonEnabled = false;
					superCannonEffect.gameObject.SetActive(false);
					superCannonAnimator.ResetTrigger("Ultimate");
				}
			}
		}

		public void SetStateForModelAndSubmachine(bool state)
		{
			if (!Object.op_Implicit((Object)(object)armModel))
			{
				return;
			}
			if (LeeHyperreal.rorSkins.Contains((int)characterBody.skinIndex))
			{
				armModel.SetActive(state);
				torsoModel.SetActive(state);
				faceModel.SetActive(false);
				hairModel.SetActive(state);
				armourPlateModel.SetActive(false);
				eyeModel.SetActive(false);
				legModel.SetActive(false);
				bkm.SetActive(false);
				yibody.SetActive(false);
				yicoat.SetActive(false);
				if (Object.op_Implicit((Object)(object)jetpackObj))
				{
					jetpackObj.SetActive(state);
				}
			}
			else if (characterBody.skinIndex == 5)
			{
				armModel.SetActive(false);
				torsoModel.SetActive(false);
				faceModel.SetActive(false);
				hairModel.SetActive(false);
				armourPlateModel.SetActive(false);
				eyeModel.SetActive(false);
				legModel.SetActive(false);
				bkm.SetActive(false);
				yibody.SetActive(state);
				yicoat.SetActive(state);
			}
			else if (characterBody.skinIndex == 6)
			{
				armModel.SetActive(false);
				torsoModel.SetActive(false);
				faceModel.SetActive(false);
				hairModel.SetActive(false);
				armourPlateModel.SetActive(false);
				eyeModel.SetActive(false);
				legModel.SetActive(false);
				bkm.SetActive(state);
				yibody.SetActive(false);
				yicoat.SetActive(false);
			}
			else
			{
				armModel.SetActive(state);
				torsoModel.SetActive(state);
				faceModel.SetActive(state);
				hairModel.SetActive(state);
				armourPlateModel.SetActive(state);
				eyeModel.SetActive(state);
				legModel.SetActive(state);
				bkm.SetActive(false);
				yibody.SetActive(false);
				yicoat.SetActive(false);
			}
			guncaseModel.SetActive(state);
			submachineModel.SetActive(state);
		}

