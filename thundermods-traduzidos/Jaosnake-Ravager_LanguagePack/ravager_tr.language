        "ROB_RAVAGER_BODY_MINECRAFT_SKIN_NAME": "minecraft",
        "ROB_RAVAGER_BODY_BLOODWELL_NAME": "Kan Kuyusu",
        "ROB_RAVAGER_BODY_BLOODWELL_DESCRIPTION": "Ravager depolanıyor<style=cIsHealth>kan</style>vuruşlarıyla, sizi iyileştirmek için dolduğunda tükeniyor<style=cIsHealing>%75 eksik sağlık</style>Ve<style=cIsDamage>becerilerinizi güçlendirin</style>geçici olarak.",
        "ROB_RAVAGER_BODY_BLOODWELL2_NAME": "İkor Kutusu",
        "ROB_RAVAGER_BODY_BLOODWELL2_DESCRIPTION": "Ravager depolanıyor<style=cIsHealth>kan</style>vuruşlarıyla, sizi iyileştirmek için dolduğunda tükeniyor<style=cIsHealing>%100 maksimum sağlık</style>Ve<style=cIsDamage>becerilerinizi güçlendirin</style>geçici olarak.<style=cIsHealth>Saldırırken daha hızlı tükenir.</style>",
        "ROB_RAVAGER_BODY_PARASITE_NAME": "Parazit",
        "ROB_RAVAGER_BODY_PARASITE_DESCRIPTION": "<style=cIsHealth>Açlık çekiyor....</style>",
        "ROB_RAVAGER_BODY_PASSIVE_NAME": "Fiziksel Yetenek",
        "ROB_RAVAGER_BODY_PASSIVE_DESCRIPTION": "Ravager yapabilir<style=cIsUtility>duvarlardan atlamak</style>Ve<style=cIsHealth>düşmanlar</style>. Kullanmak<style=cIsUtility>Öncelik</style>girmek için şarj olurken<style=cIsDamage>duruşunu koru</style>.",
        "ROB_RAVAGER_BODY_PASSIVE2_NAME": "Bükülmüş Mutasyon",
        "ROB_RAVAGER_BODY_PASSIVE2_DESCRIPTION": "<style=cIsHealth>%10 HP</style>. Bir şarj etmek için havada zıplayın<style=cIsUtility>ileri yanıp sönme</style>, atlama başına bir kez. İniş<style=cIsDamage>yakın dövüş vuruşları</style>bu yeteneği tazeler.",
        "ROB_RAVAGER_BODY_PASSIVE3_NAME": "Twisted Mutasyon (Eski)",
        "ROB_RAVAGER_BODY_PASSIVE3_DESCRIPTION": "<style=cIsHealth>Mevcut sağlığın %5'ine mal olur.</style>Havada atla<style=cIsUtility>ileri doğru yanıp sönme</style>, atlama başına bir kez. İniş<style=cIsDamage>yakın dövüş vuruşları</style>bu yeteneği tazeler.",
        "ROB_RAVAGER_BODY_CONFIRM_NAME": "Onaylamak",
        "ROB_RAVAGER_BODY_CONFIRM_DESCRIPTION": "Mevcut beceriyle devam edin.",
        "ROB_RAVAGER_BODY_CANCEL_NAME": "İptal etmek",
        "ROB_RAVAGER_BODY_CANCEL_DESCRIPTION": "Mevcut beceriyi iptal edin.",
        "ROB_RAVAGER_BODY_PRIMARY_SLASH_NAME": "Kesmek",
        "ROB_RAVAGER_BODY_PRIMARY_SLASH_DESCRIPTION": "İleriye doğru salla<style=cIsDamage>%230 hasar</style>. <style=cIsHealth>Sağlığınız ne kadar düşükse o kadar hızlı sallanır.</style>",
        "ROB_RAVAGER_BODY_PRIMARY_SLASHCOMBO_NAME": "Sökme",
        "ROB_RAVAGER_BODY_PRIMARY_SLASHCOMBO_DESCRIPTION": "İleriye doğru salla<style=cIsDamage>%180 hasar</style>. Her 3. vuruşta<style=cIsUtility>sersemletir</style>ve fırsatlar<style=cIsDamage>%390 hasar</style>.",
        "ROB_RAVAGER_BODY_SECONDARY_SPINSLASH_NAME": "bölünme",
        "ROB_RAVAGER_BODY_SECONDARY_SPINSLASH_DESCRIPTION": "İleriye doğru hamle yapın ve geniş bir hareket yapın,<style=cIsUtility>çekici</style>eğik çizgi<style=cIsDamage>%500 hasar</style>.",
        "ROB_RAVAGER_BODY_UTILITY_HEAL_NAME": "Pıhtılaştır",
        "ROB_RAVAGER_BODY_UTILITY_HEAL_DESCRIPTION": "Anında boşaltın<style=cIsHealth>Kan Kuyusu</style>, <style=cIsHealing>kendini iyileştirmek</style>tüketilen kanla birlikte.",
        "ROB_RAVAGER_BODY_UTILITY_BEAM_NAME": "İptal Et",
        "ROB_RAVAGER_BODY_UTILITY_BEAM_DESCRIPTION": "<style=cIsHealth>absorbe</style>gelen<style=cIsUtility>mermiler</style>kadar yıkıcı bir patlamayı şarj etmek için<style=cIsDamage>%5000 hasar</style>tamamen şarj olduğunda.",
        "ROB_RAVAGER_BODY_UTILITY_SWAP_NAME": "Boogie Woogie",
        "ROB_RAVAGER_BODY_UTILITY_SWAP_DESCRIPTION": "Şununla yer değiştir:<style=cIsUtility>herhangi bir varlık</style>.",
        "ROB_RAVAGER_BODY_UTILITY_SNATCH_NAME": "kapkaç",
        "ROB_RAVAGER_BODY_UTILITY_SNATCH_DESCRIPTION": "Gönder<style=cIsDamage>şeytan kolu</style>ve uzaktaki bir düşmanı pençeleriyle yakalayın,<style=cIsUtility>Kendini çarptığı yere doğru çekiyorsun</style>.",
        "ROB_RAVAGER_BODY_SPECIAL_GRAB_NAME": "Vahşileştirmek",
        "ROB_RAVAGER_BODY_SPECIAL_GRAB_DESCRIPTION": "Hamle ve<style=cIsUtility>yakalamak</style>yakındaki düşmanlara saldırın ve ardından<style=cIsDamage>%1000 hasar</style>. Eğer bu öldürürse<style=cIsHealth>tüketmek</style>geri yüklemeleri<style=cIsHealing>%10 maksimum sağlık</style>.",
        "ROB_RAVAGER_BODY_SPECIAL_GRAB_SCEPTER_NAME": "Tahribat",
        "ROB_RAVAGER_BODY_SPECIAL_GRAB_SCEPTER_DESCRIPTION": "Hamle ve<style=cIsUtility>yakalamak</style>yakındaki düşmanlara saldırın ve ardından<style=cIsDamage>%1000 hasar</style>. Eğer bu öldürürse<style=cIsHealth>tüketmek</style>geri yüklemeleri<style=cIsHealing>%10 maksimum sağlık</style>.\n<color=#d299ff>SCEPTER: Daha büyük çarpma yarıçapı ve yukarı doğru yanıp sönmek için sürüklerken Atla'ya basın.</color>",
        "ROB_RAVAGER_BODY_SPECIAL_PUNCH_NAME": "Yumruk",
        "ROB_RAVAGER_BODY_SPECIAL_PUNCH_DESCRIPTION": "Hamle ve<style=cIsUtility>yumruk</style>, işlem yapmak<style=cIsDamage>%1000 hasar</style>bir ile<style=cIsUtility>şok dalgası</style>aynı hasar için onların aracılığıyla. Eğer bu öldürürse<style=cIsHealth>tüketmek</style>geri yüklemeleri<style=cIsHealing>%10 maksimum sağlık</style>.",
        "ROB_RAVAGER_BODY_SPECIAL_THROW_NAME": "Savurmak",
        "ROB_RAVAGER_BODY_SPECIAL_THROW_DESCRIPTION": "Hamle ve<style=cIsUtility>yakalamak</style>yakındaki düşmanlara, ardından onları fırlatın<style=cIsDamage>%1000 hasar</style>etki üzerine. Eğer bu öldürürse<style=cIsHealth>tüketmek</style>geri yüklemeleri<style=cIsHealing>%10 maksimum sağlık</style>.",
        "KEYWORD_REDGUY_M12": "<style=cKeywordName>Duruşu Tutun</style><style=cSub>Duvardan atlamayı şarj ederken, bir<style=cIsUtility>duruşunu koru</style>. kadar sallanmak için serbest bırakın<style=cIsDamage>5 kat hasar</style>hıza dayanmaktadır.",
