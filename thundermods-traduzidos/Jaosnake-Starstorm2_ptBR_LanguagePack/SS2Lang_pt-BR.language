        "SS2_ELITE_MODIFIER_EMPYREAN": "{0} Empíreo {1}",
        "SS2_ELITE_EMPYREAN_SUBTITLE": "Presciência Devota de Petrichor V",
        "SS2_EQUIP_AFFIXEMPYREAN_NAME": "Harmonia",
        "SS2_EQUIP_AFFIXEMPYREAN_PICKUP": "Torne-se um aspecto da existência.",
        "SS2_ELITE_MODIFIER_STORM": "{0} Nascido da Tempestade",
