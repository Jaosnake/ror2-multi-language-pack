		public virtual string Check()
		{
			StringBuilder stringBuilder = new StringBuilder();
			Renderer component = ((Component)this).GetComponent<Renderer>();
			int i = 0;
			if (!Object.op_Implicit((Object)(object)component))
			{
				stringBuilder.AppendLine("No Renderer!");
			}
			HashSet<int> hashSet = new HashSet<int>();
			List<XScroller>.Enumerator enumerator = Scrollers.GetEnumerator();
			while (enumerator.MoveNext())
			{
				XScroller current = enumerator.Current;
				if (!hashSet.Add(current.PropertyId))
				{
					stringBuilder.AppendLine("UvScroller Conflict: " + current.TextureName);
				}
			}
			enumerator.Dispose();
			if (((object)component).GetType() != typeof(ParticleSystemRenderer) && component.sharedMaterials.Length > 1)
			{
				stringBuilder.AppendLine("Material count > 1: " + ((Object)component).name);
			}
			List<Material> list = new List<Material>();
			component.GetSharedMaterials(list);
			Material sharedMaterial = component.sharedMaterial;
			if (list.Count > 0)
			{
				HashSet<int>.Enumerator enumerator2 = hashSet.GetEnumerator();
				while (enumerator2.MoveNext())
				{
					int current2 = enumerator2.Current;
					if (!Object.op_Implicit((Object)(object)sharedMaterial))
					{
						break;
					}
					if (!sharedMaterial.HasProperty(current2))
					{
						stringBuilder.AppendLine("Cannot find property: " + current2);
					}
				}
				enumerator2.Dispose();
			}
			else
			{
				stringBuilder.AppendLine("material is null: " + ((Object)component).name);
			}
			for (int j = 0; j < Scrollers.Count; j++)
			{
				if (Scrollers[j] == null)
				{
					stringBuilder.Append("scroller is null: " + Scrollers[j]);
				}
			}
			HashSet<string> hashSet2 = new HashSet<string>();
			for (; i < Scrollers.Count; i++)
			{
				if (!hashSet2.Add(Scrollers[i].TextureName))
				{
					string text = "scroller redundancy: " + Scrollers[i].TextureName;
					string text2 = "There are two or more UV scrolling options that modify the UVs of the same mapping";
					stringBuilder.AppendLine(text + text2);
				}
			}
			return stringBuilder.ToString();
		}
	}
