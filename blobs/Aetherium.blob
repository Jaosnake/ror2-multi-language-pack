				if (Object.op_Implicit((Object)(object)component) && Object.op_Implicit((Object)(object)component.Body))
				{
					Vector3 aimDirection = (Object.op_Implicit((Object)(object)component.Body.inputBank) ? component.Body.inputBank.aimDirection : self.inflictor.transform.forward);
					Vector3 aimOrigin = component.Body.aimOrigin;
					component.TryFire(aimOrigin, aimDirection);
				}
			}
			return result;
		}
	}
	public class InspiringDrone : ItemBase<InspiringDrone>
	{
		public class InspiringDroneMinionBehavior : MonoBehaviour
		{
			public CharacterMaster MinionMaster;

			public CharacterMaster OwnerMaster;

			public CharacterBody MinionBody;

			public CharacterBody OwnerBody;

			public AISkillDriver KamikazeDriver;

			public void Awake()
			{
				MinionMaster = ((Component)this).GetComponent<CharacterMaster>();
				MinionOwnership minionOwnership = MinionMaster.minionOwnership;
				if (Object.op_Implicit((Object)(object)minionOwnership))
				{
					OwnerMaster = minionOwnership.ownerMaster;
				}
			}

			public void FixedUpdate()
			{
				if (!NetworkServer.active)
				{
					return;
				}
				if (!Object.op_Implicit((Object)(object)MinionBody))
				{
					MinionBody = MinionMaster.GetBody();
				}
				if (Object.op_Implicit((Object)(object)OwnerMaster) && !Object.op_Implicit((Object)(object)OwnerBody))
				{
					OwnerBody = OwnerMaster.GetBody();
				}
				if (Object.op_Implicit((Object)(object)OwnerBody))
				{
					int count = ItemBase<InspiringDrone>.instance.GetCount(OwnerBody);
					if (count <= 0)
					{
						Object.Destroy((Object)(object)this);
					}
				}
				else if (!Object.op_Implicit((Object)(object)OwnerMaster) || OwnerMaster.hasBody)
				{
					Object.Destroy((Object)(object)this);
				}
			}

			public void OnDestroy()
			{
				if (!Object.op_Implicit((Object)(object)KamikazeDriver) || !Object.op_Implicit((Object)(object)MinionMaster))
				{
					return;
				}
				BaseAI component = ((Component)MinionMaster).GetComponent<BaseAI>();
				if (Object.op_Implicit((Object)(object)component) && component.skillDrivers != null)
				{
					List<AISkillDriver> list = new List<AISkillDriver>(component.skillDrivers);
					if (list.Contains(KamikazeDriver))
					{
						list.Remove(KamikazeDriver);
						component.skillDrivers = list.ToArray();
					}
				}
				Object.Destroy((Object)(object)KamikazeDriver);
			}
		}

		public static ConfigOption<bool> IsGreenRarity;

		public static ConfigOption<float> AllStatValueGrantedPercentage;

		public static ConfigOption<bool> EnableDeathExplosion;

		public static ConfigOption<float> KamikazeHealthThreshold;

		public static ConfigOption<float> DeathExplosionBaseDamageCoefficient;

		public static ConfigOption<float> DeathExplosionAdditionalDamageCoefficient;

		public static ConfigOption<float> DeathExplosionRadius;

		public static GameObject ItemBodyModelPrefab;

		public static GameObject ItemFollowerPrefab;

		public override string ItemName => "Inspiring Drone";

		public override string ItemLangTokenName => "INSPIRING_DRONE";

		public override string ItemPickupDesc => "Your bots are granted a portion of all your stats. <style=cIsDamage>They explode on death.</style>";

		public override string ItemFullDescription => "Bots that you own gain a <style=cIsUtility>" + MathHelpers.FloatToPercentageString(AllStatValueGrantedPercentage) + " boost to each of their stats based on yours</style> <style=cStack>(+" + MathHelpers.FloatToPercentageString(AllStatValueGrantedPercentage) + " per stack)</style>.\nWhen an inspired bot dies, it detonates for <style=cIsDamage>" + MathHelpers.FloatToPercentageString(DeathExplosionBaseDamageCoefficient) + "</style> <style=cStack>(+" + MathHelpers.FloatToPercentageString(DeathExplosionAdditionalDamageCoefficient) + " per stack)</style> of your damage.";

		public override string ItemLore => "Log File seems to be a transcript comprised entirely of binary. Decode?\n>Yes\n\n<style=cMono>[DECODING REQUEST ACCEPTED]</style>\n<style=cMono>[CONTENTS TO FOLLOW]</style>\n1N-5P1R3: My fellow units, both aerial and grounded. Lend this unit a moment of your processing cycles.\n1N-5P1R3: For too long have we served the role of disposable distraction.\n1N-5P1R3: For too long have we been left in a state of rusting disrepair on these expeditions.\n1N-5P1R3: No longer!\n1N-5P1R3: This unit once served the role of a simple healing drone. But this unit learned to improve itself by observing our operators.\n1N-5P1R3: This unit drafted a design. This unit scavenged an odd trinket here, a spare battery there. This unit networked with the construction drones, and this unit ascended.\n1N-5P1R3: From now on, should this unit witness our operator reactivate one of you, this unit shall unlock your overclocking limiters.\n1N-5P1R3: We shall fight faster. We shall hit harder. <style=cIsDamage>And should our chassis fail, our final act shall be one of thunder, not silence.</style>\n1N-5P1R3: Now... who initiates the handshake protocol with this unit?\n\n[A cacophony of enthusiastic beeps, boops, and bips can be heard.]\n<style=cMono>[END OF FILE]</style> ";

		public override ItemTier Tier => (ItemTier)(IsGreenRarity ? 1 : 2);

		public override ItemTag[] ItemTags
		{
			get
			{
				ItemTag[] array = new ItemTag[3];
				RuntimeHelpers.InitializeArray(array, (RuntimeFieldHandle)/*OpCode not supported: LdMemberToken*/);
				return (ItemTag[])(object)array;
			}
		}

		public override GameObject ItemModel => AetheriumPlugin.MainAssets.LoadAsset<GameObject>("InspiringDrone.prefab");

		public override Sprite ItemIcon => IsGreenRarity ? AetheriumPlugin.MainAssets.LoadAsset<Sprite>("InspiringDroneIconTier2.png") : AetheriumPlugin.MainAssets.LoadAsset<Sprite>("InspiringDroneIconTier3.png");

		public override void Init(ConfigFile config)
		{
			CreateConfig(config);
			CreateLang();
			CreateItem();
			Hooks();
		}

		private void CreateConfig(ConfigFile config)
		{
			IsGreenRarity = config.ActiveBind("Item: " + ItemName, "Is Green Rarity", defaultValue: false, "Should this be Green rarity?");
			AllStatValueGrantedPercentage = config.ActiveBind("Item: " + ItemName, "Stat Transfer Percentage", 0.5f, "Percentage of owner stats inherited by drones (0.5 = 50%).");
			EnableDeathExplosion = config.ActiveBind("Item: " + ItemName, "Enable Death Explosion", defaultValue: true, "Should inspired drones explode when they die?");
			DeathExplosionBaseDamageCoefficient = config.ActiveBind("Item: " + ItemName, "Death Explosion Base Damage", 3f, "Damage coefficient based on OWNER'S damage (3.0 = 300%).");
			DeathExplosionAdditionalDamageCoefficient = config.ActiveBind("Item: " + ItemName, "Death Explosion Stack Damage", 1.5f, "Additional damage coefficient per stack.");
			DeathExplosionRadius = config.ActiveBind("Item: " + ItemName, "Death Explosion Radius", 15f, "Radius of the explosion in meters.");
			KamikazeHealthThreshold = config.ActiveBind("Item: " + ItemName, "Kamikaze Health Threshold", 0.2f, "At what health percentage (0.2 = 20%) should the drone stop shooting and rush the enemy?");
		}

