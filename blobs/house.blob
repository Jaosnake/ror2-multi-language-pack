	internal static class Tokens
	{
		internal static void AddTokens()
		{
			string text = "JAVANGLE_HOUSE_";
			string text2 = "The House is a mad gambler, who relies on his luck to push through tough situations, high risk, high reward.<color=#CCD3E0>" + Environment.NewLine + Environment.NewLine;
			text2 = text2 + "< ! > His trusty firearm, a 6 shooter revolver called ''roulette'' has a wide range of powerful and dangerous ammo availiable for it, and it fires loaded ammo in a random order, so be carefull when firing, else you'll waste a Buck shot at range, take self-damage, or otherwise botch your shot due to rng." + Environment.NewLine + Environment.NewLine;
			text2 = text2 + "< ! > The House's cards grant him a very large range of abilities, some good, some bad, some a bit of both, and others neither, while a few do something Random... if you want to try your luck." + Environment.NewLine + Environment.NewLine;
			text2 = text2 + "< ! > As The House uses a deck of cards, each card is only in the deck so many times, and when you run out, you reshuffle, so the more cards you discard, the higher the likelyhood of getting a card you have not seen yet, and you're guaranteed to see each card in the deck per shuffle (assuming you didn't shuffle early)." + Environment.NewLine + Environment.NewLine;
			text2 = text2 + "< ! > Each card slot has a cooldown, so it may not be a good idea to always be spamming through cards, as while it can earn you gold, it can also leave you wide open, so cycle wisely" + Environment.NewLine + Environment.NewLine;
			string text3 = "..and so he left, rolling higher than ever";
			string text4 = "..and so you didn't play The House...                ...The House played you";
			string text5 = "So, what was a guy like you even doing on the Contact Light anyhows?" + Environment.NewLine + Environment.NewLine + "Me? Well, I lost my playing cards right here on this hellscape, they ended up being recovered by their crew, boy was I down on my luck that day" + Environment.NewLine + Environment.NewLine + "So? I mean, who cares right? What's so special about some damn playing cards? 'you pullin' my leg aint'cha?" + Environment.NewLine + Environment.NewLine + "These aren't just playing cards, they came with this gun as a set. You see, the cards have strange properties, and summon bullets in the gun, as well as al-" + Environment.NewLine + Environment.NewLine + "Yeah right, I'm sure they do pall, I think you've spent a little too much time in the void" + Environment.NewLine + Environment.NewLine + "I can prove it... see?" + Environment.NewLine + Environment.NewLine + "... well I'll be!" + Environment.NewLine + Environment.NewLine + "The cards seem to have immense power, and wield strange effects, and no matter how hard I try, I can never draw more until I use one" + Environment.NewLine + Environment.NewLine + "How does that all work then?" + Environment.NewLine + Environment.NewLine + "I'm a gambler, not a scientist, all I know is that I can't let anyone get a hold of these artifacts, they'd be too dangerous in the hands of someone less... experienced, with lady luck" + Environment.NewLine + Environment.NewLine + "Heh, you speak as if you'd met 'er" + Environment.NewLine + Environment.NewLine + "Well, I had a run in with her" + Environment.NewLine + Environment.NewLine + "Say what now?" + Environment.NewLine + Environment.NewLine + "She runs a casino in the void, god only knows how she gets patrons down there, all I can tell you is that they definitely do NOT like said patrons walking out with more than what they went in with, slot machine nearly killed me" + Environment.NewLine + Environment.NewLine + "Woah woah Woah! Easy there, slow down now, a casino in the void? a slot machine nearly killed you?... take it thats where you got those artifacts, eh?" + Environment.NewLine + Environment.NewLine + "Well, if it weren't for my first prize being these artifacts, I might not have pulled so much from that slot machine, turned the damn thing into a money printer, the host was not so pleased, got myself kicked out, been being chased that same slot machine ever since" + Environment.NewLine + Environment.NewLine + "Speakin' o' slot machines, a new one just got installed in the ships entertainment lobby, folks've been sayin' the damn things livin' or sumin', crazy b-" + Environment.NewLine + Environment.NewLine + "..They installed what now?!";
			LanguageAPI.Add(text + "BODY_NAME", "House");
			LanguageAPI.Add(text + "BODY_DESCRIPTION", "");
			LanguageAPI.Add(text + "BODY_SUBTITLE", "The Mad Gambler");
			LanguageAPI.Add(text + "BODY_LORE", text5);
			LanguageAPI.Add(text + "BODY_OUTRO_FLAVOR", text3);
			LanguageAPI.Add(text + "BODY_OUTRO_FAILURE", text4);
			LanguageAPI.Add(text + "BODY_DEFAULT_SKIN_NAME", "House");
			LanguageAPI.Add(text + "BODY_MASTERY_SKIN_NAME", "Mansion");
			LanguageAPI.Add(text + "BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_NAME", "House: Mastery");
			LanguageAPI.Add(text + "BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_DESC", "As House, beat the game or obliterate on Monsoon.");
			LanguageAPI.Add(text + "BODY_MASTERYUNLOCKABLE_UNLOCKABLE_NAME", "House: Mastery");
			LanguageAPI.Add(text + "BODY_TYPHOONUNLOCKABLE_ACHIEVEMENT_NAME", "House: Grand Mastery");
			LanguageAPI.Add(text + "BODY_TYPHOONUNLOCKABLE_ACHIEVEMENT_DESC", "As House, beat the game or obliterate on Typhoon.");
			LanguageAPI.Add(text + "BODY_TYPHOONUNLOCKABLE_UNLOCKABLE_NAME", "House: Grand Mastery");
			LanguageAPI.Add(text + "PASSIVE_NAME", "The Game");
			LanguageAPI.Add(text + "PASSIVE_DESCRIPTION", "Instead of <style=cIsUtility>Skills</style>, The House uses <style=cIsUtility>Cards</style>, each card has a unique effect. Once a card is used, its slot goes on cooldown, you discard your hand, and draw 3 new cards.");
			LanguageAPI.Add(text + "PASSIVE_KEYWORD", "<style=cKeywordName>Note</style>Cards, bullets, and their effects can be seen in the Info/Cards Tab");
			LanguageAPI.Add(text + "STANDARDSPREAD_NAME", "Deck: Standard Spread");
			text2 = "A simplified deck, designed to be easy to use." + Environment.NewLine;
			text2 += "<style=cSub>[Check the Cards tab to see the cards in this deck]</style>";
			LanguageAPI.Add(text + "STANDARDSPREAD_DESCRIPTION", text2);
			LanguageAPI.Add(text + "FULLHOUSE_NAME", "Deck: Full House");
			text2 = "The classic House experience." + Environment.NewLine;
			text2 += "<style=cSub>[Check the Cards tab to see the cards in this deck]</style>";
			LanguageAPI.Add(text + "FULLHOUSE_DESCRIPTION", text2);
			LanguageAPI.Add(text + "DIVINATION_NAME", "Deck: Divination");
			text2 = "A complex deck that allows you to control the card composition." + Environment.NewLine;
			text2 += "<style=cSub>[Check the Cards tab to see the cards in this deck]</style>";
			LanguageAPI.Add(text + "DIVINATION_DESCRIPTION", text2);
			LanguageAPI.Add(text + "BULLETARTSEMPTY_NAME", "BulletArts: Empty");
			text2 = "Fire a loaded Shot at random." + Environment.NewLine;
			text2 += "When you have no shots left: do nothing.";
			LanguageAPI.Add(text + "BULLETARTSEMPTY_DESCRIPTION", text2);
			LanguageAPI.Add(text + "BULLETARTSQUICKDRAW_NAME", "BulletArts: Quickdraw");
			text2 = "Rapidly fire <style=cIsUtility>Standard Shots</style>, 1/" + BulletArtsQuickdraw.chanceToFire + " chance to fire a loaded shot at random" + Environment.NewLine;
			text2 = text2 + "<style=cIsUtility>Fires " + (1f - BulletArtsQuickdraw.speedModifier) * 100f + "% faster</style>, but <style=cArtifact>all shots deal " + (1f - BulletArtsQuickdraw.potency) * 100f + "% less damage</style>." + Environment.NewLine;
			text2 += "When you have no shots left: do nothing.";
			LanguageAPI.Add(text + "BULLETARTSQUICKDRAW_DESCRIPTION", text2);
			LanguageAPI.Add(text + "RELOADSTANDARD_NAME", "ReloadArts: Standard");
			text2 = "Playing any card reloads roulette." + Environment.NewLine;
			text2 += "50%/25% chance to gain 1/2 random special ammo based on the type of card used (red = Piercing/Buck/Explosive, Purple = Blank/Snake, Grey/Green = any of the previous)";
			text2 = text2 + Environment.NewLine + "<style=cSub>[Check the Cards tab to see the Shots and their effects]</style>";
			LanguageAPI.Add(text + "RELOADSTANDARD_DESCRIPTION", text2);
			LanguageAPI.Add(text + "RELOADALLIN_NAME", "ReloadArts: All-In");
			text2 = "Playing any card reloads roulette." + Environment.NewLine;
			text2 += "Load 0-6 Piercing/Buck/Explosive shots, <style=cArtifact>all remaining shots are Snake</style>.";
			text2 = text2 + Environment.NewLine + "<style=cSub>[Check the Cards tab to see the Shots and their effects]</style>";
			LanguageAPI.Add(text + "RELOADALLIN_DESCRIPTION", text2);
			LanguageAPI.Add(text + "CARDARTSHOP_NAME", "CardArts: Hop");
			text2 = "Playing any card: while in the air: will boost you forwards.";
			LanguageAPI.Add(text + "CARDARTSHOP_DESCRIPTION", text2);
			LanguageAPI.Add(text + "CARDARTSSWEEP_NAME", "CardArts: Sweep");
			text2 = $"Playing any card: swipes the card forward, dealing <style=cIsDamage>{100f * BaseCardSkill.SweepDamage}% damage</style> to enemies in melee range and <style=cIsUtility>gain barrier equal to {100f * BaseCardSkill.SweepShield}% of your max health</style> per enemy hit.";
			LanguageAPI.Add(text + "CARDARTSSWEEP_DESCRIPTION", text2);
			LanguageAPI.Add(text + "SHUFFLEART_NAME", "ShuffleArts: Ouroboros");
			text2 = "Whenever you run out of cards: reshuffle the deck back into the draw pile.";
			LanguageAPI.Add(text + "SHUFFLEART_DESCRIPTION", text2);
			LanguageAPI.Add(text + "STANDARDSHOT_NAME", "Standard Shot");
			LanguageAPI.Add(text + "STANDARDSHOT_DESCRIPTION", $"Fire a standard bullet for <style=cIsDamage>{100f * StandardShot.BaseDamage}% damage</style>.");
			LanguageAPI.Add(text + "PIERCINGSHOT_NAME", "Piercing Shot");
			LanguageAPI.Add(text + "PIERCINGSHOT_DESCRIPTION", $"Fire a special shot that pierces through targets for <style=cIsDamage>{100f * PiercingShot.BaseDamage}% damage</style> each");
			LanguageAPI.Add(text + "BUCKSHOT_NAME", "Buck Shot");
			LanguageAPI.Add(text + "BUCKSHOT_DESCRIPTION", $"Fire a shotgun blast for <style=cIsDamage>{100f * BuckShot.BaseDamage}% x {BuckShot.Count} damage</style>.");
			LanguageAPI.Add(text + "EXPLOSIVESHOT_NAME", "Explosive Shot");
			LanguageAPI.Add(text + "EXPLOSIVESHOT_DESCRIPTION", $"Fire an explosive projectile that deals <style=cIsDamage>{100f * ExplosiveShot.BaseDamage}% damage</style> in an AoE.");
			LanguageAPI.Add(text + "SNAKESHOT_NAME", "Snake Shot");
			LanguageAPI.Add(text + "SNAKESHOT_DESCRIPTION", $"Attempt to fire a shot, <style=cSub>fail</style>, and proceed to take <style=cDeath>{100f * SnakeShot.SelfDamagePercent}% of your max health as damage</style>");
			LanguageAPI.Add(text + "BLANKSHOT_NAME", "Blank Shot");
			LanguageAPI.Add(text + "BLANKSHOT_DESCRIPTION", "Attempt to fire a shot, <style=cSub>fail</style>, and proceed to look stupid lel.");
			LanguageAPI.Add(text + "MYSTERYSHOT_NAME", "Mystery Shot");
			LanguageAPI.Add(text + "MYSTERYSHOT_DESCRIPTION", "Fire a completely random projectile, it really could be anything.");
			LanguageAPI.Add(text + "ACESHOT_NAME", "Ace Shot");
			LanguageAPI.Add(text + "ACESHOT_DESCRIPTION", $"Charge a giant shot that deals <style=cIsDamage>{100f * AceShot.BaseDamage}% damage</style> to all enemies before you, striking from all ranges, and even through walls");
			LanguageAPI.Add(text + "7CLUBS_NAME", "7 of Clubs");
			LanguageAPI.Add(text + "7CLUBS_DESCRIPTION", "Load <style=cIsUtility>3 Mystery Shots</style> into roulette." + Environment.NewLine + "Additionally, <style=cIsUtility>Guarantees</style> your next bullet will be an Explosive Shot.");
			LanguageAPI.Add(text + "7SPADES_NAME", "7 of Spades");
			LanguageAPI.Add(text + "7SPADES_DESCRIPTION", $"Gain <style=cIsUtility>Increased Movement Speed</style> as well as <style=cIsUtility>2 completely random buffs</style> for {SevenOfSpades.buffDuration} seconds" + Environment.NewLine + "Additionally, <style=cIsUtility>Guarantees</style> your next bullet will be a Piercing Shot.");
			LanguageAPI.Add(text + "7DIAMONDS_NAME", "7 of Diamonds");
			LanguageAPI.Add(text + "7DIAMONDS_DESCRIPTION", "<style=cShrine>Gain Gold</style> <style=cSub>(scales with chest costs)</style>.");
			LanguageAPI.Add(text + "7HEARTS_NAME", "7 of Hearts");
			LanguageAPI.Add(text + "7HEARTS_DESCRIPTION", "<style=cIsHealing>Heal for 50% of your max HP</style> and <style=cIsUtility>Gain up to 50% Barrier</style> depending on current HP.");
			LanguageAPI.Add(text + "JACKPOT_NAME", "Jackpot");
			LanguageAPI.Add(text + "JACKPOT_DESCRIPTION", "Randomly activates the effects of ''7 of Clubs'', ''7 of Diamonds'', ''7 of Hearts'', or ''7 of Spades'' with double the effect, 20% chance to <style=cIsUtility>activate all at once</style>.");
			LanguageAPI.Add(text + "52_NAME", "Pick-Up 52");
			LanguageAPI.Add(text + "52_DESCRIPTION", "Throws all remaining cards into the air and shuffles everything back into the draw pile, each card homes in on enemies and <style=cIsDamage>deals varying amounts of Damage</style>.");
			LanguageAPI.Add(text + "SNAKE_NAME", "Snake Eyes");
			LanguageAPI.Add(text + "SNAKE_DESCRIPTION", "<style=cArtifact>Loads 2 Snake Shots</style> into roulette." + Environment.NewLine + "Additionally, <style=cIsUtility>Guarantees</style> your next bullet will be a Snake Shot." + Environment.NewLine + "<style=cIsUtility>Grants 1 stack of 'Ante'</style> each stack of 'Ante' reduces armor, and increases movement and attack speed");
			LanguageAPI.Add(text + "BUST_NAME", "Bust");
			LanguageAPI.Add(text + "BUST_DESCRIPTION", $"Instantly take <style=cDeath>{100f * Bust.selfDamagePercent}% of your max health as damage</style>, and <style=cIsDamage>deal {100f * Bust.healthToDamage}% of your max health</style> as damage to nearby enemies.");
			LanguageAPI.Add(text + "SWORDS_NAME", "10 of Swords");
			LanguageAPI.Add(text + "SWORDS_DESCRIPTION", "Summon powerful enemies around yourself.");
			LanguageAPI.Add(text + "COINS_NAME", "5 of coins");
			LanguageAPI.Add(text + "COINS_DESCRIPTION", $"<style=cArtifact>Lose {100f * Coins.goldCostFraction}% your current gold</style> and <style=cIsDamage>deal {100f * Coins.goldToDamageRatio}% of the gold lost as damage</style> to nearby enemies.");
			LanguageAPI.Add(text + "TOWER_NAME", "The Tower");
			LanguageAPI.Add(text + "TOWER_DESCRIPTION", "<style=cArtifact>Crisis</style>, <style=cDeath>Destruction</style>, <style=cArtifact>Catastrophe</style>, <style=cDeath>Losses</style>, <style=cArtifact>Obstacles</style>, <style=cDeath>Volatile</style>." + Environment.NewLine + "<style=cIsUtility>[Indestructible]</style> ");
			LanguageAPI.Add(text + "JOKER_NAME", "Joker");
			LanguageAPI.Add(text + "JOKER_DESCRIPTION", "Activates a random other <style=cArtifact>Purple Card Effect</style>, 20% chance to activate <style=cArtifact>all of them at once</style>." + Environment.NewLine + "<style=cSub>(Cannot Activate Tower.)</style>");
			LanguageAPI.Add(text + "7JACK_NAME", "Jack of Diamonds");
			LanguageAPI.Add(text + "7JACK_DESCRIPTION", "Load 6 standard shots." + Environment.NewLine + "If grounded: slides forward.");
			LanguageAPI.Add(text + "7QUEEN_NAME", "Queen of Hearts");
			LanguageAPI.Add(text + "7QUEEN_DESCRIPTION", "Temporarily <style=cIsUtility>buffs 2 random stats</style>, but <style=cArtifact>debuffs 2 random other stats</style>.");
			LanguageAPI.Add(text + "7KING_NAME", "King of Clubs");
			LanguageAPI.Add(text + "7KING_DESCRIPTION", "Loads an Explosive, Piercing, Buck, Snake, Bank, and Mystery Shot.");
			LanguageAPI.Add(text + "7ACE_NAME", "Ace of Spades");
			LanguageAPI.Add(text + "7ACE_DESCRIPTION", $"Loads nothing but 1 unique shot that deals <style=cIsDamage>{100f * AceShot.BaseDamage}% damage</style> after a long delay.");
			LanguageAPI.Add(text + "WILDCARD_NAME", "Wildcard");
			LanguageAPI.Add(text + "WILDCARD_DESCRIPTION", "Does something unpredictable. could be good, could be bad, could be neither... maybe both?" + Environment.NewLine + "<style=cIsUtility>[Indestructible]</style>");
			LanguageAPI.Add(text + "RROULETTE_NAME", "Russian Roulette");
			LanguageAPI.Add(text + "RROULETTE_DESCRIPTION", "1/6 chance <style=cDeath>to die</style>, 4/6 chance to do nothing and grant maximum stacks of 'Ante', 1/6 chance to <style=cIsDamage>kill everything on the map</style>, <style=cIsUtility>grant items</style> and <style=cIsUtility>revive all dead players</style>." + Environment.NewLine + "<style=cSub>(The rarity and amount of items received increases with number of stages cleared)</style>" + Environment.NewLine + "<style=cSub>(Cannot gain Legendary Items in Multiplayer)</style>" + Environment.NewLine + "<style=cIsUtility>[Indestructible]</style>");
			LanguageAPI.Add(text + "FORTUNE_NAME", "Wheel of Fortune");
			LanguageAPI.Add(text + "FORTUNE_DESCRIPTION", "50% chance to <style=cShrine>double current gold</style>, 50% chance to <style=cArtifact>lose all gold</style> and <style=cIsUtility>roll for a random item</style> based on gold lost.");
			LanguageAPI.Add(text + "THREEOFAKIND_NAME", "Three of a Kind");
			LanguageAPI.Add(text + "THREEOFAKIND_DESCRIPTION", "Draw and <style=cIsUtility>play the entire next hand</style> all at once.");
			LanguageAPI.Add(text + "GCLUBS_NAME", "Clubs");
			LanguageAPI.Add(text + "GCLUBS_DESCRIPTION", "Load <style=cIsUtility>3 random Positive Shots</style> into roulette." + Environment.NewLine + "Additionally, <style=cIsUtility>Guarantees</style> your next bullet will be an Explosive Shot.");
			LanguageAPI.Add(text + "GSPADES_NAME", "Spades");
			LanguageAPI.Add(text + "GSPADES_DESCRIPTION", $"Gain <style=cIsUtility> Increased Movement Speed</style> for {SevenOfSpades.buffDuration} seconds" + Environment.NewLine + "Additionally, <style=cIsUtility>Guarantees</style> your next bullet will be a Piercing Shot.");
			LanguageAPI.Add(text + "GHEARTS_NAME", "Hearts");
			LanguageAPI.Add(text + "GHEARTS_DESCRIPTION", "<style=cIsHealing>Heal for 50% of your max HP</style>");
			LanguageAPI.Add(text + "GJACK_NAME", "Jack");
			LanguageAPI.Add(text + "GJACK_DESCRIPTION", "Does nothing.");
			LanguageAPI.Add(text + "CRAZYCARD_NAME", "Crazycard");
			LanguageAPI.Add(text + "CRAZYCARD_DESCRIPTION", "Activates another Standard Spread card at random.");
			LanguageAPI.Add(text + "CASHOUT_NAME", "Cashout");
			LanguageAPI.Add(text + "CASHOUT_DESCRIPTION", "1/3 chance to <style=cArtifact>lose all money</style>, 1/3 chance to do nothing, 1/3 chance to <style=cIsDamage>damage every enemy on the map</style> and <style=cIsUtility>grant a temporary item</style>." + Environment.NewLine + "<style=cSub>(Damage and item rarity scale with money risked)</style>");
			LanguageAPI.Add(text + "THESUN_NAME", "The Sun");
			LanguageAPI.Add(text + "THESUN_DESCRIPTION", "<style=cIsUtility>Creates a duplicate of each other card in the hand</style> and draws them into the next hand." + Environment.NewLine + "<style=cSub>(Does not work on 'Indestructible' cards)</style>." + Environment.NewLine + "<style=cSub>(This effect cannot be triggered by other cards)</style>.");
			LanguageAPI.Add(text + "THEMOON_NAME", "The Moon");
			LanguageAPI.Add(text + "THEMOON_DESCRIPTION", "<style=cIsUtility>Destroys each other card in the hand</style>, removing them from the deck." + Environment.NewLine + "<style=cSub>(Does not work on 'Indestructible' cards)</style>." + Environment.NewLine + "<style=cSub>(This effect cannot be triggered by other cards)</style>.");
			LanguageAPI.Add(text + "THESTAR_NAME", "The Star");
			LanguageAPI.Add(text + "THESTAR_DESCRIPTION", "<style=cIsUtility>Creates three random cards and draws them immediately</style>, the card you use will be kept, <style=cArtifact>the other two will be destroyed.</style>" + Environment.NewLine + "<style=cSub>(Cannot create 'Indestructible' cards)</style>." + Environment.NewLine + "<style=cSub>(This effect cannot be triggered by other cards)</style>.");
			LanguageAPI.Add(text + "THEWORLD_NAME", "The World");
			LanguageAPI.Add(text + "THEWORLD_DESCRIPTION", "<style=cIsUtility>Destroys all 'The Sun', 'The Moon', 'The Star' and 'The World' cards</style> from the draw pile, hand, and discard pile, removing them from the deck." + Environment.NewLine + "<style=cSub>(This effect cannot be triggered by other cards)</style>.");
			LanguageAPI.Add(text + "JUDGEMENT_NAME", "Judgement");
			LanguageAPI.Add(text + "JUDGEMENT_DESCRIPTION", "<style=cIsUtility>Completely replaces the deck with the original version</style>, undoing any changes that have been made to it. <style=cSub>(as if you had respawned, or changed stage)</style>" + Environment.NewLine + "<style=cSub>(This effect cannot be triggered by other cards)</style>." + Environment.NewLine + "<style=cIsUtility>[Indestructible]</style>");
			LanguageAPI.Add(text + "KINGOFWANDS_NAME", "King of Wands");
			LanguageAPI.Add(text + "KINGOFWANDS_DESCRIPTION", "<style=cIsUtility>Consumes up to " + KingOfWands.AnteCostMax + " stacks of 'Ante'</style>, and <style=cIsHealing>provides up to " + (KingOfWands.healFraction + KingOfWands.healPerAnte * (float)KingOfWands.AnteCostMax) * 100f + "% healing</style> depending on how much 'Ante' was spent." + Environment.NewLine + "<style=cIsHealing>All controlled allies are healed for half the amount</style>.");
			LanguageAPI.Add(text + "QUEENOFCUPS_NAME", "Queen of Cups");
			LanguageAPI.Add(text + "QUEENOFCUPS_DESCRIPTION", "<style=cIsUtility>Consumes up to " + QueenOfCups.AnteCostMax + " stacks of 'Ante'</style>, and provides a buff that allows House to <style=cIsUtility>fire loaded shots without expending them</style>." + Environment.NewLine + "This buff lasts for up to " + QueenOfCups.buffDuration * (float)(QueenOfCups.AnteCostMax + 1) + " seconds, depending on how much 'Ante' is spent.");
			LanguageAPI.Add(text + "KNIGHTOFSWORDS_NAME", "Knight of Swords");
			LanguageAPI.Add(text + "KNIGHTOFSWORDS_DESCRIPTION", "<style=cIsUtility>Consumes up to " + KnightOfSwords.AnteCostMax + " stacks of 'Ante'</style>, and <style=cIsUtility>loads a number of positive rounds</style> equal to the amount of 'Ante' spent." + Environment.NewLine + "Additionally, <style=cIsUtility>Guarantees</style> your next bullet will be an Explosive Shot.");
			LanguageAPI.Add(text + "PAGEOFPENTACLES_NAME", "Page of Pentacles");
			LanguageAPI.Add(text + "PAGEOFPENTACLES_DESCRIPTION", "<style=cIsUtility>Consumes up to " + PageOfPentacles.AnteCostMax + " stacks of 'Ante'</style>, and summons Lunar Chimeras to fight for you, the more 'Ante' you spend, the greater the summoned force will be." + Environment.NewLine + "At " + PageOfPentacles.AnteCostMax + " stacks spent, this card will summon a random survivor instead");
			LanguageAPI.Add(text + "ANTEUP_NAME", "Up the Ante!");
			LanguageAPI.Add(text + "ANTEUP_DESCRIPTION", "<style=cIsUtility>Grants " + AnteUp.Stacks + " stacks of 'Ante'</style>." + Environment.NewLine + "Each stack of Ante reduces armor, and increases movement and attack speed");
			LanguageAPI.Add(text + "ANCIENTACE_NAME", "Ancient Ace");
			LanguageAPI.Add(text + "ANCIENTACE_DESCRIPTION", "Load <style=cIsUtility>6 Mystery Shots</style> into roulette." + Environment.NewLine + "Additionally, <style=cIsUtility>Grant one of the following effects</style>." + Environment.NewLine + "<style=cIsUtility>Dueces</style>: Every card you play, plays twice" + Environment.NewLine + "<style=cIsUtility>Flush</style>: Every time you play a card, play the rest of your hand (skipping negative and random cards)" + Environment.NewLine + "<style=cIsUtility>Cups</style>: Firing Roulette no longer costs Ammo" + Environment.NewLine + "<style=cIsUtility>[Indestructible]</style>");
			LanguageAPI.Add("ARTIFACT_OF_WILDROOM_NAME", "Artifact of Wildroom");
			LanguageAPI.Add("ARTIFACT_OF_WILDROOM_DESCRIPTION", "Summon a Wildroom at the start of every stage." + Environment.NewLine + "Wildroom can no longer remove itself, and now effects non-House players.");
			LanguageAPI.Add(text + "NULL_NAME", "Null");
			LanguageAPI.Add(text + "NULL_DESCRIPTION", "Does nothing, doesn't even reload." + Environment.NewLine + "You did it, you destroyed it all, you reduced it down to nothing, and now nothing is all that is left... are you happy..?");
		}
	}
