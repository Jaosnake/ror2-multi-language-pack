			bombProjectilePrefab = Asset.CloneProjectilePrefab("CommandoGrenadeProjectile", "ArmorerBombProjectile");
			Object.Destroy((Object)(object)bombProjectilePrefab.GetComponent<ProjectileImpactExplosion>());
			ProjectileImpactExplosion val = bombProjectilePrefab.AddComponent<ProjectileImpactExplosion>();
