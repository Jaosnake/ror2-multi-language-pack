				int skinIndex = (int)base.currentLoadout.bodyLoadoutManager.GetSkinIndex(driverBodyIndex);
				DriverWeaponDef.ModelSwapInfo modelSwapInfo = DriverWeaponSkinCatalog.GetModelSwapInfoForWeapon(SkinCatalog.GetBodySkinDefs(driverBodyIndex), skinIndex, weaponDef)[0];
				weaponRenderer.sharedMesh = modelSwapInfo.mesh;
				((Renderer)weaponRenderer).sharedMaterial = modelSwapInfo.material;
				for (int i = 0; i < characterModel.baseRendererInfos.Length; i++)
				{
					ref RendererInfo reference = ref characterModel.baseRendererInfos[i];
					reference.renderer.enabled = true;
