			if (Vector3.Distance(((Component)this).transform.position, val) <= 4f)
			{
				wallStareTimer = Mathf.Clamp(wallStareTimer + Time.fixedDeltaTime, 0f, 200f);
			}
			else
			{
				wallStareTimer = 0f;
			}
			if (Object.op_Implicit((Object)(object)characterBody) && characterBody.notMovingStopwatch <= 0f)
			{
				wallStareTimer = 0f;
			}
			RedGuyController.onStareAtWall?.Invoke(wallStareTimer);
		}

		private void OnDestroy()
		{
			AkSoundEngine.StopPlayingID(playID);
		}

		private void OnDisable()
		{
			AkSoundEngine.StopPlayingID(playID);
		}

		public void RefreshBlink()
		{
			if (passive.isBlink || passive.isLegacyBlink)
			{
				CharacterMotor characterMotor = characterBody.characterMotor;
				characterMotor.jumpCount--;
				if (characterBody.characterMotor.jumpCount < 0)
				{
					characterBody.characterMotor.jumpCount = 0;
				}
			}
		}

		public void IncrementWallJump()
		{
			wallJumpCounter++;
			RedGuyController.onWallJumpIncremented?.Invoke(wallJumpCounter);
		}

		public void FillGauge(float multiplier = 1f)
		{
			//IL_0073: Unknown result type (might be due to invalid IL or missing references)
			if (!draining)
			{
				decay = 0f;
				meter += 10f * multiplier;
				if (healthComponent.combinedHealthFraction <= 0.5f)
				{
					meter += 5f * multiplier;
				}
				NetworkIdentity component = ((Component)this).GetComponent<NetworkIdentity>();
				if (Object.op_Implicit((Object)(object)component))
				{
					NetMessageExtensions.Send((INetMessage)(object)new SyncBloodWell(component.netId, (ulong)(meter * 100f)), (NetworkDestination)1);
				}
			}
		}

		public void UpdateGauge()
		{
