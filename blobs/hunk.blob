			public static bool isInfernoActive
			{
				get
				{
					//IL_0030: Unknown result type (might be due to invalid IL or missing references)
					if (!MainPlugin.infernoInstalled)
					{
						return false;
					}
					if (!Object.op_Implicit((Object)(object)Run.instance))
					{
						return false;
					}
					DifficultyDef difficultyDef = DifficultyCatalog.GetDifficultyDef(Run.instance.ruleBook.FindDifficulty());
					if (difficultyDef.nameToken.ToLower().Contains("inferno"))
					{
						return true;
					}
					return false;
				}
			}

			public static void AddGunSkin(SkinDef skinDef, HunkWeaponDef weaponDef, GameObject modelPrefab)
			{
				gunSkins.Add(new HunkGunSkin
				{
					skinDef = skinDef,
					weaponDef = weaponDef,
					modelPrefab = modelPrefab
				});
			}

