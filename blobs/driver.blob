			((EntityState)this).PlayAnimation("AimPitch", "SteadyAimPitch");
			((EntityState)this).PlayCrossfade("Gesture, Override", "SteadyAim", "Action.playbackRate", 0.25f, 0.05f);
			muzzleTransform = childLocator.FindChild("PistolMuzzle");
			chargeupVfxGameObject = Object.Instantiate<GameObject>(ChargeCaptainShotgun.chargeupVfxPrefab, muzzleTransform);
			chargeupVfxGameObject.GetComponent<ScaleParticleSystemDuration>().newDuration = chargeDuration;
			enterSoundID = Util.PlayAttackSpeedSound(ChargeCaptainShotgun.enterSoundString, ((EntityState)this).gameObject, ((BaseState)this).attackSpeedStat);
			Util.PlaySound(ChargeCaptainShotgun.playChargeSoundString, ((EntityState)this).gameObject);
		}

		public override void Update()
		{
			((EntityState)this).Update();
			((EntityState)this).characterBody.SetSpreadBloom(0.4f + ((EntityState)this).age / chargeDuration, true);
		}

		public override void FixedUpdate()
		{
