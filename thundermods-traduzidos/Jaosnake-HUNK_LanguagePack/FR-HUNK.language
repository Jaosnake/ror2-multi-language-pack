        "ROB_NEMESIS_BODY_PASSIVE_DESCRIPTION": "<style=cIsDamage>Infliger des dégâts</style> accumule de la <style=cIsHealth>Biomasse</style>, augmentant vos <style=cIsDamage>dégâts</style> quand elle est pleine. Les sauts peuvent être <style=cIsDamage>chargés</style> pour <style=cIsUtility>des bonds puissants</style>.",
        "ROB_NEMESIS_BODY_PASSIVE2_NAME": "Armement Biologique",
        "ROB_NEMESIS_BODY_PASSIVE2_DESCRIPTION": "Le Nemesis T-Type peut <style=cIsHealth>muter</style> en consommant des <style=cIsDamage>personnes d'intérêt</style>, gagnant des <style=cIsDamage>compétences nouvelles et améliorées</style>.",
        "ROB_NEMESIS_BODY_PASSIVE22_NAME": "Augmentation de la Masse Musculaire",
        "ROB_NEMESIS_BODY_PASSIVE22_DESCRIPTION": "<style=cIsUtility>Les attaques de mêlée</style> infligent <style=cIsDamage>20%</style> plus de dégâts, <style=isHealth>MAIS les alliés peuvent subir des dégâts</style>.",
        "ROB_NEMESIS_BODY_MELEE_NAME": "Agression Brutale",
