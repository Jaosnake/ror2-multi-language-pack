					float fullCombinedHealth = healthComponent.fullCombinedHealth;
					float num2 = healthComponent.health / healthComponent.fullHealth;
					float num3 = 0f;
					if (healthComponent.fullShield > 0f)
					{
						num3 = healthComponent.shield / healthComponent.fullShield;
					}
					float num4 = healthComponent.fullHealth / fullCombinedHealth;
					float num5 = 1f - num4;
					if (healthComponent.combinedHealth < lastHealth)
					{
						medkitTimer = 2f;
					}
					lastHealth = healthComponent.combinedHealth;
					Color color = healthBarGradient.Evaluate(num2);
					if (Object.op_Implicit((Object)(object)body.inventory) && body.inventory.GetItemCount(Items.Infusion) > 0)
					{
						((Color)(ref color))..ctor(1f, 18f / 85f, 0.23137255f);
					}
					float num6 = Util.Remap(num4 * num2 / cursePenalty, 0f, 1f, minFill, maxFill);
