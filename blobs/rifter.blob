	internal class AddGameObjectOnRequest : INetMessage, ISerializableObject
	{
		private NetworkInstanceId netIdOwner;

		private NetworkInstanceId netId;

		private bool adding;

		public AddGameObjectOnRequest()
		{
		}

		public AddGameObjectOnRequest(NetworkInstanceId netIdOwner, NetworkInstanceId netId, bool adding)
		{
			//IL_0007: Unknown result type (might be due to invalid IL or missing references)
			//IL_0008: Unknown result type (might be due to invalid IL or missing references)
			//IL_000e: Unknown result type (might be due to invalid IL or missing references)
			//IL_000f: Unknown result type (might be due to invalid IL or missing references)
			this.netId = netIdOwner;
			this.netId = netId;
			this.adding = adding;
		}

		public void Deserialize(NetworkReader reader)
		{
			//IL_0002: Unknown result type (might be due to invalid IL or missing references)
			//IL_0007: Unknown result type (might be due to invalid IL or missing references)
			//IL_000e: Unknown result type (might be due to invalid IL or missing references)
			//IL_0013: Unknown result type (might be due to invalid IL or missing references)
			netIdOwner = reader.ReadNetworkId();
			netId = reader.ReadNetworkId();
			adding = reader.ReadBoolean();
		}

		public void OnReceived()
		{
			ForceAdd();
		}

		public void Serialize(NetworkWriter writer)
		{
			//IL_0002: Unknown result type (might be due to invalid IL or missing references)
			//IL_000e: Unknown result type (might be due to invalid IL or missing references)
			writer.Write(netIdOwner);
			writer.Write(netId);
			writer.Write(adding);
		}

		public void ForceAdd()
		{
			//IL_0001: Unknown result type (might be due to invalid IL or missing references)
			//IL_000d: Unknown result type (might be due to invalid IL or missing references)
			GameObject val = Util.FindNetworkObject(netIdOwner);
			GameObject val2 = Util.FindNetworkObject(netId);
			RifterOverchargePassive rifterOverchargePassive = default(RifterOverchargePassive);
			if (!Object.op_Implicit((Object)(object)val))
			{
				Debug.Log((object)"Specified Owner GameObject not found!");
			}
			else if (!Object.op_Implicit((Object)(object)val2))
			{
				Debug.Log((object)"Specified GameObject not found!");
			}
			else if (NetworkServer.localClientActive && val.TryGetComponent<RifterOverchargePassive>(ref rifterOverchargePassive))
			{
				if (adding)
				{
					rifterOverchargePassive.deployedList.Add(val2);
				}
				if (!adding)
				{
					rifterOverchargePassive.deployedList.Remove(val2);
				}
			}
		}
	}
