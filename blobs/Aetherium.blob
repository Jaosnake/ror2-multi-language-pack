					return;
				}
			}
			orig.Invoke(self, other);
		}

		private void RewardPlayerHalf(orig_OnKilledServer orig, DeathRewards self, DamageReport damageReport)
		{
			if (Object.op_Implicit((Object)(object)damageReport.attackerBody) && ((Object)damageReport.attackerBody).name.Contains(nameSuffix))
			{
				CharacterMaster attackerOwnerMaster = damageReport.attackerOwnerMaster;
				if (Object.op_Implicit((Object)(object)attackerOwnerMaster))
				{
					CharacterBody body = attackerOwnerMaster.GetBody();
					if (Object.op_Implicit((Object)(object)body))
					{
						int count = GetCount(body);
						if (count > 0)
						{
							attackerOwnerMaster.GiveExperience((ulong)(self.expReward / 2));
							attackerOwnerMaster.GiveMoney(self.goldReward / 2);
						}
					}
				}
				damageReport.attackerMaster.GiveExperience((ulong)self.expReward);
				damageReport.attackerMaster.GiveMoney(self.goldReward);
				self.goldReward = 0u;
				self.expReward = 0u;
			}
			orig.Invoke(self, damageReport);
		}

		private bool IsMinion(CharacterMaster master)
		{
			return Object.op_Implicit((Object)(object)master.minionOwnership) && Object.op_Implicit((Object)(object)master.minionOwnership.ownerMaster);
		}

		private bool IsUnstableDesignChimera(GameObject obj)
		{
			return ((Object)obj).name.Contains(nameSuffix);
		}
