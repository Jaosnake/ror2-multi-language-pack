		private static void CreateSounds()
		{
			LoadSoundbank();
			explosionSoundDef = CadetMod.Modules.Content.CreateAndAddNetworkSoundEventDef("Play_captain_shift_impact");
		}

		internal static void LoadSoundbank()
		{
			using Stream stream = Assembly.GetExecutingAssembly().GetManifestResourceStream("CadetMod.scout_bank.bnk");
			byte[] array = new byte[stream.Length];
			stream.Read(array, 0, array.Length);
			SoundBanks.Add(array);
		}

