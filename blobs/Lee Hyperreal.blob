			val2.projectileGhostReplacements = (ProjectileGhostReplacement[])(object)new ProjectileGhostReplacement[0];
			val2.minionSkinReplacements = (MinionSkinReplacement[])(object)new MinionSkinReplacement[0];
			val2.meshReplacements = (MeshReplacement[])(object)new MeshReplacement[0];
			val2.gameObjectActivations = (GameObjectActivation[])(object)new GameObjectActivation[0];
			defaultRendererInfos.CopyTo(skinDefInfo2.RendererInfos, 0);
			val2.rendererInfos = skinDefInfo2.RendererInfos;
			val.skinDefParams = val2;
			SkinDef.Awake -= new hook_Awake(DoNothing);
			return val;
		}

		private static void DoNothing(orig_Awake orig, SkinDef self)
