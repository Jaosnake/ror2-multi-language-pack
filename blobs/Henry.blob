		private static RendererInfo[] SkinRendererInfos(RendererInfo[] defaultRenderers, Material[] materials)
		{
			RendererInfo[] array = (RendererInfo[])(object)new RendererInfo[defaultRenderers.Length];
			defaultRenderers.CopyTo(array, 0);
			array[0].defaultMaterial = materials[0];
			return array;
		}

		private void HealthComponent_TakeDamage(orig_TakeDamage orig, HealthComponent self, DamageInfo damageInfo)
		{
			float num = 0f;
			if ((Object)(object)self != (Object)null && damageInfo != null && self.body.baseNameToken == "ROB_MRGREEN_BODY_NAME" && self.health != self.fullCombinedHealth)
			{
				MrGreenCloneTracker component = ((Component)self).gameObject.GetComponent<MrGreenCloneTracker>();
				if (Object.op_Implicit((Object)(object)component))
				{
					if (Object.op_Implicit((Object)(object)component.rootTracker))
					{
						if (component.rootTracker.canSpawnClone && damageInfo.damage >= 0.1f * self.fullCombinedHealth)
						{
							num = 0.9f * damageInfo.damage;
							damageInfo.damage *= 0.1f;
							((Component)self).GetComponent<EntityStateMachine>().SetNextState((EntityState)(object)new CloneDodge
							{
								storedDamage = num,
								attacker = damageInfo.attacker,
								tracker = component.rootTracker
							});
						}
					}
					else if (component.isRoot && component.canSpawnClone && damageInfo.damage >= 0.1f * self.fullCombinedHealth)
					{
						num = 0.9f * damageInfo.damage;
						damageInfo.damage *= 0.1f;
						((Component)self).GetComponent<EntityStateMachine>().SetNextState((EntityState)(object)new CloneDodge
						{
							storedDamage = num,
							attacker = damageInfo.attacker,
							tracker = component
						});
					}
				}
			}
			orig.Invoke(self, damageInfo);
		}

		private void CharacterMaster_OnBodyDeath(orig_OnBodyDeath orig, CharacterMaster self, CharacterBody body)
		{
			if (Object.op_Implicit((Object)(object)self) && Object.op_Implicit((Object)(object)body))
			{
				MrGreenCloneTracker component = ((Component)body).GetComponent<MrGreenCloneTracker>();
				if (Object.op_Implicit((Object)(object)component) && Object.op_Implicit((Object)(object)component.rootTracker))
				{
					return;
				}
			}
			orig.Invoke(self, body);
		}
