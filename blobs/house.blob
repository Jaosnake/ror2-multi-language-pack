						break;
					case 1:
						AddStackedTimedBuff(((EntityState)this).characterBody, Buffs.ASUp, buffDuration, buffStacks);
						break;
					case 2:
						AddStackedTimedBuff(((EntityState)this).characterBody, Buffs.DamageUp, buffDuration, buffStacks);
						break;
					case 3:
						AddStackedTimedBuff(((EntityState)this).characterBody, Buffs.MSUp, buffDuration, buffStacks);
						break;
					case 4:
						AddStackedTimedBuff(((EntityState)this).characterBody, Buffs.RegenUp, buffDuration, buffStacks);
						break;
					}
				}
				else
				{
					switch (array[i])
					{
					default:
						Debug.LogError((object)"[HouseError] Queen indexed outside of expected range");
						break;
					case 0:
						AddStackedTimedBuff(((EntityState)this).characterBody, Buffs.ArmorDown, buffDuration, buffStacks);
						break;
					case 1:
						AddStackedTimedBuff(((EntityState)this).characterBody, Buffs.ASDown, buffDuration, buffStacks);
						break;
					case 2:
						AddStackedTimedBuff(((EntityState)this).characterBody, Buffs.DamageDown, buffDuration, buffStacks);
						break;
					case 3:
						AddStackedTimedBuff(((EntityState)this).characterBody, Buffs.MSDown, buffDuration, buffStacks);
						break;
					case 4:
						AddStackedTimedBuff(((EntityState)this).characterBody, Buffs.RegenDown, buffDuration, buffStacks);
						break;
					}
				}
			}
		}

		private void AddStackedTimedBuff(CharacterBody characterBody, BuffDef buffDef, float duration, int stacks)
		{
			for (int i = 0; i < stacks; i++)
			{
				characterBody.AddTimedBuff(buffDef, duration, 50);
			}
		}
	}
