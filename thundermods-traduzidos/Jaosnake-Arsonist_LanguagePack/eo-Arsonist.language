{
    "eo": {
        "POPCORN_ARSONIST_BODY_NAME": "Brulpiristo",
        "POPCORN_ARSONIST_BODY_DESCRIPTION": "La Brulpiristo estas mallongdistanca tankego, kiu uzas fajron kiel ilon por atingi sian celon. Administri sian Trovarmigxan skalon ebligas al li kauxzi grandajn kvantojn da damagxo al grupoj de malamikoj. Ekvilibro estas decida por venko.</i>",
        "POPCORN_ARSONIST_BODY_SUBTITLE": "Frenezeta Piromaniulo",
        "POPCORN_ARSONIST_BODY_PASSIVE_NORMAL_GAUGE_NAME": "Normala Skalo",
        "POPCORN_ARSONIST_BODY_PASSIVE_NORMAL_GAUGE_DESCRIPTION": "Kauxzu <style=cIsDamage>100%</style> da damagxo sur la blanka parto. La Baza Skalo rezistas Trovarmigxon.</i>",
        "POPCORN_ARSONIST_BODY_PASSIVE_BLUE_GAUGE_NAME": "Kritika Skalo",
        "POPCORN_ARSONIST_BODY_PASSIVE_BLUE_GAUGE_DESCRIPTION": "Kauxzu <style=cIsDamage>70%</style> da damagxo sur la blanka parto kaj <style=cIsDamage>250%</style> da damagxo sur la blua parto. Maksimuma varmo estas fiksita.</i>",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_NAME": "Drakospiro",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_DESCRIPTION": "Pafu radion de flamo kauxzante <style=cIsDamage>90% da damagxo</style>. Pligrandigita ekbruliga sxanco, se vi estas pli proksime al la celo.</i>",
        "POPCORN_ARSONIST_BODY_PRIMARY_FIRESPRAY_NAME": "Fajrbulo",
        "POPCORN_ARSONIST_BODY_PRIMARY_FIRESPRAY_DESCRIPTION": "<style=cIsUtility>Varmo. </style>Pafas fajrbulon kauxzante <style=cIsDamage>225% da damagxo kaj ekbruligante</style> malamikojn cxe trafo.</i>",
        "POPCORN_ARSONIST_BODY_ALT_PRIMARY_FIRESPRAY_NAME": "Pretervarmigo",
        "POPCORN_ARSONIST_BODY_ALT_PRIMARY_FIRESPRAY_DESCRIPTION": "<style=cIsUtility>Varmo. </style><style=cIsUtility>Superkritiko. </style>Pafas fajrbulon kauxzante <style=cIsDamage>160% da damagxo kaj ekbruligante</style> malamikojn cxe trafo.</i>",
        "POPCORN_ARSONIST_BODY_PRIMARY_FIRESPRAY_SCEPTER_NAME": "Fajrostormo",
        "POPCORN_ARSONIST_BODY_PRIMARY_FIRESPRAY_SCEPTER_DESCRIPTION": "<style=cIsUtility>Varmo. </style>Pafu trapenetran radion de intensa varmo kauxzante <style=cIsDamage>300% da damagxo kaj ekbruligante</style> malamikojn cxe trafo. Se tenita dum mallonga periodo, pafu detruan radion je liberigo por <style=cIsDamage>450% da damagxo</style>.</i>",
        "POPCORN_ARSONIST_BODY_SECONDARY_PUNCH_NAME": "Nulpunkta Eksplodo",
        "POPCORN_ARSONIST_BODY_SECONDARY_PUNCH_DESCRIPTION": "<style=cIsUtility>Lerta. Varmo. </style>Propulsu vin antauxen, eksplodigante malamikojn malantaux vi por <style=cIsDamage>200% da damagxo</style>. Kolizii tuj post la lancxo kun la unua malamiko kauxzas <style=cIsDamage>200% da damagxo</style> en cxirkauxa eksplodo.</i>",
        "POPCORN_ARSONIST_BODY_SECONDARY_FLAREGUN_NAME": "Signalpafilo",
        "POPCORN_ARSONIST_BODY_SECONDARY_FLAREGUN_DESCRIPTION": "Pafu signalraketon kauxzante <style=cIsDamage>400% da damagxo</style> dum 5 sekundoj, poste eksplodas kauxzante <style=cIsDamage>400% da damagxo</style>, lancxante 5 signalraketojn kauxzantajn <style=cIsDamage>200% da damagxo</style> cxiu.</i>",
        "POPCORN_ARSONIST_BODY_UTILITY_CLEANSE_NAME": "Purigo",
        "POPCORN_ARSONIST_BODY_UTILITY_CLEANSE_DESCRIPTION": "<style=cIsUtility>Lerta. Varmo. </style><style=cIsDamage>Ekbruligu</style> la areon cxirkaux vi, kauxzante <style=cIsDamage>50%</style> da damagxo al proksimaj malamikoj kaj forigante aliajn statuso-efikojn. Donas malgrandan rapidecan plifortigon.</i>",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHIST_NAME": "Masocxismo",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHIST_DESCRIPTION": "<style=cIsUtility>Lerta. Varmo. </style>Damagxo de esti <style=cIsDamage>ekbruligita</style> transformigxas en <style=cIsHealing>resanigon</style> dum 6.5 sekundoj. Plialtigas Atakrapidecon je <style=cIsDamage>125%</style>.</i>",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_NAME": "Masocxismo",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_DESCRIPTION": "Atinginte la limon de <style=cKeywordName>Antauxsento</style>, periode kauxzu damagxon al vi mem en intersxangxo por areo da <style=cIsHealing>Vivosucxo</style> kaj brulado. Post maksimume 10 sekundoj, <style=cIsDamage>Eksplodu</style>, poste <style=cIsUtility>Trovarmigxu</style>.</i>",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_SURGE_NAME": "Malico",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_SURGE_DESCRIPTION": "Atinginte la limon de <style=cKeywordName>Antauxsento</style>, vi movigxas pli rapide kaj akiras <style=cKeywordName>Duoblan Pafon</style> kaj <style=cIsHealing>Vivosucxon</style>. Post maksimume 10 sekundoj, <style=cIsDamage>Eksplodu</style>, poste <style=cIsUtility>Trovarmigxu</style>.</i>",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_SCEPTER_NAME": "Riprocxo de Dante",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_SCEPTER_DESCRIPTION": "Pafu intensan radion kauxzante <style=cIsDamage>140% da damagxo</style>. Pligrandigita ekbruliga sxanco, se vi estas pli proksime al la celo. Se tenita dum 2 sekundoj aux pli, pafu finan radion je liberigo por <style=cIsDamage>150% da damagxo</style>.</i>",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_ANTICIPATION": "<style=cKeywordName>Antauxsento</style>Por cxiuj 100 varmo perditaj kaj/aux akiritaj, la Brulpiristo akiras 1 sxargon de Antauxsento; Post akiri 5 sxargojn, li povas aktivigi Masocxismon; Pliaj sxargoj plialtigas damagxon kaj dauxron; Cxiuj sxargoj konsumigxas je la fino.",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_DETONATE": "<style=cKeywordName>Eksplodo</style>La Brulpiristo eksplodas, kauxzante <style=cIsDamage>150% da damagxo</style> oble la kvanto de akumulitaj Antauxsentaj Sxargoj.",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_LIFESTEAL": "<style=cKeywordName>Vivosucxo</style>La Brulpiristo resanigxas je <style=cIsHealing>18%</style> de la kauxzita damagxo dum Masocxismo estas aktiva.",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_SURGE_LIFESTEAL": "<style=cKeywordName>Vivosucxo</style>La Brulpiristo resanigxas je <style=cIsHealing>5%</style> de la kauxzita damagxo dum Malico estas aktiva.",
        "POPCORN_ARSONIST_BODY_KEYWORD_OVERHEAT_MASO": "<style=cKeywordName>Trovarmigxo: Masocxismo</style>Se la Brulpiristo eliras el Masocxismo pro troa varmakumulo, EX Trovarmigxo aplikigxas, malaltigante Movrapidecon kaj Damagxon al 70%. Nuligi aux lasi la kapablon finigxi normale aplikas Trovarmigxon, malaltigante Atakrapidecon al 50%.",
        "POPCORN_ARSONIST_BODY_OVERHEAT_TEXT": "TROVARMIGXO!",
        "POPCORN_ARSONIST_BODY_COOLING_TEXT": "MALVARMIGXAS...!",
        "POPCORN_ARSONIST_BODY_OVERHEAT_EX_TEXT": "TROVARMIGXO:EX!",
        "POPCORN_ARSONIST_BODY_PASSIVE_NAME": "Piromanio",
        "POPCORN_ARSONIST_BODY_PASSIVE_DESCRIPTION": "Rezistu fajran damagxon de cxiuj fontoj. Konvertu unu atakon kauxzantan pli ol <style=cIsDamage>30%</style> de totala sano en <style=cIsDamage>50%</style> fajran damagxon dum tempo.",
        "POPCORN_ARSONIST_BODY_KEYWORD_PYROMANIAPASSIVE": "Piromanio ne efikas falan damagxon, krom se Fragileco estas aktiva.",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_NAME": "Brulpiristo: Majstreco",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_DESCRIPTION": "Kiel Brulpiristo, venku la ludon aux forvisxu vin en Monsoon.",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_ECLIPSE5UNLOCKABLE_ACHIEVEMENT_NAME": "Brulpiristo: Grandmajstreco",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_ECLIPSE5UNLOCKABLE_ACHIEVEMENT_DESCRIPTION": "Kiel Brulpiristo, venku la ludon en Eclipse 5 aux pli alte, AU venku la ludon en Typhoon (Starstorm 2 necesa).",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_ECLIPSE8UNLOCKABLE_ACHIEVEMENT_NAME": "Brulpiristo: Survivado",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_ECLIPSE8UNLOCKABLE_ACHIEVEMENT_DESCRIPTION": "Kiel Brulpiristo, venku la ludon en Eclipse 8, AU venku la ludon en Inferno (Inferno necesa).",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_FLAMETHROWERUNLOCKABLE_ACHIEVEMENT_NAME": "Brulpiristo: Piromaniulo",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_FLAMETHROWERUNLOCKABLE_ACHIEVEMENT_DESCRIPTION": "Kiel Brulpiristo, venku etapon sen trovarmigxi.",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_ARSONISTUNLOCKABLE_ACHIEVEMENT_NAME": "Bragxoj",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_ARSONISTUNLOCKABLE_ACHIEVEMENT_DESCRIPTION": "Mortigu teleportilan estron dum gxi estas ekbruligita."
    }
}
