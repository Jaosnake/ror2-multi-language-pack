		private static void Hooks()
		{
			spadesFilterConfig.SettingChanged += FilterChange;
			CardColorPositive.SettingChanged += ColourChange;
			CardColorNegative.SettingChanged += ColourChange;
			CardColorNeutral.SettingChanged += ColourChange;
			CardColorRandom.SettingChanged += ColourChange;
			hudScale.SettingChanged += HUDPositionChange;
			hudPositionX.SettingChanged += HUDPositionChange;
			hudPositionY.SettingChanged += HUDPositionChange;
			crosshairScale.SettingChanged += HUDPositionChange;
			crosshairPositionX.SettingChanged += HUDPositionChange;
			crosshairPositionY.SettingChanged += HUDPositionChange;
		}

		private static void ColourChange(object sender, EventArgs e)
		{
			//IL_003c: Unknown result type (might be due to invalid IL or missing references)
			//IL_0041: Unknown result type (might be due to invalid IL or missing references)
			//IL_004e: Unknown result type (might be due to invalid IL or missing references)
			//IL_0053: Unknown result type (might be due to invalid IL or missing references)
			//IL_0060: Unknown result type (might be due to invalid IL or missing references)
			//IL_0065: Unknown result type (might be due to invalid IL or missing references)
			//IL_0072: Unknown result type (might be due to invalid IL or missing references)
			//IL_0077: Unknown result type (might be due to invalid IL or missing references)
			HouseCard[] cards = HouseCardDefs.cards;
			foreach (HouseCard houseCard in cards)
			{
				switch (houseCard.type)
				{
				case HouseCard.CardType.Positive:
					houseCard.color = CardColorPositive.Value;
					break;
				case HouseCard.CardType.Negative:
					houseCard.color = CardColorNegative.Value;
					break;
				case HouseCard.CardType.Neutral:
					houseCard.color = CardColorNeutral.Value;
					break;
				case HouseCard.CardType.Random:
					houseCard.color = CardColorRandom.Value;
					break;
				}
			}
		}

		private static void FilterChange(object sender, EventArgs e)
		{
			SevenOfSpades.filteredBuffsStrings = spadesFilterConfig.Value.Split(',');
			SevenOfSpades.ApplyFilter();
		}

