		private static void CreateStaticField()
		{
			fieldProjectilePrefab = Asset.mainAssetBundle.LoadAsset<GameObject>("StaticFieldDOT");
			StaticFieldDamage staticFieldDamage = fieldProjectilePrefab.AddComponent<StaticFieldDamage>();
			staticFieldDamage.procCoefficient = 0.1f;
