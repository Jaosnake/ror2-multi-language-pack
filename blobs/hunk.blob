			public void ClientGainGauge(int amount)
			{
				if (!mayhemMode)
				{
					if (amount > 0)
					{
					}
					gauge = Mathf.Clamp(gauge + amount, 0, maxGauge);
				}
			}

			private void HandleGauge()
			{
				if (!Object.op_Implicit((Object)(object)characterBody))
				{
					return;
				}
				if (mayhemMode)
				{
					if (Object.op_Implicit((Object)(object)mayhemEffect) && !mayhemEffect.isPlaying)
					{
						mayhemOverlay = TemporaryOverlayManager.AddOverlay(((Component)characterModel).gameObject);
						mayhemOverlay.duration = 1f;
						mayhemOverlay.destroyComponentOnEnd = false;
						mayhemOverlay.originalMaterial = HunkAssets.mayhemOverlayMat;
						mayhemOverlay.inspectorCharacterModel = characterModel;
						mayhemOverlay.alphaCurve = AnimationCurve.Constant(0f, 1f, 1f);
						mayhemOverlay.animateShaderAlpha = true;
						mayhemEffect.Play();
					}
					if (gaugeStopwatch <= 0f && gauge > 0)
					{
						gauge--;
						gaugeStopwatch = 0.125f;
					}
				}
				else
				{
					if (Object.op_Implicit((Object)(object)mayhemEffect) && mayhemEffect.isPlaying)
					{
						mayhemEffect.Stop();
					}
					if (mayhemOverlay != null)
					{
						mayhemOverlay.RemoveFromCharacterModel();
					}
					if (gaugeStopwatch <= 0f && gauge < maxGauge)
					{
						gauge++;
						gaugeStopwatch = 1.5f;
					}
				}
				if ((float)gauge <= 0f)
				{
					if (NetworkServer.active && characterBody.HasBuff(Hunk.mayhemBuff))
					{
						characterBody.RemoveBuff(Hunk.mayhemBuff);
					}
					mayhemMode = false;
				}
				if (gauge < maxGauge)
				{
				}
			}

