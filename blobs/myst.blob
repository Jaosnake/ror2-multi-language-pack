		public void Synthesize(int magiciteNumber)
		{
			int num = 0;
			ObtainedMagicite obtainedMagicite = inventoryMagicites[num];
			while (obtainedMagicite.magicite.type != Magicite.MagiciteType.None && num < 99)
			{
				num++;
				obtainedMagicite = inventoryMagicites[num];
			}
			inventoryMagicites[num] = new ObtainedMagicite
			{
				magicite = MagiciteDefs.magicites[magiciteNumber]
			};
			inventoryMagicites[num].SetUpMagicite();
			menuManager.SetMagiciteColours();
			menuManager.SetMagiciteUnread(num);
		}

