        "MOFFEIN_PILOT_BODY_PRIMARY_SILENCER_DESCRIPTION": "<style=cIsDamage>Interfector</style>. Pistola silentii tua iacula pro <style=cIsDamage>100% damno</style>.",
        "MOFFEIN_PILOT_BODY_SECONDARY_NAME": "Scopus Captus!",
