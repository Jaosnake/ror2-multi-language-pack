		public static T[] Append<T>(ref T[] array, List<T> list)
		{
			int num = array.Length;
			int count = list.Count;
			Array.Resize(ref array, num + count);
			list.CopyTo(array, num);
			return array;
		}

		public static string GetAchievementNameToken(string identifier)
		{
			return "ACHIEVEMENT_" + identifier.ToUpperInvariant() + "_NAME";
		}

		public static Func<T[], T[]> AppendDel<T>(List<T> list)
		{
			return (T[] r) => Append(ref r, list);
		}

		public static string RetrieveClonePrefab(CharacterBody body)
		{
			if (Config.loreMode.Value)
			{
				return body.skinIndex switch
				{
					0u => "prospectorMasterClone", 
					1u => "comradeMasterClone", 
					4u => "scarletMasterClone", 
					5u => "yiMasterClone", 
					6u => "bkMasterClone", 
					_ => "leeMasterClone", 
				};
			}
			return body.skinIndex switch
			{
				2u => "scarletMasterClone", 
				3u => "prospectorMasterClone", 
				4u => "comradeMasterClone", 
				5u => "yiMasterClone", 
				6u => "bkMasterClone", 
				_ => "leeMasterClone", 
			};
		}

