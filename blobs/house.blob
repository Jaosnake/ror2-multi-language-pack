		public void WheelTextRandom(int wheelSlot)
		{
			if (wheelSlot == 0)
			{
				Debug.LogWarning((object)"[HouseError] WildWheel tried to index slot 0");
				return;
			}
			wheelSlot--;
			if (Seasons.isAprilFools && random.Next(3) == 0)
			{
				WildWheel[wheelSlot].text = "APRIL FOOLS!";
			}
			else
			{
				WildWheel[wheelSlot].text = DummyResponses[random.Next(DummyResponses.Length)];
			}
		}

		public void WheelTextResult()
		{
			WildWheel[2].text = result;
		}
