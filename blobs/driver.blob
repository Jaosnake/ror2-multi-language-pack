					}
					if (Config.uniqueDropsAreLegendary.Value && tier == DriverWeaponTier.Legendary && driverWeaponDef.tier > DriverWeaponTier.Legendary)
					{
						list.Add(driverWeaponDef);
					}
				}
			}
			if (list.Count == 0)
