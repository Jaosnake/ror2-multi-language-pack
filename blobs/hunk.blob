			public void FinishReload()
			{
				if (!Object.op_Implicit((Object)(object)weaponDef))
				{
					return;
				}
				int num = getMagSize;
				if (weaponDef.isInfinite)
				{
					weaponTracker.weaponData[weaponTracker.equippedIndex].totalAmmo = num;
					weaponTracker.weaponData[weaponTracker.equippedIndex].currentAmmo = num;
					ammo = num;
					return;
				}
				int num2 = maxAmmo - ammo;
				if (ammo + weaponTracker.weaponData[weaponTracker.equippedIndex].totalAmmo >= num)
				{
					weaponTracker.weaponData[weaponTracker.equippedIndex].currentAmmo += num2;
					ammo = num;
				}
				else
				{
					weaponTracker.weaponData[weaponTracker.equippedIndex].currentAmmo += weaponTracker.weaponData[weaponTracker.equippedIndex].totalAmmo;
					ammo += weaponTracker.weaponData[weaponTracker.equippedIndex].totalAmmo;
				}
				if (Object.op_Implicit((Object)(object)inventory))
				{
					if (inventory.GetItemCount(Items.SecondarySkillMagazine) > 0)
					{
						Util.PlaySound("sfx_hunk2_ammo_get", ((Component)this).gameObject);
					}
					ammo += inventory.GetItemCount(Items.SecondarySkillMagazine);
				}
				weaponTracker.weaponData[weaponTracker.equippedIndex].totalAmmo -= num2;
				if (weaponTracker.weaponData[weaponTracker.equippedIndex].totalAmmo <= 0)
				{
					weaponTracker.weaponData[weaponTracker.equippedIndex].totalAmmo = 0;
				}
			}

