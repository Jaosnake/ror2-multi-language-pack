		public override void Hooks()
		{
			//IL_0008: Unknown result type (might be due to invalid IL or missing references)
			//IL_0012: Expected O, but got Unknown
			//IL_001a: Unknown result type (might be due to invalid IL or missing references)
			//IL_0024: Expected O, but got Unknown
			CharacterBody.OnInventoryChanged += new hook_OnInventoryChanged(ManageComponent);
			GlobalEventManager.OnHitEnemy += new hook_OnHitEnemy(GrantOnKillEffectsOnHighDamage);
		}

		private void ManageComponent(orig_OnInventoryChanged orig, CharacterBody self)
		{
			orig.Invoke(self);
			if (!Object.op_Implicit((Object)(object)self.inventory))
			{
				return;
			}
			int itemCount = self.inventory.GetItemCount(ItemDef);
			WitchesRingBehavior witchesRingBehavior = ((Component)self).GetComponent<WitchesRingBehavior>();
			if (itemCount > 0)
			{
				if (!Object.op_Implicit((Object)(object)witchesRingBehavior))
				{
					witchesRingBehavior = ((Component)self).gameObject.AddComponent<WitchesRingBehavior>();
				}
				witchesRingBehavior.StackCount = itemCount;
			}
			else if (Object.op_Implicit((Object)(object)witchesRingBehavior))
			{
				Object.Destroy((Object)(object)witchesRingBehavior);
			}
		}

		private void GrantOnKillEffectsOnHighDamage(orig_OnHitEnemy orig, GlobalEventManager self, DamageInfo damageInfo, GameObject victim)
		{
			//IL_0184: Unknown result type (might be due to invalid IL or missing references)
			//IL_018b: Expected O, but got Unknown
			orig.Invoke(self, damageInfo, victim);
			if (!NetworkServer.active || !Object.op_Implicit((Object)(object)damageInfo.attacker) || !Object.op_Implicit((Object)(object)victim))
			{
				return;
			}
			WitchesRingBehavior component = damageInfo.attacker.GetComponent<WitchesRingBehavior>();
			if (!Object.op_Implicit((Object)(object)component) || component.StackCount <= 0)
			{
				return;
			}
			CharacterBody component2 = damageInfo.attacker.GetComponent<CharacterBody>();
			CharacterBody component3 = victim.GetComponent<CharacterBody>();
			if (Object.op_Implicit((Object)(object)component2) && Object.op_Implicit((Object)(object)component3) && component3.healthComponent.alive && damageInfo.damage / component2.damage >= (float)WitchesRingTriggerThreshold && !(GlobalCooldownOnUse ? component2.HasBuff(WitchesRingImmunityBuffDef) : component3.HasBuff(WitchesRingImmunityBuffDef)))
			{
				float num = (float)BaseCooldownDuration / (1f + (float)AdditionalCooldownReduction * (float)(component.StackCount - 1));
				if ((bool)GlobalCooldownOnUse)
				{
					component2.AddTimedBuff(WitchesRingImmunityBuffDef, num);
				}
				else
				{
					component3.AddTimedBuff(WitchesRingImmunityBuffDef, num);
				}
				DamageReport val = new DamageReport(damageInfo, component3.healthComponent, damageInfo.damage, component3.healthComponent.combinedHealth);
				GlobalEventManager.instance.OnCharacterDeath(val);
			}
		}
	}
}
namespace Aetherium.Items.Tier2
{
	public class BloodthirstyShield : ItemBase<BloodthirstyShield>
	{
		public static ConfigOption<bool> UseNewIcons;

		public static ConfigOption<float> ShieldPercentageRestoredPerKill;

		public static ConfigOption<float> AdditionalShieldPercentageRestoredPerKillDiminishing;

		public static ConfigOption<float> MaximumPercentageShieldRestoredPerKill;

		public static ConfigOption<float> BaseGrantShieldMultiplier;

		public static GameObject ItemBodyModelPrefab;

		public override string ItemName => "Bloodthirsty Shield";

		public override string ItemLangTokenName => "BLOODTHIRSTY_SHIELD";

		public override string ItemPickupDesc => "Killing an enemy <style=cIsHealing>restores</style> a small portion of <style=cIsHealing>shield</style>.";

		public override string ItemFullDescription => "Killing an enemy restores <style=cIsUtility>" + MathHelpers.FloatToPercentageString(ShieldPercentageRestoredPerKill) + " max shield</style> <style=cStack>(+" + MathHelpers.FloatToPercentageString(AdditionalShieldPercentageRestoredPerKillDiminishing) + " per stack hyperbolically.)</style> This item will grant <style=cIsUtility>" + MathHelpers.FloatToPercentageString(BaseGrantShieldMultiplier) + "</style> of your max health as shield on pickup once.";

		public override string ItemLore => "Ballad of Letheseus, Hero of the Isles - Act II, Scene III\n\nThe sound of metal tearing flesh ripples through the air; the soldiers within seemingly unaffected by the macabre orchestra around them. All that matters to them is their own survival, regardless of whose blood that survival costs. One after another, the Xiphos meets its mark until there is only one man left.\n\nThe sound dies down. Letheseus kneels upon the crimson soil, worn out from his deadly dance. His Xiphos shall serve him no longer. His Aspis, albeit cracked, shall continue to protect him as long as he is able to pay it a tribute he can only find in the fury of battle.";

		public override ItemTier Tier => (ItemTier)1;

		public override ItemTag[] ItemTags => (ItemTag[])(object)new ItemTag[1] { (ItemTag)2 };

		public override GameObject ItemModel => AetheriumPlugin.MainAssets.LoadAsset<GameObject>("BloodthirstyShield.prefab");

		public override Sprite ItemIcon => UseNewIcons ? AetheriumPlugin.MainAssets.LoadAsset<Sprite>("BloodSoakedShieldIconAlt.png") : AetheriumPlugin.MainAssets.LoadAsset<Sprite>("BloodthirstyShieldIcon.png");

		public override void Init(ConfigFile config)
		{
			CreateConfig(config);
			CreateLang();
			CreateItem();
			Hooks();
		}

		private void CreateConfig(ConfigFile config)
		{
			UseNewIcons = config.ActiveBind("Item: " + ItemName, "Use Alternative Icon Art?", defaultValue: false, "If set to true, will use the new icon art drawn by WaltzingPhantom, else it will use the old icon art.");
			ShieldPercentageRestoredPerKill = config.ActiveBind("Item: " + ItemName, "Percentage of Shield Restored per Kill", 0.1f, "How much shield in percentage should be restored per kill? 0.1 = 10%");
			AdditionalShieldPercentageRestoredPerKillDiminishing = config.ActiveBind("Item: " + ItemName, "Additional Shield Restoration Percentage per Additional BSS Stack (Diminishing)", 0.1f, "How much additional shield per kill should be granted with diminishing returns (hyperbolic scaling) on additional stacks? 0.1 = 10%");
			MaximumPercentageShieldRestoredPerKill = config.ActiveBind("Item: " + ItemName, "Absolute Maximum Shield Restored per Kill", 0.5f, "What should our maximum percentage shield restored per kill be? 0.5 = 50%");
			BaseGrantShieldMultiplier = config.ActiveBind("Item: " + ItemName, "Shield Granted on First BSS Stack", 0.08f, "How much should the starting shield be upon receiving the item? 0.08 = 8%");
		}

