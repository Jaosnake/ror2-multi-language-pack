        "SS2_ACHIEVEMENT_NEMESIS_MERCENARY_NEMESIS_DESC": "As Nemesis Mercenary, defeat Mercenary's vestige.",
        "SS2_EXECUTIONER2_DASH_NAME": "Sürü Dağıtma",
        "SS2_NEMMANDO_UTILITY_DODGE_DESCRIPTION": "<style=cIsUtility>Roll</style> kısa bir mesafeye giderek <style=cIsUtility>200 zırhı</style> kazanır.",
        "SS2_BORG_SPECIAL_TELEPORT_NAME": "Geri Çağırma",
        "SS2_MULE_KEYWORD_UPHEAVAL_CALIBRATED": "<style=cKeywordName>Kalibre edilmiş</style></style=cSub>Önünüzdeki zemini yumruklayın ve aynı anda 3 kayaya kadar kaldırın.",
        "SS2_ITEM_DETRITIVETREMATODE_NAME": "Detritif Trematod",
        "SS2_MULE_NAME": "MULE (SS2 BETA. ÇOK KABA PROTOTİP)",
        "SS2_BIGBROTHER_BODY_SUBTITLE": "Canlanan Yok Edici",
        "SS2_ITEM_ICETOOL_NAME": "Buz Aleti",
        "SS2_ETHEREAL_DIFFICULTY_WARNING": "<style=cEvent><style=cDeath>Gezegen size karşı çabalarını iki katına çıkarıyor..</style></style>",
        "SS2_ACIDBUG_BODY_NAME": "Okçu Böcek",
        "SS2_DUT_NAME": "DU-T (SS2 BETA. VERY ROUGH PROTOTYPE)",
        "SS2_EQUIP_AFFIXULTRA_NAME": "",
        "SS2_ACHIEVEMENT_INSECTICIDE_DESC": "As REX, kill an Elite Beetle Queen.",
        "SS2_ACHIEVEMENT_BLASTKNUCKLES_DESC": "As Loader, kill a teleporter boss in a single punch.",
        "SS2_ITEM_ITEMONBOSSKILL_LORE": "???",
        "SS2_AMBUSH_MESSAGE_SINGLE": "<style=cShrine>{0}, {1}s</color> tarafından pusuya düşürüldü.",
        "SS2_ITEM_FORK_NAME": "Çatal",
        "SS2_ITEM_BABYTOYS_NAME": "Bebek Oyuncakları",
        "SS2_ITEM_AUGURY_NAME": "Kehanet",
        "SS2_ITEM_HUNTERSSIGIL_DESC": "En az 1 saniye <style=cIsUtility>hareketsiz durmak</style> <style=cIsUtility>15</style> zırh <style=cStack>(birikim başına +10 zırh)</style> ve <style=cIsDamage>25%</style> kritik şansı <style=cStack>(birikim başına +20%)</style> verir. Etkisi hareket anından <style=cIsUtility>0.75</style> <style=cStack>(birikim başıma +0.25)</style><style=cIsUtility> saniye</stack> devam eder.",
        "SS2_BORG_SPECIAL_NOTPREON_NAME": "Aşırı Isınma Düzeltme",
        "SS2_ITEM_RELICOFTERMINATION_LORE": "Genç! Ah, geri döndüğünü gördüğüm için çok heyecanlıyım! Yeni bir şey buldun mu?\n\nOh? Var! Göster bana ufaklık. Utanmana gerek yok.\n\nHm... Bu sefer ne buldun? Sağlam ve içi boş, ama salladığınızda... olgunlaşmış fındık ağacı gibi akıp gidiyor. Burada ne kadar tuhaf bir şekil var...\n\nOh? Aman tanrım. Bir canavar tarafından kovalandın, diyorsun... Seni buraya kadar takip etmedi, değil mi? \n\n... Takip etmedi. Ama elbette bizi burada bulmak zor olur değil mi Youngling?\n\nİşte, bunu elimden alacağım. Bize canavar getiremeyeceği bir yere.\n\n...Anlıyorum. Bazen korkmakta sorun yoktur, ancak bunun sizi bunaltmasına izin veremezsiniz. Başka bir gezginin bu şekli bulması ve bunun için çok acı çekmesi zalimlik olmaz mıydı? \n\nBurada güvende olacağız Youngling. Benimle gel. Bu kadar uzun süre dışarıda kaldıktan sonra aç olmalısın.",
        "SS2_DIFFICULTY_DELUGE1_NAME": "Tufan +1",
        "SS2_ITEM_STRANGECAN_LORE": "Biri donmuş bir yuvadaki moloz denizi arasında titreyen iki figür oturuyor. Verilen tek ışık, bir ateşin küçük kalıntıları ve eski kıvılcım telleridir. Isıran soğuğa karşı neredeyse hiç koruma yok.\n\n\"Hey...\" Uzak bir umutla yukarıya bakıyor. \"Sence bu kayadan kurtulacak mıyız?\"\n\n\"Zor.\" Bulduğu rasyondan bir ısırık alır.\n\n\"Gözden kaçırdığımız bir şey olmalı, değil mi? Henüz düşünemediğimiz bir yöntem belki?\" Adam ayağa kalkar ve endişeli bir şekilde etrafta volta atmaya başlar.\n\n\"Belkide.\"Bir ısırık daha.\n\n\"Belki henüz bulamadığımız çalışan parçalarla ilgili bir enkaz var, ya da mevcut parçalarda düzeltebileceğimiz bir sorun?\" Gözlerine dönen, kendini daha umutlu ve heyecanlı kılan bir parıltı.\n\n\"Kesinlikle mümkün.\" Bir ısırık daha.\n\nYüzünden tiksinmiş bir bakış geçerken durdu. \"Ah, lütfen sadece yemek yemek yerine bir şeyler düşünmeme yardım eder misin?\"\n\n\"Yerinde olsam o konuda endişe etmezdim.\" Bir ısırık daha.\n\nİğrenmesi, yerini hızla bariz hayal kırıklığı ve öfkeye bırakır. \"Neden?! Buradan çıkmak istemiyor musun?!\"\n\nKadın İçini çeker ve elini saçlarının arasından geçirir. \"Eminim. Ancak bu, her küçük şey üzerinde strese girmemiz gerektiği anlamına gelmez. Yaşıyoruz, değil mi? En azından hayattayız.\"\n\n\"Şey... Sanırım haklısın... Hemen şimdi heyecanlanmak kötü olurdu....\" Yere baktığında ifadesi gevşedi.\n\n\"Bak? Sadece otur, rahatla ve eski zulamın seni ısıtmasına izin ver.\" Kutuyu uzatırken bir ısırık daha.\n",
        "SS2_ACHIEVEMENT_BLOODTESTER_NAME": "Medic!",
        "SS2_ACHIEVEMENT_NEMCOMMANDO_GRANDMASTERY_DESC": "As Nemesis Commando, beat the game or obliterate on Typhoon.",
        "SS2_CHIRR_HEAL_DESCRIPTION": "Kendini ve yakındaki dostlarını toplam canlarının <style=cIsHealing>15%</style> kadarını iyileştir ve <style=cIsHealth>20%</style> kadarını ise zamanla iyileştir.",
        "SS2_NEMCAPTAIN_NAME": "Düşman Kaptan",
        "SS2_DIFFICULTY_ARMAGEDDON1_NAME": "Armagedon +1",
        "SS2_ITEM_DETRITIVETREMATODE_DESC": "Kritik sağlığa sahip düşmanlar <style=cIsDamage>zamanla hasar veren</style> <style=cIsDamage>100%</style> <style=cStack>(birikim başına+100%)</style> kadar hasar alır.",
        "SS2_ITEM_DEBUFFMISSILES_DESC": "Bir düşmandaki her <style=cIsDamage>debuff</style> için, <style=cIsDamage>%400</style> TOPLAM hasarda bir boşluk kıymığı ateşleme şansı olarak <style=cIsDamage>%3<style=cStack>(+%1 birikim başına)</style></style> kazan.",
        "SS2_NEMCOMMANDO_PRIMARY_BLADE_NAME": "Fasıla Kılıcı"
    }
