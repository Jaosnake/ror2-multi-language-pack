        "ROB_HUNK_PLAGAS_SAMPLE_DESC": "A Plagas sample.",
        "ROB_HUNK_ITEM_EFFECT_TITLE": "Bonus Effect",
        "ROB_HUNK_ITEM_EFFECT_BACKUPMAG": "Gain <color=#00FF66>Fake Ammo</color> after a successful reload.",
        "ROB_HUNK_ITEM_EFFECT_BANDOLIER": "Ammo packs reload your magazine with <color=#00FF66>Fake Ammo</color>.",
        "ROB_HUNK_ITEM_EFFECT_ALIENHEAD": "Gain <style=cIsUtility>more ammo</style> upon collecting any.",
        "ROB_HUNK_ITEM_EFFECT_BRAINSTALKS": "While active, firing your weapon <style=cIsUtility>does not consume ammo</style>.",
        "ROB_HUNK_ITEM_EFFECT_LYSATECELL": "Gain <color=#00FF66>Fake Ammo</color> upon equipping a weapon.",
        "ROB_HUNK_ITEM_EFFECT_PURITY": "Doubles the <style=cIsUtility>magazine size</style>. Ammo consumption does not change.",
        "ROB_HUNK_ITEM_EFFECT_LUMINOUSSHOT": "Gain a stack after aiming for <style=cIsUtility>1 second</style>. <style=cIsHealth>Loses all stacks upon firing or stopping aim.</style>",
        "ACHIEVEMENT_ROB_HUNK_COMPLETION_UNLOCKABLE_ACHIEVEMENT_ID_NAME": "HUNK: Reaper",
        "ACHIEVEMENT_ROB_HUNK_COMPLETION_UNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "As HUNK, beat the game or obliterate. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_MONSOON_UNLOCKABLE_ACHIEVEMENT_ID_NAME": "HUNK: Mastery",
        "ACHIEVEMENT_ROB_HUNK_MONSOON_UNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "As HUNK, beat the game or obliterate on Monsoon. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_TYPHOON_UNLOCKABLE_ACHIEVEMENT_ID_NAME": "HUNK: Grand Mastery",
        "ACHIEVEMENT_ROB_HUNK_TYPHOON_UNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "As HUNK, beat the game or obliterate on Typhoon or Eclipse.\n<color=#8888>(Counts any Typhoon difficulty or higher)</color> <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_SUPPORTER_ACHIEVEMENT_ID_NAME": "HUNK: Early Supporter",
        "ACHIEVEMENT_ROB_HUNK_SUPPORTER_ACHIEVEMENT_ID_DESCRIPTION": "Play as HUNK before the official release. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_LIGHTWEIGHT_ACHIEVEMENT_ID_NAME": "HUNK: Minimalist",
        "ACHIEVEMENT_ROB_HUNK_LIGHTWEIGHT_ACHIEVEMENT_ID_DESCRIPTION": "As HUNK, complete Stage 1 without items.\n<color=#8888>(Weapons and tools do not count against you)</color> <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_GUERRILLA_ACHIEVEMENT_ID_NAME": "HUNK: Locked and Loaded",
        "ACHIEVEMENT_ROB_HUNK_GUERRILLA_ACHIEVEMENT_ID_DESCRIPTION": "As HUNK, obtain a full arsenal. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_ROOKIE_ACHIEVEMENT_ID_NAME": "HUNK: First Day on the Job",
        "ACHIEVEMENT_ROB_HUNK_ROOKIE_ACHIEVEMENT_ID_DESCRIPTION": "As HUNK, obtain a new weapon. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_SWAT_ACHIEVEMENT_ID_NAME": "HUNK: Peacekeeper",
        "ACHIEVEMENT_ROB_HUNK_SWAT_ACHIEVEMENT_ID_DESCRIPTION": "As HUNK, fully upgrade the MUP. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_CQC_ACHIEVEMENT_ID_NAME": "HUNK: CQC (Close Quarters Combat)",
        "ACHIEVEMENT_ROB_HUNK_CQC_ACHIEVEMENT_ID_DESCRIPTION": "As HUNK, perform 10 successful counterattacks in one Stage. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_INFINITEKNIFE_ACHIEVEMENT_ID_NAME": "HUNK: Ace of Spades",
        "ACHIEVEMENT_ROB_HUNK_INFINITEKNIFE_ACHIEVEMENT_ID_DESCRIPTION": "As HUNK, carry two Spades Keycards at the same time. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_WESKERKNIFE_UNLOCKABLE_ACHIEVEMENT_ID_NAME": "HUNK: Firearm Enthusiast",
        "ACHIEVEMENT_ROB_HUNK_WESKERKNIFE_UNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "As HUNK, upgrade a weapon with a new accessory. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_MACHETE_UNLOCKABLE_ACHIEVEMENT_ID_NAME": "HUNK: Don't Need No Gun",
        "ACHIEVEMENT_ROB_HUNK_MACHETE_UNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "As HUNK, complete a Stage without firing any weapon. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_RE4KNIFE_ACHIEVEMENT_ID_NAME": "HUNK: The Road Ahead",
        "ACHIEVEMENT_ROB_HUNK_RE4KNIFE_ACHIEVEMENT_ID_DESCRIPTION": "As HUNK, reach Stage 6. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_HOTDOGGER_ACHIEVEMENT_ID_NAME": "HUNK: Basic Chemistry",
        "ACHIEVEMENT_ROB_HUNK_HOTDOGGER_ACHIEVEMENT_ID_DESCRIPTION": "As HUNK, obtain the Chemical Flamethrower. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_STUNROD_ACHIEVEMENT_ID_NAME": "HUNK: Three-for-One Offer",
        "ACHIEVEMENT_ROB_HUNK_STUNROD_ACHIEVEMENT_ID_DESCRIPTION": "As HUNK, obtain the Spark Shot. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_SSG_ACHIEVEMENT_ID_NAME": "HUNK: Dominator",
        "ACHIEVEMENT_ROB_HUNK_SSG_ACHIEVEMENT_ID_DESCRIPTION": "As HUNK, obtain the SSG. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_FLAMER_ACHIEVEMENT_ID_NAME": "HUNK: Pyromaniac",
        "ACHIEVEMENT_ROB_HUNK_FLAMER_ACHIEVEMENT_ID_DESCRIPTION": "As HUNK, fully upgrade the Chemical Flamethrower. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_SURVIVALKIT_ACHIEVEMENT_ID_NAME": "HUNK: No Luck At All",
        "ACHIEVEMENT_ROB_HUNK_SURVIVALKIT_ACHIEVEMENT_ID_DESCRIPTION": "As HUNK, run out of ammo on Commencement. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_JUMPPACK_ACHIEVEMENT_ID_NAME": "HUNK: Nowhere to Go But Up",
        "ACHIEVEMENT_ROB_HUNK_JUMPPACK_ACHIEVEMENT_ID_DESCRIPTION": "As HUNK, become a victim of a parachuting accident. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_NEMESIS_BODY_NAME": "Nemesis T-Type",
        "ROB_NEMESIS_BODY_DESCRIPTION": "The Nemesis T-Type is an unstoppable bioweapon built to withstand any amount of punishment and neutralize its targets with ease.<color=#CCD3E0>\n\n< ! > Jumps can be charged for greater distance.\n\n< ! > Consuming enemies leaves you vulnerable, so find a safe place before doing so.\n\n< ! > Biomass increases your damage when full. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_NEMESIS_BODY_SUBTITLE": "Unstoppable Bioweapon",
        "ROB_NEMESIS_BODY_OUTRO_FLAVOR": "..and so he departed, all good.",
        "ROB_NEMESIS_BODY_OUTRO_FAILURE": "..and so he vanished, human unit now neutralized.",
        "ROB_NEMESIS_BODY_DEFAULT_SKIN_NAME": "Default",
        "ROB_NEMESIS_BODY_CLASSIC_SKIN_NAME": "Classic",
        "ROB_NEMESIS_BODY_VENOM_SKIN_NAME": "Symbiote",
        "ROB_NEMESIS_BODY_SUPER_SKIN_NAME": "<color=#FFFF00>Early Supporter</color>",
        "ROB_NEMESIS_BODY_MAHORAGA_SKIN_NAME": "Big Raga The Opp Stoppa",
        "ROB_NEMESIS_BODY_MINOS_SKIN_NAME": "King of Men",
        "ROB_NEMESIS_BODY_PASSIVE_NAME": "Supreme Life Form",
        "ROB_NEMESIS_BODY_PASSIVE_DESCRIPTION": "<style=cIsDamage>Dealing damage</style> stores <style=cIsHealth>Biomass</style>, increasing your <style=cIsDamage>damage</style> when full. Jumps can be <style=cIsDamage>charged</style> for <style=cIsUtility>powerful leaps</style>. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_NEMESIS_BODY_PASSIVE2_NAME": "Biological Armament",
        "ROB_NEMESIS_BODY_PASSIVE2_DESCRIPTION": "The Nemesis T-Type can <style=cIsHealth>mutate</style> by consuming <style=cIsDamage>persons of interest</style>, gaining <style=cIsDamage>new and improved abilities</style>. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_NEMESIS_BODY_PASSIVE22_NAME": "Muscle Mass Increase",
        "ROB_NEMESIS_BODY_PASSIVE22_DESCRIPTION": "<style=cIsUtility>Melee attacks</style> deal <style=cIsDamage>20%</style> more damage, <style=isHealth>BUT allies may take damage</style>. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_NEMESIS_BODY_MELEE_NAME": "Brutal Aggression",
        "ROB_NEMESIS_BODY_MELEE_DESCRIPTION": "Punch for <style=cIsDamage>350% damage</style>. Use while <style=cIsUtility>stationary</style> to stomp for <style=cIsDamage>800% damage</style>. Use while <style=cIsUtility>running</style> to shoulder bash for <style=cIsDamage>600% damage</style>. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_NEMESIS_BODY_GRAB_NAME": "Deadly Reach",
        "ROB_NEMESIS_BODY_GRAB_DESCRIPTION": "Grab an enemy. Use Primary to consume and heal 10% max health, or Secondary to charge a throw of up to 2,400% damage. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_NEMESIS_BODY_DASH_NAME": "Biohazard Rush",
        "ROB_NEMESIS_BODY_DASH_DESCRIPTION": "Use while <style=cIsUtility>in the air</style> to air dash <style=cIsDamage>once</style>. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_NEMESIS_BODY_ULTIMATE_NAME": "Critical Mass",
        "ROB_NEMESIS_BODY_ULTIMATE_DESCRIPTION": "Hold to slowly consume <style=cIsHealth>Biomass</style>, restoring up to <style=cIsHealing>100% max health</style>. <i>Backported from pt-BR. Original mod by rob. Translated by: Jaosnake</i>",
        "ROB_NEMESIS_ITEM_EFFECT_TITLE": "Bonus Effect",
        "ROB_NEMESIS_ITEM_EFFECT_BANDOLIER": "Ammo packs restore <style=cIsHealth>10% Biomass</style>.",
        "ROB_NEMESIS_ITEM_EFFECT_ALIENHEAD": "Increases <style=cIsHealth>Biomass</style> gained from <style=cIsDamage>consuming</style> enemies.",
        "ROB_NEMESIS_ITEM_EFFECT_BRAINSTALKS": "While active, <style=cIsHealth>Biomass</style> is <style=cIsUtility>unlimited</style>.",
        "ROB_NEMESIS_ITEM_EFFECT_PURITY": "Increases <style=cIsHealth>Biomass</style> gained <style=cIsDamage>on hit</style>.",
        "ROB_ARTIFACT_PURSUER_NAME": "Artifact of the Pursuer",
        "ROB_ARTIFACT_PURSUER_DESC": "Players start the run with a S.T.A.R.S. Badge.",
        "ROB_ARTIFACT_CONTAMINATION_NAME": "Artifact of Contamination",
        "ROB_ARTIFACT_CONTAMINATION_DESC": "Each player receives a random Virus event each Stage.",
        "ROB_ARTIFACT_STRIKETEAM_NAME": "Artifact of the Strike Team",
        "ROB_ARTIFACT_STRIKETEAM_DESC": "Players will occasionally have Strike Teams sent to neutralize them.",
        "ROB_HUNK_GHOST_UNLOCKABLE_NAME": "",
        "ROB_HUNK_GHOST_ACHIEVEMENT_NAME": "HUNK: The Forgotten Soldier",
        "ROB_HUNK_GHOST_ACHIEVEMENT_DESC": "",
        "ROB_HUNK_CONTAMINATION_UNLOCKABLE_NAME": "Zero Zone",
        "ROB_HUNK_CONTAMINATION_ACHIEVEMENT_NAME": "Zero Zone",
        "ROB_HUNK_CONTAMINATION_ACHIEVEMENT_DESC": "Deliver a virus sample to the Umbrella Corporation.",
        "ROB_HUNK_PURSUER_UNLOCKABLE_NAME": "Nemesis Felled",
        "ROB_HUNK_PURSUER_ACHIEVEMENT_NAME": "Nemesis Felled",
        "ROB_HUNK_PURSUER_ACHIEVEMENT_DESC": "Defeat the Nemesis T-Type.",
        "ROB_HUNK_NEMESIS_UNLOCKABLE_NAME": "A Dream of Armageddon",
        "ROB_HUNK_NEMESIS_ACHIEVEMENT_NAME": "A Dream of Armageddon",
        "ROB_HUNK_NEMESIS_ACHIEVEMENT_DESC": "Kill the Nemesis T-Type.",
