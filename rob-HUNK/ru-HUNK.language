        "ROB_HUNK_C_VIRUS_DESC": "Образец C-Вируса.",
        "ROB_HUNK_G_VIRUSFINAL_NAME": "Финальный G-Вирус",
        "ROB_HUNK_PLAGAS_NAME": "Plagas",
        "ROB_HUNK_PLAGAS_DESC": "Образец Plagas.",
        "ROB_HUNK_URO_SAMPLE_NAME": "Образец Uroboros",
        "ROB_HUNK_URO_SAMPLE_DESC": "Образец Uroboros.",
        "ROB_HUNK_G_VIRUS_SAMPLE_NAME": "Образец G-Вируса",
        "ROB_HUNK_G_VIRUS_SAMPLE_DESC": "Образец G-Вируса.",
        "ROB_HUNK_T_VIRUS_SAMPLE_NAME": "Образец T-Вируса",
        "ROB_HUNK_T_VIRUS_SAMPLE_DESC": "Образец T-Вируса.",
        "ROB_HUNK_C_VIRUS_SAMPLE_NAME": "Образец C-Вируса",
        "ROB_HUNK_C_VIRUS_SAMPLE_DESC": "Образец C-Вируса.",
        "ROB_HUNK_PLAGAS_SAMPLE_NAME": "Образец Plagas",
        "ROB_HUNK_PLAGAS_SAMPLE_DESC": "Образец Plagas.",
        "ROB_HUNK_ITEM_EFFECT_TITLE": "Бонусный Эффект",
        "ROB_HUNK_ITEM_EFFECT_BACKUPMAG": "Получите <color=#00FF66>Фальшивые Патроны</color> после успешной перезарядки.",
        "ROB_HUNK_ITEM_EFFECT_BANDOLIER": "Пачки патронов перезаряжают магазин <color=#00FF66>Фальшивыми Патронами</color>.",
        "ROB_HUNK_ITEM_EFFECT_ALIENHEAD": "Получайте <style=cIsUtility>больше патронов</style> при сборе любых.",
        "ROB_HUNK_ITEM_EFFECT_BRAINSTALKS": "Пока активно, стрельба из оружия <style=cIsUtility>не расходует патроны</style>.",
        "ROB_HUNK_ITEM_EFFECT_LYSATECELL": "Получите <color=#00FF66>Фальшивые Патроны</color> при экипировке оружия.",
        "ROB_HUNK_ITEM_EFFECT_PURITY": "Удваивает <style=cIsUtility>размер магазина</style>. Расход патронов не меняется.",
        "ROB_HUNK_ITEM_EFFECT_LUMINOUSSHOT": "Получите стак после прицеливания в течение <style=cIsUtility>1 секунды</style>. <style=cIsHealth>Теряет все стаки при выстреле или прекращении прицеливания.</style>",
        "ACHIEVEMENT_ROB_HUNK_COMPLETION_UNLOCKABLE_ACHIEVEMENT_ID_NAME": "HUNK: Жнец",
        "ACHIEVEMENT_ROB_HUNK_COMPLETION_UNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "Будучи HUNK, пройдите игру или obliterate. <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_MONSOON_UNLOCKABLE_ACHIEVEMENT_ID_NAME": "HUNK: Мастерство",
        "ACHIEVEMENT_ROB_HUNK_MONSOON_UNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "Будучи HUNK, пройдите игру или obliterate на Монсуне. <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_TYPHOON_UNLOCKABLE_ACHIEVEMENT_ID_NAME": "HUNK: Великое Мастерство",
        "ACHIEVEMENT_ROB_HUNK_TYPHOON_UNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "Будучи HUNK, пройдите игру или obliterate на Тайфуне или Затмении.\n<color=#8888>(Считается любая сложность Тайфун или выше)</color> <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_SUPPORTER_ACHIEVEMENT_ID_NAME": "HUNK: Early Supporter",
        "ACHIEVEMENT_ROB_HUNK_SUPPORTER_ACHIEVEMENT_ID_DESCRIPTION": "Играйте за HUNK до официального релиза. <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_LIGHTWEIGHT_ACHIEVEMENT_ID_NAME": "HUNK: Минималист",
        "ACHIEVEMENT_ROB_HUNK_LIGHTWEIGHT_ACHIEVEMENT_ID_DESCRIPTION": "Будучи HUNK, завершите Этап 1 без предметов.\n<color=#8888>(Оружие и инструменты не считаются против вас)</color> <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_GUERRILLA_ACHIEVEMENT_ID_NAME": "HUNK: Заряжен и Наготове",
        "ACHIEVEMENT_ROB_HUNK_GUERRILLA_ACHIEVEMENT_ID_DESCRIPTION": "Будучи HUNK, получите полный арсенал. <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_ROOKIE_ACHIEVEMENT_ID_NAME": "HUNK: Первый День на Работе",
        "ACHIEVEMENT_ROB_HUNK_ROOKIE_ACHIEVEMENT_ID_DESCRIPTION": "Будучи HUNK, получите новое оружие. <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_SWAT_ACHIEVEMENT_ID_NAME": "HUNK: Миротворец",
        "ACHIEVEMENT_ROB_HUNK_SWAT_ACHIEVEMENT_ID_DESCRIPTION": "Будучи HUNK, полностью улучшите MUP. <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_CQC_ACHIEVEMENT_ID_NAME": "HUNK: CQC (Ближний Бой)",
        "ACHIEVEMENT_ROB_HUNK_CQC_ACHIEVEMENT_ID_DESCRIPTION": "Будучи HUNK, выполните 10 успешных контратак за один Этап. <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_INFINITEKNIFE_ACHIEVEMENT_ID_NAME": "HUNK: Туз Пик",
        "ACHIEVEMENT_ROB_HUNK_INFINITEKNIFE_ACHIEVEMENT_ID_DESCRIPTION": "Будучи HUNK, носите две Keycard Пик одновременно. <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_WESKERKNIFE_UNLOCKABLE_ACHIEVEMENT_ID_NAME": "HUNK: Энтузиаст Огнестрела",
        "ACHIEVEMENT_ROB_HUNK_WESKERKNIFE_UNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "Будучи HUNK, улучшите оружие новым аксессуаром. <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_MACHETE_UNLOCKABLE_ACHIEVEMENT_ID_NAME": "HUNK: Не Нужно Оружия",
        "ACHIEVEMENT_ROB_HUNK_MACHETE_UNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "Будучи HUNK, завершите Этап, не стреляя из оружия. <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_RE4KNIFE_ACHIEVEMENT_ID_NAME": "HUNK: Дорога Впереди",
        "ACHIEVEMENT_ROB_HUNK_RE4KNIFE_ACHIEVEMENT_ID_DESCRIPTION": "Будучи HUNK, достигните Этапа 6. <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_HOTDOGGER_ACHIEVEMENT_ID_NAME": "HUNK: Основная Химия",
        "ACHIEVEMENT_ROB_HUNK_HOTDOGGER_ACHIEVEMENT_ID_DESCRIPTION": "Будучи HUNK, получите Химический Огнемёт. <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_STUNROD_ACHIEVEMENT_ID_NAME": "HUNK: Предложение Три по Цене Одного",
        "ACHIEVEMENT_ROB_HUNK_STUNROD_ACHIEVEMENT_ID_DESCRIPTION": "Будучи HUNK, получите Spark Shot. <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_SSG_ACHIEVEMENT_ID_NAME": "HUNK: Доминатор",
        "ACHIEVEMENT_ROB_HUNK_SSG_ACHIEVEMENT_ID_DESCRIPTION": "Будучи HUNK, получите SSG. <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_FLAMER_ACHIEVEMENT_ID_NAME": "HUNK: Пироманы",
        "ACHIEVEMENT_ROB_HUNK_FLAMER_ACHIEVEMENT_ID_DESCRIPTION": "Будучи HUNK, полностью улучшите Химический Огнемёт. <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_SURVIVALKIT_ACHIEVEMENT_ID_NAME": "HUNK: Никакой Удачи",
        "ACHIEVEMENT_ROB_HUNK_SURVIVALKIT_ACHIEVEMENT_ID_DESCRIPTION": "Будучи HUNK, останьтесь без патронов на Commencement. <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_JUMPPACK_ACHIEVEMENT_ID_NAME": "HUNK: Некуда Идти, Кроме Как Вверх",
        "ACHIEVEMENT_ROB_HUNK_JUMPPACK_ACHIEVEMENT_ID_DESCRIPTION": "Будучи HUNK, станьте жертвой несчастного случая с парашютом. <i>Translated by: Jaosnake</i>",
        "ROB_NEMESIS_BODY_NAME": "Nemesis T-Type",
        "ROB_NEMESIS_BODY_DESCRIPTION": "Nemesis T-Type - это неостановимое биологическое оружие, созданное, чтобы выдерживать любое количество наказаний и нейтрализовать цели с лёгкостью.<color=#CCD3E0>\n\n< ! > Прыжки можно заряжать для большей дальности.\n\n< ! > Поглощение врагов оставляет вас уязвимым, поэтому найдите безопасное место перед этим.\n\n< ! > Биомасса увеличивает ваш урон, когда полна. <i>Translated by: Jaosnake</i>",
        "ROB_NEMESIS_BODY_SUBTITLE": "Неостановимое Биологическое Оружие",
        "ROB_NEMESIS_BODY_OUTRO_FLAVOR": "..и затем он ушёл, всё в порядке.",
        "ROB_NEMESIS_BODY_OUTRO_FAILURE": "..и затем он исчез, человеческая единица теперь нейтрализована.",
        "ROB_NEMESIS_BODY_DEFAULT_SKIN_NAME": "Обычный",
        "ROB_NEMESIS_BODY_CLASSIC_SKIN_NAME": "Классический",
        "ROB_NEMESIS_BODY_VENOM_SKIN_NAME": "Симбиот",
        "ROB_NEMESIS_BODY_SUPER_SKIN_NAME": "<color=#FFFF00>Early Supporter</color>",
        "ROB_NEMESIS_BODY_MAHORAGA_SKIN_NAME": "Big Raga The Opp Stoppa",
        "ROB_NEMESIS_BODY_MINOS_SKIN_NAME": "King of Men",
        "ROB_NEMESIS_BODY_PASSIVE_NAME": "Высшая Форма Жизни",
        "ROB_NEMESIS_BODY_PASSIVE_DESCRIPTION": "<style=cIsDamage>Нанесение урона</style> накапливает <style=cIsHealth>Биомассу</style>, увеличивая ваш <style=cIsDamage>урон</style>, когда полна. Прыжки можно <style=cIsDamage>заряжать</style> для <style=cIsUtility>мощных прыжков</style>. <i>Translated by: Jaosnake</i>",
        "ROB_NEMESIS_BODY_PASSIVE2_NAME": "Биологическое Вооружение",
        "ROB_NEMESIS_BODY_PASSIVE2_DESCRIPTION": "Nemesis T-Type может <style=cIsHealth>мутировать</style>, поглощая <style=cIsDamage>лиц, представляющих интерес</style>, получая <style=cIsDamage>новые и улучшенные способности</style>. <i>Translated by: Jaosnake</i>",
        "ROB_NEMESIS_BODY_PASSIVE22_NAME": "Увеличение Мышечной Массы",
        "ROB_NEMESIS_BODY_PASSIVE22_DESCRIPTION": "<style=cIsUtility>Атаки ближнего боя</style> наносят <style=cIsDamage>20%</style> больше урона, <style=isHealth>НО союзники могут получить урон</style>. <i>Translated by: Jaosnake</i>",
        "ROB_NEMESIS_BODY_MELEE_NAME": "Жестокая Агрессия",
        "ROB_NEMESIS_BODY_MELEE_DESCRIPTION": "Удар на <style=cIsDamage>350% урона</style>. Используйте <style=cIsUtility>стоя на месте</style> для топота на <style=cIsDamage>800% урона</style>. Используйте <style=cIsUtility>бегом</style> для толчка плечом на <style=cIsDamage>600% урона</style>. <i>Translated by: Jaosnake</i>",
        "ROB_NEMESIS_BODY_GRAB_NAME": "Смертельная Хватка",
        "ROB_NEMESIS_BODY_GRAB_DESCRIPTION": "Схватите врага. Используйте Основное, чтобы поглотить и вылечить 10% макс. здоровья, или Вторичное, чтобы зарядить бросок до 2.400% урона. <i>Translated by: Jaosnake</i>",
        "ROB_NEMESIS_BODY_DASH_NAME": "Биоопасный Рывок",
        "ROB_NEMESIS_BODY_DASH_DESCRIPTION": "Используйте <style=cIsUtility>в воздухе</style> для рывка в воздухе <style=cIsDamage>один раз</style>. <i>Translated by: Jaosnake</i>",
        "ROB_NEMESIS_BODY_ULTIMATE_NAME": "Критическая Масса",
        "ROB_NEMESIS_BODY_ULTIMATE_DESCRIPTION": "Удерживайте, чтобы медленно поглощать <style=cIsHealth>Биомассу</style>, восстанавливая до <style=cIsHealing>100% макс. здоровья</style>. <i>Translated by: Jaosnake</i>",
        "ROB_NEMESIS_ITEM_EFFECT_TITLE": "Бонусный Эффект",
        "ROB_NEMESIS_ITEM_EFFECT_BANDOLIER": "Пачки патронов восстанавливают <style=cIsHealth>10% Биомассы</style>.",
        "ROB_NEMESIS_ITEM_EFFECT_ALIENHEAD": "Увеличивает <style=cIsHealth>Биомассу</style>, получаемую при <style=cIsDamage>поглощении</style> врагов.",
        "ROB_NEMESIS_ITEM_EFFECT_BRAINSTALKS": "Пока активно, <style=cIsHealth>Биомасса</style> <style=cIsUtility>неограничена</style>.",
        "ROB_NEMESIS_ITEM_EFFECT_PURITY": "Увеличивает <style=cIsHealth>Биомассу</style>, получаемую <style=cIsDamage>при попадании</style>.",
        "ROB_ARTIFACT_PURSUER_NAME": "Артефакт Преследователя",
        "ROB_ARTIFACT_PURSUER_DESC": "Игроки начинают забег со Значком S.T.A.R.S.",
        "ROB_ARTIFACT_CONTAMINATION_NAME": "Артефакт Заражения",
