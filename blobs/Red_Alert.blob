		private static void TestNoisesTogether()
		{
			List<IEnumerator> testSubEnumerators;
			if (noises > 0)
			{
				testSubEnumerators = new List<IEnumerator>();
				loads.Add(loadSubEnumerators());
			}
			IEnumerator loadSubEnumerators()
			{
				for (int j = 1; j <= noises; j++)
				{
					testSubEnumerators.Add(assetBundle.LoadAssetCoroutine<Texture2D>("NOISE" + j, (Action<Texture2D>)delegate(Texture2D result)
					{
						testTextures.Add(result);
						Log.Warning(result);
					}));
				}
				for (int i = 0; i < testSubEnumerators.Count; i++)
				{
					while (testSubEnumerators[i].MoveNext())
					{
						yield return null;
					}
				}
			}
		}

		private static void TestNoisesAsyncAsset()
		{
			if (noises > 0)
			{
				List<AsyncAsset<Texture2D>> list = new List<AsyncAsset<Texture2D>>();
				for (int i = 1; i <= noises; i++)
				{
					list.Add(new AsyncAsset<Texture2D>(assetBundle, "NOISE" + i).AddCoroutine());
				}
			}
		}
	}
