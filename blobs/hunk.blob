		internal class Parasite
		{
			internal static Parasite instance;

			internal static CharacterSpawnCard characterSpawnCard;

			internal static GameObject characterPrefab;

			internal static GameObject characterMaster;

			public static Color characterColor = new Color(29f / 51f, 0f, 1f);

			public const string bodyName = "RobHunkParasiteBody";

			internal static ItemDisplayRuleSet itemDisplayRuleSet;

			internal static List<KeyAssetRuleGroup> itemDisplayRules;

			internal static string bodyNameToken;

			internal void CreateCharacter()
			{
				instance = this;
				characterPrefab = CreateBodyPrefab();
				characterMaster = CreateMaster(characterPrefab, "RobHunkParasiteSpadeMaster");
				characterMaster.AddComponent<KeycardHolder>().itemDef = Hunk.gVirusSample;
				CreateSpawnCards();
				Hook();
			}

			private static GameObject CreateBodyPrefab()
			{
				//IL_0010: Unknown result type (might be due to invalid IL or missing references)
				//IL_0015: Unknown result type (might be due to invalid IL or missing references)
				//IL_0080: Unknown result type (might be due to invalid IL or missing references)
				//IL_0085: Unknown result type (might be due to invalid IL or missing references)
				bodyNameToken = "ROB_HUNK_PARASITE_BODY_NAME";
				GameObject val = PrefabAPI.InstantiateClone(Addressables.LoadAssetAsync<GameObject>((object)"RoR2/DLC1/EliteVoid/VoidInfestorBody.prefab").WaitForCompletion(), "RobHunkParasiteBody", true);
				val.GetComponent<CharacterBody>().baseNameToken = bodyNameToken;
				Object.DestroyImmediate((Object)(object)val.GetComponent<ExpansionRequirementComponent>());
				Object.DestroyImmediate((Object)(object)val.GetComponent<DeathRewards>());
				val.AddComponent<ParasiteController>();
				val.GetComponent<KinematicCharacterMotor>().playerCharacter = true;
				Prefabs.bodyPrefabs.Add(val);
				val.GetComponent<CharacterDeathBehavior>().deathState = new SerializableEntityStateType(typeof(HunkMod.SkillStates.Parasite.Death));
				ModelSkinController componentInChildren = val.GetComponentInChildren<ModelSkinController>();
				if (Object.op_Implicit((Object)(object)componentInChildren))
				{
					SkinDef val2 = Object.Instantiate<SkinDef>(componentInChildren.skins[0]);
					componentInChildren.skins = (SkinDef[])(object)new SkinDef[1] { val2 };
					componentInChildren.prefabInstantiationDatas = (AsyncPrefabInstantiationData[])(object)new AsyncPrefabInstantiationData[0];
				}
				CreateSkills(val);
				return val;
			}

			private static void SetupHurtboxes(GameObject bodyPrefab)
			{
			}

			private static GameObject CreateMaster(GameObject bodyPrefab, string masterName)
			{
				//IL_0006: Unknown result type (might be due to invalid IL or missing references)
				//IL_000b: Unknown result type (might be due to invalid IL or missing references)
				GameObject val = PrefabAPI.InstantiateClone(Addressables.LoadAssetAsync<GameObject>((object)"RoR2/DLC1/EliteVoid/VoidInfestorMaster.prefab").WaitForCompletion(), masterName, true);
				val.GetComponent<CharacterMaster>().bodyPrefab = bodyPrefab;
				Object.Destroy((Object)(object)val.GetComponent<GivePickupsOnStart>());
				Prefabs.masterPrefabs.Add(val);
				return val;
			}

			private static void CreateSkills(GameObject prefab)
			{
				//IL_007d: Unknown result type (might be due to invalid IL or missing references)
				//IL_0082: Unknown result type (might be due to invalid IL or missing references)
				//IL_00c2: Unknown result type (might be due to invalid IL or missing references)
				string text = "ROB";
				SkillLocator component = prefab.GetComponent<SkillLocator>();
				Skills.CreateSkillFamilies(prefab);
				component.passiveSkill.enabled = false;
				SkillDefInfo skillDefInfo = new SkillDefInfo();
				skillDefInfo.skillName = text + "_HUNK_BODY_SECONDARY_AIM_NAME";
				skillDefInfo.skillNameToken = text + "_HUNK_BODY_SECONDARY_AIM_NAME";
				skillDefInfo.skillDescriptionToken = text + "_HUNK_BODY_SECONDARY_AIM_DESCRIPTION";
				skillDefInfo.skillIcon = HunkAssets.mainAssetBundle.LoadAsset<Sprite>("texAimIcon");
				skillDefInfo.activationState = new SerializableEntityStateType(typeof(Infest));
				skillDefInfo.activationStateMachineName = "Body";
				skillDefInfo.baseMaxStock = 1;
				skillDefInfo.baseRechargeInterval = 5f;
				skillDefInfo.beginSkillCooldownOnSkillEnd = false;
				skillDefInfo.canceledFromSprinting = false;
				skillDefInfo.forceSprintDuringState = false;
				skillDefInfo.fullRestockOnAssign = true;
				skillDefInfo.interruptPriority = (InterruptPriority)0;
				skillDefInfo.resetCooldownTimerOnUse = false;
				skillDefInfo.isCombatSkill = true;
				skillDefInfo.mustKeyPress = false;
				skillDefInfo.cancelSprintingOnActivation = true;
				skillDefInfo.rechargeStock = 1;
				skillDefInfo.requiredStock = 1;
				skillDefInfo.stockToConsume = 1;
				SkillDef val = Skills.CreateSkillDef(skillDefInfo);
				Skills.AddPrimarySkills(prefab, val);
				Skills.AddSecondarySkills(prefab, val);
				Skills.AddUtilitySkills(prefab, val);
				Skills.AddSpecialSkills(prefab, val);
			}

			private static void CreateSpawnCards()
			{
				//IL_003b: Unknown result type (might be due to invalid IL or missing references)
				//IL_0046: Unknown result type (might be due to invalid IL or missing references)
				//IL_0051: Unknown result type (might be due to invalid IL or missing references)
				//IL_005c: Unknown result type (might be due to invalid IL or missing references)
				//IL_007c: Unknown result type (might be due to invalid IL or missing references)
				//IL_0086: Expected O, but got Unknown
				characterSpawnCard = ScriptableObject.CreateInstance<CharacterSpawnCard>();
				((Object)characterSpawnCard).name = "cscHunkParasite";
				((SpawnCard)characterSpawnCard).prefab = characterMaster;
				((SpawnCard)characterSpawnCard).sendOverNetwork = true;
				((SpawnCard)characterSpawnCard).hullSize = (HullClassification)0;
				((SpawnCard)characterSpawnCard).nodeGraphType = (GraphType)0;
				((SpawnCard)characterSpawnCard).requiredFlags = (NodeFlags)0;
				((SpawnCard)characterSpawnCard).forbiddenFlags = (NodeFlags)0;
				((SpawnCard)characterSpawnCard).directorCreditCost = 0;
				((SpawnCard)characterSpawnCard).occupyPosition = false;
				characterSpawnCard.loadout = new SerializableLoadout();
				characterSpawnCard.noElites = true;
				characterSpawnCard.forbiddenAsBoss = true;
			}

			private static void CreateSkins(GameObject prefab)
			{
				GameObject gameObject = ((Component)prefab.GetComponentInChildren<ModelLocator>().modelTransform).gameObject;
				CharacterModel component = gameObject.GetComponent<CharacterModel>();
				ModelSkinController val = gameObject.AddComponent<ModelSkinController>();
				ChildLocator component2 = gameObject.GetComponent<ChildLocator>();
				SkinnedMeshRenderer mainSkinnedMeshRenderer = component.mainSkinnedMeshRenderer;
				RendererInfo[] baseRendererInfos = component.baseRendererInfos;
				List<SkinDef> list = new List<SkinDef>();
				SkinDef item = Skins.CreateSkinDef("ROB_HUNK_BODY_DEFAULT_SKIN_NAME", HunkAssets.mainAssetBundle.LoadAsset<Sprite>("texMainSkin"), baseRendererInfos, mainSkinnedMeshRenderer, gameObject);
				list.Add(item);
				val.skins = list.ToArray();
			}

			private static void InitializeItemDisplays(GameObject prefab)
			{
				CharacterModel componentInChildren = prefab.GetComponentInChildren<CharacterModel>();
				if ((Object)(object)itemDisplayRuleSet == (Object)null)
				{
					itemDisplayRuleSet = ScriptableObject.CreateInstance<ItemDisplayRuleSet>();
					((Object)itemDisplayRuleSet).name = "idrsRobHunkParasiteBody";
				}
				componentInChildren.itemDisplayRuleSet = itemDisplayRuleSet;
				componentInChildren.itemDisplayRuleSet.keyAssetRuleGroups = Resources.Load<GameObject>("Prefabs/CharacterBodies/CommandoBody").GetComponentInChildren<CharacterModel>().itemDisplayRuleSet.keyAssetRuleGroups;
				itemDisplayRules = itemDisplayRuleSet.keyAssetRuleGroups.ToList();
			}

			internal static void ReplaceItemDisplay(Object keyAsset, ItemDisplayRule[] newDisplayRules)
			{
				KeyAssetRuleGroup[] array = itemDisplayRules.ToArray();
				for (int i = 0; i < array.Length; i++)
				{
					if (array[i].keyAsset == keyAsset)
					{
						array[i].displayRuleGroup.rules = newDisplayRules;
					}
				}
				itemDisplayRules = array.ToList();
			}

			private static RendererInfo[] SkinRendererInfos(RendererInfo[] defaultRenderers, Material[] materials)
			{
				RendererInfo[] array = (RendererInfo[])(object)new RendererInfo[defaultRenderers.Length];
				defaultRenderers.CopyTo(array, 0);
				array[0].defaultMaterial = materials[0];
				return array;
			}

			private static void Hook()
			{
			}
		}
	}
	namespace HunkMod.Modules.Components
	{
		public class AmmoDisplay : MonoBehaviour
		{
			public HUD targetHUD;

			public LanguageTextMeshController targetText;

			private HunkController hunk;

			private float alpha;

			private int totalAmmo => hunk.weaponTracker.weaponData[hunk.weaponTracker.equippedIndex].totalAmmo;

			private void FixedUpdate()
			{
				//IL_0240: Unknown result type (might be due to invalid IL or missing references)
				//IL_0245: Unknown result type (might be due to invalid IL or missing references)
				//IL_02bd: Unknown result type (might be due to invalid IL or missing references)
				if (Object.op_Implicit((Object)(object)targetHUD) && Object.op_Implicit((Object)(object)targetHUD.targetBodyObject) && !Object.op_Implicit((Object)(object)hunk))
				{
					hunk = targetHUD.targetBodyObject.GetComponent<HunkController>();
				}
				if (!Object.op_Implicit((Object)(object)targetText))
				{
					return;
				}
				if (Object.op_Implicit((Object)(object)hunk))
				{
					if ((float)hunk.maxAmmo <= 0f)
					{
						targetText.token = "";
						return;
					}
					if ((float)hunk.maxAmmo >= 999f || Object.op_Implicit((Object)(object)hunk.heldGrenadeDef))
					{
						targetText.token = "";
						return;
					}
					if ((float)hunk.ammo <= 0f)
					{
						if (totalAmmo > 0)
						{
							targetText.token = "<color=#C80000>0 / " + totalAmmo + "</color>";
						}
						else
						{
							targetText.token = "<color=#C80000>0 / 0</color>";
						}
					}
					else if (hunk.ammo > hunk.weaponTracker.weaponData[hunk.weaponTracker.equippedIndex].currentAmmo)
					{
						targetText.token = "<color=#00FF66>" + Mathf.CeilToInt((float)hunk.ammo) + "</color> / " + Mathf.CeilToInt((float)totalAmmo);
					}
					else
					{
						targetText.token = Mathf.CeilToInt((float)hunk.ammo) + " / " + Mathf.CeilToInt((float)totalAmmo);
					}
					Color color = ((Graphic)targetText.textMeshPro).color;
					if (hunk.ammoKillTimer <= 0f)
					{
						alpha -= 4f * Time.fixedDeltaTime;
					}
					else
					{
						alpha += 4f * Time.fixedDeltaTime;
					}
					alpha = Mathf.Clamp01(alpha);
					color.a = alpha;
					((Graphic)targetText.textMeshPro).color = color;
				}
				else
				{
					targetText.token = "";
				}
			}
		}
		public class AmmoDisplay2 : MonoBehaviour
		{
			public bool useDesiredAlpha = true;

			public TMP_FontAsset fontOverride;

			public HUD targetHUD;

			public TextMeshProUGUI currentText;

			public TextMeshProUGUI totalText;

			public TextMeshProUGUI bonusText;

			private Image divider;

			private Image mainPanel;

			private HunkController hunk;

			private float desiredAlpha;

			private float alpha;

			private GameObject infinity;

			private GameObject infinity2;

			private int totalAmmo => hunk.weaponTracker.weaponData[hunk.weaponTracker.equippedIndex].totalAmmo;

			private bool isInfinite => hunk.characterBody.HasBuff(Buffs.NoCooldowns) || hunk.mayhemMode;

			private void OnEnable()
			{
				desiredAlpha = Config.baseAmmoPanelOpacity.Value * 0.01f;
			}

			private void Start()
			{
				mainPanel = ((Component)this).GetComponent<Image>();
				divider = ((Component)((Component)this).transform.Find("Divider")).gameObject.GetComponent<Image>();
				infinity = ((Component)((Component)this).transform.Find("Infinity")).gameObject;
				infinity2 = ((Component)((Component)this).transform.Find("Infinity2")).gameObject;
				if (Object.op_Implicit((Object)(object)fontOverride))
				{
					((TMP_Text)currentText).font = fontOverride;
					((TMP_Text)totalText).font = fontOverride;
					((TMP_Text)bonusText).font = fontOverride;
				}
			}

			private void FixedUpdate()
			{
				//IL_009e: Unknown result type (might be due to invalid IL or missing references)
				//IL_00a3: Unknown result type (might be due to invalid IL or missing references)
				//IL_00fb: Unknown result type (might be due to invalid IL or missing references)
				if (Object.op_Implicit((Object)(object)targetHUD) && Object.op_Implicit((Object)(object)targetHUD.targetBodyObject) && !Object.op_Implicit((Object)(object)hunk))
				{
					hunk = targetHUD.targetBodyObject.GetComponent<HunkController>();
				}
				if (!Object.op_Implicit((Object)(object)currentText) || !Object.op_Implicit((Object)(object)totalText) || !Object.op_Implicit((Object)(object)hunk))
				{
					return;
				}
				if (isInfinite)
				{
					Color color = ((Graphic)mainPanel).color;
					alpha += 4f * Time.fixedDeltaTime;
					alpha = Mathf.Clamp01(alpha);
