			//IL_0121: Unknown result type (might be due to invalid IL or missing references)
			//IL_010f: Unknown result type (might be due to invalid IL or missing references)
			//IL_0114: Unknown result type (might be due to invalid IL or missing references)
			switch (((Component)body).GetComponent<LeeHyperrealPassive>().GetVFXPassive())
			{
			case LeeHyperrealPassive.VFXPassive.RED:
				return RED_PARTICLE.mainColor;
			case LeeHyperrealPassive.VFXPassive.ORANGE:
				return ORANGE_PARTICLE.mainColor;
			case LeeHyperrealPassive.VFXPassive.YELLOW:
				return YELLOW_PARTICLE.mainColor;
			case LeeHyperrealPassive.VFXPassive.GREEN:
				return GREEN_PARTICLE.mainColor;
			case LeeHyperrealPassive.VFXPassive.BLUE:
				return DEFAULT_PARTICLE.mainColor;
			case LeeHyperrealPassive.VFXPassive.LIGHTBLUE:
				return LIGHTBLUE_PARTICLE.mainColor;
			case LeeHyperrealPassive.VFXPassive.VIOLET:
				return VIOLET_PARTICLE.mainColor;
			case LeeHyperrealPassive.VFXPassive.PINK:
				return PINK_PARTICLE.mainColor;
			default:
			{
				uint skinIndex = body.skinIndex;
				if (LeeHyperreal.redVFXSkins.Contains((int)skinIndex))
				{
					return RED_PARTICLE.mainColor;
				}
				if (LeeHyperreal.orangeVFXSkins.Contains((int)skinIndex))
				{
					return ORANGE_PARTICLE.mainColor;
				}
				if (LeeHyperreal.lightBlueVFXSkins.Contains((int)skinIndex))
				{
					return LIGHTBLUE_PARTICLE.mainColor;
				}
				return DEFAULT_PARTICLE.mainColor;
			}
			}
		}

		public static GameObject RetrieveParticleEffectFromSkin(string particleName, CharacterBody body = null)
		{
			if (!particleDictionary.ContainsKey(particleName))
			{
				return null;
			}
			ParticleVariant particleVariant = particleDictionary[particleName];
			if (!Object.op_Implicit((Object)(object)body))
			{
				return particleVariant.colourVariants[DEFAULT_PARTICLE_VARIANT];
			}
			LeeHyperrealPassive.VFXPassive vFXPassive = ((Component)body).GetComponent<LeeHyperrealPassive>().GetVFXPassive();
			if (vFXPassive == LeeHyperrealPassive.VFXPassive.RANDOM)
			{
				Array values = Enum.GetValues(typeof(LeeHyperrealPassive.VFXPassive));
				Random random = new Random();
				LeeHyperrealPassive.VFXPassive vFXPassive2 = (LeeHyperrealPassive.VFXPassive)values.GetValue(random.Next(values.Length));
				vFXPassive = vFXPassive2;
			}
			switch (vFXPassive)
			{
			case LeeHyperrealPassive.VFXPassive.RED:
				return particleVariant.colourVariants[RED_PARTICLE.name];
			case LeeHyperrealPassive.VFXPassive.ORANGE:
				return particleVariant.colourVariants[ORANGE_PARTICLE.name];
			case LeeHyperrealPassive.VFXPassive.YELLOW:
				return particleVariant.colourVariants[YELLOW_PARTICLE.name];
			case LeeHyperrealPassive.VFXPassive.GREEN:
				return particleVariant.colourVariants[GREEN_PARTICLE.name];
			case LeeHyperrealPassive.VFXPassive.BLUE:
				return particleVariant.colourVariants[DEFAULT_PARTICLE_VARIANT];
			case LeeHyperrealPassive.VFXPassive.LIGHTBLUE:
				return particleVariant.colourVariants[LIGHTBLUE_PARTICLE.name];
			case LeeHyperrealPassive.VFXPassive.VIOLET:
				return particleVariant.colourVariants[VIOLET_PARTICLE.name];
			case LeeHyperrealPassive.VFXPassive.PINK:
				return particleVariant.colourVariants[PINK_PARTICLE.name];
			default:
			{
				uint skinIndex = body.skinIndex;
				if (LeeHyperreal.redVFXSkins.Contains((int)skinIndex) && particleVariant.colourVariants.ContainsKey(RED_PARTICLE.name))
				{
					return particleVariant.colourVariants[RED_PARTICLE.name];
				}
				if (LeeHyperreal.orangeVFXSkins.Contains((int)skinIndex) && particleVariant.colourVariants.ContainsKey(ORANGE_PARTICLE.name))
				{
					return particleVariant.colourVariants[ORANGE_PARTICLE.name];
				}
				if (LeeHyperreal.lightBlueVFXSkins.Contains((int)skinIndex) && particleVariant.colourVariants.ContainsKey(LIGHTBLUE_PARTICLE.name))
				{
					return particleVariant.colourVariants[LIGHTBLUE_PARTICLE.name];
				}
				return particleVariant.colourVariants[DEFAULT_PARTICLE_VARIANT];
			}
			}
		}

		private static void GenerateColorVariant(ParticleColorInfo color)
		{
			//IL_01a1: Unknown result type (might be due to invalid IL or missing references)
			//IL_01bf: Unknown result type (might be due to invalid IL or missing references)
			foreach (KeyValuePair<string, ParticleVariant> item in particleDictionary)
			{
				ParticleVariant value = item.Value;
				Dictionary<string, GameObject> colourVariants = item.Value.colourVariants;
				if (colourVariants.ContainsKey(color.name))
				{
					continue;
				}
				GameObject val = colourVariants[DEFAULT_PARTICLE_VARIANT];
				GameObject val2 = PrefabAPI.InstantiateClone(val, ((Object)val).name + "-" + color.name, false);
				Renderer[] componentsInChildren = val2.GetComponentsInChildren<Renderer>();
				Renderer[] array = componentsInChildren;
				foreach (Renderer rend in array)
				{
					ModifyXEffectOnRenderer(rend, color);
					ModifyNoBatchingRenderers(rend, color);
					ModifySnipeFloorRenderer(rend, color);
					ModifyCloneRenderers(rend, color);
					ModifySuperSprint(rend, color);
				}
				Light[] componentsInChildren2 = val2.GetComponentsInChildren<Light>(true);
				Light[] array2 = componentsInChildren2;
				foreach (Light light in array2)
				{
					ModifyLights(light, color);
				}
				GPUParticlePlayer[] componentsInChildren3 = val2.GetComponentsInChildren<GPUParticlePlayer>();
				GPUParticlePlayer[] array3 = componentsInChildren3;
				foreach (GPUParticlePlayer player in array3)
				{
					ModifyGPUParticles(player, color);
				}
				if (value.shouldVariantCloneUseModify)
				{
					EffectComponent component = val.GetComponent<EffectComponent>();
					string soundName = "";
					bool parentToTransform = true;
					if (Object.op_Implicit((Object)(object)component))
					{
						soundName = component.soundName;
						parentToTransform = component.parentToReferencedTransform;
					}
					DestroyOnTimer component2 = val.GetComponent<DestroyOnTimer>();
					float duration = 1f;
					if (Object.op_Implicit((Object)(object)component2))
					{
						duration = component2.duration;
					}
					VFXPriority priority = (VFXPriority)2;
					bool shouldNotPool = false;
					SetPriorityAndPooling(ref priority, ref shouldNotPool, item.Key);
					ModifyEffect(val2, soundName, parentToTransform, duration, priority, shouldNotPool);
				}
				colourVariants.Add(color.name, val2);
			}
		}

		private static void SetPriorityAndPooling(ref VFXPriority priority, ref bool shouldNotPool, string effectName)
		{
			if (!(effectName == "snipe"))
			{
				if (effectName == "snipeBulletCasing")
				{
					priority = (VFXPriority)0;
					shouldNotPool = false;
				}
			}
			else
			{
				priority = (VFXPriority)1;
				shouldNotPool = false;
			}
		}

		public static void PopulateAssets()
		{
			PopulateAerialDomainAssets();
			PopulatePrimary1Assets();
			PopulatePrimary2Assets();
			PopulatePrimary3Assets();
			PopulatePrimary4Assets();
			PopulatePrimary5Assets();
			PopulateRedOrbAssets();
			PopulateBlueOrbAssets();
			PopulateYellowOrbAssets();
			PopulateSnipeAssets();
			PopulateParryAssets();
			PopulateDodgeAssets();
			PopulateDomainTransitionAssets();
			PopulateDomainUltimateAssets();
			PopulateUltimateAssets();
			PopulateDisplayParticleAssets();
			PopulateMasterClonePrefabs();
			PopulateMiscAssets();
		}

		private static void PopulateMasterClonePrefabs()
		{
			GameObject gameObjectFromBundle = GetGameObjectFromBundle("LeeMasterClone");
			gameObjectFromBundle.AddComponent<LeeHyperrealCloneController>();
			GameObject gameObjectFromBundle2 = GetGameObjectFromBundle("ScarletMasterClone");
			gameObjectFromBundle2.AddComponent<LeeHyperrealCloneController>();
			GameObject gameObjectFromBundle3 = GetGameObjectFromBundle("ProspectorMasterClone");
			gameObjectFromBundle3.AddComponent<LeeHyperrealCloneController>();
			GameObject gameObjectFromBundle4 = GetGameObjectFromBundle("ComradeMasterClone");
			gameObjectFromBundle4.AddComponent<LeeHyperrealCloneController>();
			GameObject gameObjectFromBundle5 = GetGameObjectFromBundle("YiMasterClone");
			gameObjectFromBundle5.AddComponent<LeeHyperrealCloneController>();
			GameObject gameObjectFromBundle6 = GetGameObjectFromBundle("BKMasterClone");
			gameObjectFromBundle6.AddComponent<LeeHyperrealCloneController>();
			ParticleVariant particleVariant = new ParticleVariant(DEFAULT_PARTICLE_VARIANT, gameObjectFromBundle);
			particleVariant.shouldVariantCloneUseModify = false;
			ParticleVariant particleVariant2 = new ParticleVariant(DEFAULT_PARTICLE_VARIANT, gameObjectFromBundle2);
			particleVariant2.shouldVariantCloneUseModify = false;
			ParticleVariant particleVariant3 = new ParticleVariant(DEFAULT_PARTICLE_VARIANT, gameObjectFromBundle3);
			particleVariant3.shouldVariantCloneUseModify = false;
			ParticleVariant particleVariant4 = new ParticleVariant(DEFAULT_PARTICLE_VARIANT, gameObjectFromBundle4);
			particleVariant4.shouldVariantCloneUseModify = false;
			ParticleVariant particleVariant5 = new ParticleVariant(DEFAULT_PARTICLE_VARIANT, gameObjectFromBundle5);
			particleVariant5.shouldVariantCloneUseModify = false;
			ParticleVariant particleVariant6 = new ParticleVariant(DEFAULT_PARTICLE_VARIANT, gameObjectFromBundle6);
			particleVariant6.shouldVariantCloneUseModify = false;
			particleDictionary.Add("leeMasterClone", particleVariant);
			particleDictionary.Add("scarletMasterClone", particleVariant2);
			particleDictionary.Add("prospectorMasterClone", particleVariant3);
			particleDictionary.Add("comradeMasterClone", particleVariant4);
			particleDictionary.Add("yiMasterClone", particleVariant5);
			particleDictionary.Add("bkMasterClone", particleVariant6);
		}

		private static void PopulateMiscAssets()
		{
			GameObject gameObjectFromBundle = GetGameObjectFromBundle("Extra Jump Floor");
			EffectUnparenter effectUnparenter = gameObjectFromBundle.AddComponent<EffectUnparenter>();
			effectUnparenter.duration = 0.175f;
			ModifyEffect(gameObjectFromBundle, "", parentToTransform: true, 1.5f, (VFXPriority)2);
			GameObject gameObjectFromBundle2 = GetGameObjectFromBundle("Ror Skin Jetpack");
			ParticleVariant particleVariant = new ParticleVariant(DEFAULT_PARTICLE_VARIANT, gameObjectFromBundle2);
			particleVariant.shouldVariantCloneUseModify = false;
			GameObject gameObjectFromBundle3 = GetGameObjectFromBundle("SuperSprintVFX");
			gameObjectFromBundle3.AddComponent<DestroySprintOnDelay>();
			ParticleVariant particleVariant2 = new ParticleVariant(DEFAULT_PARTICLE_VARIANT, gameObjectFromBundle3);
			particleVariant2.shouldVariantCloneUseModify = false;
			customCrosshair = GetGameObjectFromBundle("Lee Crosshair");
