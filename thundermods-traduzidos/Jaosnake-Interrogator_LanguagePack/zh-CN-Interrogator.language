{
    "zh-CN": {
        "KENKO_INTERROGATOR_NAME": "\u5ba1\u8baf\u8005",
        "KENKO_INTERROGATOR_DESCRIPTION": "\u5ba1\u8baf\u8005\u6c89\u6d78\u5728\u4ed6\u4eba\u7684\u75db\u82e6\u4e2d\u3002\u4e0d\u8981\u592a\u5f00\u5fc3\u5730\u4f24\u5bb3\u4f60\u7684\u76df\u53cb... \u6216\u8005\u5c31\u5f00\u5fc3\u5730\u505a\u5427\u3002\n\n< ! > \u88ab\u654c\u4eba\u3001\u76df\u53cb\u3001\u751a\u81f3\u662f\u81ea\u5df1\u51fb\u4e2d\uff0c\u4ee5\u83b7\u5f97\u989d\u5916\u5c5e\u6027\u3002\u6ca1\u4eba\u662f\u5b89\u5168\u7684\u3002\n\n< ! > \u5982\u679c\u4f60\u6709\u89e6\u53d1\u88ab\u51fb\u4e2d\u65f6\u4e8b\u4ef6\u7684\u7269\u54c1\uff0c\u4f7f\u7528\u51b2\u7a81\u5bf9\u81ea\u5df1\u9020\u6210\u51fa\u8840\u3002\u6ca1\u6709\u4ed8\u51fa\uff0c\u5c31\u6ca1\u6709\u6536\u83b7\u3002\n\n< ! > \u7be1\u6539\u662f\u5f3a\u8feb\u654c\u4eba\u88ab\u6807\u8bb0\u4e3a\u6709\u7f6a\u7684\u597d\u65b9\u6cd5\u3002\u53cd\u6700\u4f73\u5316\uff1f\u4f60\u8bf4\u4ec0\u4e48\uff1f\n\n< ! > \u5b9a\u7f6a\u4e00\u4e2a\u6709\u7f6a\u76ee\u6807\uff0c\u786e\u4fdd\u4ed6\u4eec\u4e3a\u81ea\u5df1\u7684\u884c\u4e3a\u53d7\u5230\u60e9\u7f5a\u3002\u6bd5\u7adf\uff0c\u5728\u88ab\u8bc1\u660e\u65e0\u7f6a\u4e4b\u524d\uff0c\u4ed6\u4eec\u90fd\u662f\u6709\u7f6a\u7684\u3002 <i>Translated by: Jaosnake. Original mod by tsuyoikenko</i>",
        "KENKO_INTERROGATOR_SUBTITLE": "\u6298\u78e8\u4e13\u5bb6",
        "KENKO_INTERROGATOR_OUTRO_FLAVOR": "..\u4e8e\u662f\u4ed6\u79bb\u5f00\u4e86\uff0c\u6025\u5207\u5730\u8981\u5e94\u7528\u66f4\u591a\u201c\u6b63\u4e49\u201d\u3002",
        "KENKO_INTERROGATOR_OUTRO_FAILURE": "..\u4e8e\u662f\u4ed6\u6d88\u5931\u4e86\uff0c\u56e0\u4ed6\u7684\u7f6a\u884c\u800c\u53d7\u5230\u60e9\u7f5a\u3002",
        "KENKO_INTERROGATOR_DEFAULT_SKIN_NAME": "\u9ed8\u8ba4",
        "KENKO_INTERROGATOR_MASTERY_SKIN_NAME": "\u5ba1\u8baf\u8005\uff1a\u4e13\u5bb6",
        "KENKO_INTERROGATOR_PASSIVE_NAME": "\u6298\u78e8",
        "KENKO_INTERROGATOR_PASSIVE_DESCRIPTION": "\u5ba1\u8baf\u8005\u53ef\u4ee5\u51fb\u4e2d\u6216\u88ab\u76df\u53cb\u548c\u654c\u4eba\u51fb\u4e2d\u3002\u653b\u51fb\u5ba1\u8baf\u8005\u7684\u653b\u51fb\u8005\u4f1a\u88ab\u6c38\u4e45\u6807\u8bb0\u4e3a\u6709\u7f6a\u3002\u6bcf\u4e2a\u6709\u7f6a\u654c\u4eba\u63d0\u4f9b5%\u989d\u5916\u4f24\u5bb3\u3002 <i>Translated by: Jaosnake. Original mod by tsuyoikenko</i>",
        "KENKO_INTERROGATOR_PRIMARY_SWING_NAME": "\u6b8b\u62cd",
        "KENKO_INTERROGATOR_PRIMARY_SWING_DESCRIPTION": "\u6325\u52a8\u4f60\u7684\u8b66\u68cd\u653b\u51fb\u524d\u65b9\uff0c\u9020\u6210<style=cIsDamage>320%\u4f24\u5bb3</style>\u3002\u672a\u547d\u4e2d\u4f1a\u8ba9\u4f60\u53d7\u5230<style=cIsDamage>\u4f24\u5bb3</style>\u3002 <i>Translated by: Jaosnake. Original mod by tsuyoikenko</i>",
        "KENKO_INTERROGATOR_SECONDARY_AFFRAY_NAME": "\u51b2\u7a81",
        "KENKO_INTERROGATOR_SECONDARY_AFFRAY_DESCRIPTION": "\u6295\u6382\u4e00\u628a\u5207\u8089\u5200\uff0c\u9020\u6210<style=cIsDamage>450%\u4f24\u5bb3</style>\u3002<style=cIsDamage>\u523a\u6740\u8005\u3002</style>\u5982\u679c\u5207\u8089\u5200\u51fb\u6740\u76ee\u6807\uff0c\u5bf9\u533a\u57df\u5185\u6240\u6709\u654c\u4eba\u65bd\u52a0\u51fa\u8840\u548c\u538b\u529b\u3002 <i>Translated by: Jaosnake. Original mod by tsuyoikenko</i>",
        "KENKO_INTERROGATOR_UTILITY_FALSIFY_NAME": "\u7be1\u6539",
        "KENKO_INTERROGATOR_UTILITY_FALSIFY_DESCRIPTION": "\u5411\u524d\u51b2\u523a\uff0c\u9020\u6210<style=cIsDamage>390%\u4f24\u5bb3</style>\u5e76\u5bf9\u51fb\u4e2d\u76ee\u6807\u65bd\u52a0\u6709\u7f6a\u3002 <i>Translated by: Jaosnake. Original mod by tsuyoikenko</i>",
        "KENKO_INTERROGATOR_SPECIAL_CONVICT_NAME": "\u5b9a\u7f6a",
        "KENKO_INTERROGATOR_SPECIAL_CONVICT_DESCRIPTION": "\u4e0e\u6709\u7f6a\u654c\u4eba\u51b3\u659710\u79d2\u3002\u4f60\u7684\u4e3b\u8981\u653b\u51fb\u4e0d\u4f1a\u518d\u51fb\u4e2d\u4f60\uff0c\u5e76\u4e14\u51fb\u4e2d\u65f6\u63d0\u4f9b\u4e00\u5c42\u6709\u7f6a\u3002\u51b3\u6597\u671f\u95f4\uff0c\u4f60\u53d7\u5230\u7684\u5916\u90e8\u4f24\u5bb3\u88ab\u62b5\u6d88\uff0c\u4f46\u5bf9\u76ee\u6807\u4ee5\u5916\u654c\u4eba\u7684\u4f24\u5bb3\u4e5f\u88ab\u62b5\u6d88\u3002 <i>Translated by: Jaosnake. Original mod by tsuyoikenko</i>",
        "KENKO_INTERROGATOR_SPECIAL_SCEPTER_CONVICT_NAME": "\u60e9\u7f5a",
        "KENKO_INTERROGATOR_SPECIAL_SCEPTER_CONVICT_DESCRIPTION": "\u4e0e\u6709\u7f6a\u654c\u4eba\u51b3\u659710\u79d2\u3002\u4f60\u7684\u4e3b\u8981\u653b\u51fb\u4e0d\u4f1a\u518d\u51fb\u4e2d\u4f60\uff0c\u5e76\u4e14\u51fb\u4e2d\u65f6\u63d0\u4f9b\u4e00\u5c42\u6709\u7f6a\u3002\u51b3\u6597\u671f\u95f4\uff0c\u4f60\u53d7\u5230\u7684\u5916\u90e8\u4f24\u5bb3\u88ab\u62b5\u6d88\uff0c\u4f46\u5bf9\u5176\u4ed6\u654c\u4eba\u7684\u4f24\u5bb3\u51cf\u5c1175%\u3002 <i>Translated by: Jaosnake. Original mod by tsuyoikenko</i>"
    }
}
