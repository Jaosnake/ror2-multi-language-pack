        "JAVANGLE_HOUSE_DEFAULT_SKIN_NAME": "Estándar",
        "JAVANGLE_HOUSE_MASTERY_SKIN_NAME": "Palacio",
        "JAVANGLE_HOUSE_MASTERYUNLOCKABLE_ACHIEVEMENT_NAME": "The House: Mastery",
        "JAVANGLE_HOUSE_MASTERYUNLOCKABLE_ACHIEVEMENT_DESC": "Como The House, gana el juego o arrasa en Moncao.",
