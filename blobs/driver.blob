			private void VehicleSeat_onPassengerEnterGlobal(VehicleSeat vehicle, GameObject passenger)
			{
				if (!((Object)(object)passenger != (Object)(object)((Component)this).gameObject) && Object.op_Implicit((Object)(object)((Component)vehicle).GetComponent<ZiprailVehicle>()))
				{
					if (characterBody.hasEffectiveAuthority)
					{
						weaponESM.SetNextState((EntityState)(object)new StartGrind());
					}
					if (vehicle.hidePassenger)
					{
						CharacterModel obj = characterModel;
						int invisibilityCount = obj.invisibilityCount;
						obj.invisibilityCount = invisibilityCount - 1;
					}
				}
			}

			private void VehicleSeat_onPassengerExitGlobal(VehicleSeat vehicle, GameObject passenger)
			{
				if ((Object)(object)passenger != (Object)(object)((Component)this).gameObject || !Object.op_Implicit((Object)(object)((Component)vehicle).GetComponent<ZiprailVehicle>()))
				{
					return;
				}
				if (characterBody.hasEffectiveAuthority)
				{
					if (!isSkaterBoi)
					{
						weaponESM.SetNextState((EntityState)(object)new Stop());
					}
					else
					{
						weaponESM.SetNextState((EntityState)(object)new Idle());
					}
				}
				if (vehicle.hidePassenger)
				{
					CharacterModel obj = characterModel;
					int invisibilityCount = obj.invisibilityCount;
					obj.invisibilityCount = invisibilityCount + 1;
				}
			}

			public void OnEnable()
			{
				InstanceTracker.Add<DriverController>(this);
			}

			public void OnDisable()
			{
				InstanceTracker.Remove<DriverController>(this);
			}

			private void SetInventoryHook()
			{
				inventory = characterBody.inventory;
				inventory.onItemAddedClient += Inventory_onItemAddedClient;
				inventory.onInventoryChanged += Inventory_onInventoryChanged;
				isSkaterBoi = (Object)(object)skillLocator.utility.skillDef == (Object)(object)Skills.skateboardSkillDef;
				childLocator.FindChildGameObject("PistolModel").SetActive(true);
				childLocator.FindChildGameObject("KnifeModel").SetActive(false);
				childLocator.FindChildGameObject("ButtonModel").SetActive(false);
				childLocator.FindChildGameObject("SyringeModel").SetActive(false);
				childLocator.FindChildGameObject("SkateboardModel").SetActive(false);
				childLocator.FindChildGameObject("SkateboardBackModel").SetActive(isSkaterBoi);
				childLocator.FindChildGameObject("AltWeaponModel").SetActive(false);
				for (int i = 0; i < characterModel.baseRendererInfos.Length; i++)
				{
					characterModel.baseRendererInfos[i].renderer.enabled = true;
				}
				if ((Object)(object)skillLocator.special.skillDef == (Object)(object)Skills.scepterKnifeSkillDef || (Config.enableRevengence.Value && (Object)(object)skillLocator.special.skillDef == (Object)(object)Skills.knifeSkillDef))
				{
					childLocator.FindChildGameObject("AltWeaponModel").SetActive(true);
					if ((Object)(object)skillLocator.special.skillDef == (Object)(object)Skills.scepterKnifeSkillDef)
					{
						SkinnedMeshRenderer val = childLocator.FindChildComponent<SkinnedMeshRenderer>("KnifeModel");
						((Renderer)val).sharedMaterial = BaseWeapon<NemKatana>.instance.weaponDef.material;
						val.sharedMesh = BaseWeapon<NemKatana>.instance.weaponDef.mesh;
						for (int j = 0; j < characterModel.baseRendererInfos.Length; j++)
						{
							ref RendererInfo reference = ref characterModel.baseRendererInfos[j];
							if ((Object)(object)reference.renderer == (Object)(object)val)
							{
								reference.defaultMaterial = BaseWeapon<NemKatana>.instance.weaponDef.material;
							}
						}
					}
				}
				defaultWeaponDef = arsenal.LoadoutWeapon;
				PickUpWeapon(defaultWeaponDef);
				ServerGetStoredWeapon();
				onWeaponChanged = (Action<DriverWeaponDef>)Delegate.Combine(onWeaponChanged, new Action<DriverWeaponDef>(OnWeaponChanged));
			}

			private void OnDestroy()
			{
				VehicleSeat.onPassengerEnterGlobal -= VehicleSeat_onPassengerEnterGlobal;
				VehicleSeat.onPassengerExitGlobal -= VehicleSeat_onPassengerExitGlobal;
				onWeaponChanged = (Action<DriverWeaponDef>)Delegate.Remove(onWeaponChanged, new Action<DriverWeaponDef>(OnWeaponChanged));
				if (inventory != null)
				{
					inventory.onItemAddedClient -= Inventory_onItemAddedClient;
					inventory.onInventoryChanged -= Inventory_onInventoryChanged;
				}
