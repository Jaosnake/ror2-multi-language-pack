		internal static class Tokens
		{
			internal static void AddTokens()
			{
				string text = "ROB_HUNK_BODY_";
				LanguageAPI.Add("ROB_HUNK_PARASITE_BODY_NAME", "G-Young");
				LanguageAPI.Add("ROB_HUNK_HELICOPTER_BODY_NAME", "Attack Helicopter");
				string text2 = "HUNK";
				string text3 = "Grim Reaper";
				if (Config.commanderMode.Value)
				{
					text2 = "Commander";
					text3 = "John Risk";
				}
				if (Config.loreFriendly.Value)
				{
					text2 = "Specialist";
					text3 = "Elite Agent";
				}
				string text4 = text2 + " is an elite infiltrator who carries a large arsenal of weapons claimed via OSP (on-site procurement).<color=#CCD3E0>" + Environment.NewLine + Environment.NewLine;
				text4 = text4 + "< ! > Use your Combat Knife against weaker foes to conserve ammo." + Environment.NewLine + Environment.NewLine;
				text4 = text4 + "< ! > Securing the G-Virus Sample will net you a keycard, allowing you to access weapon cases on each stage." + Environment.NewLine + Environment.NewLine;
				text4 = text4 + "< ! > Quickstep near an attacking enemy or projectile to Perfect Dodge, then perform a Counterattack with Primary." + Environment.NewLine + Environment.NewLine;
				text4 = text4 + "< ! > Ammo is scarce, but can be found in opened chests. Secondary stocks and cooldown reduction also affect ammo." + Environment.NewLine + Environment.NewLine;
				text4 = text4 + "< ! > This is war. Survival is your responsibility." + Environment.NewLine + Environment.NewLine;
				string text5 = "..and so he left, fine.";
				string text6 = "..and so he vanished, human unit now killed.";
				string text7 = "**INT. ABANDONED UMBRELLA FACILITY - NIGHT**" + Environment.NewLine + Environment.NewLine + Environment.NewLine + "(HUNK, the silent and deadly operative, is locked in a fierce battle with a towering B.O.W. (Bio-Organic Weapon). He deftly dodges a swipe of the creature's massive claw, rolling to his feet and aiming his submachine gun. The B.O.W. roars, charging at HUNK with reckless abandon.)" + Environment.NewLine + Environment.NewLine + "HUNK: (grunts) Just another day at the office." + Environment.NewLine + Environment.NewLine + "(HUNK pulls out a flashbang, tossing it expertly into the B.O.W.'s face. The creature recoils, blinded by the intense light. Taking advantage of the moment, HUNK rushes in, climbing up the B.O.W.'s leg with surprising agility. As he reaches the creature's midsection, he draws his combat knife.)" + Environment.NewLine + Environment.NewLine + "(Camera cuts to a closeup of the B.O.W.'s horrified face as a loud 'slice!' is heard.)" + Environment.NewLine + Environment.NewLine + "B.O.W.: RAAAAGHHHHH!!" + Environment.NewLine + Environment.NewLine + "(A comical slide whistle plays as the B.O.W. crumples to the ground, clutching its crotch. The screen shakes with the impact, and we hear a series of exaggerated sound effects: a car horn honking, a cat yowling, and glass breaking.)" + Environment.NewLine + Environment.NewLine + "SPECTRE (Voice over comm): (Wincing) I think I felt that one." + Environment.NewLine + Environment.NewLine + "(Camera cuts to HUNK, who looks directly into the camera with his signature cold stare.)" + Environment.NewLine + Environment.NewLine + "HUNK: (deadpan) And they said I'd never make the cut." + Environment.NewLine + Environment.NewLine + "(The B.O.W. whimpers, rolling on the ground in agony. A classic 'boing' sound effect is heard.)" + Environment.NewLine + Environment.NewLine + "B.O.W.: MY... MY REGENERATOR MODULES!!!" + Environment.NewLine + Environment.NewLine + "(Cut to COMMANDER watching from the command center, his expression one of mixed amusement and exasperation.)" + Environment.NewLine + Environment.NewLine + "COMMANDER: (sighing) No matter the mission, HUNK always knows how to hit where it hurts.";
				LanguageAPI.Add(text + "NAME", text2);
				LanguageAPI.Add(text + "DESCRIPTION", text4);
				LanguageAPI.Add(text + "SUBTITLE", text3);
				LanguageAPI.Add(text + "LORE", text7);
				LanguageAPI.Add(text + "OUTRO_FLAVOR", text5);
				LanguageAPI.Add(text + "OUTRO_FAILURE", text6);
				LanguageAPI.Add("ROB_ARTIFACT_PURSUER_NAME", "Artifact of the Pursuer");
				LanguageAPI.Add("ROB_ARTIFACT_PURSUER_DESC", "Players start the run with a S.T.A.R.S. Badge.");
				LanguageAPI.Add("ROB_ARTIFACT_CONTAMINATION_NAME", "Artifact of Contamination");
				LanguageAPI.Add("ROB_ARTIFACT_CONTAMINATION_DESC", "Each player gets a random Virus event each stage.");
				LanguageAPI.Add("ROB_ARTIFACT_STRIKETEAM_NAME", "Artifact of the Poopfart");
				LanguageAPI.Add("ROB_ARTIFACT_STRIKETEAM_DESC", "Players will occasionally have Strike Teams sent in to neutralize them.");
				text4 = "The Nemesis T-Type is an unstoppable bioweapon made to withstand any amount of punishment and neutralize its targets with ease.<color=#CCD3E0>" + Environment.NewLine + Environment.NewLine;
				text4 = text4 + "< ! > Jumps can be charged for greater distance." + Environment.NewLine + Environment.NewLine;
				text4 = text4 + "< ! > Consuming enemies leaves you vulnerable so be sure to find a safe place before doing so." + Environment.NewLine + Environment.NewLine;
				text4 = text4 + "< ! > Biomass boosts your damage when full," + Environment.NewLine + Environment.NewLine;
				text4 = text4 + "< ! > " + Environment.NewLine + Environment.NewLine;
				LanguageAPI.Add("ROB_NEMESIS_BODY_NAME", "Nemesis T-Type");
				LanguageAPI.Add("ROB_NEMESIS_BODY_DESCRIPTION", text4);
				LanguageAPI.Add("ROB_NEMESIS_BODY_SUBTITLE", "Invincible Bioweapon");
				LanguageAPI.Add("ROB_NEMESIS_BODY_LORE", text7);
				LanguageAPI.Add("ROB_NEMESIS_BODY_OUTRO_FLAVOR", text5);
				LanguageAPI.Add("ROB_NEMESIS_BODY_OUTRO_FAILURE", text6);
				LanguageAPI.Add(text + "DEFAULT_SKIN_NAME", "Default");
				LanguageAPI.Add(text + "CLASSIC_SKIN_NAME", "RE2make");
				LanguageAPI.Add(text + "TOFU_SKIN_NAME", "Tofu");
				LanguageAPI.Add(text + "SUPER_SKIN_NAME", "<color=#FFFF00>Early Supporter</color>");
				LanguageAPI.Add(text + "LIGHTWEIGHT_SKIN_NAME", "Lightweight");
				LanguageAPI.Add(text + "GUERRILLA_SKIN_NAME", "Trooper");
				LanguageAPI.Add(text + "ROOKIE_SKIN_NAME", "Rookie");
				LanguageAPI.Add(text + "SWAT_SKIN_NAME", "Peacekeeper");
				LanguageAPI.Add(text + "LEON_SKIN_NAME", "Specialist");
