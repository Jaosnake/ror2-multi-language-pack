		public void Awake()
		{
			//IL_0095: Unknown result type (might be due to invalid IL or missing references)
			//IL_009a: Unknown result type (might be due to invalid IL or missing references)
			//IL_00ac: Unknown result type (might be due to invalid IL or missing references)
			animator = ((Component)this).GetComponent<Animator>();
			childLocator = ((Component)this).GetComponent<ChildLocator>();
			slotController = ((Component)((Component)this).gameObject.transform.parent).GetComponent<SurvivorMannequinSlotController>();
			loadout = slotController.currentLoadout;
			bornPackTransform = childLocator.FindChild("LeeBornAnimPack");
			baseTransform = childLocator.FindChild("BaseTransform");
			selectedNum = GenerateRandomNum();
			timer = 0f;
			SetDisableClone();
			leeIndex = BodyCatalog.FindBodyIndex("LeeHyperrealBody");
			skinIndex = loadout.bodyLoadoutManager.GetSkinIndex(leeIndex);
			SetNewSkinForAll();
		}

		public void SetDisableClone()
		{
			if (!Object.op_Implicit((Object)(object)bornPackTransform))
			{
				return;
			}
			for (int i = 0; i < bornPackTransform.childCount; i++)
			{
				if (i != selectedNum - 1)
				{
					((Component)bornPackTransform.GetChild(i)).gameObject.SetActive(true);
				}
				else
				{
					((Component)bornPackTransform.GetChild(i)).gameObject.SetActive(false);
				}
			}
		}

		public void OnEnable()
		{
			selectedNum = GenerateRandomNum();
			playedSound = false;
			timer = 0f;
			if (Object.op_Implicit((Object)(object)animator))
			{
				animator.SetBool("StartBlinking", false);
			}
			SetDisableClone();
		}

		public int GenerateRandomNum()
		{
			return Random.Range(1, 5);
		}

		public void Update()
		{
			//IL_0013: Unknown result type (might be due to invalid IL or missing references)
			//IL_0034: Unknown result type (might be due to invalid IL or missing references)
			//IL_0178: Unknown result type (might be due to invalid IL or missing references)
			//IL_017d: Unknown result type (might be due to invalid IL or missing references)
			if (skinIndex != loadout.bodyLoadoutManager.GetSkinIndex(leeIndex))
			{
				skinIndex = loadout.bodyLoadoutManager.GetSkinIndex(leeIndex);
				SetNewSkinForAll();
			}
			if (timer >= duration)
			{
				if (Object.op_Implicit((Object)(object)animator))
				{
					animator.SetBool("StartBlinking", true);
				}
			}
			else
			{
				timer += Time.deltaTime;
			}
			if (Object.op_Implicit((Object)(object)animator))
			{
				animator.SetInteger("SelectSpawnTrigger", selectedNum);
			}
			if (playedSound)
			{
				return;
			}
			playedSound = true;
			if (Config.voiceEnabled.Value && !LeeHyperreal.voiceDisabledSkins.Contains((int)skinIndex))
			{
				if (Config.voiceLanguageOption.Value == Config.VoiceLanguage.ENG)
				{
					Util.PlaySound("Play_Lee_Intro_Voice_EN", ((Component)this).gameObject);
				}
				else
				{
					Util.PlaySound("Play_Lee_Intro_Voice_JP", ((Component)this).gameObject);
				}
			}
			Util.PlaySound("Play_c_liRk4_act_born", ((Component)this).gameObject);
			if (selectedNum == 2)
			{
				Object.Instantiate<GameObject>(ParticleAssets.RetrieveParticleEffect("displayLandingEffect", ParticleAssets.DEFAULT_PARTICLE_VARIANT), baseTransform.position, Quaternion.identity, baseTransform);
			}
		}

