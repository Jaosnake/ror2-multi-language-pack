                    "SS2_NEMCAPTAIN_ORDERGRAVITY_DESCRIPTION":  "\u003cstyle=cIsUtility\u003ePull\u003c/syle\u003e nearby enemies for \u003cstyle=cIsUtility\u003e8 seconds\u003c/style\u003e.",
                    "SS2_KNIGHT_UTILITY_LEAP_UPGRADE_TOOLTIP":  "\u003cstyle=cKeywordName\u003e\u003ccolor=#fa78f3\u003eEmpowered\u003c/color\u003e\u003c/style\u003e\u003cstyle=cSub\u003eTravel further, dealing \u003cstyle=cIsDamage\u003e200% damage\u003c/style\u003e per hit.\u003c/style\u003e",
                    "SS2_EQUIP_AFFIXEMPYREAN_NAME":  "Harmony",
                    "SS2_ACHIEVEMENT_HUNTRESS_GRANDMASTERY_DESC":  "As Huntress, beat the game or obliterate on Typhoon or Harder.",
                    "SS2_ITEM_GALVANICCORE_LORE":  "Order: Galvanic Core\nTracking Number: 0121923\nEstimated Delivery: 4/22/2056\nShipping Method: Priority \nShipping Address: Science Plaza #42, MV Prime\nShipping Details:\n\nThe power is yours.\nWelcome to the latest generation of power core technology in the galaxy. The Galvanic Core is the most revolutionary invention since the Hardlight Afterburner! Don\u0027t blink, it\u0027s time to embrace the future.\nThank you for your purchase.\n\nOMNI.co",
                    "SS2_ACHIEVEMENT_BORG_NAME":  "",
                    "SS2_KEYWORD_REARM":  "\u003cstyle=cKeywordName\u003eRearming\u003c/style\u003e\u003cstyle=cSub\u003eAdds 2 more projectiles to the next use of primary, up to a maximum of 7.",
                    "SS2_ITEM_DIARY_DESC":  "When entering a stage, \u003cstyle=cIsUtility\u003egain {0} levels\u003c/style\u003e and \u003cstyle=cIsUtility\u003econsume this item.\u003c/style\u003e",
                    "SS2_ACHIEVEMENT_URANIUMHORSESHOE_NAME":  "Grand Prix",
                    "SS2_ACHIEVEMENT_EXECUTIONER_IONBURST_NAME":  "Executioner: Forced Discharge",
                    "SS2_KEYWORD_FEAR2":  "\u003cstyle=cKeywordName\u003eFear\u003c/style\u003e\u003cstyle=cSub\u003eCauses afflicted enemies to stop attacking and flee. Feared enemies are \u003cstyle=cIsHealth\u003einstantly killed\u003c/style\u003e if below \u003cstyle=cIsHealth\u003e15%\u003c/style\u003e health.\u003c/style\u003e",
                    "SS2_KNIGHT_OUTRO_FAILURE":  "..and so he vanished, shield shattered and hope snuffed out.",
                    "SS2_ITEM_SCAVENGERSFORTUNE_PICKUP":  "WIP PICKUP",
                    "SS2_ACHIEVEMENT_CROCO_GRANDMASTERY_NAME":  "Acrid: Grand Mastery",
                    "SS2_KNIGHT_SPECIAL_BANNER_NAME":  "Rally",
                    "SS2_EXECUTIONER2_IONJUGGERNAUT_NAME":  "Ion Overlord",
                    "SS2_AMBUSH_MESSAGE_SINGLE_2P":  "\u003cstyle=cShrine\u003eYou have been ambushed by {1}s\u003c/color\u003e.",
                    "SS2_ITEM_MALICE_LORE":  "You are weak.\n\nPhysically? Perhaps not. You fight to survive, and you fight well enough. But in the mind? My friend, you are frail. You fight and kill, but feel remorse for that which you kill. Why? The animals, they do not feel remorse towards you. To them, you are but prey to stalk, or predator to flee from. Those hulking titans? They bear no emotion, only a silent directive to destroy. To destroy you.\n\nAnd I know you. My friend, you do not wish to be weak. You wish to be powerful, in mind as well as in body. Do not feel pity for these mindless beasts, for they are just that. Fight to kill, not just to survive.\n\nBut man\u0027s malice can only take you so far. Take this. Be pulled further. Fight to kill, and kill to be feared.\n",
                    "SS2_ITEM_JETBOOTS_NAME":  "Prototype Jet Boots",
                    "SS2_SKIN_EXECUTIONER2_MASTERY":  "Warrior",
                    "SS2_ENGINEER_RAPIDDISPLACEMENT_NAME":  "Rapid Displacement",
                    "SS2_WARDEN_BODY_NAME":  "Warden",
                    "SS2_PLAYER_ARMOR_50_DECREASE_BODY_TOKEN":  "Players take 50% damage.",
                    "SS2_BROTHER_KILL_CHIRR2":  "Extinct at last.",
                    "SS2_ITEM_SHACKLEDLAMP_DESC":  "Every \u003cstyle=cIsDamage\u003e5 primary uses\u003c/style\u003e, fire a haunted projectile for \u003cstyle=cIsDamage\u003e200%\u003c/style\u003e \u003cstyle=cStack\u003e(+200% per stack)\u003c/style\u003e base damage.",
                    "SS2_NEMEXECUTIONER_PRIMARY_DESCRIPTION":  "ball chain lightning",
                    "SS2_SKIN_COMMANDO_ALT2":  "Scorpion",
