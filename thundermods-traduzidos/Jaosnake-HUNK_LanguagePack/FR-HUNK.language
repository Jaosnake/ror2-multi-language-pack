        "ROB_HUNK_BODY_SHOOT_SPARKSHOT_NAME": "Tirer",
        "ROB_HUNK_BODY_SHOOT_SPARKSHOT_DESCRIPTION": "Tire une aiguille électrifiée pour <style=cIsDamage>1.000% de dégâts</style>. <style=cIsUtility>Rebondit jusqu'à 3 ennemis pour <style=cIsDamage>2.000% de dégâts</style>.</style>",
        "ROB_HUNK_BODY_SHOOT_BLUEROSE_NAME": "Tirer",
