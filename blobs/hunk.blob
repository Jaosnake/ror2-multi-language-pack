			public bool ValidIndex(int i, bool countEquippedAsValid = true)
			{
				if (hunk.weaponData.Length == 0)
				{
					return false;
				}
				if (i >= hunk.weaponData.Length)
				{
					return false;
				}
				if (i == hunk.equippedIndex && !countEquippedAsValid)
				{
					return false;
				}
				return true;
			}

