                    "SS2_SKIN_NEMCOMMANDO_COMMANDO":  "Soldier",
                    "SS2_ACHIEVEMENT_NEMCOMMANDO_SWORDBEAM_DESC":  "As Nemesis Commando, reach 100% bleed chance.",
                    "SS2_DIFFICULTY_TEMPEST1_NAME":  "Tempest +1",
                    "SS2_EQUIP_PRESSURIZEDCANISTER_NAME":  "Pressurized Canister",
                    "SS2_EXECUTIONER2_CONSECRATION_DESC":  "Consume all \u003ccolor=#29e5f2\u003eIon Charges\u003c/color\u003e to \u003cstyle=cIsHealing\u003eheal\u003c/style\u003e, gain \u003cstyle=cIsUtility\u003emovement speed\u003c/style\u003e, and reduce your cooldowns by \u003cstyle=cIsUtility\u003e1 second\u003c/style\u003e per charge.",
                    "SS2_NEMCAPTAIN_ORDERREGEN_NAME":  "ORDER: Administer Relaxant",
                    "SS2_EQUIP_CLOAKINGHEADBAND_DESC":  "Become \u003cstyle=cIsUtility\u003einvisible\u003c/style\u003e and gain \u003cstyle=cIsUtility\u003e+40% movement speed\u003c/style\u003e for {0} seconds.",
                    "SS2_ACHIEVEMENT_BORG_GRANDMASTERY_NAME":  "Cyborg: Grand Mastery",
