        "SS2_WARDEN_SECONDARY_SHIELD_NAME": "Блок",
        "SS2_ACHIEVEMENT_CYBORG2_MASTERY_DESC": "As Cyborg, beat the game or obliterate on Monsoon or harder.",
        "SS2_CYBORG2_UTILITY_TRAP_NAME": "Перепрофилировать",
        "SS2_BEASTMASTER_NAME": "Чирр",
