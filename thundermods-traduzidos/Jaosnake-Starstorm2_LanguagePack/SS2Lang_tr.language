        "SS2_ITEM_OPTIONFROMCHEST_LORE": "???",
        "SS2_ELITE_MODIFIER_STORM": "Fırtınadoğan {0}",
        "SS2_ITEM_RELICOFTERMINATION_PICKUP": "Her {0} saniyede bir düşmanı işaretle ve güçlendir. Zamanında yenilirse eşya düşürür; yenilmezse hiçbir şey düşürmez.",
        "SS2_NEMCOMMANDO_SPECIAL_BOSS_DESCRIPTION": "<style=cIsDamage>Deşme.</style> <style=cIsUtility>Şarj et</style>, sonra <style=cIsUtility>ileri atıl</style> ve <style=cIsDamage>Her biri 360% hasar veren</style> <style=cIsUtility>6 kesik</style> darbesini yıkıcı bir şekilde vur. <style=cIsUtility>Saldırı hızı ile kesik sayısı artar</style>.",
        "SS2_NEMESIS_HUNTRESS_PASSIVE_DESC": "Savaş sırasında <style=cIsDamage>Zayıf Noktaları</style> vurgulayın; <style=cIsDamage>1,5 kat hasar için tüm oklarla vurulabilir</style>.",
        "SS2_MULE_LORE": "",
        "SS2_KEYWORD_IONARMORBUFF": "<style=cKeywordName>Ion Armor</style><style=cSub>Zırhı 60 arttırır ve beceri bekleme sürelerini %20 azaltır.</style>",
