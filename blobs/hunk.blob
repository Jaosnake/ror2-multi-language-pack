			private void Update()
			{
				if (Object.op_Implicit((Object)(object)characterBody) && !characterBody.isPlayerControlled)
				{
					if (isAiming && Object.op_Implicit((Object)(object)characterBody.skillLocator) && Object.op_Implicit((Object)(object)characterBody.skillLocator) && Object.op_Implicit((Object)(object)characterBody.skillLocator.primary))
					{
						characterBody.skillLocator.primary.ExecuteIfReady();
					}
					if (aiSwapCooldown <= 0f && Object.op_Implicit((Object)(object)weaponTracker) && weaponTracker.weaponData[weaponTracker.equippedIndex].totalAmmo == 0 && weaponTracker.weaponData[weaponTracker.equippedIndex].currentAmmo == 0)
