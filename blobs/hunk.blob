			public void ReloadRound()
			{
				if (weaponDef.animationSet == HunkWeaponDef.AnimationSet.Pistol)
				{
					Util.PlaySound("sfx_hunk_revolver_load", ((Component)this).gameObject);
				}
				else
				{
					Util.PlaySound("sfx_hunk_shotgun_load", ((Component)this).gameObject);
				}
				ammo++;
				weaponTracker.weaponData[weaponTracker.equippedIndex].currentAmmo++;
				weaponTracker.weaponData[weaponTracker.equippedIndex].totalAmmo--;
				if (weaponTracker.weaponData[weaponTracker.equippedIndex].totalAmmo <= 0)
				{
					weaponTracker.weaponData[weaponTracker.equippedIndex].totalAmmo = 0;
				}
			}

