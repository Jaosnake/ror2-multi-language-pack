namespace RA2Mod.Minions.TeslaTower
{
	public class TeslaTowerAI
	{
		public static void Init(GameObject bodyPrefab, string masterName, Action<GameObject> OnComplete)
		{
			ContentPacks.asyncLoadCoroutines.Add(Prefabs.CreateBlankMasterPrefabAsync(bodyPrefab, masterName, delegate(GameObject result)
			{
				BaseAI component = result.GetComponent<BaseAI>();
				component.aimVectorDampTime = 0.01f;
				component.aimVectorMaxSpeed = 360f;
				OnComplete(result);
			}));
		}
	}
	internal class TeslaTowerAssets
	{
		internal static Material ChainLightningMaterial;

		internal static List<IEnumerator> GetAssetBundleInitializedCoroutines(AssetBundle assetBundle)
		{
			List<IEnumerator> list = Asset.PreLoadAssetsAsyncCoroutines<Sprite>(assetBundle, new string[2] { "texIconTeslaTower", "texTeslaSkillSecondaryThunderclap" });
			list.Add(Asset.LoadAssetCoroutine<Material>((object)"RoR2/Base/Common/VFX/matLightningLongBlue.mat", (Action<Material>)delegate(Material result)
			{
				ChainLightningMaterial = result;
			}));
			return list;
		}
	}
