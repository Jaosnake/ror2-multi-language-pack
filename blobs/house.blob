			//IL_0147: Unknown result type (might be due to invalid IL or missing references)
			//IL_0158: Expected O, but got Unknown
			if (Object.op_Implicit((Object)(object)passiveManager) && passiveManager.CardArt == 1)
			{
				((BaseState)this).StartAimMode(duration + 0.1f, false);
				Transform modelTransform = ((EntityState)this).GetModelTransform();
				attack = new OverlapAttack
				{
					damageType = DamageTypeCombo.op_Implicit((DamageType)0),
					attacker = ((EntityState)this).gameObject,
					inflictor = ((EntityState)this).gameObject,
					teamIndex = ((BaseState)this).GetTeam(),
					damage = SweepDamage * ((BaseState)this).damageStat,
					procCoefficient = 1f,
					hitEffectPrefab = Assets.VFXcard52pExplosion,
					forceVector = Vector3.zero,
					pushAwayForce = 1500f,
					hitBoxGroup = Array.Find(((Component)modelTransform).GetComponents<HitBoxGroup>(), (HitBoxGroup element) => element.groupName == "CardSwipe"),
					isCrit = ((BaseState)this).RollCrit()
				};
				if (((EntityState)this).isAuthority)
				{
					EffectManager.SpawnEffect(cardSweepVFX, new EffectData
					{
						origin = ((EntityState)this).characterBody.transform.position,
						rootObject = ((EntityState)this).gameObject,
						rotation = ((EntityState)this).characterDirection.targetTransform.rotation,
						scale = 1f
					}, true);
				}
			}
		}

		public virtual void CardSweep()
		{
			if (Object.op_Implicit((Object)(object)passiveManager) && passiveManager.CardArt == 1 && ((EntityState)this).isAuthority && attack.Fire((List<HurtBox>)null))
			{
				((EntityState)this).healthComponent.AddBarrierAuthority(((EntityState)this).healthComponent.fullCombinedHealth * SweepShield * (float)attack.ignoredHealthComponentList.Count);
			}
		}

		private void Debugger()
		{
		}

		protected void Activate()
		{
			//IL_003d: Unknown result type (might be due to invalid IL or missing references)
			//IL_0042: Unknown result type (might be due to invalid IL or missing references)
