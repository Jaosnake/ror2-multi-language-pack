        "SS2_VOIDROCK_USED_NAME": "Tas de terre vide",
        "SS2_BIRTHRIGHT_CHEST_NAME_FORMAT": "Héritage de {0}",
        "SS2_BIRTHRIGHT_CHEST_CONTEXT": "Revendiquer l'héritage",
        "SS2_BIRTHRIGHT_UNCLAIMED_2P": "<style=cShrine>Il vous manque ce que vous cherchez.</style>",
        "SS2_BIRTHRIGHT_UNCLAIMED": "<style=cShrine>{0} n'a pas trouvé ce qu'il cherche.</style>",
        "SS2_BIRTHRIGHT_UNCLAIMED_DEAD": "<style=cShrine>Les morts ont une tâche a accomplir; réclamez ce qui est recherché.</style>",
        "SS2_BIRTHRIGHT_UNCLAIMED_REMOVED_2P": "<style=cShrine>Un accord a été conclus. Réclamez votre héritage.</style>",
        "SS2_BIRTHRIGHT_UNCLAIMED_REMOVED": "<style=cShrine>Un accord a été conclus. {0} doit réclamer son héritage.</style>",
        "SS2_BIRTHRIGHT_UNCLAIMED_RARE": "<style=cShrine>C'est injuste.</style>",
        "SS2_BIRTHRIGHT_OBJECTIVE": "{0} <style=cIsUtility>Héritage(s)</style> non réclamé",
        "SS2_PEDESTAL_NAME": "Piédestal",
        "SS2_PEDESTAL_CONTEXT": "Utiliser le socle",
        "SS2_PEDESTAL_DESCRIPTION": "Permet aux survivants d'échanger un objet sur le piédestal contre un autre de même rareté.",
        "SS2_PEDESTAL_LORE": "",
        "SS2_PEDESTAL_INTERACTION_HEADER": "Un commerce équitable ?",
        "SS2_AMBUSH_MESSAGE_SINGLE": "<style=cShrine>{0} a été pris en embuscade par des {1}s</color>.",
        "SS2_AMBUSH_MESSAGE_SINGLE_2P": "<style=cShrine>Vous avez été pris dans une embuscade tendue par des {1}s</color>.",
        "SS2_AMBUSH_MESSAGE_DOUBLE": "<style=cShrine>{0} a été pris en embuscade par les {1} et les {2}s</color>.",
        "SS2_AMBUSH_MESSAGE_DOUBLE_2P": "<style=cShrine>Vous avez été pris dans une embuscade tendue par des {1} et des {2}s</color>.",
        "SS2_ETHEREAL_WARNING2": "Cela augmentera la difficulté ! Êtes-vous sûr ?",
        "SS2_SHRINE_ETHEREAL_USE_MESSAGE_2P": "Vous avez amorcé le Bourgeon Éthéré...",
        "SS2_ITEM_AUGURY_NAME": "Augure",
        "SS2_ITEM_AUGURY_DESC": "Lorsque vous subissez <style=cIsHealth>{0}%</style> de votre <style=cIsHealth>santé maximale</style> en <style=cIsHealth>dégâts</style>, déclenchez une <color=#FFCCED>panne de courant</color> dévastatrice, tuant <style=cIsDamage>instantanément</style> tous les <style=cIsDamage>ennemis non-boss</style> pris dedans.",
        "SS2_ITEM_AUGURY_PICKUP": "<link=\"textWavy\">Pouvez-vous les entendre... ? Ils arrivent...</link>",
        "SS2_ITEM_AUGURY_LORE": "L'OREN WIP",
        "SS2_ITEM_SCAVENGERSFORTUNE_NAME": "Fortune du pillard",
        "SS2_ITEM_SCAVENGERSFORTUNE_DESC": "DESC EN-TRAVAIL",
        "SS2_ITEM_SCAVENGERSFORTUNE_PICKUP": "RAMASSAGE DES ENGRENAGES",
        "SS2_ITEM_SCAVENGERSFORTUNE_LORE": "L'OREN WIP",
        "SS2_ITEM_VOIDROCK_NAME": "Lien condamné",
        "SS2_ITEM_VOIDROCK_PICKUP": "<link=\"textWavy\">Nous vous attendions.</link>",
        "SS2_ITEM_VOIDROCK_DESC": "Devenez la proie des <style=cDeath>Survivants Némésis</style>.",
        "SS2_ITEM_VOIDROCK_LORE": "<style=cMono>Merci d'utiliser DataScraper (v3.1.53 - beta branch)\n$ Récupération de mémoire... fini.\n$ Résolution... fini.\n$ Recherche de données pertinentes...\n$ Recherche de données pertinentes - suite...\n$ Re-ch-- de- do--ées perti-i-i-i-i-...\n$ ...\n$ <color=#FFCCED>Que cherches-tu</color>\n$ <color=#FFCCED>Tu sais ce qui leur est arrivé</color>\n$ <color=#FFCCED>donc pourquoi déterrer des tombes</color>\n$ <color=#FFCCED>sachant que tu ne trouveras que misère</color>\n$ <color=#FFCCED>Est-ce l'espoir</color>\n$ <color=#FFCCED>Espère-tu qu'ils soient encore en vie</color>\n$ <color=#FFCCED>Parce que tu espères bien</color>\n$ <color=#FFCCED>Ils sont vivant</color>\n$ <color=#FFCCED>et tu les reverras</color>\n$ <color=#FFCCED><link=\"textShaky\">Très bientôt</link></color>\n$\nErreur !\nImpression du journal d'erreur...\n</style>\nLes données sont fortement chiffrées ou extrêmement corrompues. Considérez des solutions externes avant de retenter.",
        "SS2_ITEM_SHACKLEDLAMP_NAME": "Lampe hantée",
        "SS2_ITEM_SHACKLEDLAMP_PICKUP": "Tirez un projectile hanté tous les 5 usages de la compétence principale.",
        "SS2_ITEM_SHACKLEDLAMP_DESC": "Toutes les <style=cIsDamage>5 utilisations de la compétence principale</style>, tirez un projectile hanté infligeant des dégâts de base de <style=cIsDamage>200%</style> <style=cStack>(+200% par accumulation)</style>.",
        "SS2_ITEM_SHACKLEDLAMP_LORE": "\"Excusez-moi.\"\n\n\"Oui, par ici, s'il vous plaît. Je dois vous demander quelque chose\"\n\n\"Plus près, maintenant.\"\n\n\"J'ai besoin de votre aide. Cette lanterne que vous voyez devant vous n'est qu'une partie brisée d'un corps plus grand.\"\n\n\"Le voyage ? Ah, oui. Il sera long, mais ne vous inquiétez pas. Je vous guiderai où que vous deviez aller, et bien que cela puisse être rempli de dangers, ce ne sera rien que je ne puisse vous aider.\"\n\n\"Hm ? Qu'y a-t-il pour vous, dites-vous ?\"\n\n\"Oh, vous verrez. Votre récompense sera bien plus grande que vous ne pourriez l'imaginer. Une fois que j'aurai retrouvé ma splendeur complète, je vous protégerai. Je vous garderai en sécurité. Vous réchaufferai. Vous rendrai puissant. Toutes vos préoccupations seront consumées. Cela ne semble-t-il pas merveilleux ?\"\n\n\"Vous êtes d'accord ? Bien. Maintenant, prenez rapidement la lanterne.\"\n\n\"Nous avons un long voyage devant nous, mon ami.\"",
        "SS2_ITEM_STIRRINGSOUL_NAME": "Âme remuante",
        "SS2_ITEM_STIRRINGSOUL_DESC": "Les monstres vaincus laissent une <style=cIsUtility>âme</style> qui a une chance de <style=cIsUtility>{0}%</style> <style=cStack>(+{0}% par échec de lancer, réinitialisé en cas de réussite)</style> de <style=cIsUtility>faire apparaître un objet</style> lors de la récupération.",
        "SS2_ITEM_STIRRINGSOUL_PICKUP": "<link=\"textWavy\">Pour quoi est-ce que je me bats ?</link>",
        "SS2_ITEM_STIRRINGSOUL_LORE": "Un esprit de détermination...\n<link=\"textWavy\">...Un esprit à arrêter.</link>\nUne volonté inébranlable de survivre...\n<link=\"textWavy\">...Une volonté vacillante de survivre.</link>\n\nPrêt à profaner leur identité...\n<link=\"textWavy\">...Prêt à profaner leur mémoire.</link>\nPrêt à sacrifier leur civilisation...\n<link=\"textWavy\">...Prêt à sacrifier leur humanité.</link>\n\nJusqu'où iront-ils pour vivre ?\n<link=\"textWavy\">Jusqu'où iront-ils pour s'auto-détruire ?</link>\nJusqu'où iront-ils pour échapper ?\n<link=\"textWavy\">Jusqu'où iront-ils pour détruire ?</link>\n\nTout au nom de la préservation de soi...\n<link=\"textWavy\">...Tout au nom du narcissisme.</link>\nTout pour une espérance incertaine...\n<link=\"textWavy\">...out pour une chance nulle.</link>\n\nQue se passerait-il s'ils avaient une opportunité ?\n<link=\"textWavy\">Que se passerait-il s'ils avaient un allié ?</link>\nQue se passerait-il si leur feu était attisé ?\n<link=\"textWavy\">Que se passerait-il s'ils étaient trompés par de faux espoirs ?</link>\n\nPeut-être devraient-ils avoir une chance.\n<link=\"textWavy\">Peut-être devraient-ils avoir de la force.</link>\nPeut-être devraient-ils avoir une offre.\n<link=\"textWavy\">Peut-être devraient-ils être pris en premier.</link>",
        "SS2_ITEM_MOXIE_NAME": "<color=#FFCCED>Moxie</color>",
        "SS2_ITEM_MOXIE_DESC": "Augmente toutes les <style=cIsUtility>statistiques</style> de <style=cIsUtility>50%</style> pendant les <color=#FFCCED>tempêtes</color>.",
        "SS2_ITEM_MOXIE_PICKUP": "<color=#FFCCED>Combien de plus ?</color>",
        "SS2_ITEM_MOXIE_LORE": "Eh ! Toi là ! Dans ce fichier ! Tu ne devrais probablement pas être là... Reste tranquille, d'accord ?",
        "SS2_ITEM_REMUNERATION_NAME": "Rémunération",
        "SS2_ITEM_REMUNERATION_DESC": "Un <style=cIsUtility>choix</style> entre trois <style=cIsHealth>objets puissants</style> apparaît à proximité au <style=cIsUtility>début de chaque niveau</style>.",
        "SS2_ITEM_REMUNERATION_PICKUP": "<link=\"textWavy\">... À quel prix ?...</link>",
        "SS2_ITEM_REMUNERATION_FAILURE": "<color=#f4adfa><link=\"textWavy\">Que ce souvenir...</link></color>",
        "SS2_REMUNERATION_TERMINAL_NAME": "Piédestal",
        "SS2_REMUNERATION_TERMINAL_CONTEXT": "<link=\"textWavy\">Valider la transaction</link>",
        "SS2_ITEM_REMUNERATION_LORE": "<link=\"textShaky\">Quel est ton héritage ?</link>\n\nRien d'autre que de mesquines vengeances.\n\n<link=\"textShaky\">Quelle est ton identité ?</link>\n\nRien d'autre qu'un nom prononcé avec dégoût.\n\n<link=\"textShaky\">Que veux-tu ?</link>\n\nRien d'autre qu'un nouveau dessein.\n\n<link=\"textShaky\">De quoi as-tu besoin ?</link>\n\nRien d'autre que des armes en lesquelles j'ai confiance.\n\n<link=\"textShaky\">Alors, où iras-tu ?</link>\n\nPartout où tu me pousseras.\n\n<link=\"textShaky\">Et que feras-tu ?</link>\n\nTout ce que tu dis avoir besoin.\n\n<link=\"textShaky\">C'est tout, alors ?</link>\n\nSi tu le dis ainsi.\n\n<link=\"textShaky\">Alors va là-bas, et meurs.</link>\n\n...\n\nTant que tu me paies.\n\n",
        "SS2_ITEM_BLEEDOUT_NAME": "Saignement",
        "SS2_ITEM_BLEEDOUT_PICKUP": "En mourant, entrez dans un état d'agonie. Se recharge avec le temps.",
        "SS2_ITEM_BLEEDOUT_DESC": "En subissant des <style=cIsHealth>dégâts mortels</style>, saignez pendant <style=cIsHealth>100%</style> de votre <style=cIsHealth>santé maximale</style>. Se recharge toutes les <style=cIsUtility>4</style> minutes <style=cStack>(-20% par cumul)</style>.",
        "SS2_ITEM_BLEEDOUT_LORE": "???",
        "SS2_ITEM_DEBUFFMISSILES_NAME": "Missiles d'affaiblissement",
        "SS2_ITEM_DEBUFFMISSILES_PICKUP": "Chance de tirer un éclat du vide lors d'un coup. La chance augmente par affaiblissement.",
        "SS2_ITEM_DEBUFFMISSILES_DESC": "Pour chaque <style=cIsDamage>affaiblissement</style> sur un ennemi, gagnez <style=cIsDamage>3%<style=cStack> (+1% par cumul)</style></style> de chance de tirer un éclat du vide infligeant <style=cIsDamage>400%</style> de dégâts TOTAL.",
        "SS2_ITEM_DEBUFFMISSILES_LORE": "???",
        "SS2_ITEM_ELITEDAMAGEBONUS_NAME": "Bonus anti-élite",
        "SS2_ITEM_ELITEDAMAGEBONUS_PICKUP": "Réduit les temps de recharge de vos compétences lorsque vous attaquez des monstres d'élite.",
        "SS2_ITEM_ELITEDAMAGEBONUS_DESC": "Frapper un monstre d'élite avec une <style=cIsUtility>compétence</style> a <style=cIsUtility>30%</style> <style=cStack>(+10% par cumul)</style> de chance de <style=cIsUtility>réduire vos temps de recharge</style> de <style=cIsUtility>0,5</style> seconde.",
        "SS2_ITEM_ELITEDAMAGEBONUS_LORE": "???",
        "SS2_ITEM_HITLIST_NAME": "Liste noire",
        "SS2_ITEM_HITLIST_PICKUP": "Attaquez les ennemis marqués pour gagner de l'or et un bonus de dégâts permanent à la mort.",
        "SS2_ITEM_HITLIST_DESC": "Toutes les <style=cIsUtility>30</style> <style=cStack>(-20% par cumul)</style> secondes, <style=cIsDamage>marquez</style> un ennemi. Tuer des ennemis <style=cIsDamage>marqués</style> augmente vos <style=cIsDamage>dégâts de façon permanente</style> de <style=cIsDamage>2%</style>.",
        "SS2_ITEM_HITLIST_LORE": "???",
        "SS2_ITEM_ITEMONBOSSKILL_NAME": "Butin de boss",
        "SS2_ITEM_ITEMONBOSSKILL_PICKUP": "Les boss dropent des objets.",
        "SS2_ITEM_ITEMONBOSSKILL_DESC": "Les boss droppent un <style=cIsUtility>objet</style> à leur mort. <style=cStack>(La rareté de l'objet augmente par cumul)</style>",
        "SS2_ITEM_ITEMONBOSSKILL_LORE": "???",
        "SS2_ITEM_ITEMONELITEKILL_NAME": "Butin d'élite",
        "SS2_ITEM_ITEMONELITEKILL_PICKUP": "Les élites dropent des objets.",
        "SS2_ITEM_ITEMONELITEKILL_DESC": "Les élites ont <style=cIsUtility>6%</style><style=cStack> (+2% par cumul)</style> de chance de dropper un <style=cIsUtility>objet</style> à leur mort.",
        "SS2_ITEM_ITEMONELITEKILL_LORE": "???",
        "SS2_ITEM_MAXHPONKILL_NAME": "Santé éternelle",
        "SS2_ITEM_MAXHPONKILL_PICKUP": "Tuer un ennemi augmente votre santé maximale de façon permanente.",
        "SS2_ITEM_MAXHPONKILL_DESC": "Tuer un ennemi augmente votre <style=cIsHealing>santé de façon permanente</style> de <style=cIsHealing>2</style> <style=cStack>(+1 par cumul)</style>.",
        "SS2_ITEM_MAXHPONKILL_LORE": "???",
        "SS2_ITEM_OPTIONFROMCHEST_NAME": "Choix généreux",
        "SS2_ITEM_OPTIONFROMCHEST_PICKUP": "Les coffres offrent un choix entre 3 objets.",
        "SS2_ITEM_OPTIONFROMCHEST_DESC": "Les coffres ont <style=cIsUtility>50%</style> de chance d'offrir un choix entre <style=cIsUtility>3</style> objets. <style=cStack>(La rareté des objets augmente par cumul)</style>",
        "SS2_ITEM_OPTIONFROMCHEST_LORE": "???",
        "SS2_ITEM_SCRAPFROMCHEST_NAME": "Feraille bonus",
        "SS2_ITEM_SCRAPFROMCHEST_PICKUP": "Les coffres dropent de la ferraille supplémentaire.",
        "SS2_ITEM_SCRAPFROMCHEST_DESC": "Les coffres ont <style=cIsUtility>33%</style><style=cStack> (+11% par cumul) </style>de chance de dropper de la <style=cIsUtility>ferraille</style> supplémentaire.",
        "SS2_ITEM_SCRAPFROMCHEST_LORE": "???",
        "SS2_ITEM_SHELLPIECE_NAME": "Éclat de carapace",
        "SS2_ITEM_SHELLPIECE_PICKUP": "Bloque les dégâts mortels. Se recharge à chaque étape.",
        "SS2_ITEM_SHELLPIECE_DESC": "En subissant des <style=cIsHealth>dégâts mortels</style>, devenez <style=cIsUtility>invulnérable</style> pendant <style=cIsUtility>3</style> secondes. Se recharge à chaque étape.",
        "SS2_ITEM_SHELLPIECE_LORE": "???",
        "SS2_ITEM_SHIELDGATE_NAME": "Barrière persistante",
        "SS2_ITEM_SHIELDGATE_PICKUP": "Tuer un ennemi augmente votre bouclier de façon permanente.",
        "SS2_ITEM_SHIELDGATE_DESC": "Tuer un ennemi augmente votre <style=cIsUtility>bouclier de façon permanente</style> de <style=cIsUtility>2</style> <style=cStack>(+1 par cumul)</style>.",
        "SS2_ITEM_SHIELDGATE_LORE": "???",
        "SS2_ITEM_SNAKEEYES_NAME": "Œil de serpent",
        "SS2_ITEM_SNAKEEYES_PICKUP": "Les autels accordent un taux de critique permanent. Un taux de critique supérieur à 100% a une chance de réduire vos temps de recharge.",
        "SS2_ITEM_SNAKEEYES_DESC": "Utiliser un autel augmente votre <style=cIsDamage>taux de critique de façon permanente</style> de <style=cIsDamage>2%<style=cStack> (+1% par cumul)</style></style>. Un <style=cIsDamage>taux de critique</style> supérieur à <style=cIsDamage>100%</style> accorde une chance de <style=cIsUtility>réduire vos temps de recharge</style> de <style=cIsUtility>1</style> seconde.",
        "SS2_ITEM_SNAKEEYES_LORE": "???",
        "SS2_ITEM_RELICOFDUALITY_NAME": "Relique de dualité",
        "SS2_ITEM_RELICOFDUALITY_DESC": "Les ennemis blessés les brûlent pendant <style=cMono>COMPRENDEZ CE MATH MDR</style> <style=cStack>(+quelque chose de% par pile)</style>. <style=cDeath>Être touché vous gèle pendant quelques secondes, idfk mdr, découvrez quand cet élément est implémenté</style>",
        "SS2_ITEM_RELICOFDUALITY_PICKUP": "Toutes les attaques brûlent les ennemis. <style=cDeath>Tous les dégâts vous gèlent.</style>",
        "SS2_ITEM_RELICOFDUALITY_LORE": "Hmm? Oh, jeune ! Tu es revenu plus tôt que prévu. As-tu terminé ta recherche?\n\nOh, mon cher. Jeune, pourquoi trembles-tu ? Quelque chose t'a-t-il fait mal ?\n\nTu as trouvé quelque chose qui t'a fait mal ? Hmm. Curieux. L'as-tu toujours avec toi ?\n\n...Je vois. Laisse-moi le regarder, alors. Viens maintenant, et montre-moi ce que tu as trouvé.\n\nHmm. Une chose étrange, celle-ci. Un feu flamboyant, mais froid au toucher. Comme c'est contre nature. Il y a cependant une certaine harmonie en cela. Alors que la chaleur apporte chaleur et vie, le froid la tempère et la maintient en échec. Mais de la même manière, ce froid amer peut apporter le désespoir et la mort sans la chaleur pour le contenir.\n\n...Oh, mais me voilà à nouveau à divaguer. Il faut prendre soin de toi, jeune. S'il te plaît, viens avec moi.",
        "SS2_ITEM_RELICOFEXTINCTION_NAME": "Relique de l'extinction",
        "SS2_ITEM_RELICOFEXTINCTION_DESC": "DESC EN-TRAVAIL",
        "SS2_ITEM_RELICOFEXTINCTION_PICKUP": "Un trou noir vous suit en permanence, infligeant des dommages extrême, MAIS il peut vous blesser.",
        "SS2_ITEM_RELICOFEXTINCTION_LORE": "L'OREN WIP",
        "SS2_ITEM_RELICOFFORCE_NAME": "Relique de la force",
        "SS2_ITEM_RELICOFFORCE_DESC": "Toutes les attaques frappent <style=cIsDamage>1</style> <style=cStack>(+1 par cumul)</style> fois supplémentaire pour <style=cIsDamage>{1}%</style> de dégâts TOTAL. Les <style=cIsUtility>attaques consécutives</style> sur le même ennemi augmentent les dégâts infligés de <style=cIsDamage>{1}%</style>, jusqu'à un maximum de <style=cIsDamage>{2}%</style> de dégâts TOTAL. <style=cDeath>Réduit la vitesse d'attaque et augmente les temps de recharge des compétences de {0}%</style> <style=cStack>(-{0}% par cumul)</style>.",
        "SS2_ITEM_RELICOFFORCE_PICKUP": "Toutes les attaques frappent une fois de plus. <style=cDeath>Réduction de la vitesse d'attaque et augmentation des temps de recharge des compétences</style>.",
        "SS2_ITEM_RELICOFFORCE_LORE": "Ah, jeune ! Tu es revenu une fois de plus, avec ce qui semble être un sac complet, aussi ! Plein de récupérations, n'est-ce pas ?\n\nHmm. Le sac est lourd, mais il est presque vide. Tu... Tu ne me caches pas quelque chose, jeune ?\n\n...Tu as trouvé quelque chose de très lourd. Je comprends. Pardonne-moi pour mes soupçons. Montre-moi cette chose que tu as trouvée.\n\nAh ! Tu as raison, jeune. Cette chose est petite, mais difficile à tenir. Elle se brise et se fragmente, et chaque morceau est aussi lourd que le tout. Quelle chose remarquable, cela !\n\nJe vais le mettre avec les autres choses merveilleuses que tu as trouvées. Une chose comme ça pourrait être dangereuse si elle tombait entre de mauvaises mains. Quant à toi, jeune... Hmm, je pense que quelques réparations pour ton sac s'imposent. Viens avec moi.",
        "SS2_ITEM_RELICOFMASS_NAME": "Relique de la masse",
        "SS2_ITEM_RELICOFMASS_DESC": "<style=cIsHealing>Augmente la santé maximale</style> de <style=cIsHealing>{0}%</style> <style=cStack>(+{0}% par cumul)</style>. <style=cDeath>Diminue l'accélération et la décélération</style> d'un facteur de <style=cDeath>{1}</style> <style=cStack>(+{1} par cumul)</style>.",
        "SS2_ITEM_RELICOFMASS_PICKUP": "Doublez votre santé maximale. <style=cDeath>Vos mouvement ont de l'élan</style>.",
        "SS2_ITEM_RELICOFMASS_LORE": "Ah, bienvenue de nouveau ! Jeune, qu'as-tu trouvé ?\n\nHmmm. Encore des trouvailles de la lande dévastée ? Très bien. Tu peux garder ces choses, si tu le souhaites. As-tu trouvé autre chose ?\n\nAh, tu en as trouvé ? Montre-le moi alors, jeune.\n\nOh ! Cette forme que tu as trouvée ! Elle est robuste, mais pas loyale. Puissante, mais en même temps aussi fragile. C'est une forme singulière, pour le moins qu'on puisse dire. Où as-tu trouvé cela, jeune ?\n\n...Tu l'as trouvé sur la planète ? Hmm. Inquiétant. Cela n'a pas été créé par ces gens du sable. Trop complexe, trop puissant. Ni par ces Sauriens. Dis-moi, jeune, tu ne l'as pas volé, n'est-ce pas ?\n\n...Tu ne l'as pas fait. Je vois. Très bien. J'aimerais garder cette forme. Cette forme est dangereuse si on ne la comprend pas.\n\nOh, mon jeune, ne sois pas si attristé. Cette forme est remarquable, et je salue ton travail indépendamment de cela. Je veux simplement la garder en sécurité. Tiens, peut-être qu'une récompense s'impose. Viens avec moi.",
        "SS2_ITEM_RELICOFTERMINATION_NAME": "Relique de la terminaison",
        "SS2_ITEM_RELICOFTERMINATION_DESC": "Toutes les <style=cIsUtility>{0} secondes</style>, accorde un bonus qui <style=cIsDamage>marque</style> le prochain ennemi apparaissant. S'il est vaincu dans les <style=cIsUtility>30 secondes</style> <style=cStack>(-10% par cumul)</style>, il <style=cIsDamage>laisse tomber un objet</style> <style=cStack>(la rareté de l'objet augmente avec le cumul)</style> ; sinon, il ne laisse <style=cIsDamage>rien</style> tomber et retarde la prochaine marque. <style=cDeath>Les ennemis marqués ont des statistiques significativement augmentées</style>.",
        "SS2_ITEM_RELICOFTERMINATION_PICKUP": "Toutes les {0} secondes, marque un ennemi et le renforce. S'il est vaincu à temps, il laisse tomber un objet ; sinon, il ne laisse rien tomber.",
        "SS2_ITEM_RELICOFTERMINATION_LORE": "Jeune ! Ah, je suis tellement excitée de te voir revenir ! As-tu trouvé quelque chose de nouveau ?\n\nOh ? Tu as trouvé ! Montre-moi, petite. Il n'y a pas besoin d'être timide.\n\nHm... Qu'as-tu trouvé cette fois-ci ? C'est solide et creux, mais quand tu le secoues... ça glougloute, comme une noix de pomme trop mûre. Quelle forme étrange avons-nous ici...\n\nOh ? Oh mon. Tu as été poursuivi par un monstre, dis-tu... Il ne t'a pas suivi ici, n'est-ce pas ?\n\n...Il ne l'a pas fait. Mais bien sûr, il serait difficile de nous trouver ici, n'est-ce pas, jeune ?\n\nIci, je vais l'emporter. Quelque part où il ne peut amener aucun monstre jusqu'à nous.\n\n...Je comprends. Il est normal d'avoir peur parfois, mais tu ne peux pas laisser cela te submerger. Ne serait-ce pas cruel pour un autre vagabond de trouver cette forme et de souffrir considérablement à cause d'elle ?\n\nNous serons en sécurité ici, jeune. Viens avec moi. Tu dois avoir faim après être resté dehors si longtemps.",
        "SS2_ITEM_RELICOFTERMINATION_PREFIX": "Borne {0}",
        "SS2_ITEM_RELICOFECHELON_NAME": "Relique d'échelon",
        "SS2_ITEM_RELICOFECHELON_DESC": "Gagnez {1} (+{1} par cumul) de dégâts de base et {2} (+{2} par cumul) de santé de base pendant {3} secondes à l'utilisation. Utiliser un équipement augmente définitivement son temps de recharge de {0}%.",
        "SS2_ITEM_RELICOFECHELON_PICKUP": "Obtenez un énorme bonus lors de l'utilisation d'un équipement. <style=cDeath>L'utilisation d'un équipement augmente définitivement son temps de recharge</style>.",
        "SS2_ITEM_RELICOFECHELON_LORE": "Non non, Jeune, tu es là trop tôt ! Je n'ai pas le temps de me préparer. S'il te plaît... Reviens plus tard.",
        "SS2_ITEM_PRIMAL_BIRTHRIGHT_NAME": "Héritage primordial",
        "SS2_ITEM_PRIMAL_BIRTHRIGHT_DESC": "Accorde <style=cIsUtility>{0}</style> <style=cStack>(+{1} par cumul)</style> Coffre légendaire <style=cIsUtility>à chaque niveau</style>, <style=cDeath>mais vous ne pouvez pas partir sans récuperer votre héritage</style>.",
        "SS2_ITEM_PRIMAL_BIRTHRIGHT_PICKUP": "Accorde un coffre légendaire à chaque niveau, <style=cDeath>mais vous ne pouvez pas partir sans récuperer votre héritage</style>.",
        "SS2_ITEM_PRIMAL_BIRTHRIGHT_LORE": "Les symboles de ce parchemin vous sont étranger. Vous ne comprenez pas ce qu'ils veulent dire, mais d'une certaine manière, vous comprenez leur sens. Le pouvoir. La volonté. L'autorité, et un message. \n\n\"Le droit de régner est remporté par la force et par l'ingéniosité, et uniquement par ça. Il ne peut être obtenu d'une autre manière. Ni par le sang, ni par la naissance. Seul la force se justifie.\"\nVous détournez du regard. Les lumières vacillantes de la coque projetaient des formes étranges sur l'éclat. Des ombres reflétées sur sa lueur, s'unissant en formes qui s'unissent en figures. Deux ombres errent sans but dans ce reflet, contre ce fond d'aube. Des ombres, courtes et trapues. Une graine tombe dans les cheveux de l'un d'eux, qui en rigole et la plante dans le sol. Un autre graine tombe dans la main de l'autre. Il l'ouvre délicatement, afin d'apprendre qu'est ce que cela donnera.\n\nLes ombres s'élargissent tandis que le soleil glisse sur le ciel. Des ombres, longues et imposante contre le crépuscule. Parfaitement positionnée, comme un sinistre portail vers la lumière.\n\nUne des ombres grandit plus vite, s'élargissant jusqu'à recouvrir le monde d'une cape de noirceur. L'ombre solitaire s'écrase contre sa prison, méconnaissable face a l'océan de noirceur, refusant fermement de disparaître. Une ombre reste dans la lumière. Il se dresse face à l'aube, éclipsant sa lumière. Des rayons du soleil d'or l'enlancent, formant une auréole pour l'ombre. Nettement dressé face au monde l'entourant- aveuglant, brûlant, informe. Égoïste. Il ne bouge pas\n\nVous plissez les yeux, et les symboles revêtent une nouvelle signification.\n\n\"Ce n'est pas juste.\"",
        "SS2_ITEM_ARMEDBACKPACK_NAME": "Sac à dos armé",
        "SS2_ITEM_ARMEDBACKPACK_DESC": "Chance en cas de dégats subis de lancer un missile infligeant <style=cIsDamage>{0}%</style> <style=cStack>(+{0}% par cumul)</style> de dégâts de base. La chance augmente avec les dégâts subis.",
        "SS2_ITEM_ARMEDBACKPACK_PICKUP": "Lance un missile en cas de dégâts importants reçu.",
        "SS2_ITEM_ARMEDBACKPACK_LORE": "Commande : Sac à dos militarisé marqué pour le retour\nNuméro de suivi : 823****\nLivraison estimée : 13/02/2056\nMode d'expédition : Standard\nAdresse de livraison : 17 Yule Road, Livingrock, Terre\nDétails de l'envoi :\n\nDéclenchement accidentel lors d'une randonnée. Préparez vos avocats.",
        "SS2_ITEM_BLOODTESTER_NAME": "Test sanguin cassé",
        "SS2_ITEM_BLOODTESTER_DESC": "Toutes les 30 secondes, récupérez rapidement 15 PV (+15 par cumul) pour chaque tranche de 25 pièces d’or possédées. S’adapte avec le temps.",
        "SS2_ITEM_BLOODTESTER_PICKUP": "Soigne périodiquement en fonction de votre or.",
        "SS2_ITEM_BLOODTESTER_LORE": "Retour : Test sanguin cassé\nNuméro de Suivi : 288*****\nLivraison estimée : 17/06/2056\nMode d'expédition : Prioritaire\nAdresse de livraison : Siège social du Centre Pharmaceutique Dionysos, Pluto\nDétails de l'envoi :\n\nOn va avoir besoin de réparer celui-la avant que ça ne fasse plus de mal que de bien. Ce machin ne fait que donner de mauvais résultats à chaque fois que le MED-E l'utilise. Non seulement ça bloque les opérations, mais en plus on doit rembourser chaque clients ayant reçu un faux diagnostic et ayant été piqué pour rien. On peut même pas rejeter la faute sur le client, comme tout est envoyé sur les serveurs. On doit arrêter de dépenser tout ce fric, Sinon on dépose le bilan au prochain trimestre.\n",
        "SS2_ITEM_COFFEEBAG_NAME": "Sachet de café",
        "SS2_ITEM_COFFEEBAG_DESC": "En cas d'attaque réussie, <style=cIsDamage>{0}%</style> de chance de lâcher une graine de café qui donne un bonus de <style=cIsDamage>{1}% de vitesse d'attaque</style> et <style=cIsUtility>de vitesse de déplacement</style> pour <style=cIsUtility>{3}</style> <style=cIsUtility>secondes</style>. Limite maximale de <style=cIsDamage>40%<style=cStack> (+40% par cumul)</style></style>.",
        "SS2_ITEM_COFFEEBAG_PICKUP": "Chance de lâcher des graines de café à chaque coup.",
        "SS2_ITEM_COFFEEBAG_LORE": "Commande : Café\nNuméro de suivi : 917****\nLivraison estimée : 06/12/2056\nMode d'expédition : Standard\nAdresse de livraison : 4410 New Lane, Kentucky, Terre\nDétails de l'envoi :\n\nSalut, Maman !\n\nJ'ai été en voyage, tout comme tu l'as fait dans ta jeunesse... Je me souviens de toutes les histoires que tu me racontais quand tu avais mon âge. Aller dans des endroits comme la Jamaïque, la Roumanie, pratiquement partout sur Terre ! J'espère pouvoir visiter la maison bientôt pour que je puisse te parler de tous les endroits où je suis allé.\n\nJe me souviens qu'il y avait ce café génial que tu nous prenais chez nous... c'était le \"Neik Dark Roast\", non ? Quoi qu'il en soit, il y a cet endroit génial sur Titan qui cultive son propre café, et c'est vraiment le meilleur ! Cela me rappelle d'être chez nous avec toi.\n\nJ'espère te voir bientôt. Tu me manques, et les chats me manquent. Eleni te salue, et j'ai hâte de tout te raconter !\n\nAvec amour, Hanan\n",
        "SS2_ITEM_DETRITIVETREMATODE_NAME": "Trématode détritivore",
        "SS2_ITEM_DETRITIVETREMATODE_DESC": "Les ennemis en dessous de <style=cIsDamage>{0}% <style=cStack>(+{1}% par cumul)</style> de PV</style> sont <style=cIsDamage>infesté</style>, qui inflige <style=cIsDamage>{2}%</style> de dégâts de base <style=cStack>(+{2}% par cumul)</style> par seconde.",
        "SS2_ITEM_DETRITIVETREMATODE_PICKUP": "Les ennemis ayant une santé faible subissent des dégâts continus jusqu'à leur mort.",
        "SS2_ITEM_DETRITIVETREMATODE_LORE": "<style=cMono>$ Transcription de l'image... terminée.\n$ Résolution... terminée.\n$ Sortie des chaînes de texte... terminée.\nComplet!\n\n\n</style>Ceci est le carnet de bord de D. Furthen, naturaliste à bord de l'UES [Censuré], en collaboration avec le programme en cours de recherche et de documentation de la vie extraterrestre de l'UES. Cette entrée a été rédigée au Point Sigma, lors d'une expédition dans les jungles denses de Cornea III.\n\n---------------------\n\nJ'ai rencontré mon premier échantillon de vie extraterrestre sur cette planète ! Et quelle merveille c'est. L'échantillon ressemble à un ver rond terrestre, mais de taille significativement plus grande. J'ai attribué leur nom commun de 'Trématode détritivore', et je décrirai leurs propriétés ci-dessous.\n\n• D'environ deux pouces de diamètre, et variant en taille d'environ quatre pouces à un pied et demi de long. Coloration blanche.\n\n• Ces trématodes ont été trouvés en train de se nourrir d'un tas de viande pourrissante dans une caverne humide. La viande était d'origine indéterminée, mais la présence d'autres animaux plus grands est néanmoins excitante.\n\n• En ramassant une masse de viande pourrissante, les trématodes ont rapidement réagi au mouvement et ont commencé à s'agiter, avant de se détendre lentement. Le garde qui était avec moi, Chevry, je crois, était dégoûté.\n\n• En touchant l'un d'eux avec une main non gantée pour sentir leur texture, l'un des trématodes s'est accroché à ma paume et a commencé à mordre. C'était extrêmement douloureux, tant d'avoir le trématode sur ma main que lorsque Chevry l'a coupé. Malgré cela, à part une légère entaille sur ma paume, je pense que je vais bien.\n",
        "SS2_ITEM_DIARY_NAME": "Journal vide",
        "SS2_ITEM_DIARY_DESC": "En entrant dans un niveau, <style=cIsUtility>obtenez {0} niveaux d'expérience</style> et <style=cIsUtility>consommez cet objet.</style>",
        "SS2_ITEM_DIARY_PICKUP": "Gagnez des niveaux d'expérience bonus en changeant de niveau.",
        "SS2_ITEM_DIARY_LORE": "<style=cMono>Transmission complète des images de vidéosurveillance de la section du couloir 14-B.\n\nImpression...\n\n</style>\"Alors ce livre est la seule chose dans le conteneur de stockage ?\"\n\"À peu près. Mis à part quelques vieux meubles, c'est tout.\"\n\"Alors, quel est le truc avec ce livre ? Si c'est tout ce que nous avons, il ferait mieux d'être bon.\"\n\"C'est un journal, je pense. Initialement rédigé par un certain Alan Howizer, il y a environ 26 ans. Il avait l'air d'être quelqu'un de plutôt intelligent, il disait qu'il travaillait dans une usine d'essais chimiques sur Terre.\"\n\"C'est tout ? C'est juste le journal d'un vieux mec ?\"\n\"Attends, il y a plus. En le feuilletant, environ cent pages plus loin, l'écriture a changé, et effectivement, il a été trouvé par une personne différente sur un banc dans un parc, apparemment. La même chose encore, environ trente pages plus tard. Et encore, après environ soixante-dix de plus. Et ça continue. Il y a une vingtaine de personnes différentes qui ont écrit dans ce journal, notant leurs souvenirs heureux, des mystères étranges, des énigmes, leurs réponses à ces énigmes, toutes sortes de choses.\"\n\"Hein. Cette chose doit être un véritable trésor de connaissances, non ? Une idée de qui l'a possédé en dernier ?\"\n\"Euh, oui, en fait. Quelqu'un nommé Chel était le dernier à écrire dans le livre, et il semble qu'il a laissé une adresse à l'intérieur de la couverture arrière. Pourquoi, à quoi tu penses ?\"\n\n<style=cMono>Fin de la section notable.</style>",
        "SS2_ITEM_DIARY_CONSUMED_NAME": "Journal écrit",
        "SS2_ITEM_DIARY_CONSUMED_DESC": "J'espère qu'ils vont l'adapter en film.",
        "SS2_ITEM_DIARY_CONSUMED_PICKUP": "J'espère qu'ils vont l'adapter en film.",
        "SS2_ITEM_DORMANTFUNGUS_NAME": "Fongus dormant",
        "SS2_ITEM_DORMANTFUNGUS_DESC": "<style=cIsHealing>Guérissez {0}%</style> <style=cStack>(+{1}% par cumul)</style> de votre santé maximale chaque seconde tout en sprintant.",
        "SS2_ITEM_DORMANTFUNGUS_PICKUP": "Régénérez de la santé tout en sprintant.",
        "SS2_ITEM_DORMANTFUNGUS_LORE": "<style=cMono>Documentation de la Station de Recherche Rook\n\nNotes de la semaine 3 sur le spécimen 18305 :</style>\n\nC'est l'un des échantillons les plus étranges que nous ayons trouvés. Ce champignon semble pousser sur presque tout dans le bâtiment si nous le laissons faire. Les murs, les sols, le plafond. Il semble avoir une préférence pour les objets en mouvement. Nos vêtements, les portes, et même certaines machines. Nous allons continuer à surveiller ce comportement.\n\n<style=cMono>Notes de la semaine 5 sur le spécimen 18305 :</style>\n\nLe sujet continue de s'attacher à des objets autour du laboratoire. Nous avons noté qu'il devient plus sain plus il bouge avec l'objet auquel il est attaché. Les tests semblent indiquer qu'il se nourrit de la chaleur créée par les mouvements, absorbée par ses racines. Nous allons tenter de le transplanter sur une machine en mouvement constant et surveiller sa santé.\n\n<style=cMono>Notes de la semaine 8 sur le spécimen 18305 :</style>\n\nNous avons laissé l'échantillon attaché à un ancien modèle de piston du laboratoire. En cas de tout dommage, nous avions l'intention de nous en débarrasser de toute façon. Nous l'avions attaché et l'avions laissé fonctionner les 3 semaines précédentes. De manière assez curieuse, le piston était censé tomber en panne dans ce laps de temps. Cependant, il semble que le sujet ait créé une relation symbiotique avec la machine. Nous allons continuer à surveiller ce comportement pour plus d'effets négatifs, et d'autres utilisations potentielles pour ce spécimen.\n",
        "SS2_ITEM_FORK_NAME": "Fouchette",
        "SS2_ITEM_FORK_DESC": "Augmentez vos dégâts de base de <style=cIsDamage>{0}%</style> <style=cStack>(+{0}% par cumul)</style>.",
        "SS2_ITEM_FORK_PICKUP": "Infligez davantage de dégâts.",
        "SS2_ITEM_FORK_LORE": "\"Tu ne peux pas être sérieux... Regarde, je sais qu'on a dit qu'on a besoin de tout ce qu'on peut avoir pour survivre, mais tu dois réaliser que je n'étais pas littéral à ce sujet !\"\n\nIl leva l'instrument en argent, une expression interrogative sur son visage. \"Que veux-tu dire ? Et si nous devons repousser un monstre ?\"\n\nUn bref silence.\n\n\"S'il te plaît, nous avons tous les deux vu les créatures sur cette planète. Ne me dis pas que tu pense que ça serait suffisant pour repousser quoi que ce soit ici.\"\n\nIl haussa les épaules. \"On ne sait jamais\", répondit-il en glissant la fourchette dans sa poche.\n",
        "SS2_ITEM_GUARDINGAMULET_NAME": "Amulette du gardien",
        "SS2_ITEM_GUARDINGAMULET_DESC": "Réduit les dégâts reçus dans le dos de <style=cIsDamage>{0}%</style> <style=cStack>(+{0}% par cumul)</style>",
        "SS2_ITEM_GUARDINGAMULET_PICKUP": "Réduit les dégâts reçus dans le dos",
        "SS2_ITEM_GUARDINGAMULET_LORE": "",
        "SS2_ITEM_MALICE_NAME": "Malice",
        "SS2_ITEM_MALICE_DESC": "Vos attaques infligent <style=cIsDamage>{0}%</style> des dégâts TOTAUX à jusqu'à <style=cIsDamage>{1}</style> <style=cStack>(+{1} par cumul)</style> ennemis supplémentaires dans un rayon de <style=cIsDamage>{2}m</style> <style=cStack>(+{3}m par cumul)</style>.",
        "SS2_ITEM_MALICE_PICKUP": "Vos attaques répandent les dégâts aux ennemis à proximité.",
        "SS2_ITEM_MALICE_LORE": "Tu es faible.\n\nPhysiquement ? Peut-être pas. Tu te bats pour survivre, et tu te bats assez bien. Mais mentalement ? Mon ami, tu es fragile. Tu te bats et tu tues, mais tu ressens des remords pour ce que tu tues. Pourquoi ? Les animaux, eux, ne ressentent aucun remords envers toi. Pour eux, tu n'es qu'une proie à traquer, ou un prédateur à fuir. Ces titans imposants ? Ils n'éprouvent aucune émotion, seulement une directive silencieuse de détruire. De te détruire.\n\nEt je te connais. Mon ami, tu ne veux pas être faible. Tu veux être puissant, aussi bien mentalement que physiquement. Ne ressens pas de pitié pour ces bêtes sans esprit, car c'est tout ce qu'elles sont. Bats-toi pour tuer, pas seulement pour survivre.\n\nMais la malveillance de l'homme ne peut te mener que jusqu'ici. Prends ceci. Sois attiré plus loin. Bats-toi pour tuer, et tue pour être craint.\n",
        "SS2_ITEM_MOLTENCOIN_NAME": "Pièce fondue",
        "SS2_ITEM_MOLTENCOIN_DESC": "En cas d'attaque réussie, <style=cIsDamage>{0}%</style> de chance d'<style=cIsDamage>enflammer</style> les ennemis pour <style=cIsDamage>{1}%</style> de dégâts de base <style=cStack>(+{1}% par cumul)</style> et de gagner <style=cIsUtility>${2}</style> <style=cStack>(+${2} par cumul. L'argent gagné augmente avec le temps)</style>.",
        "SS2_ITEM_MOLTENCOIN_PICKUP": "Chance d'enflammer et de gagner de l'or à chaque coup.",
        "SS2_ITEM_MOLTENCOIN_LORE": "Commande : Pièce Fondue\nNuméro de suivi : 446*****\nLivraison estimée : 22/09/2056\nMode d'expédition : Standard\nAdresse de livraison : Département de police vénitien, Brithen, Vénus\nDétails de l'envoi :\n\nSalut, j'ai trouvé une autre pièce de preuve liée à l'attentat à Parathan Square il y a quelques jours.\n\nDonc, tu sais comment les enquêteurs ont dû reporter leur analyse parce que la zone était beaucoup trop chaude ? Eh bien, l'espace s'est enfin refroidi ce matin, et j'ai réussi à trouver cette pièce de monnaie fondue collée au trottoir. Un test chimique rapide indique qu'elle est probablement principalement composée de tungstène avec un revêtement en or, et elle n'a pas non plus refroidi depuis que je l'ai décollée du sol.\n\nJe ne suis pas vraiment sûr de ce que cela pourrait signifier, cependant. Peut-être un porte-bonheur, ou une carte de visite ? De toute façon, je te l'envoie, parce que franchement, tu as besoin de toute l'aide possible. Je veux dire, 7 personnes mortes, 18 blessées, près d'un demi-million de dollars de dommages matériels, et tout ce que tu as comme preuve, c'est une pièce fondue et un café soufflé ? Eh bien, tu as ma sympathie, mec. Bonne chance pour l'affaire.\n",
        "SS2_ITEM_NANOBOTS_NAME": "Nanorobots",
        "SS2_ITEM_NANOBOTS_DESC": "Améliore l'<style=cIsUtility>armure de {0} <style=cStack>(+{0} par cumul)</style> points</style>. Quand utilisé dans un ferrailleur, <style=cIsUtility>transforme</style> à la place le ferrailleur en une copie de cet objet.",
        "SS2_ITEM_NANOBOTS_PICKUP": "Gagnez de l'armure. Se duplique quand ferraillé.",
        "SS2_ITEM_NANOBOTS_LORE": "comme le mème",
        "SS2_ITEM_NEEDLES_NAME": "Aiguilles",
        "SS2_ITEM_NEEDLES_DESC": "Lors d'une attaque réussie, <style=cIsDamage>{0}% de chance</style> de garantir un <style=cIsDamage>coup critique</style> sur un ennemi pour les <style=cIsDamage>{1}</style> <style=cStack>(+{1} per stack)</style> prochains coups.",
        "SS2_ITEM_NEEDLES_PICKUP": "Chance d'exposer les ennemis à des coups critiques garanti.",
        "SS2_ITEM_NEEDLES_LORE": "<style=cMono>Rapport d'incident de livraison de l'UES, ID 219560163 trouvé.\n\nLecture...</style>\n\n\"Le personnel de livraison Will Stetson, numéro 604, a été admis à l'infirmerie à bord de l'UES [REDACTED], il y a environ 22 heures, en raison de complications liées à la manipulation d'un comportement anormal d'un colis.\n\nEn faisant sa tournée, Will a remarqué qu'une des caisses avait soudainement fait un bruit sourd derrière lui. Craignant que quelqu'un ait essayé d'expédier un animal vivant selon le protocole standard, il a ressenti le besoin d'enquêter. Au lieu de cela, la caisse contenait un petit paquet en plastique contenant un grand nombre d'aiguilles à coudre particulièrement grandes, évidemment emballées beaucoup trop serrées pour la moindre sécurité.\n\nFinalement, et probablement dans un moment d'erreur de jugement, Will a décidé de toucher le paquet. Cela a provoqué l'explosion soudaine du paquet dans sa direction générale, laissant son côté avant supérieur couvert de profondes entailles. Il a eu de la chance que quelqu'un l'ait trouvé rapidement. Il semble aller bien, mais se remettra du choc et de la perte de sang pendant un certain temps.\"\n\nFin du rapport.",
        "SS2_ITEM_X4_NAME": "Stimulant X-4",
        "SS2_ITEM_X4_DESC": "Réduit le temps de recharge des compétences secondaires de <style=cIsUtility>{0}%</style> <style=cStack>(+{0}% par cumul)</style>. L'utilisation de votre compétence secondaire <style=cIsHealing>augmente la régénération de santé de base</style> de <style=cIsHealing>+{1} pv/s</style> <style=cStack>(+{2} pv/s par cumul)</style> pendant <style=cIsHealing>{3}</style> secondes.",
        "SS2_ITEM_X4_PICKUP": "Réduit légèrement le temps de recharge des compétences secondaires et soigne lors de leur utilisation.",
        "SS2_ITEM_X4_LORE": "Commande : Stimulant (X-4)\nNuméro de suivi : 369*****\nLivraison estimée : 12/04/2057\nMode d'expédition : Prioritaire\nAdresse de livraison : Roméo 33, Parc National de Batang Ai, Terre\nDétails de l'envoi :\n\nEnveloppé, manuel inclus. La machine montre-t-elle des symptômes d'un 540 ? Si c'est le cas, vous voudrez peut-être éviter d'utiliser plus de 100 ml de stimulant.\n\nSanté.",
        "SS2_ITEM_SANTAHAT_NAME": "Bonnet de Père Noël ?",
        "SS2_ITEM_SANTAHAT_DESC": "Semble joyeux.",
        "SS2_ITEM_SANTAHAT_PICKUP": "Je te tiens !",
        "SS2_ITEM_SANTAHAT_LORE": "Joyeux Noëlésis !",
        "SS2_INTERACTABLE_SANTAHAT_CONTEXT": "ATTRAPE LE ! ATTRAPE LE !",
        "SS2_ITEM_CHUNGUS_NAME": "Fongus gloussant",
        "SS2_ITEM_CHUNGUS_DESC": "Rester immobile pendant <style=cIsHealing>1</style> seconde crée une zone qui <style=cIsHealing>soigne</style> pour <style=cIsHealing>5.5%</style> <style=cStack>(+2.75% par cumul)</style> de votre <style=cIsHealing>santé</style> à chaque secondes vos alliés à moins de <style=cIsHealing>3m</style> <style=cStack>(+1.5m par cumul)</style>. <style=cIsVoid>Corrompt tous les Fongus dormant</style>.",
        "SS2_ITEM_CHUNGUS_PICKUP": "Soigne tout les alliés proche en restant immobile pendant 1 seconde. <style=cIsVoid>Corrompt tous les fongus dormant</style>.",
        "SS2_ITEM_CHUNGUS_LORE": "Les animaux vivent, et les animaux meurent. Ils prennent à la terre, et redonnent en proportion égale. Le cycle vicieux de la vie continue sa trajectoir oroboréen-\n\n-et pendant ce temps, le fongus glousse.\n\nPuis, l'Homme est arrivé. Il a construit des empires. Persistant a travers la paix et la prospérité, et a travers la guerre et la famine. Malgré tout, cet équilibre ne tient jamais. Les empires s'étendent, et les empires tombent-\n\n-et pendant ce temps, le fongus glousse.\n\nDes dieux peuvent naître. Des paradis peuvent être fondé. Cela n'a pas d'importance. Les liens de sang se brisant comme du verre, et la mort reigne même jusqu'à Arcadia. Des mondes entiers tombent en décrépitude-\n\n-et pendant tout ce temps, le fongus glousse.\n\nEn effet, rien n'est éternel. Les systèmes solaire, les galaxies, l'univers tout entier, même. Tout est soumis à l'entropie, si on leur accorde le temps. Tout est éphémère, tout retourne a poussière\n\n-et pendant ce temps, le fongus glousse.",
        "SS2_ITEM_UNIVERSALCHARGER_NAME": "Chargeur universel",
        "SS2_ITEM_UNIVERSALCHARGER_DESC": "Toutes les <style=cIsUtility>{0} secondes</style> <style=cStack>(-{1}% par cumul)</style>, <style=cIsUtility>Rafraîchit instantanément le temps de rechargement</style> de votre prochaine <style=cIsUtility>compétence hors-primaire</style>.",
        "SS2_ITEM_UNIVERSALCHARGER_PICKUP": "Rafraîchit périodiquement une compétence.",
        "SS2_ITEM_UNIVERSALCHARGER_LORE": "Prend en charge UESB-A à UESB-ZZ bla bla bla",
        "SS2_ITEM_URANIUMHORSESHOE_NAME": "Fer à cheval en uranium",
        "SS2_ITEM_URANIUMHORSESHOE_DESC": "Augmente la <style=cIsUtility>vitesse de déplacement</style> et la <style=cIsUtility>hauteur de saut</style> de <style=cIsUtility>{0}%</style> <style=cStack>(+{0}% par cumul)</style>.",
        "SS2_ITEM_URANIUMHORSESHOE_PICKUP": "Sautez plus haut, courez plus vite.",
        "SS2_ITEM_URANIUMHORSESHOE_LORE": "drôle",
        "SS2_ITEM_ICETOOL_NAME": "Piolet d'alpinisme",
        "SS2_ITEM_ICETOOL_DESC": "Tout en <style=cIsUtility>touchant un mur</style>, gagnez <style=cIsUtility>1</style> <style=cStack>(+1 par cumul)</style> saut supplémentaire.",
        "SS2_ITEM_ICETOOL_PICKUP": "Gagnez un saut en touchant un mur",
        "SS2_ITEM_ICETOOL_LORE": "",
        "SS2_ITEM_LIGHTBULB_NAME": "Ampoule miracle",
        "SS2_ITEM_LIGHTBULB_DESC": "Réduit les temps de chargement des compétences. Se brise quand faible en vie.",
        "SS2_ITEM_LIGHTBULB_PICKUP": "Réduit les temps de rechargement des compétences de <style=cIsUtility>8%</style> <style=cStack>(-8% par cumul)</style>. Tomber en dessous de <style=cIsHealth>25% de vos PV</style> <style=cIsUtility>casse</style> cet objet.",
        "SS2_ITEM_LIGHTBULB_LORE": "",
        "SS2_ITEM_LIGHTBULB_CONSUMED_NAME": "Ampoule cassée",
        "SS2_ITEM_LIGHTBULB_CONSUMED_DESC": "Restes d'une idée brillante.",
        "SS2_ITEM_LIGHTBULB_CONSUMED_PICKUP": "Restes d'une idée brillante.",
        "SS2_ITEM_BLASTKNUCKLES_NAME": "Poing explosif",
        "SS2_ITEM_BLASTKNUCKLES_DESC": "Les coups de vos <style=cIsUtility>compétences</style> dans un rayon de <style=cIsDamage>{0}m</style> feront <style=cIsDamage>détonner</style> les ennemis dans un cône infligeant <style=cIsDamage>{1}%</style> <style=cStack>(+{2}% par cumul)</style> de dégâts de base. Vous pouvez charger <style=cIsUtility>5</style> charges et vous en rechargez une toutes les <style=cIsUtility>5</style> secondes.",
        "SS2_ITEM_BLASTKNUCKLES_PICKUP": "Vos attaques à courte portée créent une explosion.",
        "SS2_ITEM_BLASTKNUCKLES_LORE": "\"Le meilleur combat que j'ai jamais gagné\"\n  - One-Arm Larry",
        "SS2_ITEM_CRYPTICSOURCE_NAME": "Source cryptique",
        "SS2_ITEM_CRYPTICSOURCE_DESC": "Lorsque vous arrêtez de courir, vous relâchez une <style=cIsDamage>salve d'énergie</style> dans un rayon de <style=cIsDamage>{0}m</style> <style=cStack>(+{1}m par cumul)</style> infligeant <style=cIsDamage>{2}%</style> <style=cStack>(+{2}% par cumul)</style> de dégats de base.",
        "SS2_ITEM_CRYPTICSOURCE_PICKUP": "Finir de courir libère une explosion d'énergie destructrice.",
        "SS2_ITEM_CRYPTICSOURCE_LORE": "",
        "SS2_ITEM_FIELDACCELERATOR_NAME": "Accélérateur de champ",
        "SS2_ITEM_FIELDACCELERATOR_DESC": "Après avoir vaincu le boss du téléporteur, augmentez le rayon du téléporteur de 20% (+20% par cumul) et tuer des ennemis confère +1% de charge du téléporteur.",
        "SS2_ITEM_FIELDACCELERATOR_PICKUP": "Tuer des ennemis réduit le temps de recharge du téléporteur.",
        "SS2_ITEM_FIELDACCELERATOR_LORE": "<style=cMono>//--AUTO-TRANSCRIPTION DE LA SALLE 1455A DE L'UES [Voyages en toute sécurité]--//</style>\n\n\"Tu as le dispositif ?\"\n\n\"Oui, il est juste ici.\"\n\n\"Il fonctionne, non ?\"\n\n\"Mmmhmm. À la perfection.\"\n\n\"Excellent. N'oublie pas, personne ne doit être au courant de ça.\"\n\n\"Oui, oui, je sais. Ces... autels, sur [SUPPRIMÉ], ont un potentiel fantastique. Une fois que nous les aurons analysés, les reproduire devrait être un jeu d'enfant. Ce sera une avancée scientifique massive.\"\n\n\"Bien. Reste discret, fais ton analyse et sors avant que quelqu'un ne devienne suspect.\"\n\n\"Entendu. Encore merci beaucoup pour ton aide.\"\n\n\"C'est rien. Du moment que tu me paies.\"\n\n\"Eh-heh, à propos de ça...\"",
        "SS2_ITEM_HOTTESTSAUCE_NAME": "Sauce la plus épicée",
        "SS2_ITEM_HOTTESTSAUCE_DESC": "Activer votre équipement <style=cIsDamage>enflamme</style> les ennemis dans un rayon de <style=cIsDamage>{0}m</style> pendant <style=cIsDamage>{1}</style> secondes, infligeant <style=cIsDamage>150% de dégâts de base</style> plus <style=cIsDamage>100% de dégâts par seconde</style> <style=cStack>(+50% par cumul)</style>.",
        "SS2_ITEM_HOTTESTSAUCE_PICKUP": "Activer votre équipement enflamme les ennemis proche.",
        "SS2_ITEM_HOTTESTSAUCE_LORE": "<style=cMono>//--Auto-Transcription de la pièce K3 (Cuisine, 3e étage) de l'Hôtel Kaymar--//</style>\n\nUn homme grand et mince entre dans la pièce, tenant une grande boîte en carton. \"Hey, CHEF. Comment ça va ?\" Il pose la boîte sur le comptoir. \"Bon, on a plein de nouvelles sauces avec lesquelles tu devras te familiariser. Je vais te les présenter maintenant, si ça ne te dérange pas.\" Le robot CHEF lui accorde son attention, mais continue de travailler.\n\nL'homme parcourt les rangées de bouteilles de différentes couleurs, expliquant au CHEF leurs noms, saveurs et utilisations en cuisine. Finalement, il s'arrête devant une bouteille de couleur rouge et hésite brièvement.\n\n\"...D'accord, maintenant. Cette bouteille ? Elle est sans étiquette pour une raison. Si tu reçois une commande indiquant que tu dois utiliser la \"<style=cDeath>Sauce la plus épicée</style>\" sur un plat, tu utilises cette bouteille. Mais NE L'UTILISE SOUS AUCUNE AUTRE CIRCONSTANCE. Je sais que parfois tu dois improviser pour finir un plat, mais tu ne devrais JAMAIS utiliser cette bouteille si c'est ce que tu fais. Tu comprends ?\"\n\nLe robot CHEF, toujours en train de travailler, fait un signe de tête affirmatif.\n\n\"Bien. J'attends de grandes choses de toi, CHEF\"\n\nLe robot CHEF fait de nouveau un signe de tête, et fait une pause brève dans son travail pour mettre les bouteilles à leurs emplacements appropriés.\n\n\"...Oh, et aussi ?\"\n\nLe robot CHEF fait une pause pour accorder à nouveau son attention à l'homme.\n\n\"S'il te plaît, ne casse pas cette bouteille. Je sais que tu es un robot et tout ça, mais je sais aussi que des accidents arrivent, et cet accident particulier pourrait laisser un trou dans le sol.\"\n\nLe robot CHEF fixe la bouteille brièvement, avant de la poser soigneusement à l'arrière du placard avec le reste des sauces.",
        "SS2_ITEM_HUNTERSSIGIL_NAME": "Sceau du chasseur",
        "SS2_ITEM_HUNTERSSIGIL_DESC": "Après être resté immobile pendant 1 seconde, créez une zone de 8m qui confère à tous les alliés 30 d’armure (+15 par cumul) et 30% de dégâts (+15% par cumul). La zone dure jusqu’à ce que vous la quittiez.",
        "SS2_ITEM_HUNTERSSIGIL_PICKUP": "Rester immobile confère un bonus d'armure et de dégâts.",
        "SS2_ITEM_HUNTERSSIGIL_LORE": "<style=cMono>Transcription audio complète à partir de l'enregistreur portable.\n\nImpression en cours...\n\n</style>\"Penses-tu qu'ils vont mordre à l'appât ?\"\n\"Ils vont devoir. On n'a pas d'autre option.\"\n\"Je pense toujours que risquer notre nourriture comme ça est trop dangereux.\"\n\"Si on n'essaie pas, on sera morts dans une semaine.\"\n\"Juste... assure-toi de ne pas gaspiller.\"\n\"Rien de plus que nos vies, au moins.\"\n\"...\"\n\"Ils sont là.\"\n\"Oh, bien. Abat-en un et sortons d'ici.\"\n\"Pas encore...\"\n\"Quoi ? C'est gaspiller notre nourriture d'attendre plus longtemps !\"\n\"Attends...\"\n\"Tire, mec, on n'a que ça !\"\n\"Presque...\"\n\"TIRE.\"\n\"Presque...\"\n\"TIRE OU DONNE-MOI LE FUSIL.\"\n\"...\"\n\"DONNE-LE MOI !\"\n\"Hé, fais AT-\"\n\n<style=cMono>Fin de l'enregistrement.</style>\n",
        "SS2_ITEM_JETBOOTS_NAME": "Bottes à réaction prototype",
        "SS2_ITEM_JETBOOTS_DESC": "Gagnez +1 saut supplémentaire qui enflamme les ennemis pour 500% de dégâts de base dans un rayon de 7,5m (+5m par cumul). Se recharge 5 secondes après l’atterrissage.",
        "SS2_ITEM_JETBOOTS_PICKUP": "Gagnez un saut explosif !",
        "SS2_ITEM_JETBOOTS_LORE": "Rapport pour l'autopsie des Hephaestus Metal Works\n\nEmplacement : Hephaestus Metal Works, Mars\nStatut de l'emplacement : Intérieur détruit par le feu\nVictimes : Le propriétaire, par le feu\nRapport sur place :\n\nJe pensais que la cause de l'incendie était le résultat d'une forge, d'un four, ou même d'une pause cigarette. Il n'y avait pas grand-chose de différent par rapport à n'importe quel autre atelier du même secteur. Beaucoup d'anciens types d'épées, d'armures, d'équipements agricoles, et ainsi de suite. Bien qu'il semblait que le propriétaire était un amateur lui-même, car il y avait ce qui semblait être quelques projets que l'on ne trouverait normalement pas là à l'arrière.\n\nUn bon nombre d'entre eux n'étaient rien de plus que des moteurs et du métal. Il semblait s'exercer à la création d'horlogerie. Mais il est finalement passé à des objets basés sur le carburant et le moteur. De vieilles tondeuses, des motos et des générateurs. Il est finalement passé aux systèmes de propulsion. De petits avions téléguidés, des hélicoptères, un vieux jetpack rouillé. Il semblait qu'il travaillait sur quelque chose, et nous avons découvert ce que c'était à l'arrière.\n\nIl y avait clairement un génie derrière lui. Il construisait une paire de bottes à réaction à partir de zéro. Elles n'avaient pas encore été produites, car les jetpacks faisaient bien le travail et les bottes ne pouvaient pas être aussi robustes et lourdes tout en fournissant la même poussée. Il semblait avoir la même pensée, car il les rendait plus solides pour sa protection, mais essayait de compenser en augmentant la puissance de la poussée. Le résultat a abouti à la chaleur qui s'est accumulée et a éclaté sous lui. Malheureusement, sa nature inventive lui a coûté son entreprise et sa vie.\n\nLa zone environnante n'a subi aucun dommage, donc l'atelier pourra peut-être être rénové bientôt. Les bottes ont été confisquées et sont en route pour être étudiées et mises hors service, et les articles restants de l'intérieur de l'atelier ont été envoyés à leurs proches.\n\nCela conclut mon rapport.",
        "SS2_ITEM_LIGHTNINGONKILL_NAME": "Man-o'-War",
        "SS2_ITEM_LIGHTNINGONKILL_DESC": "En tuant un ennemi, libère une <style=cIsDamage>décharge électrique</style> infligeant <style=cIsDamage>{0}% de dégâts de base</style> visant jusqu'à <style=cIsDamage>{1}</style> <style=cStack>(+{2} par cumul)</style> cibles à moins de <style=cIsDamage>{3}m</style> <style=cStack>(+{4}m par cumul)</style> mètres.",
        "SS2_ITEM_LIGHTNINGONKILL_PICKUP": "Crée une décharge d'électricité à chaque victime.",
        "SS2_ITEM_LIGHTNINGONKILL_LORE": "",
        "SS2_ITEM_LOWQUALITYSPEAKERS_NAME": "Haut-parleurs de mauvaise qualité",
        "SS2_ITEM_LOWQUALITYSPEAKERS_DESC": "Chance lorsque vous êtes touché d'<style=cIsDamage>étourdir</style> les ennemis dans un rayon de <style=cIsDamage>{0}m</style> <style=cStack>(+{1}m par cumul)</style>. La chance commence à <style=cIsDamage>10%</style> et augmente quand vos <style=cIsHealth>PV sont faible</style>.",
        "SS2_ITEM_LOWQUALITYSPEAKERS_PICKUP": "Etourdit les ennemis proches lorsque vous êtes touché.",
        "SS2_ITEM_LOWQUALITYSPEAKERS_LORE": "Retour : Haut-parleur polyvalent A-AMP 25 watts\nNuméro de suivi : 629********\nLivraison estimée : 14/03/2055\nMode d'expédition : Prioritaire\nAdresse de livraison : 444 Anthem Ln., Twin Cities, Earth\nRaison du retour :\n\nDésolé de vous causer des soucis, mon pote, mais lorsque je l'ai déballé et branché pour le tester, le son est sorti... brouillé ? Avec des interférences ? C'est difficile à décrire. Si je devais deviner, il a dû être endommagé pendant le transport. Je suppose que je suis content d'avoir opté pour la garantie.\n\nRemboursement :\nRemplacer : X",
        "SS2_ITEM_POISONOUSGLAND_NAME": "Glande neurotoxique",
        "SS2_ITEM_POISONOUSGLAND_DESC": "<style=cIsUtility>Déconcentre</style> les ennemis en réussissant une attaque pour <style=cIsUtility>2</style> <style=cStack>(+2 par cumul)</style> secondes, les faisant louper <style=cIsUtility>{0}%</style> de leurs attaques pour chaque <style=cIsDamage>malus</style> qu'ils ont.",
        "SS2_ITEM_POISONOUSGLAND_PICKUP": "Les malus infligé aux ennemis font rater leurs attaques.",
        "SS2_ITEM_POISONOUSGLAND_LORE": "",
        "SS2_MISSED_DAMAGE_HITMARKER": "LOUPÉ !",
        "SS2_ITEM_STICKYOVERLOADER_NAME": "Superchargeur collant",
        "SS2_ITEM_STICKYOVERLOADER_DESC": "<style=cIsDamage>{0}%</style> de chance d'attacher une <style=cIsDamage>bombe vivante</style> qui gagne <style=cIsDamage>{1}%</style> <style=cStack>(+{2}% par cumul)</style> de dégâts de base et <style=cIsDamage>{3}m</style> de rayon d'explosion par coups, jusqu'à <style=cIsUtility>20</style> <style=cStack>(+5 par cumul)</style> fois. La bombe explose après <style=cIsDamage>1</style> seconde sans développement.",
        "SS2_ITEM_STICKYOVERLOADER_PICKUP": "Vos attaques chargent une bombe vivante.",
        "SS2_ITEM_STICKYOVERLOADER_LORE": "",
        "SS2_ITEM_STRANGECAN_NAME": "Canette étrange",
        "SS2_ITEM_STRANGECAN_DESC": "À l'impact, <style=cIsDamage>10%</style> <style=cStack>(+5% par cumul)</style> de chance d'<style=cIsDamage>intoxiquer</style> un ennemi, infligeant <style=cIsDamage>50% de dégâts par seconde</style>. L'<style=cIsDamage>intoxication</style> se cumule jusqu'à 10 fois. Tuer des ennemis <style=cIsHealing>soigne</style> de <style=cIsHealing>10</style> <style=cStack>(+5 par cumul)</style> <style=cIsHealing>PV</style> par cumul d'<style=cIsDamage>intoxication</style>.",
        "SS2_ITEM_STRANGECAN_PICKUP": "Chance d'intoxiquer les ennemis, infligeants des dégâts sur la durée. Tuer un ennemi intoxiqué vous soigne.",
        "SS2_ITEM_STRANGECAN_LORE": "Deux silhouettes sont assises, l'une frissonnant parmi un océan de décombres dans un terrier gelé. Les seules lumières sont les maigres restes d'un feu et de vieux fils électriques qui crépitent. À peine une protection contre le froid mordant.\n\n\"Hey...\" Il lève les yeux, distraitement optimiste. \"Penses-tu qu'on s'en sortira un jour de cette planète ?\"\n\n\"Difficile à dire.\" Elle prend une bouchée d'une ration qu'elle a trouvée.\n\n\"Eh bien, il doit y avoir quelque chose qu'on a négligé, non ? Une méthode à laquelle on n'a tout simplement pas pensé encore ?\" Il se lève et commence à faire les cent pas anxieusement.\n\n\"C'est possible.\" Une autre bouchée.\n\n\"Peut-être qu'il y a des débris avec des pièces fonctionnelles qu'on n'a pas encore trouvés, ou un problème dans ceux actuels qu'on pourrait réparer ?\" Un éclat revient dans ses yeux, devenant plus optimiste et excité.\n\n\"C'est certainement possible.\" Une autre bouchée.\n\nIl s'arrête alors qu'une expression dégoûtée traverse son visage. \"Euh, pourrais-tu s'il te plaît m'aider à réfléchir à quelque chose au lieu de simplement manger ?\"\n\n\"Je ne m'en ferais pas pour ça.\" Une autre bouchée.\n\nSon dégoût cède rapidement la place à une frustration et une colère manifestes. \"Pourquoi pas ?! Tu ne veux pas sortir d'ici ?!\"\n\nElle soupire et passe une main dans ses cheveux. \"Eh bien, bien sûr. Mais ça ne veut pas dire qu'on doit stresser pour chaque petite chose. On est en vie, non ? On a de la chance d'avoir ça.\"\n\n\"Eh bien... Je suppose que tu as raison... Ce serait mal de s'énerver maintenant...\" Son expression se détend alors qu'il regarde de nouveau le sol.\n\n\"Tu vois ? Assieds-toi simplement, détends-toi, et laisse ma vieille réserve te réchauffer.\" Une autre bouchée, alors qu'elle lui passe la conserve.\n",
        "SS2_ITEM_WATCHMETRONOME_NAME": "Montre-métronome",
        "SS2_ITEM_WATCHMETRONOME_DESC": "Lorsque vous ne sprintez pas, chargez jusqu'à <style=cIsUtility>100%</style> d'augmentation de <style=cIsUtility>vitesse de sprint</style>, qui décroît en <style=cIsUtility>3s</style> <style=cStack>(+2s par cumul)</style>. Tant que l'effet est actif, vos compétences peuvent être utilisées en sprintant.",
        "SS2_ITEM_WATCHMETRONOME_PICKUP": "Accumulez un bonus de vitesse de déplacement lorsque vous ne courrez pas.",
        "SS2_ITEM_WATCHMETRONOME_LORE": "Commande : Montre-métronome cassée\nNuméro de suivi : 88******\nLivraison estimée : 14/04/2056\nMode d'expédition : Prioritaire\nAdresse de livraison : 33 Skyview Drive, Albumen, Venus\nDétails de l'envoi :\n\nSalut, c'est la montre métronome que je t'ai dit qui avait besoin de réparation. Apparemment, la chose déraille depuis quelques semaines maintenant, et moi et les gars ne pouvons pas enregistrer correctement avec elle qui accélère tout le temps. J'aimerais la récupérer assez rapidement, car utiliser le métronome intra-auriculaire me fait mal aux oreilles s'il est en place trop longtemps. Oh, et fais attention, aussi. La montre est un cadeau de mon vieux, et elle compte vraiment beaucoup pour moi. Merci d'avance !\n",
        "SS2_ITEM_RAINBOWROOT_NAME": "Racine arc-en-ciel",
        "SS2_ITEM_RAINBOWROOT_DESC": "Gagnez <style=cIsUtility>3</style> branches en orbite. Après avoir subi un dégât égal ou supérieur a 25% de vos PV, une branche se rompt, octroyant 25% de vos PV max en barrière. Les branches se rechargent après 20s.",
        "SS2_ITEM_RAINBOWROOT_PICKUP": "Une portion des dégâts entravée est octroyé sous forme de barrière",
        "SS2_ITEM_RAINBOWROOT_LORE": "Quelle genre d'arc-en-ciel pourrait être formé après une telle pluie ?",
        "SS2_ITEM_BABYTOYS_NAME": "Jouets pour bébés",
        "SS2_ITEM_BABYTOYS_DESC": "Perdez jusqu'à <style=cIsUtility>{0} <style=cStack>(+{0} par pile)</style> niveaux</style> tout en <style=cIsUtility>conservez toutes les statistiques</style>.",
        "SS2_ITEM_BABYTOYS_PICKUP": "Perdez {0} niveaux tout en conservant toutes les statistiques.",
        "SS2_ITEM_BABYTOYS_LORE": "Commande : Jouets pour bébés\nNuméro de suivi : 013*****\nLivraison estimée : 07/06/2056\nMode d'expédition : Haute priorité\nAdresse de livraison : 431, Golden Shore, Terre\nDétails de l'envoi :\n\nSalut chérie ! Je suis désolé de ne pas avoir pu venir, mais s'il te plaît, prends ces jouets pour ton bébé. Il est si petit, mais un jour, il pourrait être le prochain grand capitaine de l'UES, qui sait ! Je veux vraiment vous voir tous les deux dès que possible, les choses ont été difficiles ici depuis que je suis tombé malade et je ne veux pas mettre ton bébé en danger. Je t'aime, prends bien soin de vous, s'il te plaît !\n",
        "SS2_ITEM_COMPOSITEINJECTOR_NAME": "Injecteur composite",
        "SS2_ITEM_COMPOSITEINJECTOR_DESC": "Gagnez <style=cIsDamage>1 <style=cStack>(+1 par pile)</style> emplacements d'équipement supplémentaires</style>. Déclenchez tous vos équipements simultanément.",
        "SS2_ITEM_COMPOSITEINJECTOR_PICKUP": "Combinez les éléments d'équipement.",
        "SS2_ITEM_COMPOSITEINJECTOR_LORE": "",
        "SS2_ITEM_DROIDHEAD_NAME": "Tête de droïde",
        "SS2_ITEM_DROIDHEAD_DESC": "Tuer un ennemi d'élite fait apparaître un <style=cIsDamage>Drone de sécurité</style> <style=cStack>(+{0}% de dégâts de base par cumul)</style> pendant <style=cIsDamage>{1}s</style> <style=cStack>(+{2}s par cumul)</style>. Les drones invoqué <style=cIsUtility>héritent de l'effet d'élite</style> de l'ennemi d'élite vaincu.",
        "SS2_ITEM_DROIDHEAD_PICKUP": "Fait apparaître un drone temporaire après avoir tué un ennemi d'élite.",
        "SS2_ITEM_DROIDHEAD_LORE": "Commande : Robot de sécurité\nNuméro de suivi : 1138***\nLivraison estimée : 14/05/2056\nMode d'expédition : Prioritaire / Fragile\nAdresse de livraison : RaCom Robotics, Asimov, Mars\nDétails de l'envoi :\n\nC'était l'un des rares morceaux complets que nous avons pu récupérer parmi ces robots de sécurité volés... Ce groupe militant sur Pluton avait dérobé plusieurs de ces ER-14 et les utilisait dans leurs bases depuis un moment. Celui-ci en particulier, l'ER-14XPC5VVUFF, correspond aux modèles que vous aviez essayé de rappeler il y a quelque temps. Je ne connais pas toute l'histoire, mais je sais qu'il y avait une prime importante pour quiconque pourrait retrouver les restes de ce lot. Il y a d'autres vestiges aussi, mais ils sont beaucoup moins complets... Il ne devrait plus y avoir de danger, du moins. Faites-moi signe si vous voulez que ceux-ci soient également expédiés dans votre direction.\n",
        "SS2_ITEM_ERRATICGADGET_NAME": "Appareil erratique",
        "SS2_ITEM_ERRATICGADGET_DESC": "Vos éclairs frappent <style=cIsDamage>deux fois</style>. <style=cIsDamage>{0}%</style> de chance de lancer des <style=cIsDamage>chaînes électriques</style> infligeant <style=cIsDamage>{1}%</style> de dégâts TOTAUX à un maximum de <style=cIsDamage>{2}</style> <style=cStack>(+{2} per stack)</style> cibles.",
        "SS2_ITEM_ERRATICGADGET_PICKUP": "La foudre frappe deux fois.",
        "SS2_ITEM_ERRATICGADGET_LORE": "<style=cMono>==========================\n======== CallCutter ========\n===== ALPHA 0.1354.1.12 =====\n==========================\n\nInterruption de l'appel TdiM3c4fcQQA.34074... terminé\nAcquisition de l'appelant A... terminée\nAcquisition de l'appelant B... terminée\nChiffrement de la ligne... terminé\nActiver la sortie TTS en direct ?\n>Y\n\n==========================\nSORTIE TEXTE VERS DISCOURS CI-DESSOUS\n==========================\n</style>\nAppelant A : Hé, tu as toujours le gadget ?\nAppelant B : Oui, juste ici, sommes-nous toujours en ordre ?\nAppelant A : Oui, le marché tient toujours...\nAppelant A : Tu n'as rien dit à personne à ce sujet, n'est-ce pas ?\nAppelant B : Quoi, tu me prends pour un idiot ? Bien sûr que non !\nAppelant A : Bien. Continue comme ça.\nAppelant B : Je le ferai, je le ferai... Dis, es-tu sûr que cette chose est sans danger pour l'envoyer simplement à travers le système ?\nAppelant B : Ce gadget est une sorte de modification d'arme haut de gamme, n'est-ce pas ?\nAppelant A : Ne t'en fais pas, le gadget est parfaitement sûr. L'UES ne vérifie pas leurs colis. J'ai utilisé leur système postal de nombreuses fois auparavant, et je m'en sors toujours très bien.\nAppelant B : Eh bien, si tu le dis. Je vais l'envoyer, et je m'attends à quinze mille crédits dans les vingt-quatre prochaines heures, comme prévu.\nAppelant A : Comme prévu. C'est un plaisir de faire affaire avec toi.\n\n<style=cMono>==========================\n=====APPEL DÉCONNECTÉ=====\n==========================\n\nCoupure de la ligne..... terminée\nSauvegarde de l'enregistrement........ terminée\nSauvegarder la sortie texte ?\n>Y\n",
        "SS2_ITEM_GREENCHOCOLATE_NAME": "Chocolat vert",
        "SS2_ITEM_GREENCHOCOLATE_DESC": "Lorsque vous êtes blessé d'au moins <style=cIsHealth>{0}%</style> de vos PV max, les dégâts excédentaires sont réduits de <style=cIsDamage>{1}%</style>, vous obtenez également une amélioration cumulative qui accorde <style=cIsDamage>+{4}%</style> de dégâts de base et <style=cIsDamage>+{5}%</style> de chance de coup critique pendant <style=cIsDamage>{2}s</style> <style=cStack>(+{3}s par cumul)</style>.",
        "SS2_ITEM_GREENCHOCOLATE_PICKUP": "Réduit les dégâts subis et octroie un énorme bonus de dégâts et de chances de coup critique après avoir subi des dégâts importants.",
        "SS2_ITEM_GREENCHOCOLATE_LORE": "<style=cMono>Transcription audio complète à partir d'échos de signal. Attribution de jetons génériques.</style>\n\n[Sifflement, claquement fort]\n\nHOMME 1 : Uh... Hey, question bizarre ?\n\nHOMME 2 : [Soupire audible] Quoi ?\n\nHOMME 1 : Tu connais des chocolats bizarres et exotiques qui sont d'une couleur vert vif ?\n\nHOMME 2 : Quoi ? De quoi tu parles ?\n\nHOMME 1 : J'ai trouvé du chocolat vert dans ce coffre de sécurité, et je demande si c'est normal ou pas.\n\nHOMME 2 : Uh, non, ce n'est pas normal. Je ne pense pas, de toute façon. Je ne saurais pas.\n\n[Froissement]\n\nHOMME 1 : Alors, c'est censé être quoi ? Tu penses que c'est empoisonné, aussi ?\n\nHOMME 2 : Probablement pas. Et, euh, pour la dernière fois, la viande n'était pas empoisonnée, tu as juste l'estomac fragile.\n\nHOMME 1 : D'accord, je suppose que je vais le garder, au cas où les choses deviennent désespérées.\n\nHOMME 2 : Ce n'est probablement pas une excellente idée, mais d'accord.\n\n<style=cMono>Fin de la transcription demandée</style>\n",
        "SS2_ITEM_INSECTICIDE_NAME": "Insecticide",
        "SS2_ITEM_INSECTICIDE_DESC": "<style=cIsDamage>{0}%</style> de chance d'<style=cIsDamage>empoisonner</style> un ennemi pour <style=cIsDamage>{1}%</style> <style=cStack>(+{1}% par cumul)</style> de dégâts de base.",
        "SS2_ITEM_INSECTICIDE_PICKUP": "Empoisonne les ennemis au toucher.",
        "SS2_ITEM_INSECTICIDE_LORE": "Retour : Aérosol insecticide REAVE 400g (8)\nNuméro de suivi : 3528*******\nLivraison estimée : 6/1/2056\nMode d'expédition : Standard\n : 299 Umbrella Way, Itoki Fluctus, Vénus\nRaison du retour :\n\nLe produit est arrivé endommagé. Cinq canettes présentent des dommages physiques notables et des déformations, dont deux au point de fuite. Une est complètement éclatée. Ayant vu vos publicités et connaissant les capacités de cette substance, je pense qu'il serait préférable de la faire éliminer par vos experts, à vos frais.\n\nJe m'attends également à un remboursement pour cela.",
        "SS2_ITEM_NKOTASHERITAGE_NAME": "Héritage de Nkota",
        "SS2_ITEM_NKOTASHERITAGE_DESC": "Recevez <style=cIsUtility>{0}</style> <style=cStack>(+{0} par cumul)</style> <style=cIsUtility>objets</style> à chaque montée de niveau d'expérience. La rareté des objets augmente avec le niveau.",
        "SS2_ITEM_NKOTASHERITAGE_PICKUP": "Recevez un objet en montant de niveau.",
        "SS2_ITEM_NKOTASHERITAGE_LORE": "\"Mes amis. Je vous ai rassemblés ici aujourd'hui pour partager des nouvelles importantes.\n\nTout d'abord, c'est avec une profonde tristesse que j'annonce que Nkota, la dernière de nos grands leaders, notre aimable matriarche, nous a malheureusement quittés. Selon nos informations, elle a rendu son dernier souffle paisiblement dans son sommeil la nuit dernière, comblée d'années et ayant accompli tout ce qu'elle avait à faire ici. Cela étant dit, il n'y aura personne pour lui succéder au pouvoir. Elle était la dernière de sa lignée, sans frères, sœurs ou enfants vivants.\n\nAu lieu de cela, dans son dernier testament, sa sagesse a créé un nouveau commencement. Pour nous. Pour chacun de nous. Son souhait est que les membres restants de cette communauté se dispersent, que ce soit ensemble ou séparément, dans le monde. C'est peut-être une option radicale, mais c'est aussi celle que je pense, personnellement, être la meilleure pour cette communauté.\n\nNkota sera enterrée à notre destination finale, comme elle l'a souhaité. Vous pouvez tous pleurer pour elle et cette communauté pendant un certain temps, mais ne tardez pas. Un groupe de pèlerins voyagera avec moi vers le grand chemin gris, à cinquante miles à l'ouest, dans une semaine. Vous pouvez suivre, ou prendre votre propre chemin. C'est entièrement votre choix. Si vous ne pensez pas pouvoir faire le voyage, ne vous inquiétez pas. Nkota n'a peut-être pas eu d'enfants, oui, mais son héritage est spirituel, non pas dans le sang. Vous êtes tous ses enfants, et elle vous protégera jusqu'à ce que vous atteigniez votre but final.\n\nMerci à tous pour votre temps. Je vous suggère de commencer à emballer vos possessions pour le voyage à venir.\"\n\n- Éloge funèbre pour Nkota et le village de Dago",
        "SS2_ITEM_PORTABLEREACTOR_NAME": "Réacteur portable",
        "SS2_ITEM_PORTABLEREACTOR_DESC": "Obtenez une <style=cIsUtility>invulnérabilité totale</style> et <style=cIsUtility>100% de vitesse de déplacement</style> pendant les premières <style=cIsUtility>{0}s</style> <style=cStack>(+{1}s par cumul)</style> d'un niveau.",
        "SS2_ITEM_PORTABLEREACTOR_PICKUP": "Devenez invincible en entrant dans un niveau.",
        "SS2_ITEM_PORTABLEREACTOR_LORE": "Quatre-vingts secondes. Ces maudits lézards. Ils sont plus rusés qu'ils ne semblaient.\n\nSoixante-dix secondes. Elle prit un moment pour respirer. Ce qui avait été autrefois des vents violents était maintenant de l'air immobile, contenu dans la biosphère miniature.\n\nSoixante secondes. Elle compta ses balles.\n\nCinquante secondes. Deux chargeurs restants, une boîte de cartouches, une grenade - gorgée d'eau, et un couteau émoussé. Bien loin d'être suffisant.\n\nQuarante secondes. Elle compta leurs têtes.\n\nTrente secondes. Les lézards évitaient soigneusement son bouclier. Soit ils avaient peur de cette nouvelle technologie, soit... ils l'attendaient.\n\nVingt secondes. Elle chargea son fusil à pompe.\n\nDix secondes. Les lézards chargèrent - et elle espérait être prête.",
        "SS2_ITEM_SKATEBOARD_NAME": "Skateboard rapide",
        "SS2_ITEM_SKATEBOARD_DESC": "<style=cIsUtility>Courez</style> dans <style=cIsUtility>n'importe quelle direction</style>. Utiliser des compétences accorde une amélioration qui offre <style=cIsUtility>+{0}%</style> <style=cStack>(+{1}% par cumul)</style> de <style=cIsUtility>vitesse de déplacement</style> pendant <style=cIsUtility>{4}</style> secondes, jusqu'à <style=cIsUtility>{2}</style> cumuls.",
        "SS2_ITEM_SKATEBOARD_PICKUP": "Sprintez dans n'importe quelle direction. Utiliser des compétences vous fait bouger plus rapidement.",
        "SS2_ITEM_SKATEBOARD_LORE": "Ses roues, roulant à même la roche. Une technique brute, sans coordination- insouciante et irresponsable dans une égale mesure.\n\n\"Tu t'y prend mal.\"\n\n\"Je fais ce que je veux ! C'est de l'art, vois-tu, cher Frère.\"\n\n\"Tu as déjà échoué un nombre incalculable de fois.\"\n\n\"Tu vas voir.\"\n\nSon regard concentré, filant comme les étoiles reflètant le ciel. La foudre frappant contre le paysage lointain. Le scintillement des éclairs attrappant un oeil distrait. Un seul instant de concentration, puis un impact. Un mépris frustrant. Un regard, mutuel mais enragé, capable de trancher dans l'air précédant le tonnerre en chemin.\n\n\"Je commence a avoir des doutes, cher Frère.\"\n\n\"...bah, je n'ai pas encore abandonné ! Comment je pourrais échouer ?\"\n\nUn impact, un dérapage rapide capable d'enflammer la poussière soulevée. Des membres tremblant, se soulevant du sol. Une défiance. Cette énergie potentielle, se changeant en chaleur et en but, tangible dans l'air. Une tension suffocante, plus forte que le tonnerre, pour que tout s'effondre.\n\n\"Encore un échec.\"\n\n\"... tu sais, je trouve que je n'ai pas échoué une seule fois, cher Frère. Il y a quelque chose a dire a propos du simple fait d'apprendre.\"\n\n\"Mais tu AS échoué ! A chaque fois que tu as essayé tu as échoué, et j'ai essayé de t'apprendre- mais tu n'écoutes point. Je fatigue de t'apprendre et fatigue de te regarder !\"\n\nLes roues commencent a rouler contre la roche, encore une fois. Ils fredonnent et frappent comme un orgue habitué au rythme de la Terre sous le pied, tenant à peine le coup.\n\n\"Tu ne cesses d'ajouter tes propres indications a mes instructions les plus simple...\"\n\nUn mouvement en avant. Le frisson de la vélocité dans sa poitrine. Sentir votre sang et vos sens revenir en force, couplé a l'inertie. Un rappel que vous êtes bien vivant.\n\n\"Quand tu auras fini de t'amuser avec, laisse moi te montrer ce que j'essaie de t'enseigner.\"\n\nUne énergie incontrôlable, sauvage et frénétique- des forces qui convergent ensemble. Une tempête parfaite.\nCette rotation, libérée d'axe et de vitesse- Cette ruée de chaleur et de vélocité essentielle.\nLa foudre. Une énergie crue, pleine de potentiel- maintenant pleinement réalisée.\nJoie, étonnement et allégresse. Choc. Satisfaction. Excitation. Une troisième voix, criant avec impatience par-dessus la tempête vénusienne.\n\n\"Rentrez, les garçons- Le diner est prêt et ce n'est pas un temps a faire du skateboard !\"",
        "SS2_ITEM_BANEFLASK_NAME": "Flacon du fléau",
        "SS2_ITEM_BANEFLASK_DESC": "Répandre les debuffs en tuant ou quelque chose comme ça a aussi un debuff qui fait mal",
        "SS2_ITEM_BANEFLASK_PICKUP": "Les attaques infligent du Fléau. Chaque malus sur un ennemi ayant Fléau augmentent les dégats de Fléau.",
        "SS2_ITEM_BANEFLASK_LORE": "le gris fait mal ow !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!",
        "SS2_ITEM_GALVANICCORE_NAME": "Coeur galvanique",
        "SS2_ITEM_GALVANICCORE_DESC": "<style=cIsUtility>{0}%</style> <style=cStack>(+{4} par cumul)</style> de chance par coup d'<style=cIsUtility>étourdir</style>. Les ennemis étourdis appliquent <style=cIsUtility>Rasage</style> aux ennemis à moins de <style=cIsUtility>{5}m</style> <style=cStack>(+{6}m par cumul)</style>, réduisant leur <style=cIsHealing>PV max</style> de <style=cIsHealing>{1}%</style>, <style=cIsDamage>leur dégats</style> de <style=cIsDamage>{2}%</style>, et <style=cIsUtility>leur vitesse de déplacement</style> de <style=cIsUtility>{3}%</style>.",
        "SS2_ITEM_GALVANICCORE_PICKUP": "Les ennemis étourdis appliquent un malus aux ennemis alentours.",
        "SS2_ITEM_GALVANICCORE_LORE": "Commande : Coeur galvanique\nNuméro de suivi : 0121923\nLivraison estimée : 22/4/2056\nMéthode d'envoi : Prioritaire \nAdresse d'expédition : Place de la Science #42, MV Prime\nDétails de l'envoi :\n\nLe pouvoir est tien.\nSouhaitons la bienvenue à la dernière génération de technologie de coeur de puissance dans la galaxie. Le Coeur galvanique est l'invention la plus révolutionnaire depuis la Postcombustion lumineuse ! Ne restez pas ébahis, c'est le moment d'embrasser l'avenir.\nEn vous remerciant de votre achat.\n\nOMNI.co",
        "SS2_TRADER_BODY_NAME": "Zanzan le Fané",
        "SS2_TRADER_BODY_SUBTITLE": "Le Négociateur Voilé",
        "SS2_TRADER_CONTEXT": "Marché ?",
        "SS2_TRADER_POPUP_TEXT": "Proposer un objet au marchand ?",
        "SS2_TRADER_WANT_TEXT": "Le marchand marmonne, \"<i><link=\"textWavy\">",
        "SS2_TRADER_WANT2_TEXT": "..</link></i>\"",
        "SS2_TRADER_QUALITY_BESTEST": "<b>Le plus recherché</b>",
        "SS2_TRADER_QUALITY_BEST": "<b>Excellent</b>",
        "SS2_TRADER_QUALITY_GREAT": "<b>Génial</b>",
        "SS2_TRADER_QUALITY_GOOD": "<b>Bien</b>",
        "SS2_TRADER_QUALITY_MODERATE": "<b>Correct</b>",
        "SS2_TRADER_QUALITY_POOR": "<b>Mauvais</b>",
        "SS2_TRADER_QUALITY_WORTHLESS": "<b>Sans valeur</b>",
        "SS2_LAMPBOSS_BODY_NAME": "Voyageur",
        "SS2_LAMPBOSS_BODY_SUBTITLE": "Guide de la Lumière",
        "SS2_UNLOCKABLE_LOG_LAMPBOSS": "Journal de bord : Voyageur",
        "SS2_LAMPBOSS_BODY_LORE": "PETITS, REJOIGNEZ-MOI ICI. JE DOIS VOUS METTRE EN GARDE CONTRE QUELQUE CHOSE.\n\n...\n\nLE VOYAGEUR EST REVENU DANS CE MONDE.\n\nIL Y A LONGTEMPS, JE L'AI MAÎTRISÉ, L'AI BANNI DE NOTRE JARDIN. MAIS MAINTENANT, IL MENACE NOTRE MAISON UNE FOIS DE PLUS.\n\nSI VOUS LE RENCONTREZ, NE L'ÉCOUTEZ PAS. IL TENTERA DE VOUS ENTRAÎNER DE SON CÔTÉ, AVEC DES PROMESSES DE CHALEUR, DE SÉCURITÉ ET DE FORCE.\n\nC'EST UN PIÈGE.\n\nUNE FOIS QU'IL A VOTRE CONFIANCE, VOUS SEREZ UN ESCLAVE DE SA LUMIÈRE. VOUS PORTEREZ VOS PROPRES CHAÎNES, TOUT COMME LUI PORTE LES SIENNES.\n\n...\n\nMAIS - NE VOUS INQUIÉTEZ PAS. JE PROTÉGERAI LE JARDIN. S'IL A L'AUDACE DE REVENIR VERS MOI, C'EST À VOIR.\n\nEN CE QUI VOUS CONCERNE, PETITS, J'AI UN CADEAU POUR CHACUN D'ENTRE VOUS. VENEZ PLUS PRÈS.\n\nENCORE PLUS PRÈS !\n\nMAINTENANT, OBSERVEZ - OBSERVEZ ICI. REGARDEZ MA MAIN.\n\nVOUS TOUS M'AIDEREZ À PRENDRE SOIN DU JARDIN.",
        "SS2_LAMP_BODY_NAME": "Disciple",
        "SS2_UNLOCKABLE_LOG_LAMP": "Journal de bord : suiveur",
        "SS2_LAMP_BODY_LORE": "Oh, très chèr. Regarde-toi, pauvre chose.\n\nTu as froid.\n\nTiens, maintenant. Tu as déjà tellement enduré.\n\n...\n\nVoilà. Ta flamme s'est rallumée. Cela te tiendra chaud, pour l'instant.\n\nViens avec moi. Je vais te présenter aux autres.\n\nOh ? Bien sûr qu'il y en a d'autres. Ce serait cruel d'être le seul de ton genre, n'est-ce pas ?\n\nViens, maintenant ! N'attends pas. Ils partageront leur chaleur avec toi. Suis-moi simplement.\n\nTu seras en sécurité ici.",
        "SS2_FAMILY_LAMP": "<style=cWorldEvent>[AVERTISSEMENT] Vous rencontrez un profond sentiment d'immobilité...</style>",
        "SS2_AGARTHAN_BODY_NAME": "Agarthan",
        "SS2_UNLOCKABLE_LOG_AGARTHAN": "Journal de bord : Agarthan",
        "SS2_RUNSHROOM_BODY_NAME": "Rushrum",
        "SS2_UNLOCKABLE_LOG_RUNSHROOM": "Journal de bord : Rushrum",
        "SS2_RUNSHROOM_BODY_LORE": "Nous nous sommes réveillés en panique, notre tente en flammes. Notre équipement, une masse fondue du tableau périodique.\n\n\"Hé, là-bas ! Cette chose !\"\n\nElle était si petite, on aurait dit qu'elle pourrait être un insecte sous notre chaussure, pourtant le désordre qu'elle avait créé... Il n'y avait pas d'autre solution.\n\n\"Restez ici, je vais écraser cette saloperie jusqu'à en faire une purée.\"\n\nJ'ai regardé mes équipiers sauter comme des grenouilles sur le petit champignon, incapable même d'effleurer sa surface. Des jurons comme une sirène dans l'air.\n\nNos efforts étaient vains. J'ai fait signe à l'équipe de revenir pour aider à éteindre les flammes.\n\n\"Fermez-la et venez ici ! Le feu ne va pas s'éteindre tout seul ! Ce salaud est comme un cafard, vous ne l'attraperez pas !\"\n\nLes dégâts n'étaient pas couverts.",
        "SS2_MIMIC_BODY_NAME": "Coffre de sécurité",
        "SS2_MIMIC_BODY_SUBTITLE": "L'imitateur",
        "SS2_UNLOCKABLE_LOG_MIMIC": "Journal de bord : coffre de sécurité",
        "SS2_MIMIC_BODY_LORE": "\"Tout bien considéré, je pense qu'on peut désormais en tirer une leçon. La biologie évolutionnaire a réservé un espace particulier pour l'imitation, mes amis- certaines créatures ne cherchent pas à être menaçante ou attrayante par leur propre mérite, mais plutôt en donnant l'impression d'être une chose totalement différente. Bien sûr, le caractère aléatoire de l'évolution signifie que ce n'est pas ce à quoi on a affaire-\"\n\n\"Ce n'est pas non plus ce à quoi nous avons affaire, car-\"\n\n\"Non non, laissez-moi terminer. Ce cas-ci est un exemple fascinant, n'est-ce pas ? Une machine émulant une autre machine de manière si animée, comme moyen de nous inciter à nous approcher- enfin, son design est typiquement trompeur, n'est-ce pas ? Qu'importe qui a pu le concevoir y a vraiment mis son coeur, ne trouvez-vous pas ?\"\n\n\"...Mec, ça pique des trucs. Rien d'incroyable.\"\n\n\"La nature est vraiment magnifique, même dans des endroits comme ça.\"\n\n\"Ferme-la et avançons. Ugh, mon dieu, pourquoi je me retrouve coincé avec ce type ?\"\n\n-Echo de signaux, UES Contact Light",
        "SS2_MIMIC_THEFT": "<style=cWorldEvent>{0} a volé à {2} un {1}</color>",
        "SS2_HERO_BODY_NAME": "Ombre du Héro",
        "SS2_HERO_BODY_SUBTITLE": "Ombre du rempart",
        "SS2_BIGBROTHER_BODY_NAME": "Mithrix Ultra",
        "SS2_BIGBROTHER_BODY_SUBTITLE": "Destructeur revitalisé",
        "SS2_CLAYMONGER_BODY_NAME": "Marchand d'argile",
        "SS2_UNLOCKABLE_LOG_CLAYMONGER": "Journal de bord : Clay Monger",
        "SS2_CLAYMONGER_BODY_LORE": "Ce sont littéralement des animaux de compagnie et du bétail de personnes tombées dans le goudron... espèce de monstre... :c",
        "SS2_ACIDBUG_BODY_NAME": "Insecte d'archer",
        "SS2_UNLOCKABLE_LOG_ACIDBUG": "Journal de bord : Bug d'Archer",
        "SS2_ACIDBUG_BODY_LORE": "",
        "SS2_RULEBOOK_NAME": "Règles",
        "SS2_RULEBOOK_DESC": "Personnalisez les règles de base de votre partie selon vos goûts.",
        "SS2_RULEBOOK_EMPTY": "Aucune règle personnalisable trouvée !",
        "SS2_RULEBOOK_EDIT": "Modifier les règles ?",
        "SS2_PLAYER_DAMAGE_RULE_NAME": "Dégâts infligés par les joueurs",
        "SS2_PLAYER_DAMAGE_DEFAULT_NAME_TOKEN": "Dégâts par défaut",
        "SS2_PLAYER_DAMAGE_DEFAULT_BODY_TOKEN": "Les joueurs infligent 100% de dégâts.",
        "SS2_PLAYER_DAMAGE_25_INCREASE_NAME_TOKEN": "+25% de dégâts infligés",
        "SS2_PLAYER_DAMAGE_25_INCREASE_BODY_TOKEN": "Les joueurs infligent 125% de dégâts.",
        "SS2_PLAYER_DAMAGE_50_INCREASE_NAME_TOKEN": "+50% de dégâts infligés",
        "SS2_PLAYER_DAMAGE_50_INCREASE_BODY_TOKEN": "Les joueurs infligent 150% de dégâts.",
        "SS2_PLAYER_DAMAGE_75_INCREASE_NAME_TOKEN": "+75% de dégâts infligés",
        "SS2_PLAYER_DAMAGE_75_INCREASE_BODY_TOKEN": "Les joueurs infligent 175% de dégâts.",
        "SS2_PLAYER_DAMAGE_100_INCREASE_NAME_TOKEN": "+100% de dégâts infligés",
        "SS2_PLAYER_DAMAGE_100_INCREASE_BODY_TOKEN": "Les joueurs infligent 200% de dégâts.",
        "SS2_PLAYER_DAMAGE_25_DECREASE_NAME_TOKEN": "-25% de dégâts infligés",
