			//IL_0079: Unknown result type (might be due to invalid IL or missing references)
			//IL_007b: Unknown result type (might be due to invalid IL or missing references)
			bool flag = false;
			float num = startRadius;
			Vector3 result = default(Vector3);
			Vector3 result2 = default(Vector3);
			while (!flag)
			{
				if (groundOnly)
				{
					Random random = new Random();
					NodeGraph groundNodes = SceneInfo.instance.groundNodes;
					List<NodeIndex> list = groundNodes.FindNodesInRange(startPosition, startRadius, num, (HullMask)1);
					if (list.Count > 0)
					{
						NodeIndex val = list[random.Next(list.Count)];
						bool flag2 = true;
						groundNodes.GetNodePosition(val, ref result);
						return result;
					}
					num += 1f;
					if (num >= maxRadius)
					{
						break;
					}
				}
				else
				{
					Random random2 = new Random();
					NodeGraph airNodes = SceneInfo.instance.airNodes;
					List<NodeIndex> list2 = airNodes.FindNodesInRange(startPosition, startRadius, num, (HullMask)1);
					if (list2.Count > 0)
					{
						NodeIndex val2 = list2[random2.Next(list2.Count)];
						bool flag3 = true;
						airNodes.GetNodePosition(val2, ref result2);
						return result2;
					}
					num += 1f;
					if (num >= maxRadius)
					{
						break;
					}
				}
			}
			return startPosition;
		}

