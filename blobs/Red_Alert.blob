			list.Add(Prefabs.CreateDisplayPrefabAsync(assetBundle, displayPrefabName, characterModelObject, delegate(GameObject result)
			{
				displayPrefab = result;
				InitializeSurvivor();
			}));
			return list;
		}

		protected virtual void InitializeSurvivor()
		{
			//IL_0012: Unknown result type (might be due to invalid IL or missing references)
			RegisterNewSurvivor(bodyPrefab, displayPrefab, base._bodyInfo.bodyColor, survivorTokenPrefix, characterUnlockableDef, base._bodyInfo.sortPosition);
		}

