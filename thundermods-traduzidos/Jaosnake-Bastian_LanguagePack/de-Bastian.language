        "BASTIAN_UTIL": "Nano-Frühling",
        "BASTIAN_UTIL_DESCRIPTION": "<style=cIsUtility>Ausführen</style>ein schneller Sprint in jede Richtung. Baut<style=cIsUtility>Ionenladungen</style>.",
