		internal static class Unlockables
		{
			internal static List<UnlockableDef> unlockableDefs = new List<UnlockableDef>();

			internal static UnlockableDef characterUnlockableDef;

			internal static UnlockableDef masteryUnlockableDef;

			internal static UnlockableDef grandMasteryUnlockableDef;

			internal static UnlockableDef suitUnlockableDef;

			internal static UnlockableDef supplyDropUnlockableDef;

			internal static UnlockableDef pistolPassiveUnlockableDef;

			internal static UnlockableDef godslingPassiveUnlockableDef;

			internal static void Init()
			{
				characterUnlockableDef = CreateAndAddUnlockableDef("ROB_DRIVER_BODY_UNLOCKABLE_ACHIEVEMENT_ID", "ROB_DRIVER_BODY_UNLOCKABLE_REWARD_ID", DriverUnlockAchievement.Sprite);
				masteryUnlockableDef = CreateAndAddUnlockableDef("ROB_DRIVER_BODY_MONSOONUNLOCKABLE_ACHIEVEMENT_ID", "ROB_DRIVER_BODY_MONSOONUNLOCKABLE_REWARD_ID", DriverMonsoonAchievement.Sprite);
				grandMasteryUnlockableDef = CreateAndAddUnlockableDef("ROB_DRIVER_BODY_TYPHOON_UNLOCKABLE_ACHIEVEMENT_ID", "ROB_DRIVER_BODY_TYPHOON_UNLOCKABLE_REWARD_ID", DriverTyphoonAchievement.Sprite);
				suitUnlockableDef = CreateAndAddUnlockableDef("ROB_DRIVER_BODY_SUIT_UNLOCKABLE_ACHIEVEMENT_ID", "ROB_DRIVER_BODY_SUIT_UNLOCKABLE_REWARD_ID", DriverSuitAchievement.Sprite);
				supplyDropUnlockableDef = CreateAndAddUnlockableDef("ROB_DRIVER_BODY_SUPPLY_DROP_UNLOCKABLE_ACHIEVEMENT_ID", "ROB_DRIVER_BODY_SUPPLY_DROP_UNLOCKABLE_REWARD_ID", DriverSupplyDropAchievement.Sprite);
				pistolPassiveUnlockableDef = CreateAndAddUnlockableDef("ROB_DRIVER_BODY_PISTOLPASSIVE_UNLOCKABLE_ACHIEVEMENT_ID", "ROB_DRIVER_BODY_PISTOLPASSIVE_UNLOCKABLE_REWARD_ID", DriverPistolPassiveAchievement.Sprite);
				godslingPassiveUnlockableDef = CreateAndAddUnlockableDef("ROB_DRIVER_BODY_GODSLING_UNLOCKABLE_ACHIEVEMENT_ID", "ROB_DRIVER_BODY_GODSLING_UNLOCKABLE_REWARD_ID", DriverGodslingPassiveAchievement.Sprite);
			}

			internal static UnlockableDef CreateAndAddUnlockableDef(string identifier, string unlockableIdentifier, Sprite achievementIcon)
			{
				UnlockableDef val = ScriptableObject.CreateInstance<UnlockableDef>();
				val.cachedName = unlockableIdentifier.ToUpperInvariant();
				val.nameToken = "ACHIEVEMENT_" + identifier.ToUpperInvariant() + "_NAME";
				val.achievementIcon = achievementIcon;
				unlockableDefs.Add(val);
				return val;
			}

			internal static UnlockableDef CreateAndAddWeaponUnlockableDef(string name)
			{
				return CreateAndAddWeaponUnlockableDef("ROB_DRIVER_" + name.ToUpperInvariant() + "_NAME", "ROB_DRIVER_" + name.ToUpperInvariant() + "_DESC");
			}

			public static UnlockableDef CreateAndAddWeaponUnlockableDef(string nameToken, string descriptionToken)
			{
				UnlockableDef val = ScriptableObject.CreateInstance<UnlockableDef>();
				val.cachedName = nameToken;
				val.nameToken = nameToken;
				val.getHowToUnlockString = () => Language.GetString(descriptionToken);
				val.getUnlockedString = () => Language.GetString(descriptionToken);
				val.achievementIcon = null;
				val.hidden = false;
				unlockableDefs.Add(val);
				return val;
			}
		}
	}
