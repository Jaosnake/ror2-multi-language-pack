		private static void CreateHitboxes(GameObject prefab)
		{
			ChildLocator componentInChildren = prefab.GetComponentInChildren<ChildLocator>();
			GameObject gameObject = ((Component)componentInChildren).gameObject;
			Transform val = componentInChildren.FindChild("SpearTipHitbox");
			Transform val2 = componentInChildren.FindChild("SpearBaseHitbox");
			Prefabs.SetupHitbox(gameObject, "Spear", val, val2);
			val = componentInChildren.FindChild("SwordHitbox");
			Prefabs.SetupHitbox(gameObject, val, "Sword");
		}

