			val.activationRequiresTargetLoS = false;
			val.activationRequiresAimConfirmation = false;
			val.movementType = (MovementType)1;
			val.moveTargetType = (TargetType)0;
			val.aimType = (AimType)1;
			val.ignoreNodeGraph = true;
			val.shouldSprint = true;
			val.moveInputScale = 1f;
			val.driverUpdateTimerOverride = 0.2f;
			val.buttonPressType = (ButtonPressType)1;
			AISkillDriver[] skillDrivers = component.skillDrivers;
			AISkillDriver[] array = (AISkillDriver[])(object)new AISkillDriver[skillDrivers.Length + 1];
			array[0] = val;
			for (int i = 0; i < skillDrivers.Length; i++)
			{
				array[i + 1] = skillDrivers[i];
			}
			component.skillDrivers = array;
			return val;
		}

		private void ApplyDroneStats(CharacterBody body, StatHookEventArgs args)
		{
			if (!Object.op_Implicit((Object)(object)body.master))
			{
				return;
			}
			InspiringDroneMinionBehavior component = ((Component)body.master).GetComponent<InspiringDroneMinionBehavior>();
			if (Object.op_Implicit((Object)(object)component) && Object.op_Implicit((Object)(object)component.OwnerBody))
			{
				int count = GetCount(component.OwnerBody);
				if (count > 0)
				{
					float num = (float)AllStatValueGrantedPercentage * (float)count;
					args.baseDamageAdd += component.OwnerBody.damage * num;
					args.attackSpeedMultAdd += component.OwnerBody.attackSpeed * num;
					args.critAdd += component.OwnerBody.crit * num;
					args.baseRegenAdd += component.OwnerBody.regen * num;
					args.armorAdd += component.OwnerBody.armor * num;
					args.baseHealthAdd += component.OwnerBody.maxHealth * num;
					args.baseShieldAdd += component.OwnerBody.maxShield * num;
					args.moveSpeedMultAdd += num;
				}
			}
		}

