        "ROB_DRIVER_BODY_MINECRAFT_SKIN_NAME": "Minecraft",
        "ROB_DRIVER_BODY_PASSIVE_NAME": "Survivaliste",
        "ROB_DRIVER_BODY_PASSIVE_DESCRIPTION": "Les ennemis ont une chance de lâcher une nouvelle arme <style=cIsUtility></style>. Ceux-ci accordent <style=cIsDamage>attaques puissantes</style> pour une durée limitée !</i>",
        "ROB_DRIVER_BODY_PASSIVE2_NAME": "Tireur d'élite (héritage)",
        "ROB_DRIVER_BODY_PASSIVE2_DESCRIPTION": "Votre fidèle <style=cIsHealth>pistol</style> est tout ce dont vous avez besoin.</i>",
        "ROB_DRIVER_BODY_PASSIVE3_NAME": "Pied de plomb",
        "ROB_DRIVER_BODY_PASSIVE3_DESCRIPTION": "Les ennemis ont une chance de lâcher <style=cIsHealth>ammo</style>. Ceux-ci confèrent à votre <style=cIsHealth>arme</style> <style=cIsDamage>des attaques puissantes</style> pour une durée limitée !</i>",
