{
    "de": {
        "POPCORN_ARSONIST_BODY_NAME": "Brandstifter",
        "POPCORN_ARSONIST_BODY_SUBTITLE": "Wahnsinniger Pyromane",
        "POPCORN_ARSONIST_BODY_PASSIVE_NORMAL_GAUGE_NAME": "Normalspur",
        "POPCORN_ARSONIST_BODY_PASSIVE_NORMAL_GAUGE_DESCRIPTION": "Handeln<style=cIsDamage>100 %</style>Schäden am weißen Teil. Die Basisanzeige ist beständig gegen Überhitzung.",
        "POPCORN_ARSONIST_BODY_PASSIVE_BLUE_GAUGE_NAME": "Kritisches Messgerät",
        "POPCORN_ARSONIST_BODY_PASSIVE_BLUE_GAUGE_DESCRIPTION": "Handeln<style=cIsDamage>70 %</style>Schäden am weißen Teil und<style=cIsDamage>250 %</style>Schaden am blauen Teil. Maximale Hitze ist festgelegt.",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_NAME": "Drachenatem",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_DESCRIPTION": "Feuere einen Flammenstrahl ab, der Schaden verursacht<style=cIsDamage>90 % Schaden</style>. Je näher Sie dem Ziel sind, desto größer ist die Zündwahrscheinlichkeit.",
        "POPCORN_ARSONIST_BODY_PRIMARY_FIRESPRAY_NAME": "Feuerball",
        "POPCORN_ARSONIST_BODY_PRIMARY_FIRESPRAY_DESCRIPTION": "<style=cIsUtility>Hitze.</style>Feuert einen Feuerball ab<style=cIsDamage>225 % Schaden und Entzündung</style>Feinde bei Treffer.",
        "POPCORN_ARSONIST_BODY_SECONDARY_PUNCH_NAME": "Nullpunktexplosion",
        "POPCORN_ARSONIST_BODY_SECONDARY_PUNCH_DESCRIPTION": "<style=cIsUtility>Agil. Hitze.</style>Treiben Sie sich vorwärts und lassen Sie die Feinde hinter Ihnen explodieren<style=cIsDamage>200 % Schaden</style>. Kollision unmittelbar nach dem Start mit dem ersten Feind verursacht<style=cIsDamage>200 % Schaden</style>in einer umgebenden Explosion.",
        "POPCORN_ARSONIST_BODY_SECONDARY_FLAREGUN_NAME": "Leuchtpistole",
        "POPCORN_ARSONIST_BODY_SECONDARY_FLAREGUN_DESCRIPTION": "Feuern Sie eine Leuchtrakete ab<style=cIsDamage>400 % Schaden</style>über 5 Sekunden, dann explodiert der Schaden<style=cIsDamage>400 % Schaden</style>, indem er 5 Fackeln abfeuert<style=cIsDamage>200 % Schaden</style>jede.",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHIST_NAME": "Masochismus",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHIST_DESCRIPTION": "<style=cIsUtility>Agil. Hitze.</style>Schaden durch das Sein<style=cIsDamage>entzündet</style>verwandelt sich in<style=cIsHealing>Heilung</style>für 6,5 Sekunden. Erhöht die Angriffsgeschwindigkeit um<style=cIsDamage>125 %</style>.",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_NAME": "Masochismus",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_DESCRIPTION": "Beim Erreichen der<style=cKeywordName>Vorwegnahme</style>Limit, füge dir selbst regelmäßig Schaden im Tausch gegen Fläche zu<style=cIsHealing>Lebensraub</style>und brennen. Nach spätestens 10 Sekunden<style=cIsDamage>Detonieren</style>, Dann<style=cIsUtility>Überhitzen</style>.",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_SURGE_NAME": "Trotz",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_SURGE_DESCRIPTION": "Beim Erreichen der<style=cKeywordName>Vorwegnahme</style>Limit, Sie bewegen sich schneller und gewinnen<style=cKeywordName>Doppelter Schuss</style>Und<style=cIsHealing>Lebensraub</style>. Nach spätestens 10 Sekunden<style=cIsDamage>Detonieren</style>, Dann<style=cIsUtility>Überhitzen</style>.",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_SCEPTER_NAME": "Dantes Zurechtweisung",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_SCEPTER_DESCRIPTION": "Feuern Sie einen intensiven Strahlangriff ab<style=cIsDamage>140 % Schaden</style>. Je näher Sie dem Ziel sind, desto größer ist die Zündwahrscheinlichkeit. Wenn die Taste 2 Sekunden oder länger gedrückt gehalten wird, wird beim Loslassen ein letzter Strahl abgefeuert<style=cIsDamage>150 % Schaden</style>.",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_ANTICIPATION": "<style=cKeywordName>Vorwegnahme</style>Für jeweils 100 verlorene und/oder gewonnene Hitze erhält der Brandstifter 1 Vorfreude-Ladung; Nachdem er 5 Ladungen erhalten hat, kann er den Masochismus aktivieren; Zusätzliche Ladungen erhöhen Schaden und Dauer; Am Ende sind alle Ladungen verbraucht.",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_DETONATE": "<style=cKeywordName>Detonieren</style>Brandstifter explodiert, Deal<style=cIsDamage>150 % Schaden</style>Mal den Betrag der angesammelten Antizipationsgebühren.",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_LIFESTEAL": "<style=cKeywordName>Lebensraub</style>Brandstifter heilt<style=cIsHealing>18 %</style>verursachter Schaden, während Masochismus aktiv ist.",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_SURGE_LIFESTEAL": "<style=cKeywordName>Lebensraub</style>Brandstifter heilt<style=cIsHealing>5 %</style>verursachten Schaden, während Spite aktiv ist.",
        "POPCORN_ARSONIST_BODY_KEYWORD_OVERHEAT_MASO": "<style=cKeywordName>Überhitzung: Masochismus</style>Wenn Brandstifter aufgrund übermäßiger Hitzeentwicklung den Masochismus verlässt, wird EX-Überhitzung angewendet, wodurch Bewegungsgeschwindigkeit und Schaden auf 70 % reduziert werden. Wenn Sie die Fertigkeit abbrechen oder ablaufen lassen, wird Überhitzung angewendet, wodurch die Angriffsgeschwindigkeit auf 50 % verringert wird.",
        "POPCORN_ARSONIST_BODY_OVERHEAT_TEXT": "ÜBERHITZEN!",
        "POPCORN_ARSONIST_BODY_COOLING_TEXT": "Abkühlung...!",
        "POPCORN_ARSONIST_BODY_OVERHEAT_EX_TEXT": "ÜBERHITZUNG:EX!"
    }
}
