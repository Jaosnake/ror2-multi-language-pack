	public class TowerSpawnState : BaseState
	{
		public static float TowerSpawnDuration = 1.5f;

		protected float duration;

		public override void OnEnter()
		{
			duration = TowerSpawnDuration / base.attackSpeedStat;
			Util.PlaySound("Play_buliding_uplace", ((EntityState)this).gameObject);
			((EntityState)this).PlayAnimation("Body", "ConstructionComplete", "construct.playbackRate", duration, 0f);
			((BaseState)this).OnEnter();
			((EntityState)this).characterBody.AddBuff(Buffs.HiddenInvincibility);
			MinionOwnership minionOwnership = ((EntityState)this).characterBody.master.minionOwnership;
			object obj;
			if (minionOwnership == null)
			{
				obj = null;
			}
			else
			{
				GameObject bodyObject = minionOwnership.ownerMaster.GetBodyObject();
				obj = ((bodyObject != null) ? bodyObject.GetComponent<TeslaTowerControllerController>() : null);
			}
			TeslaTowerControllerController teslaTowerControllerController = (TeslaTowerControllerController)obj;
			if (Object.op_Implicit((Object)(object)teslaTowerControllerController))
			{
				teslaTowerControllerController.addTower(((EntityState)this).gameObject);
			}
		}

		public override void FixedUpdate()
		{
			((EntityState)this).FixedUpdate();
			if (((EntityState)this).fixedAge >= duration && ((EntityState)this).isAuthority)
			{
				((EntityState)this).outer.SetNextState((EntityState)(object)new TowerIdleSearch
				{
					justSpawned = true
				});
			}
		}
	}
	internal class TowerUndeploy : BaseTimedSkillState
	{
		public override float TimedBaseDuration => 0.5f;

		public override float TimedBaseCastStartPercentTime => 1f;

		protected override void OnCastEnter()
		{
			base.OnCastEnter();
			GameObject masterObject = ((EntityState)this).characterBody.masterObject;
			Deployable val = ((masterObject != null) ? masterObject.GetComponent<Deployable>() : null);
			if (Object.op_Implicit((Object)(object)val))
			{
				CharacterMaster ownerMaster = val.ownerMaster;
				if (ownerMaster != null)
				{
					ownerMaster.RemoveDeployable(val);
				}
				val.ownerMaster = null;
				val.onUndeploy.Invoke();
			}
			else
			{
				((EntityState)this).characterBody.master.TrueKill();
			}
		}
	}
