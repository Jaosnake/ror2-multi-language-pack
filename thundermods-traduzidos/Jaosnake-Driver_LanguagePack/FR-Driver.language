        "ROB_DRIVER_BODY_SECONDARY_RAV_PUNCH_NAME": "Punch",
        "ROB_DRIVER_BODY_SECONDARY_RAV_PUNCH_DESCRIPTION": "Foncez en avant et <style=cIsUtility>punch</style>, infligeant 400 % de dégâts avec un <style=cIsUtility>shockwave</style> infligeant les mêmes dégâts.</i>",
        "ROB_DRIVER_BODY_SECONDARY_ARTI_GAUNTLET_NAME": "Nano-Bombe",
        "ROB_DRIVER_BODY_SECONDARY_ARTI_GAUNTLET_DESCRIPTION": "<style=cIsDamage>Superbe</style>. Chargez une nanobombe explosive infligeant entre 600 % et 2 000 % de dégâts.</i>",
        "ROB_DRIVER_BODY_UTILITY_SLIDE_NAME": "Toboggan de combat",
        "ROB_DRIVER_BODY_UTILITY_SLIDE_DESCRIPTION": "<style=cIsUtility>Faites glisser</style> sur le sol sur une courte distance. Vous pouvez <style=cIsDamage>tirer en glissant.</style></i>",
        "ROB_DRIVER_BODY_UTILITY_DASH_NAME": "Esquiver",
        "ROB_DRIVER_BODY_UTILITY_DASH_DESCRIPTION": "<style=cIsUtility>Dash</style> sur une courte distance. Vous pouvez <style=cIsUtility>avoir jusqu'à 2 charges.</style></i>",
        "ROB_DRIVER_BODY_UTILITY_SKATEBOARD_NAME": "Skateboard",
        "ROB_DRIVER_BODY_UTILITY_SKATEBOARD_DESCRIPTION": "Montez sur un <style=cIsUtility>skateboard</style>.</i>",
        "ROB_DRIVER_BODY_UTILITY_SKATEBOARD2_DESCRIPTION": "Démontez le <style=cIsUtility>skateboard</style>.</i>",
        "ROB_DRIVER_BODY_SPECIAL_GRENADE_NAME": "Flashbang",
        "ROB_DRIVER_BODY_SPECIAL_GRENADE_DESCRIPTION": "Lancez une grenade qui <style=cIsUtility>étourdit</style> les ennemis et leur inflige 500 % de dégâts. <style=cIsUtility>Les ennemis étourdis visent dans des directions aléatoires pendant 10 secondes.</style></i>",
        "ROB_DRIVER_BODY_SPECIAL_GRENADE_SCEPTER_NAME": "Cocktail Molotov",
        "ROB_DRIVER_BODY_SPECIAL_GRENADE_SCEPTER_DESCRIPTION": "Lancez une grenade qui <style=cIsUtility>étourdit</style> les ennemis et leur inflige 500 % de dégâts. <style=cIsUtility>Les ennemis étourdis visent dans des directions aléatoires pendant 10 secondes.</style>\n<style=cIsUtility>Sceptre : lancez un cocktail Molotov qui explose en flammes.</style></i>",
        "ROB_DRIVER_BODY_SPECIAL_SUPPLY_DROP_NAME": "Baisse d'approvisionnement",
        "ROB_DRIVER_BODY_SPECIAL_SUPPLY_DROP_DESCRIPTION": "Appelez une caisse contenant une arme aléatoire <color=#00FF66></color>. <style=cIsHealth>L'arme est livrée avec seulement la moitié des munitions.</style></i>",
        "ROB_DRIVER_BODY_SPECIAL_SUPPLY_DROP_LEGACY_NAME": "Baisse de ravitaillement (héritage)",
        "ROB_DRIVER_BODY_SPECIAL_SUPPLY_DROP_LEGACY_DESCRIPTION": "Appelez une caisse contenant un <color=#FFFF00>Prototype Rocket Launcher</color>. <style=cIsUtility>Vous ne pouvez en appeler qu'un seul par étape.</style></i>",
        "ROB_DRIVER_BODY_SPECIAL_SUPPLY_DROP_SCEPTER_NAME": "Appel annulé",
        "ROB_DRIVER_BODY_SPECIAL_SUPPLY_DROP_SCEPTER_DESCRIPTION": "Appelez une caisse contenant une arme aléatoire <color=#00FF66></color>. <style=cIsHealth>L'arme est livrée avec seulement la moitié des munitions.</style>\n<style=cIsUtility>Sceptre : appel à une arme vide.</style></i>",
        "ROB_DRIVER_BODY_SPECIAL_SUPPLY_DROP_LEGACY_SCEPTER_NAME": "Appel annulé",
        "ROB_DRIVER_BODY_SPECIAL_SUPPLY_DROP_LEGACY_SCEPTER_DESCRIPTION": "Appelez une caisse contenant un <color=#FFFF00>Prototype Rocket Launcher</color>.\n<style=cIsUtility>Sceptre : appelez une arme vide.</style></i>",
        "ROB_DRIVER_BODY_SPECIAL_HEAL_NAME": "Soins auto-administrés",
        "ROB_DRIVER_BODY_SPECIAL_HEAL_DESCRIPTION": "Sortez un <style=cIsUtility>Medkit</style> et soignez-vous progressivement jusqu'à atteindre une santé maximale.</i>",
        "ROB_DRIVER_BODY_SPECIAL_KNIFE_NAME": "Couteau de combat",
        "ROB_DRIVER_BODY_SPECIAL_KNIFE_DESCRIPTION": "Tranchez les ennemis proches avec une lame dentelée, infligeant 470 % de dégâts et les <style=cIsHealth> blessant</style>, <style=cIsDamage>réduisant l'armure</style> pendant <style=cIsUtility>4 secondes</style>.</i>",
        "ROB_DRIVER_BODY_SPECIAL_KNIFE_SCEPTER_NAME": "Couteau de combat (sceptre)",
        "ROB_DRIVER_BODY_SPECIAL_KNIFE_SCEPTER_DESCRIPTION": "Tranchez les ennemis proches avec une lame dentelée, infligeant 470 % de dégâts et les <style=cIsHealth> blessant</style>, <style=cIsDamage>réduisant l'armure</style> pendant <style=cIsUtility>4 secondes</style>.\n<style=cIsUtility>Sceptre : demi-temps de recharge et charge supplémentaire.</style></i>",
        "ROB_DRIVER_BODY_SPECIAL_SYRINGE_NAME": "Seringue expérimentale",
        "ROB_DRIVER_BODY_SPECIAL_SYRINGE_DESCRIPTION": "Injectez-vous avec une <style=cIsUtility>seringue</style>, accordant une <style=cIsDamage>vitesse d'attaque</style>, <style=cIsUtility>vitesse de déplacement</style> et <style=cIsHealing>régénération de santé</style> pour les <style=cIsUtility>6 secondes</style>.</style>0__",
        "ROB_DRIVER_BODY_SPECIAL_SYRINGE_SCEPTER_NAME": "Seringue améliorée",
        "ROB_DRIVER_BODY_SPECIAL_SYRINGE_SCEPTER_DESCRIPTION": "Injectez-vous une <style=cIsUtility>seringue</style>, ce qui vous confère une <style=cIsDamage>vitesse d'attaque</style> et une <style=cIsHealing>régénération de santé</style> pour les <style=cIsUtility>6 secondes suivantes</style>.\n<style=cIsUtility>Sceptre : augmente les dégâts et les chances de coup critique et renforce le buffs.</style></style>0__",
        "ROB_DRIVER_BODY_SPECIAL_SYRINGELEGACY_NAME": "Seringue suspecte (ancienne version)",
        "ROB_DRIVER_BODY_SPECIAL_SYRINGELEGACY_DESCRIPTION": "Injectez-vous avec une <style=cIsUtility>seringue</style>, accordant un <style=cIsDamage>buff offensif aléatoire</style> pendant les <style=cIsUtility>6 secondes suivantes</style>.</i>",
        "ROB_DRIVER_BODY_SPECIAL_SYRINGELEGACY_SCEPTER_NAME": "Seringue améliorée (ancienne version)",
        "ROB_DRIVER_BODY_SPECIAL_SYRINGELEGACY_SCEPTER_DESCRIPTION": "Injectez-vous avec une <style=cIsUtility>seringue</style>, accordant un <style=cIsDamage>buff offensif aléatoire</style> pendant les <style=cIsUtility>6 secondes suivantes</style>.\n<style=cIsUtility>Sceptre : applique les trois buffs à la fois.</style></i>",
        "ROB_DRIVER_BODY_SPECIAL_DRIVERCOIN_NAME": "Payez au suivant",
