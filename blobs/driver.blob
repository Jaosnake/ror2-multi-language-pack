			private static void CreateHitboxes(GameObject prefab)
			{
				ChildLocator componentInChildren = prefab.GetComponentInChildren<ChildLocator>();
				GameObject gameObject = ((Component)componentInChildren).gameObject;
				Prefabs.SetupHitbox(gameObject, "Hammer", componentInChildren.FindChild("HammerHitbox"));
				Prefabs.SetupHitbox(gameObject, "Sword", componentInChildren.FindChild("SwordHitboxL"), componentInChildren.FindChild("SwordHitboxR"));
				Prefabs.SetupHitbox(gameObject, "Knife", componentInChildren.FindChild("KnifeHitbox"));
			}

