			((Transform)val2).localRotation = Quaternion.identity;
			val2.anchorMin = Vector2.zero;
			val2.anchorMax = Vector2.one;
			((Transform)val2).localScale = Vector3.one;
			val2.sizeDelta = Vector2.zero;
			val2.anchoredPosition = position;
			return val3;
		}

		public void Awake()
		{
			enabledUI = false;
			baseAIPresent = false;
			orbAnimators = new List<Animator>();
			orbImages = new List<Image>();
		}

		public void Start()
		{
			characterBody = ((Component)this).GetComponent<CharacterBody>();
			orbController = ((Component)this).GetComponent<OrbController>();
			domainController = ((Component)this).GetComponent<LeeHyperrealDomainController>();
			passiveController = ((Component)this).GetComponent<LeeHyperrealPassive>();
			characterMaster = characterBody.master;
			BaseAI component = ((Component)characterMaster).GetComponent<BaseAI>();
			baseAIPresent = Object.op_Implicit((Object)(object)component);
			Hook();
			if (!Object.op_Implicit((Object)(object)characterMaster))
			{
				baseAIPresent = true;
			}
			selectedSkin = characterBody.skinIndex;
			try
			{
				InitializeUI();
			}
			catch (NullReferenceException arg)
			{
				Debug.Log((object)$"Lee: Hyperreal - NRE on UI Initialization, trying again: {arg}");
			}
			catch (ForcedUIReInitException)
			{
				Debug.Log((object)"Lee: Hyperreal - UI needs to Reinit!");
			}
			if (Config.loreMode.Value)
			{
				switch (characterBody.skinIndex)
				{
				case 0u:
					characterBody.portraitIcon = (Texture)(object)LeeHyperrealAssets.prospectorSprite.texture;
					break;
				case 1u:
					characterBody.portraitIcon = (Texture)(object)LeeHyperrealAssets.comradeSprite.texture;
					break;
				case 4u:
					characterBody.portraitIcon = (Texture)(object)LeeHyperrealAssets.scarletSprite.texture;
					break;
				default:
					characterBody.portraitIcon = (Texture)(object)LeeHyperrealAssets.leeIconSprite.texture;
					break;
				}
			}
			else
			{
				switch (characterBody.skinIndex)
				{
				case 2u:
					characterBody.portraitIcon = (Texture)(object)LeeHyperrealAssets.scarletSprite.texture;
					break;
				case 3u:
					characterBody.portraitIcon = (Texture)(object)LeeHyperrealAssets.prospectorSprite.texture;
					break;
				case 4u:
					characterBody.portraitIcon = (Texture)(object)LeeHyperrealAssets.comradeSprite.texture;
					break;
				default:
					characterBody.portraitIcon = (Texture)(object)LeeHyperrealAssets.leeIconSprite.texture;
					break;
				}
			}
		}

		public float ResolveColor()
		{
			if (Object.op_Implicit((Object)(object)passiveController))
			{
				switch (passiveController.GetVFXPassive())
				{
				case LeeHyperrealPassive.VFXPassive.RED:
					return StaticValues.redBaseHueOffset;
				case LeeHyperrealPassive.VFXPassive.ORANGE:
					return StaticValues.orangeBaseHueOffset;
				case LeeHyperrealPassive.VFXPassive.YELLOW:
					return StaticValues.yellowBaseHueOffset;
				case LeeHyperrealPassive.VFXPassive.GREEN:
					return StaticValues.greenBaseHueOffset;
				case LeeHyperrealPassive.VFXPassive.BLUE:
					return StaticValues.defaultBaseHueOffset;
				case LeeHyperrealPassive.VFXPassive.LIGHTBLUE:
					return StaticValues.lightBlueBaseHueOffset;
				case LeeHyperrealPassive.VFXPassive.VIOLET:
					return StaticValues.violetBaseHueOffset;
				case LeeHyperrealPassive.VFXPassive.PINK:
					return StaticValues.pinkBaseHueOffset;
				}
			}
			if (IsRedSkin())
			{
				return StaticValues.redBaseHueOffset;
			}
			if (IsOrangeSkin())
			{
				return StaticValues.orangeBaseHueOffset;
			}
			if (IsLightBlueSkin())
			{
				return StaticValues.lightBlueBaseHueOffset;
			}
			return StaticValues.defaultBaseHueOffset;
		}

		public bool IsRedSkin()
		{
			return LeeHyperreal.redVFXSkins.Contains((int)selectedSkin);
		}

		public bool IsOrangeSkin()
		{
			return LeeHyperreal.orangeVFXSkins.Contains((int)selectedSkin);
		}

		public bool IsLightBlueSkin()
		{
			return LeeHyperreal.lightBlueVFXSkins.Contains((int)selectedSkin);
		}

		public void InitializeUI()
		{
			if (!isInitialized && !baseAIPresent)
			{
				InitializeRoRHUD();
				InitializePowerMeter();
				InitializeHealthLayer();
				InitializeBulletUI();
				InitializeUltimateIndicator();
				InitializeOrbAnimatorArray();
				InitializeHoldOKTag();
				InitializeOrbAmountLabel();
				InitializeOrbBrackets();
				InitializeCrosshair();
				InitializeSkillIconMaterial();
				if (Object.op_Implicit((Object)(object)orbController))
				{
					UpdateOrbList(orbController.orbList);
				}
				isInitialized = true;
			}
		}

		private void InitializeRoRHUD()
		{
			if (Object.op_Implicit((Object)(object)RoRHUDObject))
			{
				RoRHUDSpringCanvasTransform = RoRHUDObject.transform.Find("MainContainer").Find("MainUIArea").Find("SpringCanvas");
				HUD component = RoRHUDObject.GetComponent<HUD>();
				GameObject gameObject = ((Component)RoRHUDObject.transform.Find("MainContainer").Find("NotificationArea")).gameObject;
				NotificationUIController component2 = gameObject.GetComponent<NotificationUIController>();
				LeeHyperrealUINotificationController leeHyperrealUINotificationController = ((Component)component2).gameObject.GetComponent<LeeHyperrealUINotificationController>();
				if (!Object.op_Implicit((Object)(object)leeHyperrealUINotificationController))
				{
					leeHyperrealUINotificationController = ((Component)component2).gameObject.AddComponent<LeeHyperrealUINotificationController>();
				}
				LeeHyperrealNotificationQueue leeHyperrealNotificationQueue = ((Component)component.targetMaster).gameObject.GetComponent<LeeHyperrealNotificationQueue>();
				if (!Object.op_Implicit((Object)(object)leeHyperrealNotificationQueue))
				{
					leeHyperrealNotificationQueue = ((Component)component.targetMaster).gameObject.AddComponent<LeeHyperrealNotificationQueue>();
				}
				leeHyperrealUINotificationController.hud = component2.hud;
				leeHyperrealUINotificationController.genericNotificationPrefab = LeeHyperrealAssets.leenotificationBoxPrefab;
				leeHyperrealUINotificationController.notificationQueue = leeHyperrealNotificationQueue;
				return;
			}
			throw new NullReferenceException();
		}

		public void Update()
		{
			if (!characterBody.hasEffectiveAuthority)
			{
				return;
			}
			if (!isInitialized && !failedToInitialize)
			{
				try
				{
					InitializeUI();
					return;
				}
				catch (NullReferenceException arg)
				{
					Debug.Log((object)$"Lee: Hyperreal - NRE on UI Initialization, trying again: {arg}");
					failAttempts++;
					if (failAttempts >= 50)
					{
						failedToInitialize = true;
						Debug.Log((object)$"Lee: Hyperreal UI failed to initialize after more than {50} attempts. Stopping attempts to initialize.");
					}
					return;
				}
				catch (ForcedUIReInitException)
				{
					Debug.Log((object)"Lee: Hyperreal - UI needs to Reinit!");
					return;
				}
			}
			if (!baseAIPresent && isInitialized)
			{
				UpdateHealthUIObject();
				UpdateMeterLevel();
				SetAnimatorMeterValue();
				HandleBulletUIChange();
				UpdateGlyphPositions();
				UpdateSprintingCrosshairState();
				HandleRGBMode();
				LateUpdatePositions();
			}
		}

		private void HandleRGBMode()
		{
			if (!Config.rgbMode.Value)
			{
				return;
			}
			if (domainController.GetDomainState() || domainController.DomainEntryAllowed())
			{
				rgbOffset += Time.deltaTime * Config.rgbPulseSpeed.Value;
				rgbOffset %= 360f;
				float num = 0f;
				if (Object.op_Implicit((Object)(object)powerBarFilledMaterial))
				{
					SetCustomUIMaterial(powerBarFilledMaterial, rgbOffset + num, -2f);
				}
				{
					foreach (Material skillIconMaterial in skillIconMaterials)
					{
						num += 10f;
						SetCustomUIMaterial(skillIconMaterial, (rgbOffset + num) % 360f, -2f);
					}
					return;
				}
			}
			if (Object.op_Implicit((Object)(object)powerBarFilledMaterial))
			{
				SetCustomUIMaterial(powerBarFilledMaterial, 0f, -2f);
			}
			foreach (Material skillIconMaterial2 in skillIconMaterials)
			{
				SetCustomUIMaterial(skillIconMaterial2, 0f, -2f);
			}
		}

