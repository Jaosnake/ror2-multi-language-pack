			public static void InitWeaponConfig(DriverWeaponDef weaponDef)
			{
				string text = ((Object)weaponDef).name.Replace("'", string.Empty);
				ConfigEntry<bool> val = BindAndOptions("07 - Weapons", text + " - Enabled", defaultValue: true, "Set to false to remove this weapon from the drop pool.");
				ConfigEntry<int> val2 = BindAndOptionsSlider("07 - Weapons", text + " - Base Ammo", weaponDef.shotCount, "How many shots this weapon can fire without any bonus attack speed.", 0, 200);
				ConfigEntry<DriverWeaponTier> val3 = BindAndOptionsEnum("07 - Weapons", text + " - Tier", weaponDef.tier, "Sets the random drop tier of the weapon. NoTier, Void and Lunar do not drop randomly.");
