			if (Object.op_Implicit((Object)(object)component))
			{
				PlayerCharacterMasterController val = (Object.op_Implicit((Object)(object)hud.targetMaster) ? hud.targetMaster.playerCharacterMasterController : null);
				if (Object.op_Implicit((Object)(object)furyGauge))
				{
					furyGauge.gameObject.SetActive(true);
					float desiredFill = component.currentFury / component.maxFury;
					float fillAmount = furyFill.fillAmount;
					FillGauge(desiredFill);
					furyFill.fillAmount = currentFill;
					float num = Mathf.Lerp(startColor.r, endColor.r, currentFill);
					float num2 = Mathf.Lerp(startColor.g, endColor.g, currentFill);
					float num3 = Mathf.Lerp(startColor.b, endColor.b, currentFill);
					Color cyan = default(Color);
					((Color)(ref cyan))..ctor(num, num2, num3);
					if (currentFill >= 1f)
					{
						cyan = Color.cyan;
					}
					((Graphic)furyFill).color = cyan;
				}
			}
			else if (Object.op_Implicit((Object)(object)furyGauge))
			{
				furyGauge.gameObject.SetActive(false);
			}
		}
	}
	public class HenryController : MonoBehaviour
	{
		public bool hasBazookaReady;

		public Transform origAimOrigin;

		private CharacterBody characterBody;

		private CharacterModel model;

		private ChildLocator childLocator;

		private HenryTracker tracker;

		private Animator modelAnimator;

		private CameraTargetParams cameraShit3;

		private bool inFrenzy;

		private ParticleSystem[] frenzyEffects;

		private ParticleSystem superSaiyanEffect;

		private void Awake()
		{
			characterBody = ((Component)this).gameObject.GetComponent<CharacterBody>();
			origAimOrigin = characterBody.aimOriginTransform;
			childLocator = ((Component)this).gameObject.GetComponentInChildren<ChildLocator>();
			model = ((Component)this).gameObject.GetComponentInChildren<CharacterModel>();
			tracker = ((Component)this).gameObject.GetComponent<HenryTracker>();
			modelAnimator = ((Component)this).gameObject.GetComponentInChildren<Animator>();
			cameraShit3 = ((Component)this).GetComponent<CameraTargetParams>();
			hasBazookaReady = false;
			inFrenzy = false;
			frenzyEffects = (ParticleSystem[])(object)new ParticleSystem[3]
			{
				((Component)childLocator.FindChild("FrenzyEffect")).gameObject.GetComponent<ParticleSystem>(),
				((Component)childLocator.FindChild("FrenzyFistEffectL")).gameObject.GetComponent<ParticleSystem>(),
				((Component)childLocator.FindChild("FrenzyFistEffectR")).gameObject.GetComponent<ParticleSystem>()
			};
			superSaiyanEffect = ((Component)childLocator.FindChild("SuperSaiyanEffect")).gameObject.GetComponent<ParticleSystem>();
			((MonoBehaviour)this).Invoke("CheckWeapon", 0.2f);
		}

		private void FixedUpdate()
		{
			if (inFrenzy && !characterBody.HasBuff(Buffs.frenzyBuff) && !characterBody.HasBuff(Buffs.frenzyScepterBuff))
			{
				ExitFrenzy();
			}
		}

		private void CheckWeapon()
		{
			string skillNameToken = characterBody.skillLocator.primary.skillDef.skillNameToken;
			string text = skillNameToken;
			if (!(text == "ROB_HENRY_BODY_PRIMARY_PUNCH_NAME"))
			{
				if (!(text == "ROB_HENRY_BODY_PRIMARY_GUN_NAME"))
				{
					((Component)childLocator.FindChild("SwordModel")).gameObject.SetActive(true);
					((Component)childLocator.FindChild("BoxingGloveL")).gameObject.SetActive(false);
					((Component)childLocator.FindChild("BoxingGloveR")).gameObject.SetActive(false);
					((Component)childLocator.FindChild("AltGun")).gameObject.SetActive(false);
					modelAnimator.SetLayerWeight(modelAnimator.GetLayerIndex("Body, Alt"), 0f);
				}
				else
				{
					((Component)childLocator.FindChild("SwordModel")).gameObject.SetActive(false);
					((Component)childLocator.FindChild("BoxingGloveL")).gameObject.SetActive(false);
					((Component)childLocator.FindChild("BoxingGloveR")).gameObject.SetActive(false);
					((Component)childLocator.FindChild("AltGun")).gameObject.SetActive(true);
					modelAnimator.SetLayerWeight(modelAnimator.GetLayerIndex("Body, Alt"), 0f);
				}
			}
			else
			{
				((Component)childLocator.FindChild("SwordModel")).gameObject.SetActive(false);
				((Component)childLocator.FindChild("BoxingGloveL")).gameObject.SetActive(true);
				((Component)childLocator.FindChild("BoxingGloveR")).gameObject.SetActive(true);
				((Component)childLocator.FindChild("AltGun")).gameObject.SetActive(false);
				modelAnimator.SetLayerWeight(modelAnimator.GetLayerIndex("Body, Alt"), 1f);
			}
			bool flag = false;
			if (characterBody.skillLocator.secondary.skillDef.skillNameToken == "ROB_HENRY_BODY_SECONDARY_STINGER_NAME")
			{
				((Component)childLocator.FindChild("GunModel")).gameObject.SetActive(false);
				((Component)childLocator.FindChild("Gun")).gameObject.SetActive(false);
				characterBody._defaultCrosshairPrefab = Asset.LoadCrosshair("SimpleDot");
				flag = true;
			}
			else if (characterBody.skillLocator.secondary.skillDef.skillNameToken == "ROB_HENRY_BODY_SECONDARY_UZI_NAME")
			{
				((Component)childLocator.FindChild("GunModel")).GetComponent<SkinnedMeshRenderer>().sharedMesh = Asset.mainAssetBundle.LoadAsset<Mesh>("meshUzi");
			}
			bool flag2 = characterBody.skillLocator.special.skillDef.skillNameToken == "ROB_HENRY_BODY_SPECIAL_FRENZY_NAME";
			if (characterBody.skillLocator.special.skillDef.skillNameToken == "ROB_HENRY_BODY_SPECIAL_SCEPFRENZY_NAME")
			{
				flag2 = true;
			}
			if (!flag2)
			{
				HenryFuryComponent component = ((Component)this).GetComponent<HenryFuryComponent>();
				if (Object.op_Implicit((Object)(object)component))
				{
					Object.Destroy((Object)(object)component);
				}
			}
			if (!flag && Object.op_Implicit((Object)(object)tracker))
			{
				Object.Destroy((Object)(object)tracker);
			}
		}

		public void UpdateCrosshair()
		{
			GameObject defaultCrosshairPrefab = Asset.LoadCrosshair("Standard");
			if (characterBody.skillLocator.secondary.skillDef.skillNameToken == "ROB_HENRY_BODY_SECONDARY_STINGER_NAME")
			{
				defaultCrosshairPrefab = Asset.LoadCrosshair("SimpleDot");
			}
			if (hasBazookaReady)
			{
				defaultCrosshairPrefab = Asset.bazookaCrosshair;
			}
			characterBody._defaultCrosshairPrefab = defaultCrosshairPrefab;
		}

		public void EnterBazookaCamera()
		{
			Camera.ActivateCameraParamsOverride(cameraShit3, Camera.ParamsType.BAZOOKA);
		}

		public void ExitBazookaCamera()
		{
			Camera.DeactivateCameraParamsOverrides(cameraShit3);
		}

		public void EnterFrenzy()
		{
			inFrenzy = true;
			if (!Config.rampageEffects.Value)
			{
				return;
			}
			for (int i = 0; i < frenzyEffects.Length; i++)
			{
				if (Object.op_Implicit((Object)(object)frenzyEffects[i]))
				{
					frenzyEffects[i].Play();
				}
			}
		}

		public void EnterScepterFrenzy()
		{
			inFrenzy = true;
			if (Config.rampageEffects.Value)
			{
				for (int i = 0; i < frenzyEffects.Length; i++)
				{
					if (Object.op_Implicit((Object)(object)frenzyEffects[i]))
					{
						frenzyEffects[i].Play();
					}
				}
			}
			((Component)childLocator.FindChild("SaiyanHair")).gameObject.SetActive(true);
		}

		private void ExitFrenzy()
		{
			inFrenzy = false;
			if (Config.rampageEffects.Value)
			{
				for (int i = 0; i < frenzyEffects.Length; i++)
				{
					if (Object.op_Implicit((Object)(object)frenzyEffects[i]))
					{
						frenzyEffects[i].Stop();
					}
				}
			}
			((Component)childLocator.FindChild("SaiyanHair")).gameObject.SetActive(false);
		}
	}
	public class HenryFuryComponent : MonoBehaviour
	{
		public float maxFury = 100f;

		public float currentFury;

		private float lastFury;

		private CharacterBody characterBody;

		private CharacterMaster characterMaster;

		private CharacterModel model;

		private ChildLocator childLocator;

		private Animator modelAnimator;

		private void Awake()
		{
			characterBody = ((Component)this).gameObject.GetComponent<CharacterBody>();
			childLocator = ((Component)this).gameObject.GetComponentInChildren<ChildLocator>();
			model = ((Component)this).gameObject.GetComponentInChildren<CharacterModel>();
			modelAnimator = ((Component)this).gameObject.GetComponentInChildren<Animator>();
		}

		private void Start()
		{
			characterMaster = characterBody.master;
		}

		public bool AddFury()
		{
			return AddFury(2f);
		}

		public bool AddFury(float amount)
		{
			if (characterBody.HasBuff(Buffs.frenzyBuff))
			{
				return false;
			}
			if (currentFury >= maxFury)
			{
				return false;
			}
			if (characterBody.healthComponent.combinedHealth <= 0.5f * characterBody.healthComponent.fullCombinedHealth)
			{
				amount *= 2f;
			}
			if (characterBody.healthComponent.combinedHealth <= 0.25f * characterBody.healthComponent.fullCombinedHealth)
			{
				amount *= 3f;
			}
			currentFury = Mathf.Clamp(currentFury + amount, 0f, maxFury);
			if (currentFury >= maxFury && lastFury < maxFury)
			{
				Util.PlaySound("HenryFrenzyReady", ((Component)this).gameObject);
			}
			lastFury = currentFury;
			return true;
		}

		public bool SpendFury(float amount)
		{
			currentFury = Mathf.Clamp(currentFury - amount, 0f, maxFury);
			lastFury = currentFury;
			return true;
		}
	}
