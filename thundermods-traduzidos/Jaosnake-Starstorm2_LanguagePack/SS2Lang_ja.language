        "SS2_ELITE_MODIFIER_EMPYREAN": "Empyrean{0} {1}",
        "SS2_ELITE_EMPYREAN_SUBTITLE": "ペトリコール 5 世の敬虔な先見の明",
        "SS2_EQUIP_AFFIXEMPYREAN_NAME": "調和",
        "SS2_EQUIP_AFFIXEMPYREAN_PICKUP": "存在の一側面となる。",
        "SS2_ELITE_MODIFIER_STORM": "ストームボーン {0}",
        "SS2_ELITE_MODIFIER_SUPERFIRE": "地獄の {0}",
        "SS2_EQUIP_AFFIXSUPERFIRE_NAME": "ロイヤルフレイム(?)",
        "SS2_EQUIP_AFFIXSUPERFIRE_PICKUP": "火の前兆となる。",
        "SS2_ELITE_MODIFIER_SUPERICE": "北方圏 {0}",
        "SS2_EQUIP_AFFIXSUPERICE_NAME": "彼女の宇宙的な輝き",
