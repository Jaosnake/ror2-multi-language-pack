				}
				return _filteredBuffs;
			}
		}

		public static void ApplyFilter()
		{
			_filteredBuffs = new List<BuffDef>();
			BuffDef[] buffDefs = BuffCatalog.buffDefs;
			foreach (BuffDef val in buffDefs)
			{
				string[] array = filteredBuffsStrings;
				foreach (string text in array)
				{
					if (((Object)val).name == text)
					{
						_filteredBuffs.Add(val);
						break;
					}
				}
			}
			foreach (BuffDef filteredBuff in filteredBuffs)
			{
				Debug.Log((object)("Successfully Filtered " + ((Object)filteredBuff).name));
			}
		}

		public override void OnEnter()
		{
			cardTypeActivationVFX = Assets.PositiveCardActivation;
			cardSweepVFX = Assets.CardSweepPositive;
