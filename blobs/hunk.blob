					{
						newString = "Neutralize the <color=#C678B4>G-Virus</color>";
					}
					else if (virusType == VirusType.TVirus)
					{
						newString = "Stop the <color=#0066FF>T-Virus</color> outbreak";
					}
					else if (virusType == VirusType.CVirus)
					{
						newString = "Eradicate the <color=#FF0033>C-Virus</color>";
					}
					else if (virusType == VirusType.Uroboros)
					{
						newString = "Suppress the <color=#140E0E>Uroboros</color> carrier";
					}
					QuestDisplay.instance.NewQuest(newString);
