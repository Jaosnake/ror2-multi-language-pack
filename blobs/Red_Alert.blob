	public static class GIStates
	{
		public static void Init()
		{
			Content.AddEntityState(typeof(ArmMutiny));
			Content.AddEntityState(typeof(MineArmingMutiny));
			Content.AddEntityState(typeof(WaitForStickMutiny));
			Content.AddEntityState(typeof(WaitForTargetMutiny));
			Content.AddEntityState(typeof(Fire3RoundPistol));
			Content.AddEntityState(typeof(FireGunHeavy));
			Content.AddEntityState(typeof(FireMissile));
			Content.AddEntityState(typeof(FireMissileHeavy));
			Content.AddEntityState(typeof(BarricadeMain));
			Content.AddEntityState(typeof(BarricadeTransform));
			Content.AddEntityState(typeof(EnterBarricade));
			Content.AddEntityState(typeof(EnterBarricadeMissile));
			Content.AddEntityState(typeof(UnBarricade));
			Content.AddEntityState(typeof(LiterallyCommandoSlide));
			Content.AddEntityState(typeof(Roll));
			Content.AddEntityState(typeof(ThrowCaltrops));
			Content.AddEntityState(typeof(ThrowMine));
		}
	}
	public static class GITokens
	{
		public static void Init()
		{
			AddHenryTokens();
		}

		public static void AddHenryTokens()
		{
			string text = "HABIBI_GI_";
			string text2 = "ra2 quote.<color=#CCD3E0>" + Environment.NewLine + Environment.NewLine + "< ! > ra2 quote." + Environment.NewLine + Environment.NewLine + "< ! > ra2 quote." + Environment.NewLine + Environment.NewLine + "< ! > ra2 quote." + Environment.NewLine + Environment.NewLine + "< ! > ra2 quote." + Environment.NewLine + Environment.NewLine;
			string text3 = "..and so he left, ra2 quote.";
			string text4 = "..and so he vanished, ra2 quote.";
			Language.Add(text + "NAME", "G.I. (Alpha)");
			Language.Add(text + "DESCRIPTION", text2);
			Language.Add(text + "SUBTITLE", "ra2 quote");
			Language.Add(text + "LORE", "ra2 quote");
			Language.Add(text + "OUTRO_FLAVOR", text3);
			Language.Add(text + "OUTRO_FAILURE", text4);
			Language.Add(text + "MASTERY_SKIN_NAME", "Alternate");
			Language.Add(text + "PASSIVE_NAME", "Henry passive");
			Language.Add(text + "PASSIVE_DESCRIPTION", "Sample text.");
			string text5 = "Fire a wide, " + Tokens.UtilityText("piercing") + " Heavy Machine Gun for " + Tokens.DamageValueText(GIConfig.M1_HeavyFire_Damage.Value) + ".";
			Language.Add(text + "PRIMARY_GUN_NAME", "Gun");
			Language.Add(text + "PRIMARY_GUN_DESCRIPTION", "Fire Pistol for " + Tokens.DamageText($"{GIConfig.M1_Pistol_Shots.Value}x{GIConfig.M1_Pistol_Damage.Value * 100f}% damage") + ".\nWhile deployed, " + text5);
			Language.Add(text + "PRIMARY_GUN_HEAVY_NAME", "Gun Heavy");
			Language.Add(text + "PRIMARY_GUN_HEAVY_DESCRIPTION", text5);
			string text6 = "Fire Heavy Missile for " + Tokens.DamageValueText(GIConfig.M1_HeavyMissile_Damage.Value) + ".";
			Language.Add(text + "PRIMARY_ROCKET_NAME", "Missile");
			Language.Add(text + "PRIMARY_ROCKET_DESCRIPTION", "Fire a rocket for " + Tokens.DamageValueText(GIConfig.M1_Missile_Damage.Value) + ".\nWhile deployed, " + text6);
			Language.Add(text + "PRIMARY_ROCKET_HEAVY_NAME", "Missile heavy");
			Language.Add(text + "PRIMARY_ROCKET_HEAVY_NAME", text6);
			string text7 = "Throw a " + Tokens.DamageText("stunning") + " mine for " + Tokens.DamageValueText(GIConfig.M2_Mine_Damage.Value) + ".";
			Language.Add(text + "SECONDARY_CALTROPS_NAME", "Caltrops");
			Language.Add(text + "SECONDARY_CALTROPS_DESCRIPTION", string.Format("Throw {0} caltrops, dealing {1} over {2} seconds.\nWhile deployed, {3}", Tokens.DamageText("slowing"), Tokens.DamageValueText(GIConfig.M2_Caltrops_DotDamage.Value * 3f * 3f), 3, text7));
			Language.Add(text + "SECONDARY_MINE_NAME", "Mine");
			Language.Add(text + "SECONDARY_MINE_DESCRIPTION", text7);
			Language.Add(text + "UTILITY_SLIDE_NAME", "Basically Commando Slide");
			Language.Add(text + "UTILITY_SLIDE_DESCRIPTION", "Commando Slide but in the air as well");
			Language.Add(text + "SPECIAL_DEPLOY_NAME", "Deploy");
			Language.Add(text + "SPECIAL_DEPLOY_DESCRIPTION", $"Deploy and swap skills and dont move and get {GIConfig.M4_Transform_Armor.Value} armor.");
			Language.Add(text + "SPECIAL_UNDEPLOY_NAME", "UnDeploy");
			Language.Add(text + "SPECIAL_UNDEPLOY_DESCRIPTION", "Go back I want to b emon ke.");
			Language.Add(Tokens.GetAchievementNameToken("HABIBI_GI_masteryAchievement"), "G.I.: Mastery");
			Language.Add(Tokens.GetAchievementDescriptionToken("HABIBI_GI_masteryAchievement"), "As G.I., beat the game or obliterate on Monsoon.");
		}
	}
