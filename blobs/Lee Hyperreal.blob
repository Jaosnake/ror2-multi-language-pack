		{
			//IL_005c: Unknown result type (might be due to invalid IL or missing references)
			//IL_0081: Unknown result type (might be due to invalid IL or missing references)
			//IL_00c1: Unknown result type (might be due to invalid IL or missing references)
			if (Object.op_Implicit((Object)(object)orbUIObject) && Object.op_Implicit((Object)(object)RoRHUDSpringCanvasTransform) && !LeeHyperrealPlugin.isHunkHudInstalled)
			{
				if (LeeHyperrealPlugin.isRiskUIInstalled)
				{
					orbUIObject.transform.localScale = new Vector3(0.7f, 0.7f, 0.7f);
					orbUIObject.transform.localPosition = new Vector3(185f, 287.8038f, 0f);
				}
				else if (Object.op_Implicit((Object)(object)RoRHUDObject))
				{
					RoRHUDSpringCanvasTransform.GetChild(0).GetChild(0).position = new Vector3(-11.4084f, -4.3756f, 12.6537f);
				}
			}
		}

		public void FixedUpdate()
		{
			//IL_0067: Unknown result type (might be due to invalid IL or missing references)
			//IL_006c: Unknown result type (might be due to invalid IL or missing references)
			if (characterBody.hasEffectiveAuthority)
			{
				if (!enabledUI && !baseAIPresent && !spawnedEffect && Object.op_Implicit((Object)(object)Camera.main))
				{
					domainOverlayObject = Object.Instantiate<GameObject>(ParticleAssets.RetrieveParticleEffectFromSkin("domainOverlayEffect", characterBody), new Vector3(0f, 0f, -0.1f), Quaternion.identity, ((Component)Camera.main).transform);
					domainOverlayObject.SetActive(false);
					spawnedEffect = true;
				}
				UpdateSkillIconMat();
			}
		}

