		private void InitializeRecolorSkills()
		{
			if (characterModelObject.GetComponent<SkinRecolorController>().Recolors == null)
			{
				Log.Warning("Could not load recolors. types not serialized?");
				return;
			}
			SkillFamily skillFamily = Skills.CreateGenericSkillWithSkillFamily(bodyPrefab, "LOADOUT_SKILL_COLOR", "Recolor", hidden: true).skillFamily;
			SkinRecolorController component = characterModelObject.GetComponent<SkinRecolorController>();
			List<SkillDef> list = new List<SkillDef>
			{
				component.createRecolorSkillDef("Red"),
				component.createRecolorSkillDef("Blue"),
				component.createRecolorSkillDef("Green"),
				component.createRecolorSkillDef("Yellow"),
				component.createRecolorSkillDef("Orange"),
				component.createRecolorSkillDef("Cyan"),
				component.createRecolorSkillDef("Purple"),
				component.createRecolorSkillDef("Pink")
			};
			if (GeneralConfig.NewColor.Value)
			{
				list.Add(component.createRecolorSkillDef("Black"));
				list.Add(component.createRecolorSkillDef("White"));
			}
			for (int i = 0; i < list.Count; i++)
			{
				Skills.AddSkillToFamily(skillFamily, list[i], (i == 0) ? null : TeslaUnlockables.recolorsUnlockableDef);
				AddCssPreviewSkill(i, skillFamily, list[i]);
			}
		}

		public override void InitializeSkins()
		{
			//IL_0386: Unknown result type (might be due to invalid IL or missing references)
			ModelSkinController component = ((Component)prefabCharacterModel).gameObject.GetComponent<ModelSkinController>();
			ChildLocator component2 = ((Component)prefabCharacterModel).GetComponent<ChildLocator>();
			RendererInfo[] baseRendererInfos = prefabCharacterModel.baseRendererInfos;
			List<TeslaSkinDef> list = new List<TeslaSkinDef>();
			List<GameObject> allObjects = Skins.CreateAllActivatedGameObjectsList(component2, "meshTeslaArmor_Fanservice", "meshTeslaEmission");
			TeslaSkinDef teslaSkinDef = Skins.CreateSkinDef<TeslaSkinDef>("DEFAULT_SKIN", assetBundle.LoadAsset<Sprite>("texTeslaSkinDefault"), baseRendererInfos, characterModelObject);
			((SkinDef)teslaSkinDef).gameObjectActivations = Skins.GetGameObjectActivationsFromList(allObjects, default(int));
			((SkinDef)teslaSkinDef).meshReplacements = assetBundle.GetMeshReplacements(baseRendererInfos, "meshTeslaArmor", "meshTeslaArmor_Fanservice", null, "meshTeslaBody", "meshTeslaArmorColor", "meshTeslaBodyColor", "meshTeslaHammer");
			list.Add(teslaSkinDef);
			TeslaSkinDef teslaSkinDef2 = Skins.CreateSkinDef<TeslaSkinDef>("HABIBI_TESLA_BODY_MASTERY_SKIN_NAME", assetBundle.LoadAsset<Sprite>("texTeslaSkinMastery"), baseRendererInfos, characterModelObject, TeslaUnlockables.masterySkinUnlockableDef);
			((SkinDef)teslaSkinDef2).gameObjectActivations = Skins.GetGameObjectActivationsFromList(allObjects, 1);
			((SkinDef)teslaSkinDef2).meshReplacements = assetBundle.GetMeshReplacements(baseRendererInfos, "meshMasteryArmor", null, "meshMasteryEmission", "meshMasteryBody", "meshMasteryArmorColor", "meshMasteryBodyColor", "meshMasteryHammer");
			((SkinDef)teslaSkinDef2).rendererInfos[0].defaultMaterial = assetBundle.CreateHopooMaterialFromBundle("matMastery");
			((SkinDef)teslaSkinDef2).rendererInfos[2].defaultMaterial = assetBundle.CreateHopooMaterialFromBundle("matMastery").SetEmission(2f);
			((SkinDef)teslaSkinDef2).rendererInfos[3].defaultMaterial = assetBundle.CreateHopooMaterialFromBundle("matMastery");
			((SkinDef)teslaSkinDef2).rendererInfos[4].defaultMaterial = assetBundle.CreateHopooMaterialFromBundle("matMastery");
			((SkinDef)teslaSkinDef2).rendererInfos[5].defaultMaterial = assetBundle.CreateHopooMaterialFromBundle("matMastery");
