        "MOFFEIN_ROCKET_BODY_UTILITY_ALT_NAME": "Ejecución de bombardeo",
        "MOFFEIN_ROCKET_BODY_UTILITY_ALT_DESCRIPTION": "<style=cIsUtility>Pesado</style>. <style=cIsDamage>Impresionante</style>. Balancea tu pala explosiva hacia un enemigo para causar <style=cIsDamage>1200% de daño</style>. Realiza <style=cIsDamage>Golpes críticos</style> mientras <style=cIsUtility>salta explosiva</style>.",
        "MOFFEIN_ROCKET_BODY_UTILITY_ALT_SCEPTER_NAME": "gran slam",
