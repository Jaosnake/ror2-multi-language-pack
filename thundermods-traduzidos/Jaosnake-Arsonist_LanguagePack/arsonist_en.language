{
    "en": {
        "POPCORN_ARSONIST_BODY_NAME": "Arsonist",
        "POPCORN_ARSONIST_BODY_SUBTITLE": "Maniac Pyromaniac",
        "POPCORN_ARSONIST_BODY_PASSIVE_NORMAL_GAUGE_NAME": "Normal Gauge",
        "POPCORN_ARSONIST_BODY_PASSIVE_NORMAL_GAUGE_DESCRIPTION": "Deal <style=cIsDamage>100%</style> damage on the white portion. The Base Gauge is resistant to Overheat.",
        "POPCORN_ARSONIST_BODY_PASSIVE_BLUE_GAUGE_NAME": "Critical Gauge",
        "POPCORN_ARSONIST_BODY_PASSIVE_BLUE_GAUGE_DESCRIPTION": "Deal <style=cIsDamage>70%</style> damage on the white portion and <style=cIsDamage>250%</style> damage on the blue portion. Maximum heat is fixed.",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_NAME": "Dragon's Breath",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_DESCRIPTION": "Fire a beam of flame dealing <style=cIsDamage>90% damage</style>. Increased ignition chance the closer you are to the target.",
        "POPCORN_ARSONIST_BODY_PRIMARY_FIRESPRAY_NAME": "Fireball",
        "POPCORN_ARSONIST_BODY_PRIMARY_FIRESPRAY_DESCRIPTION": "<style=cIsUtility>Heat. </style>Fires a fireball dealing <style=cIsDamage>225% damage and igniting</style> enemies on hit.",
        "POPCORN_ARSONIST_BODY_SECONDARY_PUNCH_NAME": "Zero Point Blast",
        "POPCORN_ARSONIST_BODY_SECONDARY_PUNCH_DESCRIPTION": "<style=cIsUtility>Agile. Heat. </style>Propel yourself forward, exploding enemies behind you for <style=cIsDamage>200% damage</style>. Colliding immediately after launch with the first enemy causes <style=cIsDamage>200% damage</style> in a surrounding explosion.",
        "POPCORN_ARSONIST_BODY_SECONDARY_FLAREGUN_NAME": "Flare Gun",
        "POPCORN_ARSONIST_BODY_SECONDARY_FLAREGUN_DESCRIPTION": "Fire a flare dealing <style=cIsDamage>400% damage</style> over 5 seconds, then explodes dealing <style=cIsDamage>400% damage</style>, launching 5 flares dealing <style=cIsDamage>200% damage</style> each.",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHIST_NAME": "Masochism",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHIST_DESCRIPTION": "<style=cIsUtility>Agile. Heat. </style>Damage from being <style=cIsDamage>ignited</style> transforms into <style=cIsHealing>healing</style> for 6.5 seconds. Increases Attack Speed by <style=cIsDamage>125%</style>.",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_NAME": "Masochism",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_DESCRIPTION": "Upon reaching the <style=cKeywordName>Anticipation</style> limit, periodically deal damage to yourself in exchange for area <style=cIsHealing>Lifesteal</style> and burn. After at most 10 seconds, <style=cIsDamage>Detonate</style>, then <style=cIsUtility>Overheat</style>.",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_SURGE_NAME": "Spite",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_SURGE_DESCRIPTION": "Upon reaching the <style=cKeywordName>Anticipation</style> limit, you move faster and gain <style=cKeywordName>Double Shot</style> and <style=cIsHealing>Lifesteal</style>. After at most 10 seconds, <style=cIsDamage>Detonate</style>, then <style=cIsUtility>Overheat</style>.",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_SCEPTER_NAME": "Dante's Rebuke",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_SCEPTER_DESCRIPTION": "Fire an intense beam dealing <style=cIsDamage>140% damage</style>. Increased ignition chance the closer you are to the target. If held for 2 seconds or more, fire a final beam on release for <style=cIsDamage>150% damage</style>.",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_ANTICIPATION": "<style=cKeywordName>Anticipation</style>For every 100 heat lost and/or gained, Arsonist gains 1 Anticipation charge; After gaining 5 charges, he can activate Masochism; Additional charges increase damage and duration; All charges are consumed at the end.",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_DETONATE": "<style=cKeywordName>Detonate</style>Arsonist explodes, dealing <style=cIsDamage>150% damage</style> times the amount of Anticipation Charges accumulated.",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_LIFESTEAL": "<style=cKeywordName>Lifesteal</style>Arsonist heals <style=cIsHealing>18%</style> of damage dealt while Masochism is active.",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_SURGE_LIFESTEAL": "<style=cKeywordName>Lifesteal</style>Arsonist heals <style=cIsHealing>5%</style> of damage dealt while Spite is active.",
        "POPCORN_ARSONIST_BODY_KEYWORD_OVERHEAT_MASO": "<style=cKeywordName>Overheat: Masochism</style>If Arsonist leaves Masochism due to excessive heat buildup, EX Overheat is applied, reducing Movement Speed and Damage to 70%. Canceling or letting the skill run its course applies Overheat, reducing Attack Speed to 50%.",
        "POPCORN_ARSONIST_BODY_OVERHEAT_TEXT": "OVERHEAT!",
        "POPCORN_ARSONIST_BODY_COOLING_TEXT": "COOLING DOWN...!",
        "POPCORN_ARSONIST_BODY_OVERHEAT_EX_TEXT": "OVERHEAT:EX!",
        "POPCORN_ARSONIST_BODY_PASSIVE_NAME": "Pyromania",
        "POPCORN_ARSONIST_BODY_PASSIVE_DESCRIPTION": "Resist fire damage from all sources. Convert one attack dealing greater than <style=cIsDamage>30%</style> of total health into <style=cIsDamage>50%</style> fire damage over time.",
        "POPCORN_ARSONIST_BODY_KEYWORD_PYROMANIAPASSIVE": "Pyromania does not affect fall damage unless Frailty is active.",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_NAME": "Arsonist: Mastery",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_DESCRIPTION": "As Arsonist, beat the game or obliterate on Monsoon.",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_ECLIPSE5UNLOCKABLE_ACHIEVEMENT_NAME": "Arsonist: Grandmastery",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_ECLIPSE5UNLOCKABLE_ACHIEVEMENT_DESCRIPTION": "As Arsonist, beat the game on Eclipse 5 or higher, OR beat the game on Typhoon (Starstorm 2 required).",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_ECLIPSE8UNLOCKABLE_ACHIEVEMENT_NAME": "Arsonist: Survival",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_ECLIPSE8UNLOCKABLE_ACHIEVEMENT_DESCRIPTION": "As Arsonist, beat the game on Eclipse 8, OR beat the game on Inferno (Inferno required).",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_FLAMETHROWERUNLOCKABLE_ACHIEVEMENT_NAME": "Arsonist: Pyromaniac",
