			text7 = text7 + "[ <style=cIsUtility>Support:</style> MP Turbo ]" + Environment.NewLine;
			text7 = text7 + "Attached Spell deals more damage, and costs more MP. <style=cSub>(linked to Ultima)</style>" + Environment.NewLine;
			text7 = text7 + "[ <style=cIsDamage>Finisher:</style> Shillelagh ]" + Environment.NewLine;
