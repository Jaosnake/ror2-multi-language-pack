{
    "zh-CN": {
        "ROB_HENRY_BODY_NAME": "亨利",
        "ROB_HENRY_BODY_DESCRIPTION": "Henry是一位熟练的战士,使用丰富的武器库击败敌人。<color=#CCD3E0>",
        "ROB_HENRY_BODY_SUBTITLE": "天选之人",
        "ROB_HENRY_BODY_LORE": "示例传说",
        "ROB_HENRY_BODY_OUTRO_FLAVOR": "..于是他离开了,寻找新的身份。",
        "ROB_HENRY_BODY_OUTRO_FAILURE": "..于是他消失了,永远是一张白纸。",
        "ROB_HENRY_BODY_DEFAULT_SKIN_NAME": "默认",
        "ROB_HENRY_BODY_MASTERY_SKIN_NAME": "替代",
        "ROB_HENRY_BODY_TYPHOON_SKIN_NAME": "V1",
        "ROB_HENRY_BODY_DANTE_SKIN_NAME": "Dante",
        "ROB_HENRY_BODY_VERGIL_SKIN_NAME": "Vergil",
        "ROB_HENRY_BODY_SAMURAI_SKIN_NAME": "武士",
        "ROB_HENRY_BODY_SOLDIER_SKIN_NAME": "冠军",
        "ROB_HENRY_BODY_ZOMBIE_SKIN_NAME": "僵尸",
        "ROB_HENRY_BODY_SKELETON_SKIN_NAME": "骷髅",
        "ROB_HENRY_BODY_PASSIVE_NAME": "Henry被动",
        "ROB_HENRY_BODY_PASSIVE_DESCRIPTION": "示例文本。",
        "ROB_HENRY_BODY_PRIMARY_SLASH_NAME": "剑",
        "ROB_HENRY_BODY_PRIMARY_SLASH_DESCRIPTION": "<style=cIsUtility>敏捷。</style>向前挥砍造成<style=cIsDamage>280%伤害</style>。",
        "ROB_HENRY_BODY_PRIMARY_PUNCH_NAME": "拳击手套",
        "ROB_HENRY_BODY_PRIMARY_PUNCH_DESCRIPTION": "<style=cIsUtility>敏捷.</style> 快速挥拳，造成<style=cIsDamage>240%伤害</style>。<style=cIsUtility>无视护甲。</style>",
        "ROB_HENRY_BODY_PRIMARY_GUN_NAME": "手枪",
        "ROB_HENRY_BODY_PRIMARY_GUN_DESCRIPTION": "<style=cIsUtility>敏捷.</style> 发射小手枪，造成<style=cIsDamage>90%伤害</style>。",
        "ROB_HENRY_BODY_SECONDARY_GUN_NAME": "手枪",
        "ROB_HENRY_BODY_SECONDARY_GUN_DESCRIPTION": "<style=cIsUtility>敏捷。</style>开火造成<style=cIsDamage>420%伤害</style>。",
        "ROB_HENRY_BODY_SECONDARY_STINGER_NAME": "Stinger",
        "ROB_HENRY_BODY_SECONDARY_STINGER_DESCRIPTION": "<style=cIsUtility>敏捷.</style> 冲向敌人，造成<style=cIsDamage>450%伤害</style>。",
        "ROB_HENRY_BODY_SECONDARY_UZI_NAME": "Uzi",
        "ROB_HENRY_BODY_SECONDARY_UZI_DESCRIPTION": "使用Uzi射击，造成<style=cIsDamage>75%伤害</style>。",
        "ROB_HENRY_BODY_UTILITY_ROLL_NAME": "翻滚",
        "ROB_HENRY_BODY_UTILITY_ROLL_DESCRIPTION": "短距离翻滚,获得<style=cIsUtility>300护甲</style>。<style=cIsUtility>翻滚期间无法被击中。</style>",
        "ROB_HENRY_BODY_UTILITY_SHOTGUN_NAME": "Shotgun",
        "ROB_HENRY_BODY_UTILITY_SHOTGUN_DESCRIPTION": "发射<style=cIsUtility>霰弹枪</style>，造成<style=cIsDamage>14x140%伤害</style>，并用后坐力推动自己。",
        "ROB_HENRY_BODY_SPECIAL_BOMB_NAME": "炸弹",
        "ROB_HENRY_BODY_SPECIAL_BOMB_DESCRIPTION": "投掷炸弹造成<style=cIsDamage>1600%伤害</style>。",
        "ROB_HENRY_BODY_SPECIAL_SCEPBOMB_NAME": "更多炸弹！",
        "ROB_HENRY_BODY_SPECIAL_SCEPBOMB_DESCRIPTION": "投掷炸弹，造成<style=cIsDamage>1600%伤害</style>。\n<color=#d299ff>SCEPTER：最多持有4枚炸弹。冷却时间减半。</color>",
        "ROB_HENRY_BODY_SPECIAL_BAZOOKA_NAME": "Bazooka",
        "ROB_HENRY_BODY_SPECIAL_BAZOOKA_DESCRIPTION": "蓄力并发射火箭，造成<style=cIsDamage>600%-1600%伤害</style>。",
        "ROB_HENRY_BODY_PRIMARY_BAZOOKA_NAME": "开火",
        "ROB_HENRY_BODY_PRIMARY_BAZOOKA_DESCRIPTION": "蓄力并发射一枚火箭，造成<style=cIsDamage>600%-1600%伤害</style>。",
        "ROB_HENRY_BODY_PRIMARY_BAZOOKAOUT_NAME": "取消",
        "ROB_HENRY_BODY_PRIMARY_BAZOOKAOUT_DESCRIPTION": "收起你的<style=cIsDamage>bazooka</style>。",
        "ROB_HENRY_BODY_SPECIAL_SCEPBAZOOKA_NAME": "Armageddon",
        "ROB_HENRY_BODY_SPECIAL_SCEPBAZOOKA_DESCRIPTION": "蓄力并发射火箭，造成<style=cIsDamage>600%-1600%伤害</style>。\n<color=#d299ff>SCEPTER: 同时持有两把Bazooka。</color>",
        "ROB_HENRY_BODY_PRIMARY_SCEPBAZOOKA_NAME": "开火",
        "ROB_HENRY_BODY_PRIMARY_SCEPBAZOOKA_DESCRIPTION": "蓄力并发射一枚火箭，造成<style=cIsDamage>600%-1600%伤害</style>。\n<color=#d299ff>SCEPTER: 同时持有两把Bazooka。</color>",
        "ROB_HENRY_BODY_SPECIAL_FRENZY_NAME": "Rampage",
        "ROB_HENRY_BODY_SPECIAL_FRENZY_DESCRIPTION": "命中时积累<style=cIsHealth>Fury</style>。充满后使用，进入<style=cIsDamage>狂暴</style>状态<style=cIsUtility>10秒</style>。<style=cIsHealth>生命值越低充能越快。</style>",
        "ROB_HENRY_BODY_SPECIAL_SCEPFRENZY_NAME": "Super Saiyan",
        "ROB_HENRY_BODY_SPECIAL_SCEPFRENZY_DESCRIPTION": "Charge up <style=cIsHealth>Fury</style> on hit. Use when fully charged to enter a <style=cIsDamage>frenzy</style> for <style=cIsUtility>10 seconds</style>. <style=cIsHealth>Charges faster at lower 生命值.</style>\n<color=#d299ff>SCEPTER: Stat bonuses massively increased. Duration increased.</color>",
        "ACHIEVEMENT_ROB_HENRY_BODY_UNLOCKABLE_ACHIEVEMENT_ID_NAME": "Prelude",
        "ACHIEVEMENT_ROB_HENRY_BODY_UNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "进入Titanic Plains。",
        "ACHIEVEMENT_ROB_HENRY_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_ID_NAME": "Henry: Mastery",
        "ACHIEVEMENT_ROB_HENRY_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "以Henry身份在Monsoon通关或湮灭。",
        "ACHIEVEMENT_ROB_HENRY_BODY_TYPHOONUNLOCKABLE_ACHIEVEMENT_ID_NAME": "Henry: Grand Mastery",
        "ACHIEVEMENT_ROB_HENRY_BODY_TYPHOONUNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "以Henry身份在Typhoon或Eclipse通关或湮灭。\n<color=#8888>（任意Typhoon或更高难度均计入）</color>",
        "ROB_HENRY_BODY_DANTEUNLOCKABLE_ACHIEVEMENT_NAME": "Henry: Jackpot",
        "ROB_HENRY_BODY_DANTEUNLOCKABLE_ACHIEVEMENT_DESC": "As Henry, defeat a Twisted Scavenger on Monsoon.",
        "ROB_HENRY_BODY_DANTEUNLOCKABLE_UNLOCKABLE_NAME": "Henry: Jackpot",
        "ROB_HENRY_BODY_VERGILUNLOCKABLE_ACHIEVEMENT_NAME": "Henry: 200% Motivated",
        "ROB_HENRY_BODY_VERGILUNLOCKABLE_ACHIEVEMENT_DESC": "As Henry, defeat the King of Nothing with no items.",
        "ROB_HENRY_BODY_VERGILUNLOCKABLE_UNLOCKABLE_NAME": "Henry: 200% Motivated",
        "ACHIEVEMENT_ROB_HENRY_MASTERYACHIEVEMENT_NAME": "Henry: Mastery",
        "ACHIEVEMENT_ROB_HENRY_MASTERYACHIEVEMENT_DESCRIPTION": "作为亨利，击败游戏或消灭季风。",
        "ROB_MRGREEN_BODY_NAME": "Mr. Green",
        "ROB_MRGREEN_BODY_DESCRIPTION": "Mr. Green<color=#CCD3E0>\n\n< ! > Sword is a good all-rounder while Boxing Gloves are better for laying a beatdown on more powerful foes.\n\n< ! > Pistol is a powerful anti air, with its low cooldown and high damage.\n\n< ! > Roll has a lingering armor buff that helps to use it aggressively.\n\n< ! > Bomb can be used to wipe crowds with ease.</color>",
        "ROB_MRGREEN_BODY_SUBTITLE": "The",
        "ROB_MRGREEN_BODY_LORE": "示例背景第2部分",
        "ROB_MRGREEN_BODY_OUTRO_FLAVOR": "..and so he left, bottom text.",
        "ROB_MRGREEN_BODY_DEFAULT_SKIN_NAME": "默认",
        "ROB_MRGREEN_BODY_PASSIVE_NAME": "Mr. Green被动",
        "ROB_MRGREEN_BODY_PASSIVE_DESCRIPTION": "示例文本。",
        "ROB_MRGREEN_BODY_PRIMARY_PUNCH_NAME": "Martial Arts",
        "ROB_MRGREEN_BODY_PRIMARY_PUNCH_DESCRIPTION": "施展快速拳脚连击，造成<style=cIsDamage>90%伤害</style>。",
        "ROB_MRGREEN_BODY_SECONDARY_CLONETHROW_NAME": "投掷克隆体",
        "ROB_MRGREEN_BODY_SECONDARY_CLONETHROW_DESCRIPTION": "召唤并向前投掷克隆体，抓住附近敌人并将其砸向地面，造成<style=cIsDamage>420%伤害</style>。",
        "ROB_MRGREEN_BODY_UTILITY_DASH_NAME": "People's Elbow",
        "ROB_MRGREEN_BODY_UTILITY_DASH_DESCRIPTION": "短距离冲刺。接触<style=cIsUtility>克隆体</style>时跃入空中，以强力<style=cIsUtility>肘击</style>造成<style=cIsDamage>800%伤害</style>。",
        "ROB_MRGREEN_BODY_SPECIAL_RES_NAME": "Resurrection",
        "ROB_MRGREEN_BODY_SPECIAL_RES_DESCRIPTION": "复活所有倒下的克隆体。",
        "ROB_NEMRY_BODY_NAME": "Nemesis Henry",
        "ROB_NEMRY_BODY_DESCRIPTION": "Nemesis Henry is a volatile swordsman who wields a special blade that stores energy to boost its attacks. He has no cooldowns, but must manage his energy well.<color=#CCD3E0>\n\n< ! > Sword Mode is used to build up energy while Gun Mode is used to spend energy for powerful attacks.\n\n< ! > Swordmaster can be charged up for more damage.\n\n< ! > Flash Step is a powerful aggressive tool that helps to build up energy.\n\n< ! > Use Hydra Bite to stay healthy and Hyper Beam to unleash a ton of damage.</color>",
        "ROB_NEMRY_BODY_SUBTITLE": "堕落者",
        "ROB_NEMRY_BODY_LORE": "示例背景",
        "ROB_NEMRY_BODY_OUTRO_FLAVOR": "..and so he left, having blown up the moon for no discernible reason.",
        "ROB_NEMRY_BODY_OUTRO_FAILURE": "..he tried so hard, and got so far. But in the end it doesn't even matter.",
        "ROB_NEMRY_BODY_DEFAULT_SKIN_NAME": "Nemesis",
        "ROB_NEMRY_BODY_MASTERY_SKIN_NAME": "Captive #001",
        "ROB_NEMRY_BODY_TYPHOON_SKIN_NAME": "FLLFFL",
        "ROB_NEMRY_BODY_PASSIVE_NAME": "酸蚀枪刃",
        "ROB_NEMRY_BODY_PASSIVE_DESCRIPTION": "Nemesis Henry wields a special weapon that can swap between Sword Mode and Gun Mode. Also, his skills don't have regular cooldowns, but instead rely on his sword's <style=cIsHealing>Energy</style> system.",
        "ROB_NEMRY_BODY_PRIMARY_SPEAR_NAME": "穿刺",
        "ROB_NEMRY_BODY_PRIMARY_SPEAR_DESCRIPTION": "<style=cIsUtility>Agile.</style> Stab forward for <style=cIsDamage>160% damage</style>. <style=cIsDamage>Deals double damage and heals for <style=cIsHealing>50%</style> of damage dealt at the tip</style>.",
        "ROB_WEAPON_SWAP_SKILL": "Weapon Swap",
        "ROB_NEMRY_BODY_PRIMARY_SWORD_NAME": "Sword Mode",
        "ROB_NEMRY_BODY_PRIMARY_SWORD_DESCRIPTION": "Swing your blade forward for <style=cIsDamage>280% damage</style>. Generate <style=cIsHealing>20% Energy</style> on hit.",
        "ROB_NEMRY_BODY_PRIMARY_GUN_NAME": "Gun Mode",
        "ROB_NEMRY_BODY_PRIMARY_GUN_DESCRIPTION": "<style=cIsHealing>2.5% Energy.</style> Fire a piercing <style=cIsHealing>Energy</style> shot for <style=cIsDamage>240% damage</style>.",
        "ROB_NEMRY_BODY_PRIMARY_SWORDCSS_NAME": "Sword Mode / Gun Mode",
        "ROB_NEMRY_BODY_PRIMARY_SWORDCSS_DESCRIPTION": "Swing your blade forward for <style=cIsDamage>280% damage</style>. Generate <style=cIsHealing>20% Energy</style> on hit.\n<style=cIsHealing>2.5% Energy.</style> Fire a piercing <style=cIsHealing>Energy</style> shot for <style=cIsDamage>240% damage</style>.",
        "ROB_NEMRY_BODY_SECONDARY_BLAST_NAME": "Null Blast",
        "ROB_NEMRY_BODY_SECONDARY_BLAST_DESCRIPTION": "<style=cIsUtility>Agile.</style> Throw a blob of <style=cIsHealth>mysterious energy</style> for <style=cIsDamage>200% damage</style>.",
        "ROB_NEMRY_BODY_SECONDARY_CHARGE_NAME": "Swordmaster",
        "ROB_NEMRY_BODY_SECONDARY_CHARGE_DESCRIPTION": "<style=cIsHealing>10% Energy.</style> Lunge at a nearby enemy for <style=cIsDamage>700% damage</style>. Perform a combo attack instead if within melee range.",
        "ROB_NEMRY_BODY_SECONDARY_TORRENT_NAME": "Gunslinger",
        "ROB_NEMRY_BODY_SECONDARY_TORRENT_DESCRIPTION": "<style=cIsHealing>5% Energy.</style> Fire a barrage of <style=cIsHealing>Energy</style> shots. Hold to continue firing, consuming more <style=cIsHealing>Energy</style> per shot.",
        "ROB_NEMRY_BODY_SECONDARY_CHARGECSS_NAME": "Swordmaster / Gunslinger",
        "ROB_NEMRY_BODY_SECONDARY_CHARGECSS_DESCRIPTION": "<style=cIsHealing>10% Energy.</style> Lunge at a nearby enemy for <style=cIsDamage>700% damage</style>. Perform a combo attack instead if within melee range.\n<style=cIsHealing>5% Energy.</style> Fire a barrage of <style=cIsHealing>Energy</style> shots. Hold to continue firing, consuming more <style=cIsHealing>Energy</style> per shot.",
        "ROB_NEMRY_BODY_UTILITY_DODGESLASH_NAME": "迅捷斩",
        "ROB_NEMRY_BODY_UTILITY_DODGESLASH_DESCRIPTION": "Backflip, slashing nearby enemies for <style=cIsDamage>300% damage</style>. <style=cIsUtility>You cannot be hit during the flip.</style>",
        "ROB_NEMRY_BODY_UTILITY_BLINK_NAME": "Flash Step",
        "ROB_NEMRY_BODY_UTILITY_BLINK_DESCRIPTION": "<style=cIsHealing>5% Energy.</style> <style=cIsUtility>Instantly blink</style> to a nearby enemy.",
        "ROB_NEMRY_BODY_UTILITY_BURST_NAME": "能量爆发",
        "ROB_NEMRY_BODY_UTILITY_BURST_DESCRIPTION": "<style=cIsHealing>10% Energy.</style> Discharge a burst of <style=cIsHealing>Energy</style> for <style=cIsDamage>400% damage</style>, <style=cIsUtility>launching yourself with the recoil</style>.",
        "ROB_NEMRY_BODY_UTILITY_BLINKCSS_NAME": "Flash Step / 能量爆发",
        "ROB_NEMRY_BODY_UTILITY_BLINKCSS_DESCRIPTION": "<style=cIsHealing>5% Energy.</style> <style=cIsUtility>Instantly blink</style> to a nearby enemy.\n<style=cIsHealing>10% Energy.</style> Discharge a burst of <style=cIsHealing>Energy</style> for <style=cIsDamage>400% damage</style>, <style=cIsUtility>launching yourself with the recoil</style>.",
        "ROB_NEMRY_BODY_SPECIAL_STAB_NAME": "Hydra Bite",
        "ROB_NEMRY_BODY_SPECIAL_STAB_DESCRIPTION": "<style=cIsHealing>100% Energy.</style> Plunge your blade into an enemy for <style=cIsDamage>2800% damage</style>, inflicting a potent debuff. <style=cIsHealing>Heal for 50% of damage dealt.</style>",
        "ROB_NEMRY_BODY_SPECIAL_BEAM_NAME": "Hyper Beam",
        "ROB_NEMRY_BODY_SPECIAL_BEAM_DESCRIPTION": "<style=cIsHealing>100% Energy.</style> Charge up a powerful barrage of lasers that deals <style=cIsDamage>10x540% damage</style>.",
        "ROB_NEMRY_BODY_SPECIAL_STABCSS_NAME": "Hydra Bite / Hyper Beam",
        "ROB_NEMRY_BODY_SPECIAL_STABCSS_DESCRIPTION": "<style=cIsHealing>100% Energy.</style> Plunge your blade into an enemy for <style=cIsDamage>2800% damage</style>, inflicting a potent debuff. <style=cIsHealing>Heal for 50% of damage dealt.</style>\n<style=cIsHealing>100% Energy.</style> Charge up a powerful beam that deals <style=cIsDamage>a lot of damage</style>.",
        "ROB_NEMRY_BODY_UNLOCKABLE_ACHIEVEMENT_NAME": "???",
        "ROB_NEMRY_BODY_UNLOCKABLE_ACHIEVEMENT_DESC": "Defeat Henry's Vestige.",
        "ROB_NEMRY_BODY_UNLOCKABLE_UNLOCKABLE_NAME": "???",
        "ROB_NEMRY_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_NAME": "Nemesis Henry: Mastery",
        "ROB_NEMRY_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_DESC": "As Nemesis Henry, beat the game or obliterate on Monsoon.",
        "ROB_NEMRY_BODY_MASTERYUNLOCKABLE_UNLOCKABLE_NAME": "Nemesis Henry: Mastery",
        "ROB_NEMRY_BODY_TYPHOONUNLOCKABLE_ACHIEVEMENT_NAME": "Nemesis Henry: Grand Mastery",
        "ROB_NEMRY_BODY_TYPHOONUNLOCKABLE_ACHIEVEMENT_DESC": "As Nemesis Henry, beat the game or obliterate on Typhoon.",
        "ROB_NEMRY_BODY_TYPHOONUNLOCKABLE_UNLOCKABLE_NAME": "Nemesis Henry: Grand Mastery"
    }
