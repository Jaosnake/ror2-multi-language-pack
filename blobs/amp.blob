		internal static void CreatePassiveSkill(SkillLocator skillLocator, string BodyName)
		{
			if (BodyName == "Amp")
			{
				string text = "NT_AMP_BODY_";
				skillLocator.passiveSkill.enabled = true;
				skillLocator.passiveSkill.icon = Asset.mainAssetBundle.LoadAsset<Sprite>("texCharge");
				skillLocator.passiveSkill.skillNameToken = text + "PASSIVE_NAME";
				skillLocator.passiveSkill.skillDescriptionToken = text + "PASSIVE_DESCRIPTION";
				skillLocator.passiveSkill.keywordToken = text + "KEYWORD_CHARGE";
			}
			else
			{
				string text2 = "NT_NEMAMP_BODY_";
				skillLocator.passiveSkill.enabled = true;
				skillLocator.passiveSkill.icon = Asset.mainAssetBundle.LoadAsset<Sprite>("texNemPassive");
				skillLocator.passiveSkill.skillNameToken = text2 + "PASSIVE_NAME";
				skillLocator.passiveSkill.skillDescriptionToken = text2 + "PASSIVE_DESCRIPTION";
			}
		}

