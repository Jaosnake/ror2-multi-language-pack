    "SS2_EQUIP_AFFIXSUPERFIRE_NAME": "Llama Real",
    "SS2_EQUIP_AFFIXSUPERFIRE_PICKUP": "Conviértete en un presagio de fuego.",
    "SS2_ELITE_MODIFIER_SUPERICE": "Boreal {0}",
    "SS2_EQUIP_AFFIXSUPERICE_NAME": "Su Brillantez Cósmica",
    "SS2_EQUIP_AFFIXSUPERICE_PICKUP": "Conviértete en un presagio de hielo.",
