			permaBossCling = Config.permanentBossCling.Value;
			steamEffect = ((Component)childLocator.FindChild("Steam")).gameObject.GetComponent<ParticleSystem>();
			chargeEffect = ((Component)childLocator.FindChild("ArmCharge")).gameObject.GetComponent<ParticleSystem>();
			blackElectricityEffect = ((Component)childLocator.FindChild("BlackElectricity")).gameObject.GetComponent<ParticleSystem>();
			handElectricityEffect = ((Component)childLocator.FindChild("HandElectricity")).gameObject.GetComponent<ParticleSystem>();
