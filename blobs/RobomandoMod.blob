			if ((int)in_type == 8)
			{
				AkDurationCallbackInfo val = (AkDurationCallbackInfo)in_info;
				float duration = val.fDuration / 1000f;
				if (!system.isPlaying)
				{
					system.Play();
				}
				if (!voiceChain.IsValid())
				{
					((MonoBehaviour)this).StartCoroutine(StopVoiceSystemAndReset(duration));
				}
				else
				{
					((MonoBehaviour)this).StartCoroutine(DelayNextPostEvent(duration, voiceChain));
