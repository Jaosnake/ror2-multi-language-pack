					{
						PlaySoundCue("sfx_hunk_retheme_global");
					}
					else if (virusType == VirusType.CVirus)
					{
						PlaySoundCue("sfx_hunk_cvirus_stinger");
					}
					else if (virusType == VirusType.Uroboros)
					{
						PlaySoundCue("sfx_hunk_uroboros_theme");
