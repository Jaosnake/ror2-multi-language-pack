        "MOFFEIN_PILOT_BODY_PRIMARY_SILENCER_NAME": "Fuoco soppresso",
        "MOFFEIN_PILOT_BODY_PRIMARY_SILENCER_DESCRIPTION": "<style=cIsDamage>Uccisore</style>. Spara con la tua pistola silenziata<style=cIsDamage>Danno al 100%.</style>.",
        "MOFFEIN_PILOT_BODY_SECONDARY_NAME": "Obiettivo acquisito!",
