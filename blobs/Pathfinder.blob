			attackFinished = true;
			stopwatch = 0f;
		}

		public override void OnExit()
		{
			CharacterModel obj = characterModel;
			obj.invisibilityCount--;
			batteryComponent.pauseDrain = false;
			squallVFXComponent.ToggleVFX(onOff: true);
			((EntityState)this).OnExit();
		}

