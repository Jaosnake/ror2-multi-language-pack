		public static void ShaderConversion(AssetBundle assets)
		{
			IEnumerable<Material> enumerable = from material in assets.LoadAllAssets<Material>()
				where ((Object)material.shader).name.StartsWith("Fake RoR")
				select material;
			foreach (Material item in enumerable)
			{
				Shader val = LegacyResourcesAPI.Load<Shader>(ShaderLookup[((Object)item.shader).name.ToLowerInvariant()]);
				if (Object.op_Implicit((Object)(object)val))
				{
					item.shader = val;
					SwappedMaterials.Add(item);
				}
			}
		}

