		internal static List<IEnumerator> GetAssetBundleInitializedCoroutines(AssetBundle assetBundle)
		{
			List<IEnumerator> list = new List<IEnumerator>();
			list.Add(Asset.LoadAssetCoroutine<Material>((object)"RoR2/Base/Common/VFX/matLightningLongBlue.mat", (Action<Material>)delegate(Material mat)
