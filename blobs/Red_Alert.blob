	public class TeslaTrooperSurvivor : SurvivorBase<TeslaTrooperSurvivor>
	{
		public const string TOKEN_PREFIX = "HABIBI_TESLA_BODY_";

		private Func<ItemIndex, bool> TeslaTowerCopyFilterDelegate = TeslaTowerCopyFilter;

