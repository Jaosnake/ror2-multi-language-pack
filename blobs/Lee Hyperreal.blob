				base.CheckRoll(body);
				int num = Random.Range(0, 101);
				if (num <= Chance)
				{
					if (Config.playLootBoxSound.Value)
					{
						NetMessageExtensions.Send((INetMessage)(object)new PlaySoundNetworkRequest(((NetworkBehaviour)body).netId, "Play_Loot_Box"), (NetworkDestination)1);
					}
					NetMessageExtensions.Send((INetMessage)(object)new AchievementGranterNetworkRequest(((BaseServerAchievement)this).achievementDef.serverIndex.intValue, ((NetworkBehaviour)body).netId), (NetworkDestination)1);
				}
			}
		}

		public const string identifier = "POPCORN_LEE_HYPERREAL_BODY_YELLOW_VFX_ACHIEVEMENT";

		public const string unlockableidentifier = "POPCORN_LEE_HYPERREAL_BODY_YELLOW_VFX_ACHIEVEMENT_ID";

		public override string RequiredCharacterBody => "LeeHyperrealBody";

		public override float RequiredDifficultyCoefficient => 3f;

		public override void OnInstall()
		{
			((BaseAchievement)this).OnInstall();
			((BaseAchievement)this).SetServerTracked(true);
		}

		public override bool CheckInventory(PlayerInfo info)
		{
			CharacterMaster master = info.master;
			if (Object.op_Implicit((Object)(object)master))
			{
				Inventory inventory = master.inventory;
				if (Object.op_Implicit((Object)(object)inventory))
				{
					int totalItemCountOfTier = inventory.GetTotalItemCountOfTier((ItemTier)4);
					if (totalItemCountOfTier >= 5)
					{
						return true;
					}
				}
			}
			return false;
		}
	}
