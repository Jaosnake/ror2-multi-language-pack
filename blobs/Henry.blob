			string text = "Nemry";
			if (!isPlayer)
			{
				text += "Monster";
			}
			GameObject val = Prefabs.CreatePrefab(newBodyName, "mdlNemry", new BodyInfo
			{
				armor = 20f,
				armorGrowth = 0f,
				bodyName = newBodyName,
				bodyNameToken = "ROB_NEMRY_BODY_NAME",
				bodyColor = Color.green,
				characterPortrait = Asset.LoadCharacterIcon(text),
				crosshair = Asset.LoadCrosshair("SimpleDot"),
				damage = 12f,
				healthGrowth = 33f,
				healthRegen = 1.5f,
				jumpCount = 1,
				maxHealth = 110f,
				subtitleNameToken = "ROB_NEMRY_BODY_SUBTITLE",
				podPrefab = null
			});
			if (!isPlayer)
			{
				CharacterBody component = val.GetComponent<CharacterBody>();
				component.baseMaxHealth = 2800f;
				component.levelMaxHealth = 840f;
				component.baseRegen = 0f;
				component.levelRegen = 0f;
				component.baseDamage = 4f;
			}
			val.AddComponent<HenryTracker>();
			val.AddComponent<NemryEnergyComponent>();
			((Component)val.transform.Find("ModelBase").Find("AimOrigin")).transform.localPosition = new Vector3(0f, 3f, 0f);
			SkillLocator component2 = val.GetComponent<SkillLocator>();
			component2.passiveSkill.enabled = true;
			component2.passiveSkill.icon = Asset.mainAssetBundle.LoadAsset<Sprite>("texNemPassiveIcon");
			component2.passiveSkill.skillNameToken = "ROB_NEMRY_BODY_PASSIVE_NAME";
			component2.passiveSkill.skillDescriptionToken = "ROB_NEMRY_BODY_PASSIVE_DESCRIPTION";
			EntityStateMachine component3 = val.GetComponent<EntityStateMachine>();
			component3.mainStateType = new SerializableEntityStateType(typeof(MainState));
			component3.initialStateType = new SerializableEntityStateType(typeof(SpawnState));
			Material material = Asset.CreateMaterial("matNemry", 30f);
			bodyRendererIndex = 1;
			Prefabs.SetupCharacterModel(val, new CustomRendererInfo[2]
			{
				new CustomRendererInfo
				{
					childName = "SpearModel",
					material = material
				},
				new CustomRendererInfo
				{
					childName = "Model",
					material = material
				}
			}, bodyRendererIndex);
			CreateHitboxes(val);
			CreateSkills(val);
			CreateItemDisplays(val);
			CreateSkins(val);
			return val;
		}

