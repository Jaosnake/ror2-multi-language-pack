{
    "ru": {
        "BLAKE_RIFTER_NAME": "\u0420\u0438\u0444\u0442\u0435\u0440",
        "BLAKE_RIFTER_DESCRIPTION": "\u0420\u0438\u0444\u0442\u0435\u0440 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0435\u0442 \u0441\u0442\u0440\u0430\u0442\u0435\u0433\u0438\u0447\u0435\u0441\u043a\u043e\u0435 \u043f\u043e\u0437\u0438\u0446\u0438\u043e\u043d\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435, \u0447\u0442\u043e\u0431\u044b \u0441\u043e\u0437\u0434\u0430\u0432\u0430\u0442\u044c \u0440\u0430\u0437\u0440\u0443\u0448\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0435 \u0440\u0430\u0437\u043b\u043e\u043c\u044b \u0432 \u0440\u0435\u0430\u043b\u044c\u043d\u043e\u0441\u0442\u0438.<color=#CCD3E0>\n\n<!> \u0420\u0430\u0437\u043b\u043e\u043c\u044b \u0437\u043d\u0430\u0447\u0438\u0442\u0435\u043b\u044c\u043d\u043e \u0441\u0438\u043b\u044c\u043d\u0435\u0435 \u043b\u0438\u043d\u0438\u0439 \u0440\u0430\u0437\u043b\u043e\u043c\u0430 - \u043f\u043e\u0437\u0438\u0446\u0438\u043e\u043d\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435 \u0438\u043c\u0435\u0435\u0442 \u043a\u043b\u044e\u0447\u0435\u0432\u043e\u0435 \u0437\u043d\u0430\u0447\u0435\u043d\u0438\u0435!\n\n<!> \u0418\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0438\u0435 \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e\u0441\u0442\u0435\u0439 \u0432\u0430\u0448\u0435\u0433\u043e \u043e\u0441\u043d\u043e\u0432\u043d\u043e\u0433\u043e \u043d\u0430 \u0434\u0430\u043b\u044c\u043d\u0435\u0439 \u0438 \u0441\u0440\u0435\u0434\u043d\u0435\u0439 \u0434\u0438\u0441\u0442\u0430\u043d\u0446\u0438\u0438 \u043f\u043e\u0437\u0432\u043e\u043b\u044f\u0435\u0442 \u0432\u0430\u0440\u044c\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0432\u0430\u0448\u0438 \u043f\u043e\u0437\u0438\u0446\u0438\u0438.\n\n<!> \u041d\u0435\u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0441\u043f\u043e\u0441\u043e\u0431\u043d\u043e\u0441\u0442\u0438 \u043c\u043e\u0433\u0443\u0442 \u0442\u0435\u043b\u0435\u043f\u043e\u0440\u0442\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0432\u0440\u0430\u0433\u043e\u0432, \u0432 \u0442\u043e \u0432\u0440\u0435\u043c\u044f \u043a\u0430\u043a \u0434\u0440\u0443\u0433\u0438\u0435 \u044f\u0432\u043b\u044f\u044e\u0442\u0441\u044f \u0443\u0441\u043b\u043e\u0432\u043d\u044b\u043c\u0438. \u0418\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0438\u0435 \u044d\u0442\u043e\u0439 \u0441\u0438\u043b\u044b \u043c\u043e\u0436\u0435\u0442 \u0443\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0442\u044c \u0432\u0440\u0430\u0433\u043e\u0432 \u043d\u0430 \u0440\u0430\u0441\u0441\u0442\u043e\u044f\u043d\u0438\u0438.\n\n<!> \u0411\u043b\u043e\u043a\u0438\u0440\u043e\u0432\u043a\u0430 \u0412\u0440\u0435\u043c\u0435\u043d\u0438 \u043c\u043e\u0436\u0435\u0442 \u0431\u044b\u0442\u044c \u043c\u043e\u0449\u043d\u044b\u043c \u0438\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442\u043e\u043c \u0434\u043b\u044f \u0441\u0431\u043e\u0440\u0430 \u0432\u0440\u0430\u0433\u043e\u0432 \u0438 \u043f\u043e\u0434\u0440\u044b\u0432\u0430 \u0438\u0445 \u0432\u0441\u0435\u0445 \u0441\u0440\u0430\u0437\u0443! <i>Translated by: Jaosnake</i>",
        "BLAKE_RIFTER_SUBTITLE": "\u041c\u0430\u043d\u0438\u043f\u0443\u043b\u044f\u0442\u043e\u0440 \u0420\u0430\u0437\u043b\u043e\u043c\u043e\u0432",
        "BLAKE_RIFTER_OUTRO_FLAVOR": "..\u0438 \u0442\u0430\u043a \u043e\u043d \u043e\u0441\u0442\u0430\u0432\u0438\u043b \u0440\u0430\u0441\u043a\u043e\u043b\u043e\u0442\u044b\u0439 \u043c\u0438\u0440 \u043f\u043e\u0437\u0430\u0434\u0438.",
        "BLAKE_RIFTER_OUTRO_FAILURE": "..\u0438 \u0442\u0430\u043a \u043e\u043d \u0438\u0441\u0447\u0435\u0437 \u0438\u0437 \u0432\u0441\u0435\u0445 \u043c\u0438\u0440\u043e\u0432.",
        "BLAKE_RIFTER_MASTERY_SKIN_NAME": "\u0420\u0438\u0444\u0442\u0435\u0440: \u041c\u0430\u0441\u0442\u0435\u0440\u0441\u0442\u0432\u043e",
        "BLAKE_RIFTER_PASSIVE_RIFT_BOOST": "\u0423\u0441\u043a\u043e\u0440\u0435\u043d\u0438\u0435 \u0420\u0430\u0437\u043b\u043e\u043c\u0430",
        "BLAKE_RIFTER_PASSIVE_RIFT_BOOST_DESCRIPTION": "\u0412\u0430\u0448\u0438 \u0440\u0430\u0437\u043b\u043e\u043c\u044b \u0434\u0430\u044e\u0442 \u043f\u0440\u0438\u0431\u0430\u0432\u043a\u0443 \u043a \u0441\u043a\u043e\u0440\u043e\u0441\u0442\u0438 \u043f\u0435\u0440\u0435\u0434\u0432\u0438\u0436\u0435\u043d\u0438\u044f \u043f\u0440\u0438 \u043f\u0440\u043e\u0445\u043e\u0436\u0434\u0435\u043d\u0438\u0438 \u0447\u0435\u0440\u0435\u0437 \u043d\u0438\u0445. <i>Translated by: Jaosnake</i>",
        "BLAKE_RIFTER_PASSIVE_RIFT_FRACTURE": "\u041e\u0441\u043a\u043e\u043b\u043e\u0447\u043d\u044b\u0439 \u0420\u0430\u0437\u043b\u043e\u043c",
        "BLAKE_RIFTER_PASSIVE_RIFT_FRACTURE_DESCRIPTION": "\u0412\u0440\u0430\u0433\u0438, \u043f\u043e\u0440\u0430\u0436\u0451\u043d\u043d\u044b\u0435 \u0440\u0430\u0437\u043b\u043e\u043c\u0430\u043c\u0438, \u043d\u0430\u043a\u0430\u043f\u043b\u0438\u0432\u0430\u044e\u0442 \u043e\u0441\u043a\u043e\u043b\u043a\u0438, \u0443\u0432\u0435\u043b\u0438\u0447\u0438\u0432\u0430\u044f \u043f\u043e\u043b\u0443\u0447\u0430\u0435\u043c\u044b\u0439 \u0443\u0440\u043e\u043d. <i>Translated by: Jaosnake</i>",
        "BLAKE_RIFTER_PRIMARY_GAUNTLET_RANGED": "\u0420\u0430\u0437\u043b\u043e\u043c-\u0421\u043d\u0430\u0440\u044f\u0434",
        "BLAKE_RIFTER_PRIMARY_GAUNTLET_RANGED_DESCRIPTION": "\u0412\u044b\u0441\u0442\u0440\u0435\u043b\u0438\u0442\u0435 \u0440\u0430\u0437\u043b\u043e\u043c\u043e\u043c \u0434\u0430\u043b\u044c\u043d\u0435\u0433\u043e \u0440\u0430\u0434\u0438\u0443\u0441\u0430 \u043d\u0430 500% \u0443\u0440\u043e\u043d\u0430. <i>Translated by: Jaosnake</i>",
        "BLAKE_RIFTER_SECONDARY_FRACTURE": "\u0420\u0430\u0437\u0440\u044b\u0432",
        "BLAKE_RIFTER_SECONDARY_FRACTURE_DESCRIPTION": "<style=cIsDamage>\u0420\u0430\u0437\u0440\u044b\u0432</style>. \u0412\u044b\u0441\u0442\u0440\u0435\u043b\u0438\u0442\u0435 \u0440\u0430\u0437\u043b\u043e\u043c\u043e\u043c \u0434\u0430\u043b\u044c\u043d\u0435\u0433\u043e \u0440\u0430\u0434\u0438\u0443\u0441\u0430 \u043d\u0430 75% \u0443\u0440\u043e\u043d\u0430, \u0432\u044b\u0437\u044b\u0432\u0430\u044f \u0434\u043e 5 \u043e\u0441\u043a\u043e\u043b\u043a\u043e\u0432. <i>Translated by: Jaosnake</i>",
        "BLAKE_RIFTER_SECONDARY_FAULT_LINE": "\u041b\u0438\u043d\u0438\u044f \u0420\u0430\u0437\u043b\u043e\u043c\u0430",
        "BLAKE_RIFTER_SECONDARY_FAULT_LINE_DESCRIPTION": "<style=cIsDamage>\u0420\u0430\u0437\u0440\u044b\u0432</style>. \u0421\u043e\u0437\u0434\u0430\u0439\u0442\u0435 \u043b\u0438\u043d\u0438\u044e \u0440\u0430\u0437\u043b\u043e\u043c\u0430, \u043a\u043e\u0442\u043e\u0440\u0430\u044f \u0440\u0430\u0441\u043a\u0430\u043b\u044b\u0432\u0430\u0435\u0442\u0441\u044f, \u043d\u0430\u043d\u043e\u0441\u044f 700% \u0443\u0440\u043e\u043d\u0430. <i>Translated by: Jaosnake</i>",
        "BLAKE_RIFTER_UTILITY_SLIPSTREAM": "\u041f\u0440\u043e\u0441\u0442\u0440\u0430\u043d\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0435 \u0422\u0435\u0447\u0435\u043d\u0438\u0435",
        "BLAKE_RIFTER_UTILITY_SLIPSTREAM_DESCRIPTION": "\u0422\u0435\u043b\u0435\u043f\u043e\u0440\u0442\u0438\u0440\u0443\u0439\u0442\u0435\u0441\u044c \u043d\u0430 \u043a\u043e\u0440\u043e\u0442\u043a\u043e\u0435 \u0440\u0430\u0441\u0441\u0442\u043e\u044f\u043d\u0438\u0435. \u0412\u043e\u0441\u0441\u0442\u0430\u043d\u0430\u0432\u043b\u0438\u0432\u0430\u0435\u0442 \u0437\u0430\u043f\u0430\u0441 \u0432\u0442\u043e\u0440\u0438\u0447\u043d\u043e\u0433\u043e \u043d\u0430\u0432\u044b\u043a\u0430. <i>Translated by: Jaosnake</i>",
        "BLAKE_RIFTER_UTILITY_QUANTUM_RIFT": "\u041a\u0432\u0430\u043d\u0442\u043e\u0432\u044b\u0439 \u0420\u0430\u0437\u043b\u043e\u043c",
        "BLAKE_RIFTER_UTILITY_QUANTUM_RIFT_DESCRIPTION": "\u041e\u0442\u043a\u0440\u043e\u0439\u0442\u0435 \u043a\u0432\u0430\u043d\u0442\u043e\u0432\u044b\u0439 \u0440\u0430\u0437\u043b\u043e\u043c, \u0438\u0441\u043a\u0430\u0436\u0430\u044e\u0449\u0438\u0439 \u043e\u043a\u0440\u0443\u0436\u0430\u044e\u0449\u0435\u0435 \u043f\u0440\u043e\u0441\u0442\u0440\u0430\u043d\u0441\u0442\u0432\u043e. <i>Translated by: Jaosnake</i>",
        "BLAKE_RIFTER_UTILITY_CHAINED_WORLDS": "\u0421\u043a\u043e\u0432\u0430\u043d\u043d\u044b\u0435 \u041c\u0438\u0440\u044b",
        "BLAKE_RIFTER_UTILITY_CHAINED_WORLDS_DESCRIPTION": "\u0421\u043e\u0435\u0434\u0438\u043d\u0438\u0442\u0435 \u0434\u0432\u0435 \u0442\u043e\u0447\u043a\u0438 \u0432 \u043f\u0440\u043e\u0441\u0442\u0440\u0430\u043d\u0441\u0442\u0432\u0435, \u0441\u043e\u0437\u0434\u0430\u0432 \u043f\u043e\u0440\u0442\u0430\u043b, \u043f\u0435\u0440\u0435\u043d\u043e\u0441\u044f\u0449\u0438\u0439 \u0441\u043d\u0430\u0440\u044f\u0434\u044b. <i>Translated by: Jaosnake</i>",
        "BLAKE_RIFTER_SPECIAL_TIMELOCK": "\u0412\u0440\u0435\u043c\u0435\u043d\u043d\u0430\u044f \u0411\u043b\u043e\u043a\u0438\u0440\u043e\u0432\u043a\u0430",
        "BLAKE_RIFTER_SPECIAL_TIMELOCK_DESCRIPTION": "\u0417\u0430\u0431\u043b\u043e\u043a\u0438\u0440\u0443\u0439\u0442\u0435 \u0432\u0440\u0435\u043c\u044f \u0432\u0440\u0430\u0433\u043e\u0432 \u0432 \u043e\u0431\u043b\u0430\u0441\u0442\u0438, \u0437\u0430\u043c\u043e\u0440\u0430\u0436\u0438\u0432\u0430\u044f \u0438\u0445 \u043d\u0430 \u043d\u0435\u0441\u043a\u043e\u043b\u044c\u043a\u043e \u0441\u0435\u043a\u0443\u043d\u0434. <i>Translated by: Jaosnake</i>",
        "BLAKE_NEM_RIFTER_NAME": "\u041d\u0435\u043c\u0435\u0437\u0438\u0441 \u0420\u0438\u0444\u0442\u0435\u0440",
        "BLAKE_NEM_RIFTER_SUBTITLE": "\u0418\u0441\u043a\u0430\u0436\u0451\u043d\u043d\u044b\u0439 \u0420\u0430\u0437\u043b\u043e\u043c"
    }
}
