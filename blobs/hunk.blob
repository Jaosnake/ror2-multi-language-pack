				}
				if ((Object)(object)weaponDef == (Object)(object)BaseWeapon<MUP>.instance.weaponDef && Object.op_Implicit((Object)(object)inventory) && inventory.GetItemCount(MUP.extendedMag) > 0)
				{
					maxAmmo = 33;
				}
				if ((Object)(object)weaponDef == (Object)(object)BaseWeapon<M19>.instance.weaponDef && Object.op_Implicit((Object)(object)inventory) && inventory.GetItemCount(M19.extendedMag) > 0)
				{
					maxAmmo = 15;
				}
				if ((Object)(object)weaponDef == (Object)(object)BaseWeapon<SG09>.instance.weaponDef && Object.op_Implicit((Object)(object)inventory) && inventory.GetItemCount(SG09.extendedMag) > 0)
				{
					maxAmmo = 32;
				}
				if (onInventoryUpdate != null)
				{
					onInventoryUpdate(inventory);
