			if (isCombo)
			{
				activationTime = 0.035f;
				duration = 0.1f;
			}
			passiveManager = ((EntityState)this).GetComponent<HousePassiveManager>();
			drawHand();
			if (NetworkServer.active && ((EntityState)this).characterBody.HasBuff(Buffs.StarBuff))
			{
				((EntityState)this).characterBody.RemoveBuff(Buffs.StarBuff);
			}
			((EntityState)this).PlayAnimation("Gesture, Override Full", "UseCard", "UseCard.playbackRate", duration * 1.2f, 0f);
			CardHopOnEnter();
			CardSweepEnter();
		}

		public virtual void drawHand()
		{
			if (!isCombo && ((EntityState)this).isAuthority)
			{
				passiveManager.NextHand(CardNo.ToString());
			}
		}

		public override void OnExit()
		{
			((EntityState)this).OnExit();
		}

		public override void FixedUpdate()
		{
			((EntityState)this).FixedUpdate();
			CardHop();
			if (((EntityState)this).fixedAge >= activationTime)
			{
				Activate();
			}
			if (!(((EntityState)this).fixedAge >= duration))
			{
				return;
			}
			if (((EntityState)this).isAuthority && cardCombo.Length != 0)
			{
				BaseCardSkill baseCardSkill = (BaseCardSkill)Activator.CreateInstance(((object)HouseCardDefs.cards[cardCombo[0]].skillstate).GetType());
				baseCardSkill.isCombo = true;
				if (cardCombo.Length > 1)
				{
					int[] array = new int[cardCombo.Length - 1];
					for (int num = cardCombo.Length - 1; num > 0; num--)
					{
						array[num - 1] = cardCombo[num];
					}
					baseCardSkill.cardCombo = array;
				}
				((EntityState)this).outer.SetNextState((EntityState)(object)baseCardSkill);
			}
			else
			{
				((EntityState)this).outer.SetNextStateToMain();
			}
		}

