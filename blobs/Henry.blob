			text2 = $"<style=cIsHealing>10% Energy.</style> Lunge at a nearby enemy for <style=cIsDamage>{100f * Lunge.minDamageCoefficient}% damage</style>. Perform a combo attack instead if within melee range.";
			LanguageAPI.Add(text + "SECONDARY_CHARGE_NAME", "Swordmaster");
			LanguageAPI.Add(text + "SECONDARY_CHARGE_DESCRIPTION", text2);
			text2 = "<style=cIsHealing>5% Energy.</style> Fire a barrage of <style=cIsHealing>Energy</style> shots. Hold to continue firing, consuming more <style=cIsHealing>Energy</style> per shot.";
			LanguageAPI.Add(text + "SECONDARY_TORRENT_NAME", "Gunslinger");
			LanguageAPI.Add(text + "SECONDARY_TORRENT_DESCRIPTION", text2);
			text2 = $"<style=cIsHealing>10% Energy.</style> Lunge at a nearby enemy for <style=cIsDamage>{100f * Lunge.minDamageCoefficient}% damage</style>.";
			text2 += "\n<style=cIsHealing>5% Energy.</style> Fire a barrage of <style=cIsHealing>Energy</style> shots.";
			LanguageAPI.Add(text + "SECONDARY_CHARGECSS_NAME", "Swordmaster / Gunslinger");
			LanguageAPI.Add(text + "SECONDARY_CHARGECSS_DESCRIPTION", text2);
			LanguageAPI.Add(text + "UTILITY_DODGESLASH_NAME", "Swift Slash");
			LanguageAPI.Add(text + "UTILITY_DODGESLASH_DESCRIPTION", "Backflip, slashing nearby enemies for <style=cIsDamage>300% damage</style>. <style=cIsUtility>You cannot be hit during the flip.</style>");
			text2 = "<style=cIsHealing>5% Energy.</style> <style=cIsUtility>Instantly blink</style> to a nearby enemy.";
			LanguageAPI.Add(text + "UTILITY_BLINK_NAME", "Flash Step");
			LanguageAPI.Add(text + "UTILITY_BLINK_DESCRIPTION", text2);
			text2 = "<style=cIsHealing>10% Energy.</style> Discharge a burst of <style=cIsHealing>Energy</style> for <style=cIsDamage>400% damage</style>, <style=cIsUtility>launching yourself with the recoil</style>.";
			LanguageAPI.Add(text + "UTILITY_BURST_NAME", "Energy Burst");
			LanguageAPI.Add(text + "UTILITY_BURST_DESCRIPTION", text2);
			text2 = "<style=cIsHealing>5% Energy.</style> <style=cIsUtility>Instantly blink</style> to a nearby enemy.";
			text2 += "\n<style=cIsHealing>10% Energy.</style> Discharge a burst of <style=cIsHealing>Energy</style> for <style=cIsDamage>400% damage</style>.";
			LanguageAPI.Add(text + "UTILITY_BLINKCSS_NAME", "Flash Step / Energy Burst");
			LanguageAPI.Add(text + "UTILITY_BLINKCSS_DESCRIPTION", text2);
			text2 = $"<style=cIsHealing>100% Energy.</style> Plunge your blade into an enemy for <style=cIsDamage>{2800f}% damage</style>, inflicting a potent debuff. <style=cIsHealing>Heal for 50% of damage dealt.</style>";
			LanguageAPI.Add(text + "SPECIAL_STAB_NAME", "Hydra Bite");
			LanguageAPI.Add(text + "SPECIAL_STAB_DESCRIPTION", text2);
			text2 = $"<style=cIsHealing>100% Energy.</style> Charge up a powerful barrage of lasers that deals <style=cIsDamage>{10}x{100f * FireBeamBarrage.laserDamageCoefficient}% damage</style>.";
			LanguageAPI.Add(text + "SPECIAL_BEAM_NAME", "Hyper Beam");
			LanguageAPI.Add(text + "SPECIAL_BEAM_DESCRIPTION", text2);
			text2 = "<style=cIsHealing>100% Energy.</style> Plunge your blade into an enemy for <style=cIsDamage>2800% damage</style>, inflicting a potent debuff. <style=cIsHealing>Heal for 50% of damage dealt.</style>";
			text2 += "\n<style=cIsHealing>100% Energy.</style> Charge up a powerful beam that deals <style=cIsDamage>a lot of damage</style>.";
			LanguageAPI.Add(text + "SPECIAL_STABCSS_NAME", "Hydra Bite / Hyper Beam");
			LanguageAPI.Add(text + "SPECIAL_STABCSS_DESCRIPTION", text2);
			LanguageAPI.Add(text + "UNLOCKABLE_ACHIEVEMENT_NAME", "???");
			LanguageAPI.Add(text + "UNLOCKABLE_ACHIEVEMENT_DESC", "Defeat Henry's Vestige.");
			LanguageAPI.Add(text + "UNLOCKABLE_UNLOCKABLE_NAME", "???");
			LanguageAPI.Add(text + "MASTERYUNLOCKABLE_ACHIEVEMENT_NAME", "Nemesis Henry: Mastery");
			LanguageAPI.Add(text + "MASTERYUNLOCKABLE_ACHIEVEMENT_DESC", "As Nemesis Henry, beat the game or obliterate on Monsoon.");
			LanguageAPI.Add(text + "MASTERYUNLOCKABLE_UNLOCKABLE_NAME", "Nemesis Henry: Mastery");
			LanguageAPI.Add(text + "TYPHOONUNLOCKABLE_ACHIEVEMENT_NAME", "Nemesis Henry: Grand Mastery");
			LanguageAPI.Add(text + "TYPHOONUNLOCKABLE_ACHIEVEMENT_DESC", "As Nemesis Henry, beat the game or obliterate on Typhoon.");
			LanguageAPI.Add(text + "TYPHOONUNLOCKABLE_UNLOCKABLE_NAME", "Nemesis Henry: Grand Mastery");
		}

		public static string GetAchievementNameToken(string identifier)
		{
			return "ACHIEVEMENT_" + identifier.ToUpperInvariant() + "_NAME";
		}

		public static string GetAchievementDescToken(string identifier)
		{
			return "ACHIEVEMENT_" + identifier.ToUpperInvariant() + "_DESCRIPTION";
		}
	}
}
