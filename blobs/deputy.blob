			search.origin = ((Component)this).transform.position;
			search.mask = ((LayerIndex)(ref LayerIndex.entityPrecise)).mask;
			search.radius = searchRadius;
			search.RefreshCandidates();
			search.FilterCandidatesByHurtBoxTeam(TeamMask.GetEnemyTeams(teamFilter.teamIndex));
			search.OrderCandidatesByDistance();
			search.FilterCandidatesByDistinctHurtBoxEntities();
			bestCandidate = search.GetHurtBoxes().FirstOrDefault();
			search.ClearCandidates();
		}
