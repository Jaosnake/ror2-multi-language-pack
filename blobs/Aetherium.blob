					abyssalDash.blinkDistance = BlinkDistance;
					val.SetInterruptState((EntityState)(object)abyssalDash, (InterruptPriority)0);
					NetworkIdentity component = ((Component)slot.characterBody).gameObject.GetComponent<NetworkIdentity>();
					if (Object.op_Implicit((Object)(object)component))
					{
						NetMessageExtensions.Send((INetMessage)(object)new AbyssalDashMessage(component.netId), (NetworkDestination)1);
					}
