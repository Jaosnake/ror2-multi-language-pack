{
    "zh-CN": {
        "BOG_MORRIS_BODY_NAME": "殡仪师",
        "BOG_MORRIS_BODY_DESCRIPTION": "殡仪师是一名缓慢但坚韧的近战死灵法师,擅长用他的亡灵大军控制领土。",
        "BOG_MORRIS_BODY_SUBTITLE": "亡者",
