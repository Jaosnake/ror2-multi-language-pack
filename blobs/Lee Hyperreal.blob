			{
				switch (orbType)
				{
				case OrbType.BLUE:
					val.SetInterruptState((EntityState)(object)new BlueOrb
					{
						moveStrength = strength
					}, (InterruptPriority)7);
					break;
				case OrbType.YELLOW:
					val.SetInterruptState((EntityState)(object)new YellowOrbEntry
					{
						moveStrength = strength
					}, (InterruptPriority)7);
					break;
				case OrbType.RED:
					val.SetInterruptState((EntityState)(object)new RedOrbEntry
					{
						moveStrength = strength
					}, (InterruptPriority)7);
					break;
				}
			}
		}

		public void FixedUpdate()
		{
			if (charBody.hasEffectiveAuthority && !PauseManager.isPaused && !baseAIPresent)
			{
				orbIncrementor += 0.5f * Time.fixedDeltaTime;
				if (orbIncrementor >= orbGrantRate)
				{
					orbIncrementor = 0f;
					GrantOrb();
				}
				RecalcUpdateRate();
			}
		}

		public void GrantOrb()
		{
			if (orbList.Count < OrbLimit)
			{
				int num = Random.Range(1, 4);
				OrbType item = (OrbType)num;
				orbList.Add(item);
				if (Object.op_Implicit((Object)(object)uiController))
				{
					uiController.UpdateOrbList(orbList);
				}
			}
		}

		public void Grant3Ping(BulletController.BulletType type)
		{
			switch (type)
			{
			case BulletController.BulletType.BLUE:
				orbList.Add(OrbType.BLUE);
				orbList.Add(OrbType.BLUE);
				orbList.Add(OrbType.BLUE);
				break;
			case BulletController.BulletType.RED:
				orbList.Add(OrbType.RED);
				orbList.Add(OrbType.RED);
				orbList.Add(OrbType.RED);
				break;
			case BulletController.BulletType.YELLOW:
				orbList.Add(OrbType.YELLOW);
				orbList.Add(OrbType.YELLOW);
				orbList.Add(OrbType.YELLOW);
				break;
			}
		}

		public void AddToIncrementor(float amount)
		{
			orbIncrementor += amount;
		}
	}
