			component3.ghostPrefab = CreateGhostPrefab("NeutralMissile");
			component3.startSound = "House_Shuffle";
			ProjectileSteerTowardTarget val = NeutralCardMissilePrefab.AddComponent<ProjectileSteerTowardTarget>();
			val.yAxisOnly = false;
			val.rotationSpeed = 180f;
			ProjectileSimple component4 = NeutralCardMissilePrefab.GetComponent<ProjectileSimple>();
			component4.desiredForwardSpeed = 60f;
			component4.lifetime = 15f;
			component4.updateAfterFiring = true;
			component4.enableVelocityOverLifetime = false;
			component4.oscillate = false;
			component4.oscillateMagnitude = 0f;
			component4.oscillateSpeed = 0f;
			ProjectileDirectionalTargetFinder val2 = NeutralCardMissilePrefab.AddComponent<ProjectileDirectionalTargetFinder>();
			val2.onlySearchIfNoTarget = false;
			val2.allowTargetLoss = false;
			val2.lookCone = 180f;
			val2.lookRange = 80f;
			val2.targetSearchInterval = 1f;
