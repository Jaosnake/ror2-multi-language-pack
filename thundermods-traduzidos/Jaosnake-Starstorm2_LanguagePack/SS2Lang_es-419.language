    "SS2_WARDEN_PRIMARY_SWORD_NAME": "Hoja de eonio",
    "SS2_WARDEN_PRIMARY_SWORD_DESC": "Balancea tu espada para causar un X% de daño y el tercer golpe apuñala hacia adelante para causar un X% de daño.",
    "SS2_WARDEN_SECONDARY_SHIELD_NAME": "Bloquear",
    "SS2_WARDEN_SECONDARY_SHIELD_DESC": "Levanta tu escudo para bloquear, ganando X% de armadura y Y% de disminución de velocidad de movimiento. Bloquear un ataque dentro de los primeros 0,5 segundos de activación detiene el ataque y potencia tu siguiente habilidad. Tu principal se convierte en un golpe de escudo y saltar mientras sostienes tu escudo te hace rodar.",
    "SS2_WARDEN_SHIELD_BASH_NAME": "Intento",
    "SS2_WARDEN_SHIELD_BASH_DESC": "Golpea con escudo frente a ti para causar <style=cIsDamage>240% de daño. Los enemigos </style> y <style=cIsUtility>stun</style> golpean.",
    "SS2_WARDEN_UTILITY_LEAP_NAME": "Acometidas sorprendentes",
