			{
				masterPrefab = MasterCatalog.FindMasterPrefab("MageMonsterMaster"),
				summonerBodyObject = ((Component)mageOwnerBody).gameObject,
				ignoreTeamMemberLimit = true,
				inventoryToCopy = mageOwnerBody.inventory,
				useAmbientLevel = true,
				position = ((Component)interactor).transform.position + Vector3.up,
				rotation = Quaternion.identity,
