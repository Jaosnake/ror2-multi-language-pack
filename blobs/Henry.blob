		internal override void InitializeCharacter()
		{
			//IL_0057: Unknown result type (might be due to invalid IL or missing references)
			//IL_0061: Expected O, but got Unknown
			base.InitializeCharacter();
			if (HenryPlugin.scepterInstalled)
			{
				CreateScepterSkills();
			}
			bodyPrefab.GetComponent<SfxLocator>().deathSound = "HenryDeath";
			bodyPrefab.AddComponent<HenryController>();
			bodyPrefab.AddComponent<HenryTracker>();
			bodyPrefab.AddComponent<HenryFuryComponent>();
			HUD.Awake += new hook_Awake(HUDAwake);
		}

		internal override void InitializeUnlockables()
		{
			characterUnlockableDef = Content.CreateAndAddUnlockbleDef("ROB_HENRY_BODY_UNLOCKABLE_REWARD_ID", Tokens.GetAchievementNameToken("ROB_HENRY_BODY_UNLOCKABLE_ACHIEVEMENT_ID"), Asset.mainAssetBundle.LoadAsset<Sprite>("texHenryAchievement"));
			masterySkinUnlockableDef = Content.CreateAndAddUnlockbleDef("ROB_HENRY_BODY_MASTERYUNLOCKABLE_REWARD_ID", Tokens.GetAchievementNameToken("ROB_HENRY_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_ID"), Asset.mainAssetBundle.LoadAsset<Sprite>("texMasteryAchievement"));
			grandMasterySkinUnlockableDef = Content.CreateAndAddUnlockbleDef("ROB_HENRY_BODY_TYPHOONUNLOCKABLE_REWARD_ID", Tokens.GetAchievementNameToken("ROB_HENRY_BODY_TYPHOONUNLOCKABLE_ACHIEVEMENT_ID"), Asset.mainAssetBundle.LoadAsset<Sprite>("texGrandMasteryAchievement"));
		}

		internal override void InitializeDoppelganger()
		{
			base.InitializeDoppelganger();
		}

		internal override void InitializeHitboxes()
		{
			ChildLocator componentInChildren = bodyPrefab.GetComponentInChildren<ChildLocator>();
			GameObject gameObject = ((Component)componentInChildren).gameObject;
			Transform hitboxTransform = componentInChildren.FindChild("SwordHitbox");
			Prefabs.SetupHitbox(gameObject, hitboxTransform, "Sword");
			hitboxTransform = componentInChildren.FindChild("PunchHitbox");
			Prefabs.SetupHitbox(gameObject, hitboxTransform, "Punch");
		}

