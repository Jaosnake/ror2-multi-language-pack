			if (Object.op_Implicit((Object)(object)component2))
			{
				overlay = TemporaryOverlayManager.AddOverlay(((Component)this).gameObject);
				overlay.originalMaterial = mat;
				overlay.animateShaderAlpha = temporary;
				overlay.duration = 0.5f;
				overlay.alphaCurve = curve;
				overlay.destroyComponentOnEnd = true;
				overlay.AddToCharacterModel(component2);
			}
		}
	}

	public void Reset()
	{
		overlay.stopwatch = 0f;
		stopwatch = 0f;
	}

	private void FixedUpdate()
	{
