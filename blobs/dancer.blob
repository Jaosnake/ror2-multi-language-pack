					list.AddRange((from ai2 in Addressables.LoadAssetAsync<GameObject>((object)"RoR2/Base/Engi/EngiWalkerTurretMaster.prefab").WaitForCompletion().GetComponents<AISkillDriver>()
						where (int)ai2.moveTargetType == 2
						select ai2).ToList());
					master.aiComponents[0].skillDrivers = list.ToArray();
					Object.DontDestroyOnLoad((Object)(object)master);
					master.destroyOnBodyDeath = false;
					master.killedByUnsafeArea = false;
				}
