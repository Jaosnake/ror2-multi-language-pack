			string text8 = "Hold to: Slice at enemies before you dealing <style=cIsDamage>damage</style>." + Environment.NewLine + "If target is far away, Myst will instead execute a dashing attack to close the distance." + Environment.NewLine + "If a Finisher is equipped, it will be activated after the third combo swing.";
