			foreach (GameObject val in array2)
			{
				IEnumerable<Renderer> enumerable = from x in val.GetComponentsInChildren<Renderer>()
					where Object.op_Implicit((Object)(object)x.sharedMaterial) && ((Object)x.sharedMaterial.shader).name.StartsWith("Hopoo Games")
					select x;
				foreach (Renderer item in enumerable)
