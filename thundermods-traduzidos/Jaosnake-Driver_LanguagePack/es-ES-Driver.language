{
    "es-ES": {
        "ROB_DRIVER_BODY_NAME": "Conductor",
        "ROB_DRIVER_BODY_DESCRIPTION": "El conductor soy literalmente yo.<color=#CCD3E0></i>",
        "ROB_DRIVER_BODY_SUBTITLE": "¿Conductor? ¡Casi no la conozco!",
        "ROB_DRIVER_BODY_LORE": "De espaldas contra la pared y contra todo pronóstico\nCon la fuerza de una voluntad y una causa\nTus hazañas se llaman notables\nEres emocionalmente complejo\n\nContra la corriente de afirmaciones distópicas\nNo los pensamientos que albergan tus acciones\nY demostraste ser\n\n\nUn verdadero ser humano y un verdadero hero\n\n\"Entonces, ¿a qué te dedicas?\"\n\n\"Yo conduzco\".",
        "ROB_DRIVER_BODY_OUTRO_FLAVOR": "..y luego se fue, igual que cuando empezó.",
        "ROB_DRIVER_BODY_OUTRO_FAILURE": "..y luego desapareció, sin convertirse nunca en un verdadero ser humano.",
        "ROB_DRIVER_BODY_DEFAULT_SKIN_NAME": "Por defecto",
        "ROB_DRIVER_BODY_MONSOON_SKIN_NAME": "Chaqueta",
        "ROB_DRIVER_BODY_TYPHOON_SKIN_NAME": "toletero",
        "ROB_DRIVER_BODY_SUIT_SKIN_NAME": "Sicario",
        "ROB_DRIVER_BODY_SUIT2_SKIN_NAME": "Sicario EX",
        "ROB_DRIVER_BODY_SPECIALFORCES_SKIN_NAME": "Fuerzas Especiales",
        "ROB_DRIVER_BODY_GUERRILLA_SKIN_NAME": "Guerrilla",
        "ROB_DRIVER_BODY_GREEN_SKIN_NAME": "Verde",
        "ROB_DRIVER_BODY_MINECRAFT_SKIN_NAME": "minecraft",
        "ROB_DRIVER_BODY_PASSIVE_NAME": "Superviviente",
        "ROB_DRIVER_BODY_PASSIVE_DESCRIPTION": "Los enemigos tienen la posibilidad de soltar una nueva <style=cIsUtility>arma</style>. ¡Estos otorgan <style=cIsDamage>ataques poderosos</style> por tiempo limitado!</i>",
        "ROB_DRIVER_BODY_PASSIVE2_NAME": "Tirador (heredado)",
        "ROB_DRIVER_BODY_PASSIVE2_DESCRIPTION": "Tu confiable <style=cIsHealth>pistol</style> es todo lo que necesitas.</i>",
        "ROB_DRIVER_BODY_PASSIVE3_NAME": "Pie de plomo",
        "ROB_DRIVER_BODY_PASSIVE3_DESCRIPTION": "Los enemigos tienen la posibilidad de soltar <style=cIsHealth>munición</style>. ¡Estos otorgan a tu <style=cIsHealth>arma</style> <style=cIsDamage>poderosos ataques</style> por tiempo limitado!</i>",
        "ROB_DRIVER_BODY_PASSIVE4_NAME": "Dioses",
        "ROB_DRIVER_BODY_PASSIVE4_DESCRIPTION": "Yo <style=cIsHealth>conduce</style>.</i>",
