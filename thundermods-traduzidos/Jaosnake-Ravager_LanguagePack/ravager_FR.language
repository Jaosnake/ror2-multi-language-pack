        "ROB_RAVAGER_BODY_UNLOCKABLE_ACHIEVEMENT_DESC": "Appliquez 50 charges de Saignement sur un ennemi.",
        "ROB_RAVAGER_BODY_MONSOONUNLOCKABLE_UNLOCKABLE_NAME": "Ravageur : Maîtrise",
