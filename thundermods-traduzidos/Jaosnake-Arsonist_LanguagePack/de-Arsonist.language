{
    "de": {
        "POPCORN_ARSONIST_BODY_NAME": "Brandstifter",
        "POPCORN_ARSONIST_BODY_DESCRIPTION": "Der Arsonist ist ein Panzer mit kurzer Reichweite, der Feuer als Mittel zum Zweck nutzt. Durch die Verwaltung seiner Überhitzungsanzeige kann er Gruppen von Feinden großen Schaden zufügen. Ausgewogenheit ist entscheidend für den Sieg.</i>",
        "POPCORN_ARSONIST_BODY_SUBTITLE": "Wahnsinniger Pyromane",
        "POPCORN_ARSONIST_BODY_PASSIVE_NORMAL_GAUGE_NAME": "Normalspur",
        "POPCORN_ARSONIST_BODY_PASSIVE_NORMAL_GAUGE_DESCRIPTION": "Handeln<style=cIsDamage>100 %</style>Schäden am weißen Teil. Die Basisanzeige ist beständig gegen Überhitzung.</i>",
        "POPCORN_ARSONIST_BODY_PASSIVE_BLUE_GAUGE_NAME": "Kritisches Messgerät",
        "POPCORN_ARSONIST_BODY_PASSIVE_BLUE_GAUGE_DESCRIPTION": "Handeln<style=cIsDamage>70 %</style>Schäden am weißen Teil und<style=cIsDamage>250 %</style>Schaden am blauen Teil. Maximale Hitze ist festgelegt.</i>",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_NAME": "Drachenatem",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_DESCRIPTION": "Feuere einen Flammenstrahl ab, der Schaden verursacht<style=cIsDamage>90 % Schaden</style>. Je näher Sie dem Ziel sind, desto größer ist die Zündwahrscheinlichkeit.</i>",
        "POPCORN_ARSONIST_BODY_PRIMARY_FIRESPRAY_NAME": "Feuerball",
        "POPCORN_ARSONIST_BODY_PRIMARY_FIRESPRAY_DESCRIPTION": "<style=cIsUtility>Hitze.</style>Feuert einen Feuerball ab<style=cIsDamage>225 % Schaden und Entzündung</style>Feinde bei Treffer.</i>",
        "POPCORN_ARSONIST_BODY_ALT_PRIMARY_FIRESPRAY_NAME": "Overdrive",
        "POPCORN_ARSONIST_BODY_ALT_PRIMARY_FIRESPRAY_DESCRIPTION": "<style=cIsUtility>Hitze.</style><style=cIsUtility>Superkrit.</style>Feuert einen Feuerball ab<style=cIsDamage>160 % Schaden und Entzündung</style>Feinde bei Treffer.</i>",
        "POPCORN_ARSONIST_BODY_PRIMARY_FIRESPRAY_SCEPTER_NAME": "Feuersturm",
        "POPCORN_ARSONIST_BODY_PRIMARY_FIRESPRAY_SCEPTER_DESCRIPTION": "<style=cIsUtility>Hitze.</style>Feuern Sie einen durchdringenden Strahl intensiver Hitze ab<style=cIsDamage>300 % Schaden und Entzündung</style>Feinde bei Treffer. Bei kurzer Dauer wird ein zerstörerischer Strahl abgefeuert<style=cIsDamage>450 % Schaden</style>bei Veröffentlichung.</i>",
        "POPCORN_ARSONIST_BODY_SECONDARY_PUNCH_NAME": "Nullpunktexplosion",
        "POPCORN_ARSONIST_BODY_SECONDARY_PUNCH_DESCRIPTION": "<style=cIsUtility>Agil. Hitze.</style>Treiben Sie sich vorwärts und lassen Sie die Feinde hinter Ihnen explodieren<style=cIsDamage>200 % Schaden</style>. Kollision unmittelbar nach dem Start mit dem ersten Feind verursacht<style=cIsDamage>200 % Schaden</style>in einer umgebenden Explosion.</i>",
        "POPCORN_ARSONIST_BODY_SECONDARY_FLAREGUN_NAME": "Leuchtpistole",
        "POPCORN_ARSONIST_BODY_SECONDARY_FLAREGUN_DESCRIPTION": "Feuern Sie eine Leuchtrakete ab<style=cIsDamage>400 % Schaden</style>über 5 Sekunden, dann explodiert der Schaden<style=cIsDamage>400 % Schaden</style>, indem er 5 Fackeln abfeuert<style=cIsDamage>200 % Schaden</style>jede.</i>",
        "POPCORN_ARSONIST_BODY_UTILITY_CLEANSE_NAME": "Reinigen",
        "POPCORN_ARSONIST_BODY_UTILITY_CLEANSE_DESCRIPTION": "<style=cIsUtility>Agil. Hitze.</style><style=cIsDamage>Entzünden</style>die Gegend um dich herum, Umgang<style=cIsDamage>50 %</style>Schaden an Gegnern in der Nähe und Entfernen anderer Statuseffekte. Gewährt einen kleinen Geschwindigkeitsschub.</i>",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHIST_NAME": "Masochismus",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHIST_DESCRIPTION": "<style=cIsUtility>Agil. Hitze.</style>Schaden durch das Sein<style=cIsDamage>entzündet</style>verwandelt sich in<style=cIsHealing>Heilung</style>für 6,5 Sekunden. Erhöht die Angriffsgeschwindigkeit um<style=cIsDamage>125 %</style>.</i>",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_NAME": "Masochismus",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_DESCRIPTION": "Beim Erreichen der<style=cKeywordName>Vorwegnahme</style>Limit, füge dir selbst regelmäßig Schaden im Tausch gegen Fläche zu<style=cIsHealing>Lebensraub</style>und brennen. Nach spätestens 10 Sekunden<style=cIsDamage>Detonieren</style>, Dann<style=cIsUtility>Überhitzen</style>.</i>",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_SURGE_NAME": "Trotz",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_SURGE_DESCRIPTION": "Beim Erreichen der<style=cKeywordName>Vorwegnahme</style>Limit, Sie bewegen sich schneller und gewinnen<style=cKeywordName>Doppelter Schuss</style>Und<style=cIsHealing>Lebensraub</style>. Nach spätestens 10 Sekunden<style=cIsDamage>Detonieren</style>, Dann<style=cIsUtility>Überhitzen</style>.</i>",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_SCEPTER_NAME": "Dantes Zurechtweisung",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_SCEPTER_DESCRIPTION": "Feuern Sie einen intensiven Strahlangriff ab<style=cIsDamage>140 % Schaden</style>. Je näher Sie dem Ziel sind, desto größer ist die Zündwahrscheinlichkeit. Wenn die Taste 2 Sekunden oder länger gedrückt gehalten wird, wird beim Loslassen ein letzter Strahl abgefeuert<style=cIsDamage>150 % Schaden</style>.</i>",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_ANTICIPATION": "<style=cKeywordName>Vorwegnahme</style>Für jeweils 100 verlorene und/oder gewonnene Hitze erhält der Brandstifter 1 Vorfreude-Ladung; Nachdem er 5 Ladungen erhalten hat, kann er den Masochismus aktivieren; Zusätzliche Ladungen erhöhen Schaden und Dauer; Am Ende sind alle Ladungen verbraucht.",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_DETONATE": "<style=cKeywordName>Detonate</style>Der Brandstifter explodiert und verursacht <style=cIsDamage>150 % Schaden</style> Mal die Menge der angesammelten Antizipationsladungen.",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_LIFESTEAL": "<style=cKeywordName>Lebensraub</style>Brandstifter heilt<style=cIsHealing>18 %</style>verursachter Schaden, während Masochismus aktiv ist.",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_SURGE_LIFESTEAL": "<style=cKeywordName>Lebensraub</style>Brandstifter heilt<style=cIsHealing>5 %</style>verursachten Schaden, während Spite aktiv ist.",
        "POPCORN_ARSONIST_BODY_KEYWORD_OVERHEAT_MASO": "<style=cKeywordName>Überhitzung: Masochismus</style>Wenn Brandstifter aufgrund übermäßiger Hitzeentwicklung den Masochismus verlässt, wird EX-Überhitzung angewendet, wodurch Bewegungsgeschwindigkeit und Schaden auf 70 % reduziert werden. Wenn Sie die Fertigkeit abbrechen oder ablaufen lassen, wird Überhitzung angewendet, wodurch die Angriffsgeschwindigkeit auf 50 % verringert wird.",
        "POPCORN_ARSONIST_BODY_OVERHEAT_TEXT": "ÜBERHITZEN!",
        "POPCORN_ARSONIST_BODY_COOLING_TEXT": "Abkühlung...!",
        "POPCORN_ARSONIST_BODY_OVERHEAT_EX_TEXT": "ÜBERHITZUNG:EX!",
        "POPCORN_ARSONIST_BODY_PASSIVE_NAME": "Pyromanie",
        "POPCORN_ARSONIST_BODY_PASSIVE_DESCRIPTION": "Widersteht Feuerschaden aus allen Quellen. Wandelt einen Angriff, der mehr als <style=cIsDamage>30%</style> der Gesamtgesundheit verursacht, in <style=cIsDamage>50%</style> Feuerschaden über Zeit um.",
        "POPCORN_ARSONIST_BODY_KEYWORD_PYROMANIAPASSIVE": "Pyromanie beeinflusst Fallschaden nicht, außer Gebrechlichkeit ist aktiv.",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_NAME": "Arsonist: Mastery",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_DESCRIPTION": "As Arsonist, beat the game or obliterate on Monsoon.",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_ECLIPSE5UNLOCKABLE_ACHIEVEMENT_NAME": "Arsonist: Grandmastery",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_ECLIPSE5UNLOCKABLE_ACHIEVEMENT_DESCRIPTION": "As Arsonist, beat the game on Eclipse 5 or higher, OR beat the game on Typhoon (Starstorm 2 required).",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_ECLIPSE8UNLOCKABLE_ACHIEVEMENT_NAME": "Arsonist: Survival",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_ECLIPSE8UNLOCKABLE_ACHIEVEMENT_DESCRIPTION": "As Arsonist, beat the game on Eclipse 8, OR beat the game on Inferno (Inferno required).",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_FLAMETHROWERUNLOCKABLE_ACHIEVEMENT_NAME": "Arsonist: Pyromaniac",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_FLAMETHROWERUNLOCKABLE_ACHIEVEMENT_DESCRIPTION": "As Arsonist, beat a stage without overheating.",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_ARSONISTUNLOCKABLE_ACHIEVEMENT_NAME": "Embers",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_ARSONISTUNLOCKABLE_ACHIEVEMENT_DESCRIPTION": "Kill a teleporter boss while it is ignited."
    }
}
