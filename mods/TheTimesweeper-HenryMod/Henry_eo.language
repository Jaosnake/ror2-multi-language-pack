{
    "eo": {
        "ROB_HENRY_BODY_NAME": "Henry",
        "ROB_HENRY_BODY_DESCRIPTION": "Henry estas lerta batalanto, kiu uzas vastan arsenalon de armiloj por faligi siajn malamikojn.<color=#CCD3E0>\n\n< ! > Glavo estas bona cxiuflanka elekto, dum Boksaj Gantoj pli tauxgas por bati pli fortajn malamikojn.\n\n< ! > Pistolo estas potenca kontrauxaera ilo, kun malalta resxarga tempo kaj alta damagxo.\n\n< ! > Ruligxo havas dauxran kirasan plifortigon, kiu helpas uzi gxin agreseme.\n\n< ! > Bombo povas facile forvisxi amasojn da malamikoj.</color>",
        "ROB_HENRY_BODY_SUBTITLE": "La Elektito",
        "ROB_HENRY_BODY_LORE": "Ekzempla historio",
        "ROB_HENRY_BODY_OUTRO_FLAVOR": "..kaj tiel li foriris, sercxante novan identecon.",
        "ROB_HENRY_BODY_OUTRO_FAILURE": "..kaj tiel li malaperis, por cxiam blanka folio.",
        "ROB_HENRY_BODY_DEFAULT_SKIN_NAME": "Defauxlta",
        "ROB_HENRY_BODY_MASTERY_SKIN_NAME": "Alternativa",
        "ROB_HENRY_BODY_TYPHOON_SKIN_NAME": "V1",
        "ROB_HENRY_BODY_DANTE_SKIN_NAME": "Dante",
        "ROB_HENRY_BODY_VERGIL_SKIN_NAME": "Vergil",
        "ROB_HENRY_BODY_SAMURAI_SKIN_NAME": "Samurajo",
        "ROB_HENRY_BODY_SOLDIER_SKIN_NAME": "Cxampiono",
        "ROB_HENRY_BODY_ZOMBIE_SKIN_NAME": "Zombio",
        "ROB_HENRY_BODY_SKELETON_SKIN_NAME": "Skeleto",
        "ROB_HENRY_BODY_PASSIVE_NAME": "Pasivo de Henry",
        "ROB_HENRY_BODY_PASSIVE_DESCRIPTION": "Ekzempla teksto.",
        "ROB_HENRY_BODY_PRIMARY_SLASH_NAME": "Glavo",
        "ROB_HENRY_BODY_PRIMARY_SLASH_DESCRIPTION": "<style=cIsUtility>Lerta.</style> Svingu antauxen por <style=cIsDamage>280% da damagxo</style>.",
        "ROB_HENRY_BODY_PRIMARY_PUNCH_NAME": "Boksaj Gantoj",
        "ROB_HENRY_BODY_PRIMARY_PUNCH_DESCRIPTION": "<style=cIsUtility>Lerta.</style> Rapide pugnobatu por <style=cIsDamage>240% da damagxo</style>. <style=cIsUtility>Ignoras kirason.</style>",
        "ROB_HENRY_BODY_PRIMARY_GUN_NAME": "Pistolo",
        "ROB_HENRY_BODY_PRIMARY_GUN_DESCRIPTION": "<style=cIsUtility>Lerta.</style> Pafu per malgranda pistolo por <style=cIsDamage>90% da damagxo</style>.",
        "ROB_HENRY_BODY_SECONDARY_GUN_NAME": "Manpafilo",
        "ROB_HENRY_BODY_SECONDARY_GUN_DESCRIPTION": "<style=cIsUtility>Lerta.</style> Pafu per manpafilo por <style=cIsDamage>420% da damagxo</style>.",
        "ROB_HENRY_BODY_SECONDARY_STINGER_NAME": "Stinger",
        "ROB_HENRY_BODY_SECONDARY_STINGER_DESCRIPTION": "<style=cIsUtility>Lerta.</style> Saltataku malamikon por <style=cIsDamage>450% da damagxo</style>.",
        "ROB_HENRY_BODY_SECONDARY_UZI_NAME": "Uzi",
        "ROB_HENRY_BODY_SECONDARY_UZI_DESCRIPTION": "Pafu per uzi por <style=cIsDamage>75% da damagxo</style>.",
        "ROB_HENRY_BODY_UTILITY_ROLL_NAME": "Ruligxo",
        "ROB_HENRY_BODY_UTILITY_ROLL_DESCRIPTION": "Ruligxu mallongan distancon, akirante <style=cIsUtility>300 kirason</style>. <style=cIsUtility>Vi ne povas esti trafita dum la ruligxo.</style>",
        "ROB_HENRY_BODY_UTILITY_SHOTGUN_NAME": "Shotgun",
        "ROB_HENRY_BODY_UTILITY_SHOTGUN_DESCRIPTION": "Pafu per <style=cIsUtility>shotgun</style> por <style=cIsDamage>14x140% da damagxo</style>, lancxante vin per la retropusxo.",
        "ROB_HENRY_BODY_SPECIAL_BOMB_NAME": "Bombo",
        "ROB_HENRY_BODY_SPECIAL_BOMB_DESCRIPTION": "Jxetu bombon por <style=cIsDamage>1600% da damagxo</style>.",
        "ROB_HENRY_BODY_SPECIAL_SCEPBOMB_NAME": "Pli da Bomboj!",
        "ROB_HENRY_BODY_SPECIAL_SCEPBOMB_DESCRIPTION": "Jxetu bombon por <style=cIsDamage>1600% da damagxo</style>.\n<color=#d299ff>SCEPTER: Tenu gxis 4 bombojn. Resxargo duonigxas.</color>",
        "ROB_HENRY_BODY_SPECIAL_BAZOOKA_NAME": "Bazooka",
        "ROB_HENRY_BODY_SPECIAL_BAZOOKA_DESCRIPTION": "Sxargu kaj pafu raketojn por <style=cIsDamage>600%-1600% da damagxo</style>.",
        "ROB_HENRY_BODY_PRIMARY_BAZOOKA_NAME": "Pafi",
        "ROB_HENRY_BODY_PRIMARY_BAZOOKA_DESCRIPTION": "Sxargu kaj pafu raketon por <style=cIsDamage>600%-1600% da damagxo</style>.",
        "ROB_HENRY_BODY_PRIMARY_BAZOOKAOUT_NAME": "Nuligi",
        "ROB_HENRY_BODY_PRIMARY_BAZOOKAOUT_DESCRIPTION": "Formetu vian <style=cIsDamage>bazooka</style>.",
        "ROB_HENRY_BODY_SPECIAL_SCEPBAZOOKA_NAME": "Armageddon",
        "ROB_HENRY_BODY_SPECIAL_SCEPBAZOOKA_DESCRIPTION": "Sxargu kaj pafu raketojn por <style=cIsDamage>600%-1600% da damagxo</style>.\n<color=#d299ff>SCEPTER: Tenu du Bazooka samtempe.</color>",
        "ROB_HENRY_BODY_PRIMARY_SCEPBAZOOKA_NAME": "Pafi",
        "ROB_HENRY_BODY_PRIMARY_SCEPBAZOOKA_DESCRIPTION": "Sxargu kaj pafu raketon por <style=cIsDamage>600%-1600% da damagxo</style>.\n<color=#d299ff>SCEPTER: Tenu du Bazooka samtempe.</color>",
        "ROB_HENRY_BODY_SPECIAL_FRENZY_NAME": "Rampage",
        "ROB_HENRY_BODY_SPECIAL_FRENZY_DESCRIPTION": "Akumulu <style=cIsHealth>Fury</style> dum trafoj. Uzu kiam plene sxargite por eniri <style=cIsDamage>frenezon</style> dum <style=cIsUtility>10 sekundoj</style>. <style=cIsHealth>Sxargxas pli rapide je malalta sano.</style>",
        "ROB_HENRY_BODY_SPECIAL_SCEPFRENZY_NAME": "Super Saiyan",
        "ROB_HENRY_BODY_SPECIAL_SCEPFRENZY_DESCRIPTION": "Akumulu <style=cIsHealth>Fury</style> dum trafoj. Uzu kiam plene sxargite por eniri <style=cIsDamage>frenezon</style> dum <style=cIsUtility>10 sekundoj</style>. <style=cIsHealth>Sxargxas pli rapide je malalta sano.</style>\n<color=#d299ff>SCEPTER: Statistikaj bonusoj multe pligrandigxas. Dauxro plilongigxas.</color>",
        "ACHIEVEMENT_ROB_HENRY_BODY_UNLOCKABLE_ACHIEVEMENT_ID_NAME": "Prelude",
        "ACHIEVEMENT_ROB_HENRY_BODY_UNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "Kiel Henry, eniru Titanic Plains.",
        "ACHIEVEMENT_ROB_HENRY_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_ID_NAME": "Henry: Mastery",
        "ACHIEVEMENT_ROB_HENRY_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "Kiel Henry, venku la ludon aux forvisxu vin en Monsoon.",
        "ACHIEVEMENT_ROB_HENRY_BODY_TYPHOONUNLOCKABLE_ACHIEVEMENT_ID_NAME": "Henry: Grand Mastery",
        "ACHIEVEMENT_ROB_HENRY_BODY_TYPHOONUNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "Kiel Henry, venku la ludon aux forvisxu vin en Typhoon aux Eclipse.\n<color=#8888>(Validas por ajna malfacileco Typhoon aux pli alta)</color>",
        "ROB_HENRY_BODY_DANTEUNLOCKABLE_ACHIEVEMENT_NAME": "Henry: Jackpot",
        "ROB_HENRY_BODY_DANTEUNLOCKABLE_ACHIEVEMENT_DESC": "Kiel Henry, venku Twisted Scavenger en Monsoon.",
        "ROB_HENRY_BODY_DANTEUNLOCKABLE_UNLOCKABLE_NAME": "Henry: Jackpot",
        "ROB_HENRY_BODY_VERGILUNLOCKABLE_ACHIEVEMENT_NAME": "Henry: 200% Motivated",
        "ROB_HENRY_BODY_VERGILUNLOCKABLE_ACHIEVEMENT_DESC": "Kiel Henry, venku la King of Nothing sen ajxoj.",
        "ROB_HENRY_BODY_VERGILUNLOCKABLE_UNLOCKABLE_NAME": "Henry: 200% Motivated",
        "ACHIEVEMENT_ROB_HENRY_MASTERYACHIEVEMENT_NAME": "Henry: Mastery",
        "ACHIEVEMENT_ROB_HENRY_MASTERYACHIEVEMENT_DESCRIPTION": "Kiel Henry, venku la ludon aux forvisxu vin en Monsoon.",
        "ROB_MRGREEN_BODY_NAME": "Mr. Green",
        "ROB_MRGREEN_BODY_DESCRIPTION": "Mr. Green<color=#CCD3E0>\n\n< ! > Glavo estas bona cxiuflanka elekto, dum Boksaj Gantoj pli tauxgas por bati pli fortajn malamikojn.\n\n< ! > Pistolo estas potenca kontrauxaera ilo, kun malalta resxarga tempo kaj alta damagxo.\n\n< ! > Ruligxo havas dauxran kirasan plifortigon, kiu helpas uzi gxin agreseme.\n\n< ! > Bombo povas facile forvisxi amasojn da malamikoj.</color>",
        "ROB_MRGREEN_BODY_SUBTITLE": "La",
        "ROB_MRGREEN_BODY_LORE": "ekzempla historio parto 2",
        "ROB_MRGREEN_BODY_OUTRO_FLAVOR": "..kaj tiel li foriris, malsupra teksto.",
        "ROB_MRGREEN_BODY_DEFAULT_SKIN_NAME": "Defauxlta",
        "ROB_MRGREEN_BODY_PASSIVE_NAME": "Pasivo de Mr. Green",
        "ROB_MRGREEN_BODY_PASSIVE_DESCRIPTION": "Ekzempla teksto.",
        "ROB_MRGREEN_BODY_PRIMARY_PUNCH_NAME": "Martial Arts",
        "ROB_MRGREEN_BODY_PRIMARY_PUNCH_DESCRIPTION": "Faru rapidan kombon de pugnoj kaj piedbatoj por <style=cIsDamage>90% da damagxo</style>.",
        "ROB_MRGREEN_BODY_SECONDARY_CLONETHROW_NAME": "Jxeto de Klono",
        "ROB_MRGREEN_BODY_SECONDARY_CLONETHROW_DESCRIPTION": "Alvoku klonon kaj jxetu gxin antauxen, kaptante proksimajn malamikojn kaj frapante ilin en la grundon por <style=cIsDamage>420% da damagxo</style>.",
        "ROB_MRGREEN_BODY_UTILITY_DASH_NAME": "People's Elbow",
        "ROB_MRGREEN_BODY_UTILITY_DASH_DESCRIPTION": "Impulsu mallongan distancon. Cxe kontakto kun <style=cIsUtility>klono</style>, saltigu vin en la aeron kaj malsuprenfalu per potenca <style=cIsUtility>kubutfrapo</style> por <style=cIsDamage>800% da damagxo</style>.",
        "ROB_MRGREEN_BODY_SPECIAL_RES_NAME": "Resurrection",
        "ROB_MRGREEN_BODY_SPECIAL_RES_DESCRIPTION": "Revivaigu cxiujn falintajn klonojn.",
        "ROB_NEMRY_BODY_NAME": "Nemesis Henry",
        "ROB_NEMRY_BODY_DESCRIPTION": "Nemesis Henry estas volatila glavisto, kiu uzas specialan klingon, kiu konservas energion por plifortigi siajn atakojn. Li ne havas ordinarajn resxargojn, sed devas bone administri sian energion.<color=#CCD3E0>\n\n< ! > Sword Mode konstruas energion, dum Gun Mode elspezas energion por potencaj atakoj.\n\n< ! > Swordmaster povas esti sxargita por pli da damagxo.\n\n< ! > Flash Step estas potenca agresema ilo, kiu helpas konstrui energion.\n\n< ! > Uzu Hydra Bite por resti sana kaj Hyper Beam por liberigi amason da damagxo.</color>",
        "ROB_NEMRY_BODY_SUBTITLE": "La Falinta",
        "ROB_NEMRY_BODY_LORE": "ekzempla historio",
        "ROB_NEMRY_BODY_OUTRO_FLAVOR": "..kaj tiel li foriris, eksplodiginte la lunon sen klare komprenebla kialo.",
        "ROB_NEMRY_BODY_OUTRO_FAILURE": "..li penis tiel forte, kaj atingis tiel for. Sed fine tio ecx ne gravas.",
        "ROB_NEMRY_BODY_DEFAULT_SKIN_NAME": "Nemesis",
        "ROB_NEMRY_BODY_MASTERY_SKIN_NAME": "Captive #001",
        "ROB_NEMRY_BODY_TYPHOON_SKIN_NAME": "FLLFFL",
        "ROB_NEMRY_BODY_PASSIVE_NAME": "Acida Gunblade",
        "ROB_NEMRY_BODY_PASSIVE_DESCRIPTION": "Nemesis Henry uzas specialan armilon, kiu povas sxangxi inter Sword Mode kaj Gun Mode. Liaj kapabloj ne havas ordinarajn resxargojn; ili dependas de la sistemo de <style=cIsHealing>Energio</style> de lia glavo.",
        "ROB_NEMRY_BODY_PRIMARY_SPEAR_NAME": "Trapiki",
        "ROB_NEMRY_BODY_PRIMARY_SPEAR_DESCRIPTION": "<style=cIsUtility>Lerta.</style> Piku antauxen por <style=cIsDamage>160% da damagxo</style>. <style=cIsDamage>Kauxzas duoblan damagxon kaj resanigas je <style=cIsHealing>50%</style> de la kauxzita damagxo cxe la pinto</style>.",
        "ROB_WEAPON_SWAP_SKILL": "Weapon Swap",
        "ROB_NEMRY_BODY_PRIMARY_SWORD_NAME": "Sword Mode",
        "ROB_NEMRY_BODY_PRIMARY_SWORD_DESCRIPTION": "Svingu vian klingon antauxen por <style=cIsDamage>280% da damagxo</style>. Generu <style=cIsHealing>20% Energion</style> cxe trafo.",
        "ROB_NEMRY_BODY_PRIMARY_GUN_NAME": "Gun Mode",
        "ROB_NEMRY_BODY_PRIMARY_GUN_DESCRIPTION": "<style=cIsHealing>2.5% Energio.</style> Pafu trapikan pafon de <style=cIsHealing>Energio</style> por <style=cIsDamage>240% da damagxo</style>.",
        "ROB_NEMRY_BODY_PRIMARY_SWORDCSS_NAME": "Sword Mode / Gun Mode",
        "ROB_NEMRY_BODY_PRIMARY_SWORDCSS_DESCRIPTION": "Svingu vian klingon por <style=cIsDamage>280% da damagxo</style>. Generu <style=cIsHealing>20% Energion</style> cxe trafo.\n<style=cIsHealing>2.5% Energio.</style> Pafu trapikan pafon de <style=cIsHealing>Energio</style> por <style=cIsDamage>240% da damagxo</style>.",
        "ROB_NEMRY_BODY_SECONDARY_BLAST_NAME": "Null Blast",
        "ROB_NEMRY_BODY_SECONDARY_BLAST_DESCRIPTION": "<style=cIsUtility>Lerta.</style> Jxetu bulon de <style=cIsHealth>mistera energio</style> por <style=cIsDamage>200% da damagxo</style>.",
        "ROB_NEMRY_BODY_SECONDARY_CHARGE_NAME": "Swordmaster",
        "ROB_NEMRY_BODY_SECONDARY_CHARGE_DESCRIPTION": "<style=cIsHealing>10% Energio.</style> Saltataku proksiman malamikon por <style=cIsDamage>700% da damagxo</style>. Faru komban atakon anstatauxe se ene de manbataldistanco.",
        "ROB_NEMRY_BODY_SECONDARY_TORRENT_NAME": "Gunslinger",
        "ROB_NEMRY_BODY_SECONDARY_TORRENT_DESCRIPTION": "<style=cIsHealing>5% Energio.</style> Pafu salvon de <style=cIsHealing>Energio</style>. Tenu por dauxrigi pafadon, konsumante pli da <style=cIsHealing>Energio</style> per pafo.",
        "ROB_NEMRY_BODY_SECONDARY_CHARGECSS_NAME": "Swordmaster / Gunslinger",
        "ROB_NEMRY_BODY_SECONDARY_CHARGECSS_DESCRIPTION": "<style=cIsHealing>10% Energio.</style> Saltataku proksiman malamikon por <style=cIsDamage>700% da damagxo</style>.\n<style=cIsHealing>5% Energio.</style> Pafu salvon de <style=cIsHealing>Energio</style>.",
        "ROB_NEMRY_BODY_UTILITY_DODGESLASH_NAME": "Rapida Trancxo",
        "ROB_NEMRY_BODY_UTILITY_DODGESLASH_DESCRIPTION": "Faru retrosalton, trancxante proksimajn malamikojn por <style=cIsDamage>300% da damagxo</style>. <style=cIsUtility>Vi ne povas esti trafita dum la salto.</style>",
        "ROB_NEMRY_BODY_UTILITY_BLINK_NAME": "Flash Step",
        "ROB_NEMRY_BODY_UTILITY_BLINK_DESCRIPTION": "<style=cIsHealing>5% Energio.</style> <style=cIsUtility>Tuj blinku</style> al proksima malamiko.",
        "ROB_NEMRY_BODY_UTILITY_BURST_NAME": "Energy Burst",
        "ROB_NEMRY_BODY_UTILITY_BURST_DESCRIPTION": "<style=cIsHealing>10% Energio.</style> Liberigu eksplodon de <style=cIsHealing>Energio</style> por <style=cIsDamage>400% da damagxo</style>, <style=cIsUtility>lancxante vin per la retropusxo</style>.",
        "ROB_NEMRY_BODY_UTILITY_BLINKCSS_NAME": "Flash Step / Energy Burst",
        "ROB_NEMRY_BODY_UTILITY_BLINKCSS_DESCRIPTION": "<style=cIsHealing>5% Energio.</style> <style=cIsUtility>Tuj blinku</style> al proksima malamiko.\n<style=cIsHealing>10% Energio.</style> Liberigu eksplodon de <style=cIsHealing>Energio</style> por <style=cIsDamage>400% da damagxo</style>.",
        "ROB_NEMRY_BODY_SPECIAL_STAB_NAME": "Hydra Bite",
        "ROB_NEMRY_BODY_SPECIAL_STAB_DESCRIPTION": "<style=cIsHealing>100% Energio.</style> Enpiku vian klingon en malamikon por <style=cIsDamage>2800% da damagxo</style>, aplikante potencan malbonigon. <style=cIsHealing>Resanigxu je 50% de la kauxzita damagxo.</style>",
        "ROB_NEMRY_BODY_SPECIAL_BEAM_NAME": "Hyper Beam",
        "ROB_NEMRY_BODY_SPECIAL_BEAM_DESCRIPTION": "<style=cIsHealing>100% Energio.</style> Sxargu potencan salvon de laseroj, kiu kauxzas <style=cIsDamage>10x540% da damagxo</style>.",
        "ROB_NEMRY_BODY_SPECIAL_STABCSS_NAME": "Hydra Bite / Hyper Beam",
        "ROB_NEMRY_BODY_SPECIAL_STABCSS_DESCRIPTION": "<style=cIsHealing>100% Energio.</style> Enpiku vian klingon en malamikon por <style=cIsDamage>2800% da damagxo</style>, aplikante potencan malbonigon. <style=cIsHealing>Resanigxu je 50% de la kauxzita damagxo.</style>\n<style=cIsHealing>100% Energio.</style> Sxargu potencan radion, kiu kauxzas <style=cIsDamage>multe da damagxo</style>.",
        "ROB_NEMRY_BODY_UNLOCKABLE_ACHIEVEMENT_NAME": "???",
        "ROB_NEMRY_BODY_UNLOCKABLE_ACHIEVEMENT_DESC": "Venku la Vestige de Henry.",
        "ROB_NEMRY_BODY_UNLOCKABLE_UNLOCKABLE_NAME": "???",
        "ROB_NEMRY_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_NAME": "Nemesis Henry: Mastery",
        "ROB_NEMRY_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_DESC": "Kiel Nemesis Henry, venku la ludon aux forvisxu vin en Monsoon.",
        "ROB_NEMRY_BODY_MASTERYUNLOCKABLE_UNLOCKABLE_NAME": "Nemesis Henry: Mastery",
        "ROB_NEMRY_BODY_TYPHOONUNLOCKABLE_ACHIEVEMENT_NAME": "Nemesis Henry: Grand Mastery",
        "ROB_NEMRY_BODY_TYPHOONUNLOCKABLE_ACHIEVEMENT_DESC": "Kiel Nemesis Henry, venku la ludon aux forvisxu vin en Typhoon.",
        "ROB_NEMRY_BODY_TYPHOONUNLOCKABLE_UNLOCKABLE_NAME": "Nemesis Henry: Grand Mastery"
