			text11 = "MP Cost: " + ConeOfFrost.MPCost + Environment.NewLine;
			text11 = text11 + "Damage: " + ConeOfFrost.Damage * 100f + "%" + Environment.NewLine;
			text11 = text11 + Environment.NewLine + "What is made hard, is also made brittle. Things in stasis are easy to study, but I wasn't sent here to gain knowledge, I must gather Experience.";
			LanguageAPI.Add(text2 + "CONEOFFROST_INFO", text11);
			LanguageAPI.Add(text2 + "CALLLIGHTNING_NAME", "Call Lightning");
