		private GameObject swordActiveEffect;

		private AmpLightningController lightningController;

		private ChildLocator childLocator;

		public LocalUser localUser;

		public static event Action<Run> onSunSurvived;

		public override void OnEnter()
		{
			((GenericCharacterMain)this).OnEnter();
			if (((EntityState)this).healthComponent.combinedHealth >= 0f)
			{
				swordActive = true;
			}
			else
			{
				swordActive = false;
				swordTransition = 0f;
			}
			lightningController = ((Component)((EntityState)this).characterBody).GetComponent<AmpLightningController>();
			if (Object.op_Implicit((Object)(object)((EntityState)this).characterBody))
			{
				Transform modelTransform = ((EntityState)this).GetModelTransform();
				if (Object.op_Implicit((Object)(object)modelTransform))
				{
					childLocator = ((Component)modelTransform).GetComponent<ChildLocator>();
				}
			}
			if (Object.op_Implicit((Object)(object)childLocator))
			{
				Transform obj = childLocator.FindChild("SwordSparks");
				if (obj != null)
				{
					((Component)obj).gameObject.SetActive(false);
				}
				if (lightningController.isRed)
				{
					Transform obj2 = childLocator.FindChild("SwordSparksRed");
					swordActiveEffect = ((obj2 != null) ? ((Component)obj2).gameObject : null);
				}
				else
				{
					Transform obj3 = childLocator.FindChild("SwordSparks");
					swordActiveEffect = ((obj3 != null) ? ((Component)obj3).gameObject : null);
				}
			}
		}

		public override void FixedUpdate()
		{
			((GenericCharacterMain)this).FixedUpdate();
			if (Object.op_Implicit((Object)(object)((EntityState)this).healthComponent) && ((EntityState)this).healthComponent.combinedHealth >= 0f)
			{
				swordActive = true;
			}
			if (swordActive && Object.op_Implicit((Object)(object)swordActiveEffect))
			{
				swordActiveEffect.SetActive(true);
			}
		}

		static AmpMain()
		{
			AmpMain.onSunSurvived = delegate
			{
			};
		}
	}
