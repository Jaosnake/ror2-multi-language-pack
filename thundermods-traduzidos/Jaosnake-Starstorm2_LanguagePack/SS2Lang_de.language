    "SS2_DRONE_SHOCK_NAME": "Schockdrohne",
    "SS2_DRONE_SHOCK_INTERACTABLE_NAME": "Kaputte Schockdrohne",
    "SS2_DRONE_SHOCK_INTERACTABLE_CONTEXT": "Schockdrohne reparieren",
    "SS2_DRONE_SHOCK_PICKUP": "<style=cIsUtility>Shocks</style> nahe Feinde, unterbricht und betäubt sie.",
    "SS2_DRONE_SHOCK_DESCRIPTION": "Ein mit Gold gekaufter Begleiter, der dem Überlebenden aus nächster Nähe folgt, Feinde <style=cIsUtility>schockiert</style>, sie unterbricht und betäubt.",
    "SS2_DRONE_SHOCK_SKILL_DESCRIPTION": "Feuert eine elektrische Explosion ab, die <style=cIsDamage>100 % Schaden</style> in einem Bereich verursacht und Gegner <style=cIsUtility>schockierende</style> für <style=cIsUtility>5 Sekunden</style>.",
    "SS2_DRONE_SHOCK_COMMAND_DESCRIPTION": "",
    "SS2_DRONE_CLONE_NAME": "Duplikator-Drohne",
    "SS2_DRONE_CLONE_INTERACTABLE_NAME": "Kaputte Duplikator-Drohne",
    "SS2_DRONE_CLONE_INTERACTABLE_CONTEXT": "Reparatur-Duplikator-Drohne",
    "SS2_DRONE_CLONE_PICKUP": "Gelegentlich <style=cIsUtility>dupliziert</style> in der Nähe befindliche Elemente.",
    "SS2_DRONE_CLONE_DESCRIPTION": "Ein mit Gold gekaufter Begleiter, der dem Überlebenden aus nächster Nähe folgt. <style=cIsUtility>Dupliziert</style> das Aufheben von Gegenständen in der Nähe.",
    "SS2_DRONE_CLONE_SKILL_DESCRIPTION": "Kanäle auf einem in der Nähe befindlichen Element. Erstellt nach Abschluss ein <style=cIsUtility>Duplikat</style> des Elements.",
    "SS2_DRONE_CLONE_COMMAND_DESCRIPTION": "",
    "SS2_DROIDDRONE_NAME": "Sicherheitsdrohne",
    "SS2_DROIDDRONE_PICKUP": "Schießt auf Feinde in der Nähe. <style=cIsUtility>Erbt den Elitetyp</style> der getöteten Elite.",
    "SS2_DROIDDRONE_DESCRIPTION": "Ein vorübergehender Begleiter, der entsteht, wenn man den Droidenkopf hält und Eliteeinheiten tötet, der dem Überlebenden aus nächster Nähe folgt und in der Nähe befindliche Feinde erschießt.",
    "SS2_DROIDDRONE_SKILL_DESCRIPTION": "",
