				{
					weaponDef = BaseWeapon<NoWeapon>.instance.weaponDef;
					HandleAnimationLayer();
					if (Object.op_Implicit((Object)(object)heldWeaponInstance))
					{
						Object.Destroy((Object)(object)heldWeaponInstance);
					}
					if (Object.op_Implicit((Object)(object)backWeaponInstance))
					{
						Object.Destroy((Object)(object)backWeaponInstance);
					}
					crosshairPrefab = weaponDef.crosshairPrefab;
					characterBody._defaultCrosshairPrefab = crosshairPrefab;
					if (onWeaponUpdate != null)
					{
						onWeaponUpdate(this);
					}
					return;
				}
