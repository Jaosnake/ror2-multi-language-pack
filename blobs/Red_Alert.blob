			Language.Add("HABIBI_CHRONO_DRIVER_GUN_DESCRIPTION", "Makes enemies vanish from existence.");
			Language.Add("HABIBI_CHRONO_PRIMARY_SHOOT_DRIVER_NAME", "Chrono Gun");
