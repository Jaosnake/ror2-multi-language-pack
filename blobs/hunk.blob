					shieldFill.fillAmount = Mathf.Lerp(shieldFill.fillAmount, num7, fillSpeed * Time.fixedDeltaTime);
					damageFill.fillAmount = Mathf.Lerp(damageFill.fillAmount, num7, 0.25f * fillSpeed * Time.fixedDeltaTime);
					if (Object.op_Implicit((Object)(object)body.inventory))
					{
