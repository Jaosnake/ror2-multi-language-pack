    "SS2_BIRTHRIGHT_CHEST_CONTEXT": "Beanspruchen Sie das Geburtsrecht",
    "SS2_BIRTHRIGHT_UNCLAIMED_2P": "<style=cShrine>Ihnen fehlt, was Sie suchen.</style>",
    "SS2_BIRTHRIGHT_UNCLAIMED": "<style=cShrine>{0} fehlt das, was sie suchen.</style>",
    "SS2_BIRTHRIGHT_UNCLAIMED_DEAD": "<style=cShrine>Die Toten haben unerledigte Geschäfte; Anspruch auf das Gesuchte erheben.</style>",
    "SS2_BIRTHRIGHT_UNCLAIMED_REMOVED_2P": "<style=cShrine>Es wurde ein Deal abgeschlossen. Fordern Sie Ihr Erstgeburtsrecht an.</style>",
    "SS2_BIRTHRIGHT_UNCLAIMED_REMOVED": "<style=cShrine>Es wurde ein Deal abgeschlossen. {0} müssen ihr Erstgeburtsrecht beanspruchen.</style>",
