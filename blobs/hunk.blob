				AkSoundEngine.StopPlayingID(bgmPlayID);
			}

			public void AddAmmoFromIndex(int index, float multiplier = 1f)
			{
				if (passive.isFullArsenal)
				{
					return;
				}
				if (Object.op_Implicit((Object)(object)equippedPerkDef) && (Object)(object)equippedPerkDef == (Object)(object)Hunk.focusedAmmoPerkDef)
				{
					index = weaponTracker.equippedIndex;
				}
				if (Object.op_Implicit((Object)(object)inventory))
				{
					float num = 0.25f;
					if (MainPlugin.greenAlienHeadInstalled)
					{
						num = 0.1f;
					}
					int itemCount = inventory.GetItemCount(Items.AlienHead);
					if (itemCount > 0)
					{
						for (int i = 0; i < itemCount; i++)
						{
							multiplier = ((!MainPlugin.greenAlienHeadInstalled) ? (multiplier + num) : (multiplier + num));
						}
					}
				}
				int num2 = weaponTracker.weaponData[index].weaponDef.magSize;
				if (((Object)(object)weaponTracker.weaponData[index].weaponDef == (Object)(object)BaseWeapon<SMG>.instance.weaponDef || (Object)(object)weaponTracker.weaponData[index].weaponDef == (Object)(object)BaseWeapon<FakeSMG>.instance.weaponDef) && Object.op_Implicit((Object)(object)inventory) && inventory.GetItemCount(SMG.extendedMag) > 0)
				{
					num2 = 90;
				}
				if ((Object)(object)weaponTracker.weaponData[index].weaponDef == (Object)(object)BaseWeapon<M19>.instance.weaponDef && Object.op_Implicit((Object)(object)inventory) && inventory.GetItemCount(M19.extendedMag) > 0)
				{
					num2 = 15;
				}
				if ((Object)(object)weaponTracker.weaponData[index].weaponDef == (Object)(object)BaseWeapon<SG09>.instance.weaponDef && Object.op_Implicit((Object)(object)inventory) && inventory.GetItemCount(SG09.extendedMag) > 0)
				{
					num2 = 32;
				}
				if ((Object)(object)weaponTracker.weaponData[index].weaponDef == (Object)(object)BaseWeapon<Magnum>.instance.weaponDef && Object.op_Implicit((Object)(object)inventory) && inventory.GetItemCount(Magnum.ammoCache) > 0)
				{
					num2 = 21;
				}
				int num3 = Mathf.CeilToInt((float)num2 * multiplier * weaponTracker.weaponData[index].weaponDef.magPickupMultiplier);
				weaponTracker.weaponData[index].totalAmmo += num3;
				if (Object.op_Implicit((Object)(object)AmmoNotificationHandler.instance) && characterBody.hasEffectiveAuthority)
				{
					AmmoNotificationHandler.instance.QueueNotification(weaponTracker.weaponData[index].weaponDef, num3);
				}
				Util.PlaySound("sfx_hunk_pickup", ((Component)this).gameObject);
				if (!Object.op_Implicit((Object)(object)equippedPerkDef) || !((Object)(object)equippedPerkDef == (Object)(object)Hunk.focusedAmmoPerkDef))
				{
					return;
				}
				ModelLocator modelLocator = characterBody.modelLocator;
				if (Object.op_Implicit((Object)(object)modelLocator))
				{
					Transform modelTransform = modelLocator.modelTransform;
					if (Object.op_Implicit((Object)(object)modelTransform))
					{
						TemporaryOverlayInstance val = TemporaryOverlayManager.AddOverlay(((Component)modelTransform).gameObject);
						val.duration = 0.5f;
						val.destroyComponentOnEnd = true;
						val.originalMaterial = HunkAssets.extremeFocusOverlayMat;
						val.inspectorCharacterModel = ((Component)modelTransform).GetComponent<CharacterModel>();
						val.alphaCurve = AnimationCurve.EaseInOut(0f, 3f, 1f, 0f);
						val.animateShaderAlpha = true;
					}
				}
			}

