        "ROB_HUNK_KEYCARD_DESC": "用于打开来自<style=cIsUtility>Umbrella Corporation</style>的<color=#C80202>武器箱</color>。",
        "ROB_HUNK_KEYCARD_MASTER_DESC": "用于打开来自<style=cIsUtility>Umbrella Corporation</style>的<color=#C80202>武器箱</color>。打开<style=cIsHealing>所有箱子</style>并将其他钥匙卡变成<style=cIsUtility>废料</style>。",
        "ROB_HUNK_STARSBADGE_NAME": "S.T.A.R.S.徽章",
        "ROB_HUNK_STARSBADGE_DESC": "来自R.P.D.特种部队<color=#F20443>S.T.A.R.S.</color>的特殊徽章。<style=cIsHealth>也许捡起这个是个坏主意？</style>",
        "ROB_HUNK_STARSBADGE_DESCFULL": "每个阶段会生成一个特殊的<color=#F20443>S.T.A.R.S.</color>箱子，只能用此徽章打开。然而，<style=cIsHealth>Nemesis T-Type</style>会无情地追捕你。",
        "ROB_HUNK_STARSBADGE2_NAME": "USB加密狗钥匙",
        "ROB_HUNK_STARSBADGE2_DESC": "用于访问每个阶段的<style=cIsUtility>特殊箱子</style>。",
