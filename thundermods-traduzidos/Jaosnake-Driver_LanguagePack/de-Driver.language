        "ROB_DRIVER_BODY_PRIMARY_NEMMERC_NAME": "Spray",
        "ROB_DRIVER_BODY_PRIMARY_NEMMERC_DESCRIPTION": "Feuern Sie eine Explosion aus kurzer Distanz ab, die 6x150 % Schaden verursacht, und noch einmal, wenn Sie loslassen.</i>",
        "ROB_DRIVER_BODY_PRIMARY_NEMMANDO_SWORD_NAME": "Klinge der Beendigung",
        "ROB_DRIVER_BODY_PRIMARY_NEMMANDO_SWORD_DESCRIPTION": "<style=cIsDamage>Fugenhobeln</style>. <style=cIsUtility>Agil</style>. Zerschneide Feinde vor dir und füge ihnen 160 % Schaden zu.</i>",
        "ROB_DRIVER_BODY_PRIMARY_RAV_SLASHCOMBO_NAME": "Demontieren",
        "ROB_DRIVER_BODY_PRIMARY_RAV_SLASHCOMBO_DESCRIPTION": "Schlage nach vorne und verursache 280 % Schaden. Jeder 3. Treffer<style=cIsUtility>betäubt</style>und verursacht 560 % Schaden.</i>",
        "ROB_DRIVER_BODY_PRIMARY_ARMCANNON_NAME": "Feuer",
