			//IL_0292: Unknown result type (might be due to invalid IL or missing references)
			//IL_0297: Unknown result type (might be due to invalid IL or missing references)
			//IL_029c: Unknown result type (might be due to invalid IL or missing references)
			//IL_02a6: Expected O, but got Unknown
			SwordProjectile = (UseImpaleProjectile ? PrefabAPI.InstantiateClone(LegacyResourcesAPI.Load<GameObject>("Prefabs/Projectiles/Thermite"), "SwordProjectile", true) : PrefabAPI.InstantiateClone(LegacyResourcesAPI.Load<GameObject>("Prefabs/Projectiles/FMJ"), "SwordProjectile", true));
			GameObject val = (UseAlternateModel ? AetheriumPlugin.MainAssets.LoadAsset<GameObject>("BlasterSwordAltProjectile.prefab") : AetheriumPlugin.MainAssets.LoadAsset<GameObject>("BlasterSwordProjectile.prefab"));
			val.AddComponent<NetworkIdentity>();
			val.AddComponent<ProjectileGhostController>();
			ProjectileController component = SwordProjectile.GetComponent<ProjectileController>();
			component.procCoefficient = 0.5f;
			component.ghostPrefab = val;
			SwordProjectile.GetComponent<TeamFilter>().teamIndex = (TeamIndex)1;
			ProjectileDamage component2 = SwordProjectile.GetComponent<ProjectileDamage>();
			component2.damageType = DamageTypeCombo.op_Implicit((DamageType)4194304);
			component2.damage = 0f;
			ProjectileIntervalOverlapAttack component3 = SwordProjectile.GetComponent<ProjectileIntervalOverlapAttack>();
			Object.Destroy((Object)(object)component3);
			GameObject impactEffect = LegacyResourcesAPI.Load<GameObject>("Prefabs/Effects/ImpactEffects/VagrantCannonExplosion");
			if ((bool)UseImpaleProjectile)
			{
				ProjectileImpactExplosion component4 = SwordProjectile.GetComponent<ProjectileImpactExplosion>();
				component4.impactEffect = impactEffect;
				((ProjectileExplosion)component4).blastRadius = 2f;
				((ProjectileExplosion)component4).blastProcCoefficient = 0f;
				component4.lifetimeAfterImpact = 1.5f;
				component4.timerAfterImpact = true;
				((ProjectileExplosion)component4).blastDamageCoefficient = 1f;
				ProjectileStickOnImpact component5 = SwordProjectile.GetComponent<ProjectileStickOnImpact>();
				component5.alignNormals = false;
			}
			else
			{
				ProjectileOverlapAttack component6 = SwordProjectile.GetComponent<ProjectileOverlapAttack>();
				component6.impactEffect = impactEffect;
				ApplyTorqueOnStart val2 = SwordProjectile.AddComponent<ApplyTorqueOnStart>();
				val2.localTorque = new Vector3(0f, 1500f, 0f);
			}
			if ((bool)HomingProjectiles)
			{
				ProjectileTargetComponent targetComponent = SwordProjectile.AddComponent<ProjectileTargetComponent>();
				ProjectileDirectionalTargetFinder val3 = SwordProjectile.AddComponent<ProjectileDirectionalTargetFinder>();
				val3.lookRange = 25f;
				val3.lookCone = 20f;
				val3.targetSearchInterval = 0.1f;
				val3.onlySearchIfNoTarget = true;
				val3.allowTargetLoss = false;
				val3.testLoS = false;
				val3.ignoreAir = false;
				val3.flierAltitudeTolerance = float.PositiveInfinity;
				val3.targetComponent = targetComponent;
				ProjectileSteerTowardTarget val4 = SwordProjectile.AddComponent<ProjectileSteerTowardTarget>();
				val4.targetComponent = targetComponent;
				val4.rotationSpeed = 90f;
				val4.yAxisOnly = false;
				ProjectileSimple component7 = SwordProjectile.GetComponent<ProjectileSimple>();
				component7.enableVelocityOverLifetime = true;
				component7.updateAfterFiring = true;
				component7.velocityOverLifetime = new AnimationCurve((Keyframe[])(object)new Keyframe[2]
				{
					new Keyframe(0f, 0f),
					new Keyframe(2f, 70f)
				});
			}
			if (Object.op_Implicit((Object)(object)SwordProjectile))
			{
				PrefabAPI.RegisterNetworkPrefab(SwordProjectile);
			}
			ContentAddition.AddProjectile(SwordProjectile);
		}

