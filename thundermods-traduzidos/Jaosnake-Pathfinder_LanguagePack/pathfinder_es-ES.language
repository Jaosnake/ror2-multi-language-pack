{
    "es-ES": {
        "BOG_PATHFINDER_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_NAME": "Pathfinder: Mastery",
        "BOG_PATHFINDER_BODY_NAME": "Pionero",
        "BOG_PATHFINDER_BODY_SUBTITLE": "Cazador interplanetario",
        "BOG_PATHFINDER_BODY_DESCRIPTION": "Pathfinder es un hostigador astuto y evasivo que lucha junto a su halcón robótico, Squall.",
        "BOG_PATHFINDER_BODY_PASSIVE_NAME": "Halconero",
        "BOG_PATHFINDER_BODY_PASSIVE_DESCRIPTION": "Te acompaña tu halcón robótico, Squall. Squall hereda <style=cIsDamage>la mayoría de</style> de tus artículos y es inmune al daño, pero funciona con una <style=cIsUtility>batería</style>.",
        "BOG_PATHFINDER_BODY_DEFAULT_SKIN_NAME": "Por defecto",
        "BOG_PATHFINDER_BODY_MASTERY_SKIN_NAME": "cazador de cabezas",
        "BOG_PATHFINDER_BODY_OUTRO_FLAVOR": "..y así se fueron, como los nuevos reyes de la cadena alimentaria.",
        "BOG_PATHFINDER_BODY_OUTRO_FAILURE": "...y así desaparecieron, perdidos para siempre en la indiferente naturaleza.",
        "BOG_SQUALL_BODY_NAME": "Chubasco",
        "BOG_SQUALL_BODY_DEFAULT_SKIN_NAME": "Por defecto",
        "BOG_SQUALL_BODY_MASTERY_SKIN_NAME": "Maestría",
        "PRIMARY_THRUST_NAME": "Empuje",
        "PRIMARY_THRUST_DESCRIPTION": "<style=cIsUtility>Piercing</style>. Empuja tu lanza hacia adelante para causar <style=cIsDamage>250% de daño</style>.",
        "SECONDARY_DASH_NAME": "Pie ligero",
        "SECONDARY_DASH_DESCRIPTION": "<style=cIsUtility>Deslice</style> una distancia corta. La próxima vez que uses tu habilidad principal, lanza una <style=cIsDamage>lanza explosiva</style> para <style=cIsDamage>800% de daño</style> y recupera <style=cIsUtility>800% de batería</style>, duplicado en golpes críticos.",
        "SECONDARY_JAVELIN_NAME": "Lanzamiento de lanza",
        "SECONDARY_JAVELIN_DESCRIPTION": "Lanza una <style=cIsDamage>lanza explosiva</style> para <style=cIsDamage>800% de daño</style>.",
        "UTILITY_SPIN_NAME": "Garras desgarradoras",
        "UTILITY_SPIN_DESCRIPTION": "Elévate en el aire y gira rápidamente para causar <style=cIsDamage>300% de daño</style>. Al aterrizar, realiza un barrido horizontal para causar <style=cIsDamage>800% de daño</style>.",
        "UTILITY_BOLAS_NAME": "bolas de choque",
        "UTILITY_BOLAS_DESCRIPTION": "Lanza bolas cargadas eléctricamente que <style=cIsUtility>chocan a</style> a los enemigos cercanos y dejan un campo <style=cIsUtility>electrocutador</style> durante <style=cIsUtility>10 segundos</style>.",
        "SPECIAL_COMMAND_NAME": "Comando de emisión",
        "SPECIAL_COMMAND_DESCRIPTION": "Prepara un comando para Squall. Puedes emitir un comando <color=#FF0000>Attack</color>, <color=#00FF00>Follow</color> o <color=#efeb1c>Special</color> presionando las teclas de habilidad primaria, secundaria o especial respectivamente.",
        "SPECIAL_COMMAND2_NAME": "Comando de emisión: anulación de utilidad",
        "SPECIAL_ATTACK_NAME": "Ataque",
        "SPECIAL_ATTACK_DESCRIPTION": "Dirige la atención de Squall al enemigo objetivo y activa <color=#FF0000>Modo de ataque</color>, otorgando acceso a ametralladoras que causan <style=cIsDamage>2x30% de daño</style> y un lanzador de misiles que causa <style=cIsDamage>150% de daño</style>.",
        "SPECIAL_FOLLOW_NAME": "Seguir",
        "SPECIAL_FOLLOW_DESCRIPTION": "Vuelve a acercar a Squall y activa <color=#00FF00>Modo de seguimiento</color>, lo que hará que permanezca cerca de ti.",
        "SPECIAL_CANCEL_NAME": "Cancelar modo de comando",
        "SPECIAL_CANCEL_DESCRIPTION": "Cancela el modo de comando.",
        "SQUALL_SPECIAL_GOFORTHROAT_NAME": "¡Ve por la garganta!",
        "SQUALL_SPECIAL_GOFORTHROAT_DESCRIPTION": "Ordena a Squall que ataque repetidamente al enemigo objetivo e inflija <style=cIsDamage>70% de daño</style>. Cada ataque reduce brevemente <style=cIsDamage>armadura</style> y <style=cIsUtility>regenera 1%</style> batería, duplicada en golpes críticos. Esta habilidad puede <style=cIsUtility>sobrecargar brevemente</style> la batería.",
        "BOG_PATHFINDER_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_DESC": "Como Pathfinder, completa el juego o aniquila en Monsoon.",
