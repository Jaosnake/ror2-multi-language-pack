{
    "en": {
        "BOG_DEPUTY_BODY_NAME": "The Deputy",
        "BOG_DEPUTY_BODY_DESCRIPTION": "The Deputy is a hyperaggressive speed demon who dispenses justice with her twin revolvers and lethal kicks. <i>Backported from pt-BR. Translated by: Jaosnake</i>",
        "BOG_DEPUTY_BODY_SUBTITLE": "Lightning Justice",
        "BOG_DEPUTY_BODY_OUTRO_FLAVOR": "..and so she left, to the sound of thunderous applause.",
