        "HABIBI_CHRONO_SPECIAL_VANISH_DRIVER_NAME": "Desvanecer do Motorista",
        "HABIBI_CHRONO_SPECIAL_VANISH_DRIVER_DESCRIPTION": "Desvaneça com poder adicional.\n\n",
