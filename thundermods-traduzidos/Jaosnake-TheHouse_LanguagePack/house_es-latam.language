        "JAVANGLE_HOUSE_JOKER_NAME": "Comodín",
        "JAVANGLE_HOUSE_JOKER_DESCRIPTION": "Activa aleatoriamente el efecto de otra <style=cArtifact>Tarjeta Morada</style>. 20% de probabilidad de activar <style=cArtifact>todos a la vez</style>.",
        "JAVANGLE_HOUSE_7JACK_NAME": "Sota de diamantes",
        "JAVANGLE_HOUSE_7JACK_DESCRIPTION": "Carga 6 disparos estándar.\nSi está en el suelo: deslícese hacia adelante.",
        "JAVANGLE_HOUSE_7QUEEN_NAME": "Reina de corazones",
