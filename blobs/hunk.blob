				{
					((Component)weaponRenderer).gameObject.SetActive(false);
					if (Object.op_Implicit((Object)(object)heldWeaponInstance))
					{
						Object.Destroy((Object)(object)heldWeaponInstance);
					}
					GameObject weaponModelPrefab = GetWeaponModelPrefab(weaponDef);
					if ((!Object.op_Implicit((Object)(object)inventory) || inventory.GetItemCount(Items.LunarSecondaryReplacement) <= 0) && Object.op_Implicit((Object)(object)weaponModelPrefab))
					{
						string text = "Weapon";
						if (weaponDef.nameToken.Contains("SHIELD"))
						{
							text = "ShieldBase";
						}
						heldWeaponInstance = Object.Instantiate<GameObject>(weaponModelPrefab);
						heldWeaponInstance.transform.parent = childLocator.FindChild(text);
						heldWeaponInstance.transform.localPosition = Vector3.zero;
						heldWeaponInstance.transform.localRotation = Quaternion.identity;
						heldWeaponInstance.transform.localScale = Vector3.one;
					}
				}
				else
				{
					((Component)weaponRenderer).gameObject.SetActive(true);
					if (Object.op_Implicit((Object)(object)heldWeaponInstance))
					{
						Object.Destroy((Object)(object)heldWeaponInstance);
					}
				}
				if (Object.op_Implicit((Object)(object)inventory) && inventory.GetItemCount(Items.LunarSecondaryReplacement) > 0 && Object.op_Implicit((Object)(object)heldWeaponInstance))
				{
					Object.Destroy((Object)(object)heldWeaponInstance);
				}
				crosshairPrefab = weaponDef.crosshairPrefab;
				characterBody._defaultCrosshairPrefab = crosshairPrefab;
				((Component)childLocator.FindChild("KnifeModel")).gameObject.SetActive(false);
				HandleAnimationLayer();
				HandleBackWeapon();
				if (onWeaponUpdate != null)
				{
					onWeaponUpdate(this);
				}
			}

			public void HandleAnimationLayer()
			{
				ToggleLayer("Body (Pistol)", toEnable: false);
				ToggleLayer("Gesture (Pistol)", toEnable: false);
				ToggleLayer("FullBody (Pistol)", toEnable: false);
				ToggleLayer("Body (Pistol2)", toEnable: false);
				ToggleLayer("Gesture (Pistol2)", toEnable: false);
				ToggleLayer("FullBody (Pistol2)", toEnable: false);
				ToggleLayer("Gesture (Grenade)", toEnable: false);
				ToggleLayer("Body (Rocket)", toEnable: false);
				ToggleLayer("Gesture (Rocket)", toEnable: false);
				ToggleLayer("FullBody (Rocket)", toEnable: false);
				ToggleLayer("Body (Railgun)", toEnable: false);
				ToggleLayer("Gesture (Railgun)", toEnable: false);
				ToggleLayer("FullBody (Railgun)", toEnable: false);
				ToggleLayer("Body (Jacket)", toEnable: false);
				ToggleLayer("Gesture (Jacket)", toEnable: false);
				ToggleLayer("FullBody (Jacket)", toEnable: false);
				ToggleLayer("Gesture (Shield)", toEnable: false);
				if ((Object.op_Implicit((Object)(object)inventory) && inventory.GetItemCountEffective(Items.LunarSecondaryReplacement) > 0) || knifeOutTimer > 0f || weaponTracker.weaponData.Length == 0)
				{
					ToggleLayer("Body (Pistol2)", toEnable: true);
					ToggleLayer("Gesture (Pistol2)", toEnable: true);
					ToggleLayer("FullBody (Pistol2)", toEnable: true);
					return;
				}
				switch (weaponDef.animationSet)
				{
				case HunkWeaponDef.AnimationSet.Pistol:
					ToggleLayer("Body (Pistol)", toEnable: true);
					ToggleLayer("Gesture (Pistol)", toEnable: true);
					ToggleLayer("FullBody (Pistol)", toEnable: true);
					break;
				case HunkWeaponDef.AnimationSet.PistolAlt:
					ToggleLayer("Body (Pistol2)", toEnable: true);
					ToggleLayer("Gesture (Pistol2)", toEnable: true);
					ToggleLayer("FullBody (Pistol2)", toEnable: true);
					break;
				case HunkWeaponDef.AnimationSet.Rocket:
					ToggleLayer("Body (Rocket)", toEnable: true);
					if (weaponDef.nameToken.Contains("SHIELD"))
					{
						ToggleLayer("Gesture (Shield)", toEnable: true);
					}
					else
					{
						ToggleLayer("Gesture (Rocket)", toEnable: true);
					}
					ToggleLayer("FullBody (Rocket)", toEnable: true);
					break;
				case HunkWeaponDef.AnimationSet.Throwable:
					ToggleLayer("Body (Pistol2)", toEnable: true);
					ToggleLayer("Gesture (Grenade)", toEnable: true);
					ToggleLayer("FullBody (Pistol2)", toEnable: true);
					break;
				case HunkWeaponDef.AnimationSet.Railgun:
					ToggleLayer("Body (Railgun)", toEnable: true);
					ToggleLayer("Gesture (Railgun)", toEnable: true);
					ToggleLayer("FullBody (Railgun)", toEnable: true);
					break;
				case HunkWeaponDef.AnimationSet.Jacket:
					if (Object.op_Implicit((Object)(object)variant))
					{
						ToggleLayer("Body (Jacket)", toEnable: true);
						ToggleLayer("Gesture (Jacket)", toEnable: true);
						ToggleLayer("FullBody (Jacket)", toEnable: true);
						((Component)childLocator.FindChild("KnifeModel")).gameObject.SetActive(true);
					}
					else
					{
						ToggleLayer("Body (Pistol)", toEnable: true);
						ToggleLayer("Gesture (Pistol)", toEnable: true);
						ToggleLayer("FullBody (Pistol)", toEnable: true);
					}
					break;
				case HunkWeaponDef.AnimationSet.SMG:
				case HunkWeaponDef.AnimationSet.Unarmed:
					break;
				}
			}

			public GameObject GetWeaponModelPrefab(HunkWeaponDef _weaponDef)
			{
				if (!Object.op_Implicit((Object)(object)_weaponDef))
				{
					return null;
				}
				if (Hunk.gunSkins.Count > 0 && Object.op_Implicit((Object)(object)modelSkinController))
