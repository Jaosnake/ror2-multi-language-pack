namespace RA2Mod.Survivors.Tesla.SkillDefs
{
	public class TeslaTrackingResettingSkillDef : SkillDef
	{
		protected class InstanceData : BaseSkillInstanceData
		{
			public TeslaTrackerComponentDash teslaTracker;

			public float timeoutTimer;

			public bool hasExtraStock;
		}

		public float timeoutDuration = 3f;

		public Sprite refreshedIcon;

		public override BaseSkillInstanceData OnAssigned([NotNull] GenericSkill skillSlot)
		{
			return (BaseSkillInstanceData)(object)new InstanceData
			{
				teslaTracker = ((Component)skillSlot).GetComponent<TeslaTrackerComponentDash>()
			};
		}

		private static bool HasTarget([NotNull] GenericSkill skillSlot)
		{
			HurtBox val = ((InstanceData)(object)skillSlot.skillInstanceData).teslaTracker?.GetTrackingTarget();
			return (Object)(object)val != (Object)null;
		}

		public override bool IsReady([NotNull] GenericSkill skillSlot)
		{
			if (((SkillDef)this).IsReady(skillSlot))
			{
				return HasTarget(skillSlot);
			}
			return false;
		}

		public override bool CanExecute([NotNull] GenericSkill skillSlot)
		{
			if (HasTarget(skillSlot))
			{
				return ((SkillDef)this).CanExecute(skillSlot);
			}
			return false;
		}

		public override void OnExecute([NotNull] GenericSkill skillSlot)
		{
			((SkillDef)this).OnExecute(skillSlot);
			InstanceData instanceData = (InstanceData)(object)skillSlot.skillInstanceData;
			int stock = skillSlot.stock;
			skillSlot.stock = stock + 1;
			instanceData.hasExtraStock = true;
			instanceData.timeoutTimer = timeoutDuration;
		}

		public override void OnFixedUpdate([NotNull] GenericSkill skillSlot, float deltaTime)
		{
			((SkillDef)this).OnFixedUpdate(skillSlot, deltaTime);
			InstanceData instanceData = (InstanceData)(object)skillSlot.skillInstanceData;
			((InstanceData)(object)skillSlot.skillInstanceData).teslaTracker.SetIsSkillReady(((SkillDef)this).IsReady(skillSlot));
			instanceData.timeoutTimer -= deltaTime;
			if (instanceData.timeoutTimer <= 0f && instanceData.hasExtraStock)
			{
				int stock = skillSlot.stock;
				skillSlot.stock = stock - 1;
				instanceData.hasExtraStock = false;
			}
		}

		public override Sprite GetCurrentIcon([NotNull] GenericSkill skillSlot)
		{
			if (!((InstanceData)(object)skillSlot.skillInstanceData).hasExtraStock)
			{
				return base.icon;
			}
			return refreshedIcon;
		}
	}
