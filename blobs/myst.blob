					val.purchaseInteraction = new PurchaseInteraction();
					val.costTypeDef = CostTypeCatalog.GetCostTypeDef((CostTypeIndex)4);
					val.cost = 2;
					val.rng = new Xoroshiro128Plus(Run.instance.treasureRng.nextUlong);
					PayCostResults val2 = default(PayCostResults);
					((BasePool<PayCostResults>)(object)PayCostResults.pool).Request(ref val2);
					CostTypeCatalog.GetCostTypeDef((CostTypeIndex)4).PayCost(val, val2);
					break;
				}
				case 4:
				case 5:
				case 6:
					characterBody.master.inventory.RemoveItemPermanent(MagiciteDust.itemDef, 5);
					break;
				case 7:
					characterBody.master.inventory.RemoveItemPermanent(MagiciteDust.itemDef, 10);
					break;
				}
			}
		}

