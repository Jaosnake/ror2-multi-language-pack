		private static RendererInfo[] SkinRendererInfos(RendererInfo[] defaultRenderers, Material[] materials)
		{
			RendererInfo[] array = (RendererInfo[])(object)new RendererInfo[defaultRenderers.Length];
			defaultRenderers.CopyTo(array, 0);
			for (int i = 0; i < materials.Length; i++)
			{
				if (!((Object)(object)materials[i] == (Object)null))
				{
					switch (i)
					{
					case 0:
					case 1:
						array[i].defaultMaterial = materials[i];
						break;
					case 2:
						array[SurvivorBase.instance.mainRendererIndex].defaultMaterial = materials[i];
						break;
					case 3:
						array[4].defaultMaterial = materials[i];
						break;
					case 4:
						array[9].defaultMaterial = materials[i];
						break;
					}
				}
			}
			return array;
		}

		internal static void HUDAwake(orig_Awake orig, HUD self)
		{
			//IL_005e: Unknown result type (might be due to invalid IL or missing references)
			//IL_0079: Unknown result type (might be due to invalid IL or missing references)
			//IL_007e: Unknown result type (might be due to invalid IL or missing references)
			//IL_009e: Unknown result type (might be due to invalid IL or missing references)
			orig.Invoke(self);
			FuryHUD furyHUD = ((Component)self).gameObject.AddComponent<FuryHUD>();
			GameObject val = Object.Instantiate<GameObject>(Asset.mainAssetBundle.LoadAsset<GameObject>("FuryGauge"), ((Component)self).transform.Find("MainContainer").Find("MainUIArea").Find("SpringCanvas")
				.Find("BottomLeftCluster"));
			((Transform)val.GetComponent<RectTransform>()).localPosition = Vector3.zero;
			val.GetComponent<RectTransform>().anchoredPosition = Vector2.op_Implicit(new Vector3(0f, -147.8f));
			((Transform)val.GetComponent<RectTransform>()).localScale = new Vector3(0.72f, 0.15f, 1f);
			furyHUD.furyGauge = val;
			furyHUD.furyFill = ((Component)val.transform.Find("GaugeFill")).gameObject.GetComponent<Image>();
		}
	}
	internal class SimpleCharacter : SurvivorBase
	{
		internal static Material henryMat = Asset.CreateMaterial("matHenry");

		private static UnlockableDef masterySkinUnlockableDef;

		internal override string bodyName { get; set; } = "HenrySimple";


		internal override GameObject bodyPrefab { get; set; }

		internal override GameObject displayPrefab { get; set; }

		internal override ConfigEntry<bool> characterEnabled { get; set; }

		internal override BodyInfo bodyInfo { get; set; } = new BodyInfo
		{
			armor = 20f,
			armorGrowth = 0f,
			bodyName = SurvivorBase.instance.bodyName + "Body",
			bodyNameToken = "ROB_HENRY_BODY_NAME",
			bodyColor = Color.grey,
			characterPortrait = Asset.LoadCharacterIcon("Henry"),
			crosshair = Asset.LoadCrosshair("Standard"),
			damage = 12f,
			healthGrowth = 33f,
			healthRegen = 1.5f,
			jumpCount = 1,
			maxHealth = 110f,
			subtitleNameToken = "ROB_HENRY_BODY_SUBTITLE",
			podPrefab = Resources.Load<GameObject>("Prefabs/NetworkedObjects/SurvivorPod")
		};


		internal override int mainRendererIndex { get; set; } = 2;


		internal override CustomRendererInfo[] customRendererInfos { get; set; } = new CustomRendererInfo[3]
		{
			new CustomRendererInfo
			{
				childName = "SwordModel",
				material = henryMat
			},
			new CustomRendererInfo
			{
				childName = "GunModel",
				material = henryMat
			},
			new CustomRendererInfo
			{
				childName = "Model",
				material = henryMat
			}
		};


		internal override Type characterMainState { get; set; } = typeof(GenericCharacterMain);


		internal override ItemDisplayRuleSet itemDisplayRuleSet { get; set; }

		internal override List<KeyAssetRuleGroup> itemDisplayRules { get; set; }

		internal override UnlockableDef characterUnlockableDef { get; set; }

		internal override void InitializeUnlockables()
		{
			characterUnlockableDef = Content.CreateAndAddUnlockbleDef("ROB_HENRY_BODY_UNLOCKABLE_REWARD_ID", Tokens.GetAchievementNameToken("ROB_HENRY_BODY_UNLOCKABLE_ACHIEVEMENT_ID"), Asset.mainAssetBundle.LoadAsset<Sprite>("texHenryAchievement"));
		}

		private static void CreateDoppelganger()
		{
			Prefabs.CreateGenericDoppelganger(SurvivorBase.instance.bodyPrefab, "HenryMonsterMaster", "Merc");
		}

		internal override void InitializeHitboxes()
		{
			ChildLocator componentInChildren = bodyPrefab.GetComponentInChildren<ChildLocator>();
			GameObject gameObject = ((Component)componentInChildren).gameObject;
			Transform hitboxTransform = componentInChildren.FindChild("SwordHitbox");
			Prefabs.SetupHitbox(gameObject, hitboxTransform, "Sword");
			hitboxTransform = componentInChildren.FindChild("PunchHitbox");
			Prefabs.SetupHitbox(gameObject, hitboxTransform, "Punch");
		}

		internal override void InitializeSkills()
		{
			//IL_002e: Unknown result type (might be due to invalid IL or missing references)
			//IL_00c9: Unknown result type (might be due to invalid IL or missing references)
