			//IL_01ff: Unknown result type (might be due to invalid IL or missing references)
			//IL_020c: Expected O, but got Unknown
			if (!vfxBeenAssigned)
			{
				buffOnEffect = lightningController.buffOnVFX;
				overlayMat = lightningController.buffOverlayMat;
				buffOffEffect = lightningController.buffOffVFX;
				if (lightningController.isBlue && !Config.NemOriginPurpleLightning.Value)
				{
					sparkEffect = childLocator.FindChild("BuffLightningBlue");
				}
				else
				{
					sparkEffect = childLocator.FindChild("BuffLightning");
				}
				vfxBeenAssigned = true;
			}
