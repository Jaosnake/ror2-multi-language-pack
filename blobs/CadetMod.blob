	public class FireEcho : BaseCadetSkillState
	{
		private float duration = 1.25f;

		private bool hasFired2;

		private GameObject projectilePrefab = CadetAssets.echoDrones;

		public override void OnEnter()
		{
			RefreshState();
			base.OnEnter();
			((EntityState)this).PlayCrossfade("Gesture, Override", "Special", 0.05f);
			Util.PlaySound("sfx_driver_prep_nuke", ((EntityState)this).gameObject);
		}

		public override void FixedUpdate()
		{
			base.FixedUpdate();
			if (((EntityState)this).fixedAge > duration / 2f && !hasFired2)
			{
				hasFired2 = true;
				Fire();
			}
			if (((EntityState)this).fixedAge >= duration)
			{
				Fire();
				((EntityState)this).outer.SetNextStateToMain();
			}
		}

