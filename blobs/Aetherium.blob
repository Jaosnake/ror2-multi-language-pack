		private void CreateNetworking()
		{
			NetworkingAPI.RegisterMessageType<SyncBleedPool>();
		}

		private void CreateConfig(ConfigFile config)
		{
			BaseDamageSpreadPercentage = config.ActiveBind("Item: " + ItemName, "Base Damage Spread", 0.25f, "Percentage of damage to delay.");
			AdditionalDamageSpreadPercentage = config.ActiveBind("Item: " + ItemName, "Spread Per Stack", 0.25f, "Hyperbolic scaling per stack.");
			MaxDamageSpreadPercentage = config.ActiveBind("Item: " + ItemName, "Max Spread Cap", 0.75f, "Hard cap on percentage delayed.");
			DurationOfDamageSpread = config.ActiveBind("Item: " + ItemName, "Spread Duration", 5f, "Seconds to spread damage over.");
			SharkTeethIsNonLethal = config.ActiveBind("Item: " + ItemName, "Non-Lethal Bleed", defaultValue: false, "If true, bleed ticks cannot kill you (leaves you at 1 HP).");
			EnableCleanseOnHit = config.ActiveBind("Item: " + ItemName, "Berserker Mode (Cleanse on Hit)", defaultValue: true, "If true, dealing damage reduces your stored bleed amount. Distinguishes this item from Warped Echo.");
			CleansePercentage = config.ActiveBind("Item: " + ItemName, "Cleanse Percentage", 0.1f, "Percentage of stored bleed removed when you deal damage.");
		}

