        "JAVANGLE_HOUSE_7HEARTS_DESCRIPTION": "<style=cIsHealing>Cura el 50% de tu salud máxima</style> y <style=cIsUtility>gana hasta un 50% de Barrera</style> dependiendo de la salud actual.",
        "JAVANGLE_HOUSE_JACKPOT_NAME": "Bote",
