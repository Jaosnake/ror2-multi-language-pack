			}
			else if (moveStrength > 0)
			{
				if (moveStrength >= 3)
				{
					bulletController.GrantColouredBullet(BulletController.BulletType.YELLOW);
				}
				((EntityState)this).outer.SetInterruptState((EntityState)(object)new YellowOrb
				{
					moveStrength = moveStrength
				}, (InterruptPriority)2);
			}
			else
			{
				((EntityState)this).PlayAnimation("Body", "BufferEmpty");
				((EntityState)this).outer.SetNextStateToMain();
			}
		}

