			int num = (int)(Driver_M2_Duration.Value / Driver_M2_TickInterval.Value);
			Language.Add("HABIBI_CHRONO_SPECIAL_VANISH_DRIVER_NAME", "Deconstructing");
			Language.Add("HABIBI_CHRONO_SPECIAL_VANISH_DRIVER_DESCRIPTION", "Focus your rifle for up to " + Tokens.DamageValueText(Driver_M2_Damage.Value * (float)num) + ". An enemy below the " + Tokens.UtilityText("Chrono Sickness") + " threshold will vanish from existence.");
		}
