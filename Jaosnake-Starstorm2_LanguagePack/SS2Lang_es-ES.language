        "SS2_DRONE_CLONE_INTERACTABLE_NAME": "Drone duplicador roto",
        "SS2_DRONE_CLONE_INTERACTABLE_CONTEXT": "Reparación de drones duplicadores",
        "SS2_DRONE_CLONE_PICKUP": "Ocasionalmente, <style=cIsUtility>duplica </style> elementos cercanos.",
        "SS2_DRONE_CLONE_DESCRIPTION": "Un compañero comprado con oro que seguirá de cerca al superviviente. <style=cIsUtility>Duplica </style> recogidas de artículos cercanos.",
        "SS2_DRONE_CLONE_SKILL_DESCRIPTION": "Canales en un elemento cercano. Al finalizar, crea un <style=cIsUtility>duplicado</style> del artículo.",
        "SS2_DRONE_CLONE_COMMAND_DESCRIPTION": "",
        "SS2_DROIDDRONE_NAME": "Dron de seguridad",
        "SS2_DROIDDRONE_PICKUP": "Dispara a los enemigos cercanos. <style=cIsUtility>Hereda el tipo de élite </style> de la élite asesinada.",
        "SS2_DROIDDRONE_DESCRIPTION": "Un compañero temporal creado al sostener Droid Head y matar a las élites que seguirán al sobreviviente a corta distancia, disparando a los enemigos cercanos.",
