		public static ConfigEntry<bool> VoiceOnSpawn;

		public static ConfigEntry<bool> VoiceOnDeath;

		public static ConfigEntry<bool> RA2Icon;

		public static ConfigEntry<bool> TeslaEnabled;

		public static ConfigEntry<bool> DesolatorEnabled;

		public static ConfigEntry<bool> ChronoEnabled;

		public static ConfigEntry<bool> ConscriptEnabled;

		public static ConfigEntry<bool> GIEnabled;

		public static ConfigEntry<bool> MCVEnabled;

		public static ConfigEntry<KeyboardShortcut> RestKeybind { get; private set; }

		public static ConfigEntry<KeyboardShortcut> VoiceKey { get; private set; }

		public static void Init()
		{
			//IL_0061: Unknown result type (might be due to invalid IL or missing references)
			//IL_009d: Unknown result type (might be due to invalid IL or missing references)
			string text = "0-0. General";
			Debug = ((BaseUnityPlugin)RA2Plugin.instance).Config.Bind<bool>(text, "Debug Logs", false, "In case I forget to remove something");
			NewColor = Config.BindAndOptions(text, "New Color (s?)", defaultValue: false, "add black for the wife", restartRequired: true);
			Cursed = Config.BindAndOptions(text, "Cursed", defaultValue: false, "Enables extra/wip content\nyes there's a minecraft skin", restartRequired: true);
			RestKeybind = Config.BindAndOptions<KeyboardShortcut>(text, "Rest Key", new KeyboardShortcut((KeyCode)49, Array.Empty<KeyCode>()), "key to play Rest emote");
			ClassicSounds = Config.BindAndOptions(text, "Classic Sounds", defaultValue: false, "Plays classic Red Alert 2 sounds instead of the updated ones, where applicable (currently only Desolator)");
			VoiceKey = Config.BindAndOptions<KeyboardShortcut>(text, "Voice Line Key", new KeyboardShortcut((KeyCode)301, Array.Empty<KeyCode>()), "key to play voice lines from Red Alert 2");
			VoiceInLobby = Config.BindAndOptions(text, "Voice Line In Lobby", defaultValue: false, "For the Red Alert 2 fans out there");
			RA2Icon = Config.BindAndOptions(text, "red alert 2 icon", defaultValue: false, "Changes character icon to the unit icon from Red Alert 2", restartRequired: true);
			string text2 = "0-1. Survivors";
			TeslaEnabled = Config.CharacterEnableConfig(text2, "Tesla Trooper");
			DesolatorEnabled = Config.CharacterEnableConfig(text2, "Desolator");
			ChronoEnabled = Config.CharacterEnableConfig(text2, "Chrono Legionnaire", "multiplayer ready and everything. just needs polish, and some maybe kit reworks. feedback welcome!");
			ConscriptEnabled = Config.CharacterEnableConfig(text2, "Conscript Beta", "Skills Functional and networked. Model is rad but no animations. Missing a polish, but I believe he's good to play, gameplay-wise.", enabledByDefault: false);
			GIEnabled = Config.CharacterEnableConfig(text2, "GI Alpha", "All skills perfactly functional in multiplayer and everything, just needs visuals. reach out and give feedback!", enabledByDefault: false);
			MCVEnabled = ((BaseUnityPlugin)RA2Plugin.instance).Config.Bind<bool>(text2, "MCV Test", false, "We're getting stupid now");
		}
	}
