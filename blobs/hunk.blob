						val.localPosition = new Vector3(-0.5f, 2.98f, 0.87f);
						val.localScale = Vector3.one * 1.25f;
					}
				}
				if ((Object)(object)itemDef == (Object)(object)BaseWeapon<Slugger>.instance.itemDef)
				{
					Highlight component2 = ((Component)this).GetComponent<Highlight>();
					if (Object.op_Implicit((Object)(object)component2))
					{
						Transform val2 = ((Component)component2.targetRenderer).transform.parent.parent.parent.Find("WeaponHolder");
						val2.localPosition = new Vector3(0.6f, 2.98f, -0.16f);
					}
				}
				if ((Object)(object)purchaseInteraction != (Object)null)
				{
					purchaseInteraction.displayNameToken = string.Format("{0}{1}", Language.GetStringFormatted("ROB_HUNK_CHEST_NAME", Array.Empty<object>()), Language.GetStringFormatted(itemDef.nameToken, Array.Empty<object>()));
					purchaseInteraction.contextToken = "ROB_HUNK_CHEST_CONTEXT";
					if (shouldSpawnRocketLauncher)
					{
						purchaseInteraction.costType = (CostTypeIndex)0;
					}
					if (shouldSpawnShield)
					{
						purchaseInteraction.costType = (CostTypeIndex)0;
					}
				}
				gunPickup.Init();
				SetChestType(chestType);
				Hunk.discoveredWeapons.Add(itemDef);
			}

			private void AddToPool(ItemDef itemDef)
