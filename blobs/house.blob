		private void MultiplayerEffects()
		{
			switch (passiveManager.random.Next(4))
			{
			default:
				Debug.LogError((object)"[HouseError] Tower result was ouside the bounds of the list");
				break;
			case 0:
				PermaPolymorph();
				break;
			case 1:
				PermaNoHeal();
				break;
			case 2:
				TonicAfflictor();
				break;
			case 3:
				TowerHappyFunTimes();
				break;
			}
		}

		private void PermaPolymorph()
		{
			string text = passiveManager.random.Next(3) switch
			{
				0 => "GipBody", 
				1 => "LemurianBody", 
				2 => "HermitCrabBody", 
				_ => "GipBody", 
			};
			Debug.Log((object)("[HouseMessage] transforming to: " + text));
			((EntityState)this).characterBody.master.TransformBody(text);
			((EntityState)this).characterBody.master.bodyPrefab = HouseMod.Modules.Survivors.House.characterPrefab;
			PolymorphBuffComponent val = ((Component)((EntityState)this).characterBody.master).gameObject.AddComponent<PolymorphBuffComponent>();
			val.master = ((EntityState)this).characterBody.master;
			val.buffDuration = 120f;
		}

		private void PermaNoHeal()
		{
			((EntityState)this).characterBody.AddTimedBuff(Buffs.HealingDisabled, 120f);
			((EntityState)this).characterBody.AddTimedBuff(Buffs.Weak, 120f);
		}

		private void TonicAfflictor()
		{
			for (int num = 120; num > 0; num--)
			{
				((EntityState)this).characterBody.AddTimedBuff(Buffs.PermanentCurse, 120f);
			}
			for (int num2 = 10; num2 > 0; num2--)
			{
				((EntityState)this).characterBody.AddTimedBuff(Buffs.BeetleJuice, 120f);
			}
		}

		private void TowerHappyFunTimes()
		{
			//IL_003a: Unknown result type (might be due to invalid IL or missing references)
			//IL_0040: Unknown result type (might be due to invalid IL or missing references)
			if (!Object.op_Implicit((Object)(object)((EntityState)this).characterBody.healthComponent))
			{
				Debug.LogError((object)"[HouseError] TowerHappyFunTimes could not find HealthComponent");
			}
			else
			{
				((EntityState)this).characterBody.healthComponent.Suicide(((EntityState)this).gameObject, (GameObject)null, default(DamageTypeCombo));
			}
		}

