			//IL_006a: Unknown result type (might be due to invalid IL or missing references)
			//IL_006d: Invalid comparison between Unknown and I4
			//IL_007e: Unknown result type (might be due to invalid IL or missing references)
			ValidBossIndices.Clear();
			foreach (GameObject allBodyPrefab in BodyCatalog.allBodyPrefabs)
			{
				if (!Object.op_Implicit((Object)(object)allBodyPrefab))
				{
					continue;
				}
				string prefabName = ((Object)allBodyPrefab).name;
				if (RouteEnderBossNames.Any((string target) => prefabName.Contains(target)))
				{
					BodyIndex val = BodyCatalog.FindBodyIndex(allBodyPrefab);
					if ((int)val != -1)
					{
						ValidBossIndices.Add(val);
					}
				}
			}
			ValidEliteDefs.Clear();
			if (BlacklistedAffixesString != null && !string.IsNullOrWhiteSpace(BlacklistedAffixesString.ToString()))
			{
				string[] array = BlacklistedAffixesString.ToString().Split(',');
				string[] array2 = array;
				foreach (string text in array2)
				{
					BlacklistedAffixes.Add(text.Trim());
				}
			}
			EliteDef[] eliteDefs = EliteCatalog.eliteDefs;
			foreach (EliteDef val2 in eliteDefs)
			{
				if (Object.op_Implicit((Object)(object)val2.eliteEquipmentDef) && Object.op_Implicit((Object)(object)val2.eliteEquipmentDef.passiveBuffDef) && !BlacklistedAffixes.Contains(((Object)val2).name) && !BlacklistedAffixes.Contains(((Object)val2.eliteEquipmentDef).name) && !BlacklistedAffixes.Contains(((Object)val2.eliteEquipmentDef.passiveBuffDef).name))
				{
					ValidEliteDefs.Add(val2);
				}
			}
		}

		private void GiveBossEliteAffix(orig_OnBodyStart orig, CharacterMaster self, CharacterBody body)
		{
			//IL_0051: Unknown result type (might be due to invalid IL or missing references)
			//IL_00e5: Unknown result type (might be due to invalid IL or missing references)
			orig.Invoke(self, body);
			if (!NetworkServer.active || !base.ArtifactEnabled || !Object.op_Implicit((Object)(object)body) || !ValidBossIndices.Contains(body.bodyIndex) || ValidEliteDefs.Count == 0)
			{
				return;
			}
			List<EliteDef> list = ValidEliteDefs.Where((EliteDef x) => !body.HasBuff(x.eliteEquipmentDef.passiveBuffDef)).ToList();
			Util.ShuffleList<EliteDef>(list, Run.instance.stageRng);
			int num = NumberOfEliteAffixesToGiveMithrix;
			for (int i = 0; i < num && i < list.Count; i++)
			{
				EliteDef val = list[i];
				if (i == 0)
				{
					body.inventory.SetEquipmentIndex(val.eliteEquipmentDef.equipmentIndex, false);
				}
				else
				{
					body.AddBuff(val.eliteEquipmentDef.passiveBuffDef);
				}
			}
		}
	}
