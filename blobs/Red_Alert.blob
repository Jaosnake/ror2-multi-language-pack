		{
			masterPrefab = PrefabAPI.InstantiateClone(TeslaTowerNotSurvivor.masterPrefab, "TeslaTowerScepterMaster");
			masterPrefab.GetComponent<CharacterMaster>().bodyPrefab = bodyPrefab;
