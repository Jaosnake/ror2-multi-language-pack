				Object.Destroy((Object)(object)GarrisonHealthBarPrefab.GetComponent<VerticalLayoutGroup>());
				Object.Destroy((Object)(object)((Component)GarrisonHealthBarPrefab.transform.Find("LevelDisplayCluster")).gameObject);
				GarrisonHealthBarPrefab.transform.Find("HealthbarRoot").localPosition = new Vector3(0f, -26.6f, 0f);
				((Component)GarrisonHealthBarPrefab.transform.Find("HealthbarRoot")).GetComponent<RectTransform>().sizeDelta = new Vector2(360f, 24f);
			});
		}

