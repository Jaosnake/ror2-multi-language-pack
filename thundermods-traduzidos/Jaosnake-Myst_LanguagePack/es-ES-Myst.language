        "JAVANGLE_MYST_BODY_JOBCLASS_CHAD_DESCRIPTION": "Comienza la carrera sin magia.",
        "JAVANGLE_MYST_BODY_JOBCLASS_CHAD_KEYWORD": "Chad",
        "JAVANGLE_MYST_MAGICITE_FIREBALL_NAME": "bola de fuego",
        "JAVANGLE_MYST_MAGICITE_FIREBALL_DESCRIPTION": "Dispara una bola de fuego dirigida al objetivo que explota al impactar, causando daño y <style=cIsDamage>encendiendo</style> enemigos en el área de efecto.",
        "JAVANGLE_MYST_MAGICITE_CALL_LIGHTNING_NAME": "Llamar relámpago",
        "JAVANGLE_MYST_MAGICITE_CALL_LIGHTNING_DESCRIPTION": "Invoca un rayo sobre tu objetivo, que inflige daño y derriba a los enemigos aéreos del cielo.",
        "JAVANGLE_MYST_MAGICITE_CONE_OF_FROST_NAME": "Cono de escarcha",
        "JAVANGLE_MYST_MAGICITE_CONE_OF_FROST_DESCRIPTION": "Invoca un cono de viento helado para infligir daño y <style=cIsDamage>congelar</style> enemigos frente a ti.",
        "JAVANGLE_MYST_MAGICITE_FORTIFY_NAME": "Fortalecer",
        "JAVANGLE_MYST_MAGICITE_FORTIFY_DESCRIPTION": "Después de una breve canalización: otorga una poderosa mejora de <style=cIsUtility>armor</style> a ti y a un aliado objetivo.",
        "JAVANGLE_MYST_MAGICITE_MEND_WOUNDS_NAME": "Reparar heridas",
        "JAVANGLE_MYST_MAGICITE_MEND_WOUNDS_DESCRIPTION": "Después de una breve canalización: te cura a ti y a un aliado objetivo por <style=cIsHealing>50% de la salud máxima</style>.",
        "JAVANGLE_MYST_MAGICITE_MAGNET_NAME": "Imán",
        "JAVANGLE_MYST_MAGICITE_MAGNET_DESCRIPTION": "Invoca un campo magnético para atraer enemigos en un área amplia alrededor del objetivo.",
        "JAVANGLE_MYST_MAGICITE_HASTE_NAME": "Prisa",
        "JAVANGLE_MYST_MAGICITE_HASTE_DESCRIPTION": "Después de una breve canalización: otorga velocidad de movimiento y velocidad de ataque a ti y a un aliado objetivo.",
        "JAVANGLE_MYST_MAGICITE_MAGIC_MISSILE_NAME": "Misil mágico",
        "JAVANGLE_MYST_MAGICITE_MAGIC_MISSILE_DESCRIPTION": "Dispara una andanada de proyectiles mágicos guiados que buscan objetivos. Más MP resulta en más proyectiles disparados.",
        "JAVANGLE_MYST_MAGICITE_ECLIPSE_GATE_NAME": "Puerta del eclipse",
        "JAVANGLE_MYST_MAGICITE_ECLIPSE_GATE_DESCRIPTION": "Invoca un fragmento de poder umbral para infligir daño al objetivo según el MP faltante.",
        "JAVANGLE_MYST_MAGICITE_ULTIMA_NAME": "Última",
        "JAVANGLE_MYST_MAGICITE_ULTIMA_DESCRIPTION": "Después de una breve canalización: gasta todo el poder mágico restante para crear un enorme vórtice de energía que causa un daño increíble a todos los enemigos en un área amplia después de un largo retraso.",
        "JAVANGLE_MYST_MAGICITE_FATED_CIRCLE_NAME": "Círculo predestinado",
        "JAVANGLE_MYST_MAGICITE_FATED_CIRCLE_DESCRIPTION": "Un ataque giratorio que aturde y atrae a los enemigos, seguido de explosiones de fuego que los derriban y causan grandes daños.",
        "JAVANGLE_MYST_MAGICITE_EXPLOSION_NAME": "Explosión",
        "JAVANGLE_MYST_MAGICITE_EXPLOSION_DESCRIPTION": "<style=cIsUtility>(Los finalistas difieren según si Myst está en tierra o en el aire)</style>. Mantén tu posición e invoca Orbes de Luz para que orbiten contigo, causando daño y aturdiendo a los enemigos cercanos.",
        "JAVANGLE_MYST_MAGICITE_CHALLENGING_SHOUT_NAME": "Grito desafiante",
        "JAVANGLE_MYST_MAGICITE_CHALLENGING_SHOUT_DESCRIPTION": "Deja escapar un grito de mando que debilita y atrae a los enemigos hacia ti.",
        "JAVANGLE_MYST_MAGICITE_BLADE_DANCE_NAME": "Danza de espadas",
        "JAVANGLE_MYST_MAGICITE_BLADE_DANCE_DESCRIPTION": "Una serenata artística de golpes cortantes que impulsa al usuario y causa daño rápidamente.",
        "JAVANGLE_MYST_MAGICITE_JUDGEMENT_CUT_NAME": "Corte de juicio",
        "JAVANGLE_MYST_MAGICITE_JUDGEMENT_CUT_DESCRIPTION": "Vuélvete intangible y ataca varias veces en un área de efecto, logrando más golpes con mayor velocidad de ataque.",
        "JAVANGLE_MYST_MAGICITE_SHILLELAGH_NAME": "Cachiporra",
        "JAVANGLE_MYST_MAGICITE_SHILLELAGH_DESCRIPTION": "Cuando está en <style=cIsUtility>Magic Recharge</style>: causa mucho daño y restaura el poder mágico. Pero por lo demás, poco impresionante.",
        "JAVANGLE_MYST_MAGICITE_BLASTING_ZONE_NAME": "Zona de voladura",
        "JAVANGLE_MYST_MAGICITE_BLASTING_ZONE_DESCRIPTION": "Invoca un pilar de fuerza gigante para envolver la Espada Vorpal, antes de balancear la hoja para golpearla contra los enemigos frente a ti, causando un daño increíble en un área amplia.",
        "JAVANGLE_MYST_MAGICITE_BERSERK_FORM_NAME": "Forma berserker",
        "JAVANGLE_MYST_MAGICITE_BERSERK_FORM_DESCRIPTION": "Myst se enfurece y obtiene mayor velocidad de movimiento y altura de salto, así como un conjunto de movimientos centrado en los ataques.",
        "JAVANGLE_MYST_MAGICITE_JUDGEMENT_CUT_END_NAME": "Corte del juicio final",
        "JAVANGLE_MYST_MAGICITE_JUDGEMENT_CUT_END_DESCRIPTION": "Envaina la espada Vorpal y acumula energía antes de lanzar una ráfaga de cortes ultrarrápidos que causan un daño increíble después de un retraso.",
        "JAVANGLE_MYST_MAGICITE_POWER_WORD_KILL_NAME": "Palabra de poder matar",
        "JAVANGLE_MYST_MAGICITE_POWER_WORD_KILL_DESCRIPTION": "Después de una breve canalización: <style=cIsDamage>instantáneamente</style> elimina el objetivo.",
        "JAVANGLE_MYST_MAGICITE_MP_THRIFT_NAME": "Ahorro MP",
        "JAVANGLE_MYST_MAGICITE_MP_THRIFT_DESCRIPTION": "El hechizo vinculado cuesta menos MP.",
