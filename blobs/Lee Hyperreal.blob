	internal class OrbController : MonoBehaviour
	{
		internal enum OrbType : ushort
		{
			BLUE = 1,
			RED,
			YELLOW
		}

		private bool onFire = false;

		public List<OrbType> orbList;

		private int OrbLimit = 16;

		private float orbIncrementor = 0f;

		private const bool autoIncrementOrbIncrementor = true;

		private float orbUIStopwatch = 0f;

		private float baseOrbGrantRate = 5f;

		private float orbGrantRate;

		private float updateRate = 0.25f;

		private LeeHyperrealUIController uiController;

		private CharacterBody charBody;

		private CharacterMaster characterMaster;

		private bool baseAIPresent;

		private EntityStateMachine[] stateMachines;

		private InputContainer inputContainer;

		public bool isExecutingSkill = false;

		public bool isCheckingInput = false;

		public bool blueInputConsumed = false;

		public bool redInputConsumed = false;

		public bool yellowInputConsumed = false;

		public float isCheckingInputTimer = 0f;

		public float isExecutingInputTimer = 0f;

		public void Awake()
		{
			orbIncrementor = 0f;
			orbList = new List<OrbType>();
		}

		public void Start()
		{
			charBody = ((Component)this).gameObject.GetComponent<CharacterBody>();
			uiController = ((Component)this).gameObject.GetComponent<LeeHyperrealUIController>();
			if (LeeHyperrealPlugin.isControllerCheck)
			{
				InitializeInputBank();
			}
			stateMachines = ((Component)charBody).gameObject.GetComponents<EntityStateMachine>();
			characterMaster = charBody.master;
			BaseAI component = ((Component)characterMaster).GetComponent<BaseAI>();
			baseAIPresent = Object.op_Implicit((Object)(object)component);
			if (!Object.op_Implicit((Object)(object)characterMaster))
			{
				baseAIPresent = true;
			}
			RecalcUpdateRate();
		}

		[MethodImpl(MethodImplOptions.NoInlining)]
		public void InitializeInputBank()
		{
			inputContainer = new InputContainer(((Component)this).gameObject, this);
		}

		public void Hook()
		{
		}

		public void Unhook()
		{
		}

		public void RecalcUpdateRate()
		{
			int itemCount = charBody.inventory.GetItemCount(Items.AlienHead);
			int itemCount2 = charBody.inventory.GetItemCount(Items.LunarBadLuck);
			float num = 1f;
			for (int i = 0; i < itemCount; i++)
			{
				num *= 0.75f;
			}
			float num2 = 0f;
			if (itemCount2 > 0)
			{
				num2 += 2f + 1f * (float)(itemCount2 - 1);
			}
			orbGrantRate = Mathf.Min(baseOrbGrantRate, Mathf.Max(0.2f, baseOrbGrantRate * num - num2));
		}

		public void UpdateBracketPositionFromIntArr(int[] ints, OrbType orbType)
		{
			int num = 0;
			for (int i = 0; i < ints.Length; i++)
			{
				if (ints[i] != -1)
				{
					num++;
				}
			}
			if (num != 0)
			{
				LeeHyperrealUIController.BracketType bracketType = LeeHyperrealUIController.BracketType.ONE;
				switch (num)
				{
				case 1:
					bracketType = LeeHyperrealUIController.BracketType.ONE;
					break;
				case 2:
					bracketType = LeeHyperrealUIController.BracketType.TWO;
					break;
				case 3:
					bracketType = LeeHyperrealUIController.BracketType.THREE;
					break;
				}
				uiController.SetBracketOnOrb(ints[0], bracketType, orbType);
			}
			else
			{
				uiController.DisableBracket(orbType);
			}
		}

		public void Update()
		{
			if (!charBody.hasEffectiveAuthority || PauseManager.isPaused || baseAIPresent)
			{
				return;
			}
			if (Config.isSimple.Value)
			{
				UpdateBracketPositionFromIntArr(CheckMoveValidity(OrbType.BLUE), OrbType.BLUE);
				UpdateBracketPositionFromIntArr(CheckMoveValidity(OrbType.RED), OrbType.RED);
				UpdateBracketPositionFromIntArr(CheckMoveValidity(OrbType.YELLOW), OrbType.YELLOW);
			}
			else if (!Config.isSimple.Value)
			{
				uiController.DisableBracket(OrbType.BLUE);
				uiController.DisableBracket(OrbType.RED);
				uiController.DisableBracket(OrbType.YELLOW);
			}
			if (!isExecutingSkill && !isCheckingInput)
			{
				bool flag = false;
				if (Config.isSimple.Value)
				{
					flag = CheckSimpleInput();
				}
				else
				{
					CheckNonSimpleInput();
				}
				if (!flag && LeeHyperrealPlugin.isControllerCheck)
				{
					inputContainer.ExtraSkillSlotControllerInputCheck();
				}
			}
			if (isCheckingInput)
			{
				isCheckingInputTimer += Time.deltaTime;
				if (isCheckingInputTimer >= 3f)
				{
					isCheckingInput = false;
					isCheckingInputTimer = 0f;
				}
			}
			if (!isCheckingInput)
			{
				isCheckingInputTimer = 0f;
			}
			if (isExecutingSkill)
			{
				isExecutingInputTimer += Time.deltaTime;
				if (isExecutingInputTimer >= 3f)
				{
					isExecutingSkill = false;
					isExecutingInputTimer = 0f;
				}
			}
			if (!isExecutingSkill)
			{
				isExecutingInputTimer = 0f;
			}
			if (Object.op_Implicit((Object)(object)uiController))
			{
				orbUIStopwatch += Time.deltaTime;
				if (orbUIStopwatch >= updateRate)
				{
					orbUIStopwatch = 0f;
					uiController.UpdateOrbList(orbList);
					uiController.UpdateOrbAmount(orbList.Count, OrbLimit);
				}
			}
		}

		private bool CheckSimpleInput()
		{
			//IL_0008: Unknown result type (might be due to invalid IL or missing references)
			//IL_000d: Unknown result type (might be due to invalid IL or missing references)
			//IL_0010: Unknown result type (might be due to invalid IL or missing references)
			//IL_0031: Unknown result type (might be due to invalid IL or missing references)
			//IL_0036: Unknown result type (might be due to invalid IL or missing references)
			//IL_0039: Unknown result type (might be due to invalid IL or missing references)
			//IL_005a: Unknown result type (might be due to invalid IL or missing references)
			//IL_005f: Unknown result type (might be due to invalid IL or missing references)
