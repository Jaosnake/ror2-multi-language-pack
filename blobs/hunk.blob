					Helpers.TryPlayTerminalAnimation(context.purchasedObject);
				}
				else if (context.activatorMaster.inventory.GetItemCountPermanent(Hunk.cVirusSample) > 0)
				{
					context.activatorMaster.inventory.RemoveItemPermanent(Hunk.cVirusSample, 1);
					Helpers.CreateItemTakenOrb(context.activatorBody.corePosition, context.purchasedObject, Hunk.cVirusSample.itemIndex);
