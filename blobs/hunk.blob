		public class WeaponNotificationQueue : MonoBehaviour
		{
			public const float firstNotificationLengthSeconds = 6f;

			public const float repeatNotificationLengthSeconds = 6f;

			private CharacterMaster master;

			private TimedNotificationInfo notification;

			public event Action<WeaponNotificationQueue> onCurrentNotificationChanged;

			public static WeaponNotificationQueue GetNotificationQueueForMaster(CharacterMaster master)
			{
				if ((Object)(object)master != (Object)null)
				{
					WeaponNotificationQueue weaponNotificationQueue = ((Component)master).GetComponent<WeaponNotificationQueue>();
					if (!Object.op_Implicit((Object)(object)weaponNotificationQueue))
					{
						weaponNotificationQueue = ((Component)master).gameObject.AddComponent<WeaponNotificationQueue>();
						weaponNotificationQueue.master = master;
					}
					return weaponNotificationQueue;
				}
				return null;
			}

			public static void PushWeaponNotification(CharacterMaster characterMaster, int weaponIndex)
			{
				//IL_003c: Unknown result type (might be due to invalid IL or missing references)
				//IL_004b: Expected O, but got Unknown
				if (!((NetworkBehaviour)characterMaster).hasAuthority)
				{
					return;
				}
				WeaponNotificationQueue notificationQueueForMaster = GetNotificationQueueForMaster(characterMaster);
				if (Object.op_Implicit((Object)(object)notificationQueueForMaster))
				{
					HunkWeaponDef weaponFromIndex = HunkWeaponCatalog.GetWeaponFromIndex(weaponIndex);
					if (Object.op_Implicit((Object)(object)weaponFromIndex))
					{
						notificationQueueForMaster.PushNotification(new NotificationInfo((object)weaponFromIndex, (TransformationInfo)null, false, 0), 3.5f);
					}
				}
			}

			private void PushNotification(NotificationInfo info, float duration)
			{
				//IL_0002: Unknown result type (might be due to invalid IL or missing references)
				//IL_0007: Unknown result type (might be due to invalid IL or missing references)
				//IL_000e: Unknown result type (might be due to invalid IL or missing references)
				//IL_001e: Unknown result type (might be due to invalid IL or missing references)
				//IL_002a: Expected O, but got Unknown
				notification = new TimedNotificationInfo
				{
					notification = info,
					startTime = Run.instance.fixedTime,
					duration = duration
				};
				this.onCurrentNotificationChanged?.Invoke(this);
			}

			public float GetCurrentNotificationT()
			{
				return (Run.instance.fixedTime - notification.startTime) / notification.duration;
			}

			public NotificationInfo GetCurrentNotification()
			{
				return notification?.notification;
			}
		}
		public class WeaponNotificationUIController : MonoBehaviour
		{
			public HUD hud;

			public GameObject genericNotificationPrefab;

			public WeaponNotification currentNotification;

			public CharacterMaster targetMaster;

			public WeaponNotificationQueue notificationQueue;

			public void OnEnable()
			{
				CharacterMaster.onCharacterMasterLost += OnCharacterMasterLost;
			}

			public void OnDisable()
			{
				CharacterMaster.onCharacterMasterLost -= OnCharacterMasterLost;
				CleanUpCurrentMaster();
			}

			public void Update()
			{
				if ((Object)(object)hud.targetMaster != (Object)(object)targetMaster)
				{
					SetTargetMaster(hud.targetMaster);
				}
				if (Object.op_Implicit((Object)(object)currentNotification) && Object.op_Implicit((Object)(object)notificationQueue))
				{
					((GenericNotification)currentNotification).SetNotificationT(notificationQueue.GetCurrentNotificationT());
				}
			}

			private void SetUpNotification(NotificationInfo notificationInfo)
			{
				currentNotification = Object.Instantiate<GameObject>(genericNotificationPrefab).GetComponent<WeaponNotification>();
				object data = notificationInfo.data;
				HunkWeaponDef weapon;
				if (data != null && (Object)(object)(weapon = data as HunkWeaponDef) != (Object)null)
				{
					currentNotification.SetWeapon(weapon);
				}
				((Transform)((Component)currentNotification).GetComponent<RectTransform>()).SetParent((Transform)(object)((Component)this).GetComponent<RectTransform>(), false);
			}

			private void OnCurrentNotificationChanged(WeaponNotificationQueue notificationQueue)
			{
				ShowCurrentNotification(notificationQueue);
			}

			private void ShowCurrentNotification(WeaponNotificationQueue notificationQueue)
			{
				DestroyCurrentNotification();
				NotificationInfo val = notificationQueue.GetCurrentNotification();
				if (val != (NotificationInfo)null)
				{
					SetUpNotification(val);
				}
			}

			private void DestroyCurrentNotification()
			{
				if (Object.op_Implicit((Object)(object)currentNotification))
				{
					Object.Destroy((Object)(object)((Component)currentNotification).gameObject);
					currentNotification = null;
				}
			}

			private void SetTargetMaster(CharacterMaster newMaster)
			{
				DestroyCurrentNotification();
				CleanUpCurrentMaster();
				targetMaster = newMaster;
				if (Object.op_Implicit((Object)(object)newMaster))
				{
					notificationQueue = WeaponNotificationQueue.GetNotificationQueueForMaster(newMaster);
					notificationQueue.onCurrentNotificationChanged += OnCurrentNotificationChanged;
					ShowCurrentNotification(notificationQueue);
				}
			}

			private void OnCharacterMasterLost(CharacterMaster master)
			{
				if ((Object)(object)master == (Object)(object)targetMaster)
				{
					CleanUpCurrentMaster();
				}
			}

			private void CleanUpCurrentMaster()
			{
				if (Object.op_Implicit((Object)(object)notificationQueue))
				{
					notificationQueue.onCurrentNotificationChanged -= OnCurrentNotificationChanged;
				}
				notificationQueue = null;
				targetMaster = null;
			}
		}
		public class WeaponPickup : MonoBehaviour
		{
