        "ROB_DRIVER_BODY_SECONDARY_LUNARHAMMER_DESCRIPTION": "<style=cIsUtility>Lerta</style>. Pafu salvon de lunaj fragmentoj, kauxzantaj 180% da damagxo cxiu.</i>",
        "ROB_DRIVER_BODY_SECONDARY_MANDO_SMG_NAME": "Subpresa Pafado",
        "ROB_DRIVER_BODY_SECONDARY_MANDO_SMG_DESCRIPTION": "<style=cIsDamage>Stupore.</style> Pafu plurfoje por 6x250% da damagxo. La nombro de pafoj kreskas kun atakrapideco.</i>",
        "ROB_DRIVER_BODY_SECONDARY_NEMMANDO_NAME": "Subigo",
        "ROB_DRIVER_BODY_SECONDARY_NEMMANDO_DESCRIPTION": "<style=cIsDamage>Stupore</style>. Pafu plurfoje por 6x250% da damagxo po pafo. La nombro de pafoj kreskas kun atakrapideco.</i>",
        "ROB_DRIVER_BODY_SECONDARY_NEMMERC_NAME": "Bategi",
        "ROB_DRIVER_BODY_SECONDARY_NEMMERC_DESCRIPTION": "<style=cIsDamage>Stuporigu</style> kaj <style=cIsUtility>forpusxu</style> proksimajn malamikojn por 250% da damagxo.</i>",
        "ROB_DRIVER_BODY_SECONDARY_RAV_PUNCH_NAME": "Pugnobato",
        "ROB_DRIVER_BODY_SECONDARY_RAV_PUNCH_DESCRIPTION": "Sprintu antauxen kaj <style=cIsUtility>pugnobatu</style>, kauxzante 400% da damagxo kun <style=cIsUtility>sxokondo</style> kauxzanta la samon damagxon.</i>",
        "ROB_DRIVER_BODY_SECONDARY_ARTI_GAUNTLET_NAME": "Nano-Bombo",
        "ROB_DRIVER_BODY_SECONDARY_ARTI_GAUNTLET_DESCRIPTION": "<style=cIsDamage>Stupore</style>. Sxargu eksplodeman nanobombon kauxzantan 600%-2,000% da damagxo.</i>",
        "ROB_DRIVER_BODY_UTILITY_SLIDE_NAME": "Batala Glito",
        "ROB_DRIVER_BODY_UTILITY_SLIDE_DESCRIPTION": "<style=cIsUtility>Glitu</style> sur la teron mallongan distancon. Vi povas <style=cIsDamage>pafi dum glitado.</style></i>",
        "ROB_DRIVER_BODY_UTILITY_DASH_NAME": "Eviti",
        "ROB_DRIVER_BODY_UTILITY_DASH_DESCRIPTION": "<style=cIsUtility>Sprintu</style> mallongan distancon. Vi povas <style=cIsUtility>teni gxis 2 sxargojn.</style></i>",
        "ROB_DRIVER_BODY_UTILITY_SKATEBOARD_NAME": "Rultabulo",
        "ROB_DRIVER_BODY_UTILITY_SKATEBOARD_DESCRIPTION": "Rajdu sur <style=cIsUtility>rultabulo</style>.</i>",
