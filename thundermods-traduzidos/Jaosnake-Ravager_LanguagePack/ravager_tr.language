        "KEYWORD_REDGUY_GRAB": "<style=cKeywordName>Güçlendirilmiş Etki</style><style=cSub>Patronları yakalayabilir. Düşmanları yerde sürükleyerek zamanla hasar verir.",
        "KEYWORD_REDGUY_GRAB2": "<style=cKeywordName>Patronlar</style><style=cSub>Patronlara karşı, onlara <style=cIsDamage>sarılarak</style> goblin moduna geçin.</style>",
