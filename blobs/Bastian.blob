			M4_Charge_Multiplier = Config.BindAndOptions(SectionSkills, "M4_Charge_Multiplier", 0.4f, 0f, 20f);
			M4_Min_Damage = Config.BindAndOptions(SectionSkills, "M4_Min_Damage", 5f, 0f, 100f);
