			{
				instanceData.graceStopwatch += deltaTime;
				if ((instanceData.graceStopwatch >= graceDuration || instanceData.currentStock == 0) && skillSlot.cooldownRemaining <= 0f)
				{
					int buffCount = ((Component)skillSlot).GetComponent<CharacterBody>().GetBuffCount(ConscriptBuffs.magazineBuff);
					SerializableEntityStateType val = ((buffCount >= 1) ? hasMagazineReloadState : reloadState);
					EntityState val2 = EntityStateCatalog.InstantiateState(ref val);
					ISkillState val3;
					if ((val3 = (ISkillState)(object)((val2 is ISkillState) ? val2 : null)) != null)
					{
						val3.activatorSkillSlot = skillSlot;
					}
					skillSlot.stateMachine.SetNextState(val2);
				}
			}
			else
			{
				instanceData.graceStopwatch = 0f;
			}
		}

		public override void OnExecute([NotNull] GenericSkill skillSlot)
		{
