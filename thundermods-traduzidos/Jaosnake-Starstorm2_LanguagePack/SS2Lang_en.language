                    "SS2_KEYWORD_COMBUSTING":  "\u003cstyle=cKeywordName\u003eCombusting\u003c/style\u003e\u003cstyle=cSub\u003eResets the duration of ignite stacks each second.",
                    "SS2_KEYWORD_PARRY":  "\u003cstyle=cKeywordName\u003eParry\u003c/style\u003e\u003cstyle=cSub\u003eBlock an incoming hit to \u003cstyle=cIsUtility\u003estun\u003c/style\u003e and deal \u003cstyle=cIsDamage\u003e350% damage\u003c/style\u003e to all enemies around you. You also become \u003cstyle=cIsUtility\u003eimmune to damage\u003c/style\u003e for 1 second.\u003c/style\u003e",
                    "SS2_COST_DRONE_FORMAT":  "{0} Drone",
