			private void HandleSprint()
			{
				if (!Object.op_Implicit((Object)(object)characterBody) || !Object.op_Implicit((Object)(object)equippedPerkDef) || (Object.op_Implicit((Object)(object)equippedPerkDef) && (Object)(object)equippedPerkDef != (Object)(object)Hunk.runnerPerkDef))
				{
					return;
				}
				if (characterBody.isSprinting)
				{
					sprintStopwatch += Time.fixedDeltaTime;
					if (sprintStopwatch >= 1.5f)
					{
						float num = Mathf.Clamp(sprintStopwatch, 0f, 5f);
						sprintMultiplier = Util.Remap(num, 1.5f, 5f, 1f, 1.25f);
					}
				}
				else
				{
					sprintStopwatch = 0f;
					sprintMultiplier = 1f;
				}
				characterBody.sprintingSpeedMultiplier = baseSprintValue * sprintMultiplier;
				if (lastSprintMultiplier != sprintMultiplier)
				{
					characterBody.RecalculateStats();
				}
				lastSprintMultiplier = sprintMultiplier;
			}

			public void GainGauge(int amount)
			{
				//IL_0013: Unknown result type (might be due to invalid IL or missing references)
				NetworkIdentity component = ((Component)this).GetComponent<NetworkIdentity>();
				if (Object.op_Implicit((Object)(object)component))
				{
					NetMessageExtensions.Send((INetMessage)(object)new SyncGainGauge(component.netId, amount), (NetworkDestination)1);
				}
