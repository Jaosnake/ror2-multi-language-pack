			public void ConsumeAmmo(int amount = 1)
			{
				if (Object.op_Implicit((Object)(object)heldGrenadeDef))
				{
					return;
				}
				reloadTimer = 2f;
				weaponTracker.usedAmmoThisStage = true;
				if (!characterBody.HasBuff(Buffs.NoCooldowns) && !mayhemMode)
				{
					if (ammo <= weaponTracker.weaponData[weaponTracker.equippedIndex].currentAmmo)
					{
						weaponTracker.weaponData[weaponTracker.equippedIndex].currentAmmo -= amount;
					}
					ammo -= amount;
					if (ammo <= 0)
					{
						ammo = 0;
					}
					if (weaponTracker.weaponData[weaponTracker.equippedIndex].currentAmmo <= 0)
					{
						weaponTracker.weaponData[weaponTracker.equippedIndex].currentAmmo = 0;
					}
					if (weaponDef.animationSet == HunkWeaponDef.AnimationSet.Pistol || weaponDef.animationSet == HunkWeaponDef.AnimationSet.PistolAlt || weaponDef.animationSet == HunkWeaponDef.AnimationSet.Jacket || (Object)(object)weaponDef == (Object)(object)BaseWeapon<AssaultRifle>.instance.weaponDef || (Object)(object)weaponDef == (Object)(object)BaseWeapon<Minigun>.instance.weaponDef || (Object)(object)weaponDef == (Object)(object)BaseWeapon<SMG>.instance.weaponDef || (Object)(object)weaponDef == (Object)(object)BaseWeapon<FakeSMG>.instance.weaponDef)
					{
						((MonoBehaviour)this).Invoke("BulletDrop", Random.Range(0.3f, 0.65f));
					}
					onAmmoUse(weaponTracker.totalAmmo);
				}
			}

			public void ApplyBandolier()
			{
				if (ammo <= maxAmmo && (ammo - weaponTracker.weaponData[weaponTracker.equippedIndex].currentAmmo < maxAmmo || ammo == weaponTracker.weaponData[weaponTracker.equippedIndex].currentAmmo))
				{
					if (inventory.GetItemCount(Items.Bandolier) > 0)
					{
						Util.PlaySound("sfx_hunk2_ammo_get", ((Component)this).gameObject);
					}
					ammo += Mathf.CeilToInt((float)maxAmmo * 1f);
					if (ammo > maxAmmo)
					{
						ammo = maxAmmo;
					}
				}
			}

