        "HASTEREAPR_ASSASSIN_PASSIVE_NAME": "Die Wut des verrückten Gottes",
        "HASTEREAPR_ASSASSIN_PASSIVE_DESCRIPTION": "Wenn Sie unter <style=cIsHealth>60 % der maximalen Gesundheit</style> getroffen werden, erhöhen sich Ihre Angriffsgeschwindigkeit und Ihr Schaden um <style=cIsDamage>7,5 % pro Stapel</style>, für <style=cIsUtility>3 Sekunden.</style>",
        "HASTEREAPR_ASSASSIN_ALT_PASSIVE_NAME": "Giftiger Terror",
        "HASTEREAPR_ASSASSIN_ALT_PASSIVE_DESCRIPTION": "Bei einem Treffer wird ein Gift in die Schadensrichtung geschleudert und verursacht <style=cIsDamage>250 % Schaden</style> plus zusätzlich <style=cIsDamage>500 % Schaden über Zeit</style>.",
        "HASTEREAPR_ASSASSIN_ALT1_PASSIVE_NAME": "Trick des Tricksters",
        "HASTEREAPR_ASSASSIN_ALT1_PASSIVE_DESCRIPTION": "Bei einem Treffer besteht die Chance, dass ein Lockvogel entsteht, der 5 Sekunden lang lebt und explodiert und <style=cIsDamage>1500 % Schaden</style> verursacht.",
        "HASTEREAPR_ASSASSIN_PRIMARY_DAGGER_NAME": "Dolch",
        "HASTEREAPR_ASSASSIN_PRIMARY_DAGGER_DESCRIPTION": "<style=cIsUtility>Agile.</style>Wirf 2 Dolche für <style=cIsDamage>100 % Schaden</style>.",
        "HASTEREAPR_ASSASSIN_PRIMARY_CUTTER_NAME": "Geisterdolch",
        "HASTEREAPR_ASSASSIN_PRIMARY_CUTTER_DESCRIPTION": "<style=cIsUtility>Agile.</style>Wirf 1 Dolch für <style=cIsDamage>30 % bis 200 % Schaden</style>.",
        "HASTEREAPR_ASSASSIN_SECONDARY_POISON_NAME": "Gift",
        "HASTEREAPR_ASSASSIN_SECONDARY_POISON_DESCRIPTION": "<style=cIsUtility>Agile.</style>Werfe einen giftigen Trank für <style=cIsDamage>250 % Schaden</style> plus zusätzlich <style=cIsDamage>500 % Schaden über Zeit.</style>",
        "HASTEREAPR_ASSASSIN_SECONDARY_POISON_DESCRIPTION_SCEPTER": "<style=cIsUtility>Agile.</style>Werfe einen gebündelten Gifttrank für <style=cIsDamage>250 % Schaden</style> plus zusätzlich jeweils <style=cIsDamage>500 % Schaden über Zeit.</style> \n\n<style=cKeywordName>Werfe unter dem Einfluss von Kriegsschrei einen rekursiv gebündelten Trank, mit schwächeren Kindern.</style>",
        "HASTEREAPR_ASSASSIN_SECONDARY_POISON_NAME_ALT": "Virulentes Gift",
        "HASTEREAPR_ASSASSIN_SECONDARY_POISON_DESCRIPTION_ALT": "<style=cIsUtility>Agil.</style>Wirf einen anhaltenden Trank, der <style=cIsDamage>500 % Schaden verursacht.</style> <style=cIsUtility>Gifte bleiben 5 Sekunden lang bestehen.</style> <style=cDeath>Verursacht kein Gift.</style>",
        "HASTEREAPR_ASSASSIN_SCEPTER_SECONDARY_POISON_DESCRIPTION_ALT": "<style=cIsUtility>Agile.</style>Wirf 2 verbleibende Tränke in einen losen Fächer, um <style=cIsDamage>500 % Schaden zu verursachen.</style> <style=cIsUtility>Toxine bleiben 5 Sekunden lang bestehen.</style> <style=cDeath>Verursacht kein Gift.</style>",
        "HASTEREAPR_ASSASSIN_UTILITY_CLOAK_NAME": "Teleportieren",
        "HASTEREAPR_ASSASSIN_UTILITY_CLOAK_DESCRIPTION": "Wirf einen Trank auf deinen Cursor, <style=cIsUtility>teleportiere dich dorthin, wo er landet,</style> wirf dann einen Trank auf den Boden, <style=cIsUtility>explodiert in einer Rauchwolke und erhält den Tarngeschwindigkeits-Buff.</style>",
        "HASTEREAPR_ASSASSIN_UTILITY_ROLL_NAME": "Tarnrolle",
        "HASTEREAPR_ASSASSIN_UTILITY_ROLL_DESCRIPTION": "Rollen Sie vorwärts, werden Sie unsichtbar und erhalten Sie eine kleine Steigerung der Bewegungsgeschwindigkeit.",
        "HASTEREAPR_ASSASSIN_UTILITY_DECOY_NAME": "Lockvogelprisma",
        "HASTEREAPR_ASSASSIN_UTILITY_DECOY_DESCRIPTION": "Springen Sie vorwärts und lassen Sie einen explodierenden Köder an Ihrer alten Position zurück.",
        "HASTEREAPR_ASSASSIN_SPECIAL_POISON_SPAM_NAME": "Kriegsschrei",
