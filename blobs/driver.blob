			private static GameObject CreateGhostPrefab(string ghostName, string ghostNameToSet)
			{
				GameObject obj = PrefabAPI.InstantiateClone(Assets.mainAssetBundle.LoadAsset<GameObject>(ghostName), ghostNameToSet, true);
				obj.AddComponent<NetworkIdentity>();
				obj.AddComponent<ProjectileGhostController>();
				obj.AddComponent<VFXAttributes>().DoNotPool = true;
				Assets.ConvertAllRenderersToHopooShader(obj);
				return obj;
			}

			private static GameObject CloneProjectilePrefab(string prefabName, string newPrefabName)
			{
				return PrefabAPI.InstantiateClone(Resources.Load<GameObject>("Prefabs/Projectiles/" + prefabName), newPrefabName);
			}
		}
