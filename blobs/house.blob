		private void AddStackedTimedBuff(CharacterBody characterBody, BuffDef buffDef, float duration, int stacks)
		{
			for (int i = 0; i < stacks; i++)
			{
				characterBody.AddTimedBuff(buffDef, duration, 50);
			}
		}

		private void AddStackedBuff(CharacterBody characterBody, BuffDef buffDef, int stacks)
		{
			for (int i = 0; i < stacks; i++)
			{
				characterBody.AddBuff(buffDef);
			}
		}
	}
