				if (GeneralCompat.ScepterInstalled)
				{
					FixScepterDisplayRule(itemDisplayRules);
				}
			}
			catch (Exception ex3)
			{
				Log.Debug("error adding displays for Scepter \n" + ex3);
			}
		}

