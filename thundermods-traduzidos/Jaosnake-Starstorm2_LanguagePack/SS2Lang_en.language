                    "SS2_FAMILY_LAMP":  "\u003cstyle=cWorldEvent\u003e[WARNING] You encounter a profound sense of stillness..\u003c/style\u003e",
                    "SS2_EXECUTIONER2_FIRINGSQUAD_NAME":  "Fusillade",
