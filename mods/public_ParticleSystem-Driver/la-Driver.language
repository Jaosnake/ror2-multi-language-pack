{
    "la": {
        "ROB_DRIVER_BODY_NAME": "Auriga",
        "ROB_DRIVER_BODY_DESCRIPTION": "Auriga lauxlitere ego sum.<color=#CCD3E0></i>",
        "ROB_DRIVER_BODY_SUBTITLE": "Auriga? Vix eam novi!",
        "ROB_DRIVER_BODY_LORE": "Tergo ad murum et contra fortunam\nCum vi voluntatis et causa\nFacta tua mirabilia vocantur\nEs animo complexus\n\nContra fluctum assertionum dystopicarum\nNon cogitationes quas facta tua oblectant\nEt te ostendisti esse\n\n\nVerum hominem et verum heroem\n\n\"Quid igitur agis?\"\n\n\"Aurigo.\"",
        "ROB_DRIVER_BODY_OUTRO_FLAVOR": "..atque deinde discessit, idem qualis cum incepit.",
        "ROB_DRIVER_BODY_OUTRO_FAILURE": "..atque deinde evanuit, numquam verus homo factus.",
