    "SS2_SHRINE_ETHEREAL_NAME": "以太终端",
    "SS2_SHRINE_ETHEREAL_CONTEXT": "启动以太终端……?\n(这将永久增加难度!)",
    "SS2_SHRINE_ETHEREAL_CONTEXT_CANCEL": "驱散以太能量……？",
    "SS2_SHRINE_ETHEREAL_FAIL_MESSAGE": "<style=cEvent>这颗星球感到被嘲弄……</style>",
    "SS2_SHRINE_ETHEREAL_WARN_MESSAGE": "{0} 激活了以太终端……",
