		internal class StarsBox : NetworkBehaviour
		{
			private ParticleSystem beam;

			private Animator animator;

			private float stopwatch;

			private bool isActive = true;

			private bool localPlayerHasBadge
			{
				get
				{
					if (!isActive)
					{
						return false;
					}
					bool result = false;
					foreach (CharacterMaster instances in CharacterMaster.instancesList)
					{
						if (((NetworkBehaviour)instances).hasAuthority && Object.op_Implicit((Object)(object)instances.inventory) && instances.inventory.GetItemCount(Hunk.starsBadge2) > 0)
						{
							result = true;
							break;
						}
					}
					return result;
				}
			}

			private void Awake()
			{
				beam = ((Component)this).GetComponentInChildren<ParticleSystem>();
				animator = ((Component)((Component)((Component)this).GetComponent<Highlight>().targetRenderer).transform.parent.parent).GetComponent<Animator>();
			}

			private void FixedUpdate()
			{
				stopwatch -= Time.fixedDeltaTime;
				if (stopwatch <= 0f)
				{
					stopwatch = 0.5f;
					Check();
				}
			}

			public void PlayAnimation()
			{
				((MonoBehaviour)this).CancelInvoke();
				isActive = false;
				if (Object.op_Implicit((Object)(object)animator))
				{
					animator.PlayInFixedTime("Open");
				}
				((MonoBehaviour)this).Invoke("PlayDelayed", 0.3f);
			}

			private void PlayDelayed()
			{
				Util.PlaySound("sfx_hunk_keycard_accepted", ((Component)this).gameObject);
			}

			private void Check()
			{
				if (localPlayerHasBadge)
				{
					if (!beam.isPlaying)
					{
						beam.Play();
					}
				}
				else if (beam.isPlaying)
				{
					beam.Stop();
				}
			}
		}
