		public abstract class BaseWeapon<T> : BaseWeapon where T : BaseWeapon<T>
		{
			public static T instance { get; private set; }

			public BaseWeapon()
			{
				if (instance != null)
				{
					throw new InvalidOperationException("Singleton class \"" + typeof(T).Name + "\" inheriting BaseWeapon was instantiated twice");
				}
				instance = this as T;
			}
		}
		public abstract class BaseWeapon
		{
			public DriverWeaponDef weaponDef { get; set; }

			public abstract string weaponName { get; }

			public abstract string weaponNameToken { get; }

			public abstract string weaponDesc { get; }

			public abstract string weaponDescToken { get; }

			public abstract Sprite icon { get; }

			public abstract DriverWeaponTier dropTier { get; }

			public abstract DriverWeaponDef.AnimationSet animationSet { get; }

			public abstract DriverWeaponDef.BuffType buffType { get; }

			public abstract int shotCount { get; }

			public abstract Mesh mesh { get; }

			public abstract Material material { get; }

			public virtual GameObject crosshairPrefab { get; }

			public virtual GameObject pickupPrefabOverride { get; }

			public virtual Color? colorOverride { get; }

			public abstract SkillDef primarySkillDef { get; }

			public abstract SkillDef secondarySkillDef { get; }

			public virtual SkillDef arsenalSkillDef => Skills.CreateAndAddWeaponSkillDef(weaponNameToken, weaponDescToken);

			public virtual UnlockableDef unlockableDef => Unlockables.CreateAndAddWeaponUnlockableDef(weaponNameToken, weaponDescToken);

			public virtual string equipAnimationString => "BufferEmpty";

			public virtual string reloadAnimationString => "ReloadPistol";

			public virtual string calloutSoundString => "sfx_driver_callout_generic";

			public virtual string uniqueDropBodyName => "";

			public virtual float dropChance => 0f;

			public virtual bool disableHolster => false;

			public virtual void Init()
			{
				CreateLang();
				CreateWeaponDef();
				AddWeaponToCatalog();
				AddWeaponDrops();
			}

			protected virtual void CreateLang()
			{
				LanguageAPI.Add(weaponNameToken.ToUpperInvariant(), weaponName);
				LanguageAPI.Add(weaponDescToken.ToUpperInvariant(), weaponDesc);
			}

			protected virtual void CreateWeaponDef()
			{
				if (weaponDef == null)
				{
					DriverWeaponDef driverWeaponDef2 = (weaponDef = DriverWeaponDef.CreateWeaponDefFromInfo(new DriverWeaponDefInfo
					{
						name = weaponName,
						nameToken = weaponNameToken,
						description = weaponDesc,
						descriptionToken = weaponDescToken,
						icon = icon,
						tier = dropTier,
						animationSet = animationSet,
						buffType = buffType,
						shotCount = shotCount,
						primarySkillDef = primarySkillDef,
						secondarySkillDef = secondarySkillDef,
						arsenalSkillDef = arsenalSkillDef,
						unlockableDef = unlockableDef,
						mesh = mesh,
						material = material,
						crosshairPrefab = crosshairPrefab,
						pickupPrefabOverride = pickupPrefabOverride,
						colorOveride = colorOverride,
						equipAnimationString = equipAnimationString,
						calloutSoundString = calloutSoundString,
						dropChance = dropChance,
						disableHolster = disableHolster,
						reloadAnimationString = reloadAnimationString
					}));
				}
			}

			protected virtual void AddWeaponToCatalog()
			{
				DriverWeaponCatalog.CreateAndAddWeapon(weaponDef);
			}

			protected virtual void AddWeaponDrops()
			{
				DriverWeaponCatalog.AddWeaponDrop(uniqueDropBodyName, weaponDef);
			}
		}
		public abstract class BundledWeapon<T> : BaseWeapon where T : BaseWeapon
		{
			public static T instance { get; private set; }

			public override string weaponName => base.weaponDef.weaponName;

			public override string weaponNameToken => base.weaponDef.nameToken;

			public override string weaponDesc => base.weaponDef.description;

			public override string weaponDescToken => base.weaponDef.descriptionToken;

			public override Sprite icon => base.weaponDef.icon;

			public override DriverWeaponTier dropTier => base.weaponDef.tier;

			public override DriverWeaponDef.AnimationSet animationSet => base.weaponDef.animationSet;

			public override DriverWeaponDef.BuffType buffType => base.weaponDef.buffType;

			public override int shotCount => base.weaponDef.shotCount;

			public override Mesh mesh => base.weaponDef.mesh;

			public override Material material => base.weaponDef.material;

			public override GameObject crosshairPrefab => base.weaponDef.crosshairPrefab;

			public override SkillDef primarySkillDef => base.weaponDef.primarySkillDef;

			public override SkillDef secondarySkillDef => base.weaponDef.secondarySkillDef;

			public BundledWeapon()
			{
				if (instance != null)
				{
					throw new InvalidOperationException("Singleton class \"" + typeof(T).Name + "\" inheriting BaseWeapon was instantiated twice");
				}
				instance = this as T;
				LoadWeaponFromBundle();
				instance.Init();
			}

			public abstract void LoadWeaponFromBundle();
		}
