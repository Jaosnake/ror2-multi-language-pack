		public void OnKilledOtherServer(DamageReport damageReport)
		{
			//IL_0007: Unknown result type (might be due to invalid IL or missing references)
			if (DamageAPI.HasModdedDamageType(damageReport.damageInfo, DeputyPlugin.resetUtilityOnKill) && NetworkServer.active)
			{
				CallRpcAddUtilityStock();
			}
		}

		[ClientRpc]
		public void RpcAddUtilityStock()
		{
			if (((NetworkBehaviour)this).hasAuthority && Object.op_Implicit((Object)(object)skillLocator) && skillLocator.utility.stock < skillLocator.utility.maxStock)
			{
				skillLocator.utility.AddOneStock();
			}
		}

		private void UNetVersion()
		{
		}

		protected static void InvokeRpcRpcAddUtilityStock(NetworkBehaviour obj, NetworkReader reader)
		{
			if (!NetworkClient.active)
			{
				Debug.LogError((object)"RPC RpcAddUtilityStock called on server.");
			}
			else
			{
				((ResetUtilityOnKill)(object)obj).RpcAddUtilityStock();
			}
		}

		public void CallRpcAddUtilityStock()
		{
			//IL_0016: Unknown result type (might be due to invalid IL or missing references)
			//IL_001c: Expected O, but got Unknown
			//IL_0041: Unknown result type (might be due to invalid IL or missing references)
			if (!NetworkServer.active)
			{
				Debug.LogError((object)"RPC Function RpcAddUtilityStock called on client.");
				return;
			}
			NetworkWriter val = new NetworkWriter();
			val.Write((short)0);
			val.Write((short)2);
			val.WritePackedUInt32((uint)kRpcRpcAddUtilityStock);
			val.Write(((Component)this).GetComponent<NetworkIdentity>().netId);
			((NetworkBehaviour)this).SendRPCInternal(val, 0, "RpcAddUtilityStock");
		}

		static ResetUtilityOnKill()
		{
			//IL_0020: Unknown result type (might be due to invalid IL or missing references)
			//IL_002a: Expected O, but got Unknown
			kRpcRpcAddUtilityStock = 1433125275;
			NetworkBehaviour.RegisterRpcDelegate(typeof(ResetUtilityOnKill), kRpcRpcAddUtilityStock, new CmdDelegate(InvokeRpcRpcAddUtilityStock));
			NetworkCRC.RegisterBehaviour("ResetUtilityOnKill", 0);
		}

		public override bool OnSerialize(NetworkWriter writer, bool forceAll)
		{
			bool result = default(bool);
			return result;
		}

		public override void OnDeserialize(NetworkReader reader, bool initialState)
		{
		}
	}
