					ospFill.fillAmount = Util.Remap(healthComponent.combinedHealth * body.oneShotProtectionFraction / cursePenalty, 0f, healthComponent.fullCombinedHealth / cursePenalty, minFill, maxFill);
					if (shouldShowLowHealth)
					{
