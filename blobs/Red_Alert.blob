			RecalculateStatsAPI.GetStatCoefficients += new StatHookEventHandler(RecalculateStatsAPI_GetStatCoefficients);
			Detonate.OnEnter += new hook_OnEnter(Detonate_OnEnter);
			ChaseTarget.FixedUpdate += new Manipulator(ChaseTarget_FixedUpdate);
			CharacterBody.RecalculateStats += new hook_RecalculateStats(CharacterBody_RecalculateStats);
		}

		private void CharacterBody_RecalculateStats(orig_RecalculateStats orig, CharacterBody self)
