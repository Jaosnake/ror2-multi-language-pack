        "ROB_HUNK_NEMESIS_ACHIEVEMENT_NAME": "A Dream of Armageddon",
        "ROB_HUNK_BODY_NAME": "STÜCK",
        "ROB_HUNK_BODY_DESCRIPTION": "HUNK ist ein Elite-Infiltrator, der über ein großes Arsenal an Waffen verfügt, die über OSP (On-Site Procurement) erworben wurden.<color=#CCD3E0></i>",
        "ROB_HUNK_BODY_SUBTITLE": "Der Schnitter",
        "ROB_HUNK_BODY_OUTRO_FLAVOR": "..und so ging er, alles gut.",
        "ROB_HUNK_BODY_OUTRO_FAILURE": "..und so verschwand er, die menschliche Einheit war nun neutralisiert.",
        "ROB_HUNK_BODY_DEFAULT_SKIN_NAME": "Standard",
        "ROB_HUNK_BODY_CLASSIC_SKIN_NAME": "RE2make",
        "ROB_HUNK_BODY_TOFU_SKIN_NAME": "Tofu",
        "ROB_HUNK_BODY_SUPER_SKIN_NAME": "<color=#FFFF00>Früher Unterstützer</color>",
        "ROB_HUNK_BODY_LIGHTWEIGHT_SKIN_NAME": "Leicht",
        "ROB_HUNK_BODY_GUERRILLA_SKIN_NAME": "Soldat",
        "ROB_HUNK_BODY_ROOKIE_SKIN_NAME": "Anfänger",
        "ROB_HUNK_BODY_SWAT_SKIN_NAME": "Friedensstifter",
        "ROB_HUNK_BODY_LEON_SKIN_NAME": "Spezialist",
        "ROB_HUNK_BODY_LEONSHIRT_SKIN_NAME": "Spezialist EX",
        "ROB_HUNK_BODY_ENFORCER_SKIN_NAME": "Bulldozer",
        "ROB_HUNK_BODY_WESKER_SKIN_NAME": "Mastermind",
        "ROB_HUNK_BODY_DOOM_SKIN_NAME": "Jäger",
        "ROB_HUNK_BODY_COMMANDO_SKIN_NAME": "Kommando",
        "ROB_HUNK_BODY_JACKET_SKIN_NAME": "Jacke",
        "ROB_HUNK_BODY_PPASSIVE_NAME": "OSP (Beschaffung vor Ort)",
        "ROB_HUNK_BODY_PPASSIVE_DESCRIPTION": "HUNK kann <color=#FFFF00>U.C. sammeln. Schlüsselkarten</color>, um <style=cIsDamage>Waffenkoffer</style> zu öffnen und sein Arsenal zu erweitern.",
        "ROB_HUNK_BODY_PPASSIVE2_NAME": "Vergessener Soldat",
        "ROB_HUNK_BODY_PPASSIVE2_DESCRIPTION": "Der erste <style=cIsHealth>Boss</style>, der auf jeder Stufe stirbt, lässt ein <style=cIsDamage>Versorgungspaket</style> fallen, das eine Waffe oder ein Zubehör enthält.",
        "ROB_HUNK_BODY_PASSIVE_NAME": "Schattenkampf",
        "ROB_HUNK_BODY_PASSIVE_DESCRIPTION": "Beginnen Sie mit einem <style=cIsDamage>LE 5</style> und einer <style=cIsDamage>Sekundärwaffe</style>. Sie können <style=cIsDamage>scavenge</style> <style=cIsUtility>chests</style> für Munition.",
        "ROB_HUNK_BODY_PASSIVE2_NAME": "Drohende Angst",
        "ROB_HUNK_BODY_PASSIVE2_DESCRIPTION": "Beginnen Sie mit einem <style=cIsDamage>vollen Arsenal</style>, <style=cIsHealth>ABER</style> Sie können nicht mehr <style=cIsHealth>zusätzliche Munition erhalten</style>.",
        "ROB_HUNK_BODY_RANDOMPASSIVE_NAME": "Neues Spiel+",
        "ROB_HUNK_BODY_RANDOMPASSIVE_DESCRIPTION": "Beginnen Sie mit einem <style=cIsDamage>LE 5</style> und einer <style=cIsDamage>Sekundärwaffe</style>. Sie können <style=cIsDamage>scavenge</style> <style=cIsUtility>chests</style> für Munition. <style=cIsHealth>Alle Inhalte des Waffenkoffers sind zufällig.</style>",
        "ROB_HUNK_BODY_SHOTGUNPASSIVE_NAME": "Oberste Autorität",
        "ROB_HUNK_BODY_SHOTGUNPASSIVE_DESCRIPTION": "Beginnen Sie mit einem <style=cIsDamage>W-870</style> und einer <style=cIsDamage>Sekundärwaffe</style>. Sie können <style=cIsDamage>scavenge</style> <style=cIsUtility>chests</style> für Munition.",
        "ROB_HUNK_BODY_SMGPASSIVE_NAME": "Höchster Söldner",
        "ROB_HUNK_BODY_SMGPASSIVE_DESCRIPTION": "Starten Sie <style=cIsHealth>ONLY</style> mit einem <style=cIsDamage>vollständig aktualisierten LE 5</style>. Sie können <style=cIsDamage>scavenge</style> <style=cIsUtility>chests</style> für Munition. Der <style=cIsDamage>Special</style> wird durch</style>0__Chaos Mode</style>1__ ersetzt.",
        "ROB_HUNK_BODY_WPASSIVE_NAME": "Vollständige globale Sättigung",
        "ROB_HUNK_BODY_WPASSIVE_DESCRIPTION": "Starten Sie <style=cIsHealth>ONLY</style> mit einer <style=cIsDamage>Sekundärwaffe</style>. Sie können <style=cIsDamage>scavenge</style> <style=cIsUtility>chests</style> für Munition. Das <style=cIsDamage>Utility</style> wird durch</style>0__Uroboros</style>1__ ersetzt.",
        "ROB_HUNK_BODY_FLAMERPASSIVE_NAME": "Pyromanie",
        "ROB_HUNK_BODY_FLAMERPASSIVE_DESCRIPTION": "Starten Sie <style=cIsHealth>NUR</style> mit einem <style=cIsDamage>Chemischen Flammenwerfer</style>. Sie können <style=cIsDamage>scavenge</style> <style=cIsUtility>chests</style> für Munition. <style=cIsHealth>Pro Stufe erscheint nur EIN Waffenkoffer.</style>",
        "ROB_HUNK_BODY_PRIMARY_KNIFE_NAME": "Kampfmesser",
        "ROB_HUNK_BODY_PRIMARY_KNIFE_DESCRIPTION": "<style=cIsUtility>Draw.</style> <style=cIsDamage>Cut</style> in der Nähe befindliche Kämpfer fügen <style=cIsDamage>200 % Schaden</style> zu und verursachen <style=cIsHealth>Mangled</style>.",
        "ROB_HUNK_BODY_PRIMARY_CQC_NAME": "CQC (Nahkampf)",
        "ROB_HUNK_BODY_PRIMARY_CQC_DESCRIPTION": "<style=cIsUtility>Draw.</style> <style=cIsDamage>Kick zweimal</style> für <style=cIsDamage>200 % und 250 % Schaden</style>. Wenn der <style=cIsUtility>Sekunden-Kick</style> eine Verbindung herstellt, folgen Sie mit einem <style=cIsDamage>Gegenangriff</style>.",
        "ROB_HUNK_BODY_PRIMARY_RELOAD_NAME": "Neu laden",
        "ROB_HUNK_BODY_RELOAD_DESCRIPTION": "Laden Sie Ihre aktuelle Waffe neu.",
        "ROB_HUNK_BODY_SECONDARY_AIM_NAME": "Zielen Sie ruhig",
        "ROB_HUNK_BODY_SECONDARY_AIM_DESCRIPTION": "Zielen Sie, <style=cIsUtility>die Schwachstellen des Feindes aufzudecken</style>. <style=cIsDamage>Wenn Sie beim Zielen die Primärwaffe verwenden, wird Ihre ausgerüstete Waffe abgefeuert.</style>",
        "ROB_HUNK_BODY_UTILITY_DODGE_NAME": "Quickstep",
        "ROB_HUNK_BODY_UTILITY_DODGE_DESCRIPTION": "<style=cIsUtility>Advance</style> eine kurze Distanz. Bei präventiver Verwendung zur <style=cIsUtility>Vermeidung eines Angriffs</style> führen Sie ein <style=cIsDamage>Perfektes Ausweichen</style> durch.",
        "ROB_HUNK_BODY_UTILITY_DODGE_SCEPTER_NAME": "Uroboros",
        "ROB_HUNK_BODY_UTILITY_DODGE_SCEPTER_DESCRIPTION": "<style=cIsUtility>Advance</style> eine kurze Distanz. Bei präventiver Verwendung zur <style=cIsUtility>Vermeidung eines Angriffs</style> führen Sie ein <style=cIsDamage>Perfektes Ausweichen</style> durch. Die Kraft von Uroboros durchströmt dich.",
        "ROB_HUNK_BODY_UTILITY_PARRY_NAME": "Parieren",
        "ROB_HUNK_BODY_UTILITY_PARRY_DESCRIPTION": "<style=cIsUtility>Block</style> einen Angriff, <style=cIsDamage>nulliert</style> den Schaden und <style=cIsUtility>erstattet die Abklingzeit</style>. Führen Sie bei präventiver Verwendung einen <style=cIsDamage>Perfect Parry</style> durch.",
        "ROB_HUNK_BODY_UTILITY_BASH_NAME": "Schulterschlag",
        "ROB_HUNK_BODY_UTILITY_BASH_DESCRIPTION": "<style=cIsUtility>Triff</style> Gegner in der Nähe mit deiner Schulter, <style=cIsUtility>betäube sie</style> und verursache <style=cIsDamage>400 % Schaden</style>. Bei präventiver Verwendung zum <style=cIsUtility>Abbrechen eines Angriffs</style> führen Sie eine <style=cIsDamage>Perfect Deflection</style> durch.",
        "ROB_HUNK_BODY_SPECIAL_SWAP_NAME": "Legion",
        "ROB_HUNK_BODY_SPECIAL_SWAP_DESCRIPTION": "<style=cIsUtility>Swap</style> zu einer <style=cIsDamage>anderen Waffe</style>. Tippen Sie hier, um zu Ihrer <style=cIsUtility>zuletzt verwendeten Waffe</style> zu wechseln.",
        "ROB_HUNK_BODY_SPECIAL_MAYHEM_NAME": "Chaos-Modus",
        "ROB_HUNK_BODY_SPECIAL_MAYHEM_DESCRIPTION": "Wechseln Sie in den <style=cIsDamage>Chaos-Modus</style> und steigern Sie die Waffenleistung drastisch.",
        "ROB_HUNK_BODY_CONFIRM_NAME": "Bestätigen",
        "ROB_HUNK_BODY_CONFIRM_DESCRIPTION": "Fahren Sie mit der aktuellen Fähigkeit fort.",
        "ROB_HUNK_BODY_CANCEL_NAME": "Stornieren",
        "ROB_HUNK_BODY_CANCEL_DESCRIPTION": "Aktuelle Fähigkeit abbrechen.",
        "ROB_HUNK_BODY_KNIFE_DEFAULT_NAME": "Kampfmesser",
        "ROB_HUNK_BODY_KNIFE_DEFAULT_DESCRIPTION": "Ein Standard-Militärmesser. Sicherlich nützlich an engen Stellen.",
        "ROB_HUNK_BODY_KNIFE_INFINITE_NAME": "Kampfmesser EX",
        "ROB_HUNK_BODY_KNIFE_INFINITE_DESCRIPTION": "Ein speziell behandeltes, unglaublich gehärtetes Militärmesser. Angeblich auf Langlebigkeit ausgelegt.",
        "ROB_HUNK_BODY_KNIFE_HIDDEN_NAME": "Versteckte Klinge",
        "ROB_HUNK_BODY_KNIFE_HIDDEN_DESCRIPTION": "Eine flache, einziehbare Klinge, die in der Hülse versteckt ist. Ideal für Stealth-Operationen.",
        "ROB_HUNK_BODY_KNIFE_WESKER_NAME": "Maßgeschneidertes Messer",
        "ROB_HUNK_BODY_KNIFE_WESKER_DESCRIPTION": "Eine grausame Klinge mit gezackter Schneide, die Ihnen dabei hilft, Ihre Gegner in Stücke zu reißen.",
        "ROB_HUNK_BODY_KNIFE_MACHETE_NAME": "Machete",
        "ROB_HUNK_BODY_KNIFE_MACHETE_DESCRIPTION": "Eine riesige Klinge, die hauptsächlich für Guerilla-Taktiken gedacht ist.",
        "ROB_HUNK_BODY_KNIFE_RE4_NAME": "Primärmesser",
        "ROB_HUNK_BODY_KNIFE_RE4_DESCRIPTION": "Ein geschmiedetes Messer mit unendlichen Möglichkeiten.",
        "ROB_HUNK_BODY_KNIFE_BLOODY_NAME": "Blutige Klinge",
        "ROB_HUNK_BODY_KNIFE_BLOODY_DESCRIPTION": "Eine blutige Klinge mit gezackter Schneide, die schon viele Gegner in Stücke gerissen hat.",
        "ROB_HUNK_BODY_KNIFE_HOTDOGGER_NAME": "HEISSER DOGGER",
        "ROB_HUNK_BODY_KNIFE_HOTDOGGER_DESCRIPTION": "Wie der Name schon sagt, wird dieses von Umbrella entwickelte Anti-Biowaffenmesser von denen verwendet, die gerne angeben.",
        "ROB_HUNK_BODY_KNIFE_STUNROD_NAME": "Betäubungsrute",
        "ROB_HUNK_BODY_KNIFE_STUNROD_DESCRIPTION": "ACHTUNG: Betäubt nicht wirklich.",
        "ROB_HUNK_BODY_KNIFE_KITCHEN_NAME": "Küchenmesser",
        "ROB_HUNK_BODY_KNIFE_KITCHEN_DESCRIPTION": "Ein Messer zum Kochen. Seine Klinge splittert leicht.",
