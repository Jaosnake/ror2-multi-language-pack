				return;
			}
			float num = ((EntityState)this).characterBody.master.money;
			int num2 = 0;
			if (num > (float)passiveManager.GetDifficultyScaledCost(50))
			{
				num2 = 1;
			}
			if (num > (float)passiveManager.GetDifficultyScaledCost(75))
			{
				num2 = 2;
			}
			if (num > (float)passiveManager.GetDifficultyScaledCost(300))
			{
				num2 = 3;
			}
			((EntityState)this).characterBody.master.money = 0u;
			((EntityState)this).characterBody.ClearTimedBuffs(Buffs.Ante);
			Inventory inventory = ((EntityState)this).characterBody.master.inventory;
			if (num2 > 0 && Object.op_Implicit((Object)(object)inventory))
			{
				ItemIndex val;
				switch (num2)
				{
				default:
					return;
				case 1:
					val = ItemCatalog.tier1ItemList[passiveManager.random.Next(ItemCatalog.tier1ItemList.Count)];
					break;
				case 2:
					val = ItemCatalog.tier2ItemList[passiveManager.random.Next(ItemCatalog.tier2ItemList.Count)];
					break;
				case 3:
					val = ItemCatalog.tier3ItemList[passiveManager.random.Next(ItemCatalog.tier3ItemList.Count)];
					break;
				}
				UniquePickup val2 = default(UniquePickup);
				val2.pickupIndex = PickupCatalog.FindPickupIndex(val);
				UniquePickup val3 = val2;
				val3.decayValue = 1f;
				PickupDropletController.CreatePickupDroplet(val3, ((EntityState)this).characterBody.corePosition, new Vector3(0f, 5f, 0f), false, false);
			}
		}

		public override void OnSerialize(NetworkWriter writer)
		{
			base.OnSerialize(writer);
			writer.Write(result);
		}

		public override void OnDeserialize(NetworkReader reader)
		{
			base.OnDeserialize(reader);
			result = reader.ReadInt32();
		}
	}
	internal class Wildcard : BaseCardSkill
