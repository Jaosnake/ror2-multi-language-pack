        "SANDSWEPT_VOID_SHRINE_RUIN_NAME": "Yıkım Sunağı",
        "SANDSWEPT_VOID_SHRINE_RUIN_CONTEXT": "Yıkım Sunağı'na Sun",
        "SANDSWEPT_VOID_SHRINE_RUIN_USE_MESSAGE_2P": "<style=cShrine>Yozlaşma yayılıyor.</color>",
        "SANDSWEPT_VOID_SHRINE_RUIN_USE_MESSAGE": "<style=cShrine>Yozlaşma yayılıyor.</color>",
        "SANDSWEPT_SHRINE_OF_RUIN_DESCRIPTION": "Bir hayatta kalan tarafından etkinleştirildiğinde, Yıkım Sunağı envanterden 10 rastgele beyaz eşya tüketir ve bir sonraki bölgeyi yozlaştırır.",

        "SANDSWEPT_SHRINE_SACRIFICE_NAME": "Kurban Sunağı",
        "SANDSWEPT_SHRINE_SACRIFICE_CONTEXT": "Kurban Sunağı'na Sun",
        "SANDSWEPT_SHRINE_SACRIFICE_USE_MESSAGE_2P": "<style=cShrine>Zamanın kurban edildi.</color>",
        "SANDSWEPT_SHRINE_SACRIFICE_USE_MESSAGE": "<style=cShrine>{0}'ın zamanı kurban edildi.</color>",
        "SANDSWEPT_SHRINE_SACRIFICE_DESCRIPTION": "Etkinleştirildiğinde, Kurban Sunağı, hayatta kalanın maksimum canının %{curseCost}'ini {itemCount} kopya rastgele bir ortak eşya karşılığında tüketir.",
        "SANDSWEPT_SHRINE_OF_SACRIFICE_DESCRIPTION": "Etkinleştirildiğinde, Kurban Sunağı, hayatta kalanın maksimum canının %{curseCost}'ini {itemCount} kopya rastgele bir ortak eşya karşılığında tüketir.",

        "SANDSWEPT_SHRINE_FUTURE_NAME": "Gelecek Sunağı",
        "SANDSWEPT_SHRINE_FUTURE_CONTEXT": "Gelecek Sunağı'na Sun",
