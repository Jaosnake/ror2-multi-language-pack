{
    "es-ES": {
        "POPCORN_ARSONIST_BODY_NAME": "Incendiario",
        "POPCORN_ARSONIST_BODY_SUBTITLE": "Pirómano maníaco",
        "POPCORN_ARSONIST_BODY_PASSIVE_NORMAL_GAUGE_NAME": "Calibre normal",
        "POPCORN_ARSONIST_BODY_PASSIVE_NORMAL_GAUGE_DESCRIPTION": "Inflige <style=cIsDamage>100%</style> daño en la porción blanca. El medidor base es resistente al sobrecalentamiento.",
        "POPCORN_ARSONIST_BODY_PASSIVE_BLUE_GAUGE_NAME": "Indicador crítico",
        "POPCORN_ARSONIST_BODY_PASSIVE_BLUE_GAUGE_DESCRIPTION": "Inflige <style=cIsDamage>70%</style> de daño en la parte blanca y <style=cIsDamage>250%</style> de daño en la parte azul. El calor máximo es fijo.",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_NAME": "Aliento de dragón",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_DESCRIPTION": "Dispara un rayo de llamas que inflige <style=cIsDamage>90% de daño</style>. Mayor probabilidad de ignición cuanto más cerca esté del objetivo.",
        "POPCORN_ARSONIST_BODY_PRIMARY_FIRESPRAY_NAME": "bola de fuego",
        "POPCORN_ARSONIST_BODY_PRIMARY_FIRESPRAY_DESCRIPTION": "<style=cIsUtility>Calor. </style>Dispara una bola de fuego que inflige <style=cIsDamage>225 % de daño y enciende a </style> enemigos al golpear.",
        "POPCORN_ARSONIST_BODY_SECONDARY_PUNCH_NAME": "Explosión de punto cero",
        "POPCORN_ARSONIST_BODY_SECONDARY_PUNCH_DESCRIPTION": "<style=cIsUtility>Ágil. Calor. </style>Impulsate hacia adelante, explotando a los enemigos detrás de ti e infligiendo <style=cIsDamage>200% de daño</style>. Chocar inmediatamente después del lanzamiento con el primer enemigo causa <style=cIsDamage>200% de daño</style> en una explosión circundante.",
        "POPCORN_ARSONIST_BODY_SECONDARY_FLAREGUN_NAME": "Pistola de bengalas",
        "POPCORN_ARSONIST_BODY_SECONDARY_FLAREGUN_DESCRIPTION": "Dispara una bengala que causa <style=cIsDamage>400% de daño</style> durante 5 segundos, luego explota y causa <style=cIsDamage>400% de daño</style>, lanzando 5 bengalas que causan <style=cIsDamage>200% de daño</style> cada una.",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHIST_NAME": "Masoquismo",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHIST_DESCRIPTION": "<style=cIsUtility>Ágil. Calor. </style>El daño causado por <style=cIsDamage>encendido</style> se transforma en <style=cIsHealing>curación</style> durante 6,5 segundos. Aumenta la velocidad de ataque en <style=cIsDamage>125%</style>.",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_NAME": "Masoquismo",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_DESCRIPTION": "Al alcanzar el límite de <style=cKeywordName>Anticipación</style>, inflige daño periódicamente a ti mismo a cambio del área <style=cIsHealing>Robo de vida</style> y quema. Después de 10 segundos como máximo, <style=cIsDamage>Detonate</style>, luego <style=cIsUtility>Overheat</style>.",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_SURGE_NAME": "Despecho",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_SURGE_DESCRIPTION": "Al alcanzar el límite de <style=cKeywordName>Anticipación</style>, te mueves más rápido y obtienes <style=cKeywordName>Doble disparo</style> y <style=cIsHealing>Robo de vida</style>. Después de 10 segundos como máximo, <style=cIsDamage>Detonate</style>, luego <style=cIsUtility>Overheat</style>.",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_SCEPTER_NAME": "La reprimenda de Dante",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_SCEPTER_DESCRIPTION": "Dispara un rayo intenso que inflige <style=cIsDamage>140% de daño</style>. Mayor probabilidad de ignición cuanto más cerca esté del objetivo. Si se mantiene presionado durante 2 segundos o más, dispara un rayo final al soltarlo para causar <style=cIsDamage>150% de daño</style>.",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_ANTICIPATION": "<style=cKeywordName>Anticipación</style>Por cada 100 de calor perdido y/o ganado, el pirómano gana 1 carga de anticipación; Después de obtener 5 cargas, puede activar el Masoquismo; Los cargos adicionales aumentan el daño y la duración; Todos los cargos se consumen al final.",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_DETONATE": "<style=cKeywordName>Detonar</style>El pirómano explota e inflige <style=cIsDamage>150 % de daño</style> veces la cantidad de cargos de anticipación acumulados.",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_LIFESTEAL": "<style=cKeywordName>Robo de vida</style>El pirómano cura <style=cIsHealing>18%</style> del daño infligido mientras el masoquismo está activo.",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_SURGE_LIFESTEAL": "<style=cKeywordName>Robo de vida</style>El pirómano cura <style=cIsHealing>5%</style> del daño infligido mientras Rencor está activo.",
        "POPCORN_ARSONIST_BODY_KEYWORD_OVERHEAT_MASO": "<style=cKeywordName>Overheat: Masoquismo</style>Si el pirómano abandona el Masoquismo debido a una acumulación excesiva de calor, se aplica EX Overheat, lo que reduce la velocidad de movimiento y el daño al 70 %. Cancelar o dejar que la habilidad siga su curso aplica Sobrecalentamiento, lo que reduce la velocidad de ataque al 50 %.",
        "POPCORN_ARSONIST_BODY_OVERHEAT_TEXT": "¡SOBRECALENTAR!",
        "POPCORN_ARSONIST_BODY_COOLING_TEXT": "¡REFRESCÁNDOSE...!",
        "POPCORN_ARSONIST_BODY_OVERHEAT_EX_TEXT": "SOBRECALENTAMIENTO: ¡EX!",
        "POPCORN_ARSONIST_BODY_PASSIVE_NAME": "Piromanía",
        "POPCORN_ARSONIST_BODY_PASSIVE_DESCRIPTION": "Resiste el daño de fuego de todas las fuentes. Convierte un ataque que inflija más del <style=cIsDamage>30%</style> de la salud total en <style=cIsDamage>50%</style> de daño de fuego con el tiempo.",
        "POPCORN_ARSONIST_BODY_KEYWORD_PYROMANIAPASSIVE": "Piromanía no afecta el daño por caída a menos que Fragilidad esté activa.",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_NAME": "Arsonist: Mastery",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_DESCRIPTION": "As Arsonist, beat the game or obliterate on Monsoon.",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_ECLIPSE5UNLOCKABLE_ACHIEVEMENT_NAME": "Arsonist: Grandmastery",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_ECLIPSE5UNLOCKABLE_ACHIEVEMENT_DESCRIPTION": "As Arsonist, beat the game on Eclipse 5 or higher, OR beat the game on Typhoon (Starstorm 2 required).",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_ECLIPSE8UNLOCKABLE_ACHIEVEMENT_NAME": "Arsonist: Survival",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_ECLIPSE8UNLOCKABLE_ACHIEVEMENT_DESCRIPTION": "As Arsonist, beat the game on Eclipse 8, OR beat the game on Inferno (Inferno required).",
