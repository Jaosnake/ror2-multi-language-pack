{
    "la": {
        "MOFFEIN_PILOT_BODY_NAME": "Pilot",
        "MOFFEIN_PILOT_BODY_SUBTITLE": "Volans Excellens",
        "MOFFEIN_PILOT_BODY_LORE": "United Enterprise Shipping pilotis ex toto universo noto suadet ut ad programma nostrum Commissionum Auctarum pro Pilotis Praelatis se offerant! Beneficia comprehendunt accessum ad augmentationes cyberneticas pro facilioribus terrigenis, programma certificationis Armorum et Securitatis, et opportunitates recreationis luxuriosae! (Candidati quinque annis ante operationes volatus applicare expectantur. Cybernetica non omnibus participantibus promittitur. Certificationes Armorum et Securitatis solum per UES valent. Omnes opportunitates sicut-dantur proponuntur nec ulla emolumenta ulteriora praesumuntur, quaecumque iura maritima spatii in planetis participantibus fiant.",
        "MOFFEIN_PILOT_BODY_DESCRIPTION": "Pilot est pugnator volans qui in damno de superne pluendo excellit.<style=cSub>\r\n\r\n< ! > Pilot periculum vitare potest in aere manendo. Callidus usus artium eius maximam moram aeris tibi concedet.\r\n\r\n< ! > Scopus Captus! adhiberi potest ut casum tuum frenares.\r\n\r\n< ! > Expeditio Velox sursum it cum in terra utitur, et ante cum in aere utitur.\r\n\r\n< ! > Hostes in caelum Impetu Aerio pelle, deinde id cum Scopo Capto! coniunge ut eos in aere versites.",
        "MOFFEIN_PILOT_BODY_OUTRO_FLAVOR": "..atque ita discessit, somniis de caelo iam infra relictis.",
        "MOFFEIN_PILOT_BODY_MAIN_ENDING_ESCAPE_FAILURE_FLAVOR": "..atque ita evanuit, caelum in perpetuum inattingibile.",
        "MOFFEIN_PILOT_BODY_OUTRO_FAILURE": "..atque ita evanuit, caelum in perpetuum inattingibile.",
        "MOFFEIN_PILOT_BODY_PRIMARY_NAME": "Ignis Cumulatus",
        "MOFFEIN_PILOT_BODY_PRIMARY_DESCRIPTION": "Armis tuis iacula pro <style=cIsDamage>160% damno</style>. Omnis tertius ictus <style=cIsDamage>explodit</style> et pro <style=cIsDamage>320% damno</style> facit.",
        "MOFFEIN_PILOT_BODY_PRIMARY_RETURNS_DESCRIPTION": "Armis tuis iacula pro <style=cIsDamage>160% damno</style>. Omnis tertius ictus pro <style=cIsDamage>320% damno</style> facit et <style=cIsDamage>penetrat</style>.",
