			if (mageFreed && Object.op_Implicit((Object)(object)mageBuddy) && !stage.sceneDef.suppressPlayerEntry && stage.sceneDef.suppressNpcEntry)
			{
				mageBuddy.Respawn(stage.GetPlayerSpawnTransform().position, Quaternion.identity, false);
			}
			if (sceneDef.baseSceneName == "bazaar" && !mageFreed)
			{
				GameObject val = GameObject.Find("HOLDER: Store/HOLDER: Store Platforms/LockedMage/");
				Object.Destroy((Object)(object)val.GetComponent<GameObjectUnlockableFilter>());
				val.SetActive(true);
			}
		}

		private void Run_onRunStartGlobal(Run obj)
		{
