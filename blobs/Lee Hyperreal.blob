			skillLocator = ((Component)this).gameObject.GetComponent<SkillLocator>();
			iconState = UltimateIconState.NONE;
			energy = 0f;
			energyRegenAllowed = true;
			ChildLocator component = ((Component)modelLocator.modelTransform).GetComponent<ChildLocator>();
			baseTransform = component.FindChild("BaseTransform");
			loopDomainEffect = Object.Instantiate<GameObject>(ParticleAssets.RetrieveParticleEffectFromSkin("domainFieldLoopEffect", charBody), ((Component)baseTransform).transform.position, Quaternion.identity);
			loopDomainEffect.transform.localScale = new Vector3(4f, 4f, 4f);
			despawnDomainEffect = Object.Instantiate<GameObject>(ParticleAssets.RetrieveParticleEffectFromSkin("domainFieldEndEffect", charBody), ((Component)baseTransform).transform);
			loopDomainEffect.SetActive(false);
			despawnDomainEffect.SetActive(false);
			yellowOrbDomainEffects = new List<GameObject>();
			yellowCloneObjects = new List<GameObject>();
			redCloneObjects = new List<GameObject>();
			if (AkSoundEngine.IsInitialized())
			{
				AkSoundEngine.SetRTPCValue("Volume_Lee_Voice", Config.voiceVolume.Value);
			}
			domainAerialEffectLoop = Object.Instantiate<GameObject>(ParticleAssets.RetrieveParticleEffectFromSkin("primaryAerialLoop", charBody), baseTransform);
			domainAerialEffectLoopParticleSystem = ((Component)domainAerialEffectLoop.transform.GetChild(0).GetChild(0)).GetComponent<ParticleSystem>();
			domainAerialEffectLoopParticleSystem.Stop();
