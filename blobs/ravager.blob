	internal static class Config
	{
		public static ConfigFile myConfig;

		public static ConfigEntry<KeyboardShortcut> restKey;

		public static ConfigEntry<KeyboardShortcut> tauntKey;

		public static ConfigEntry<KeyboardShortcut> danceKey;

		public static ConfigEntry<bool> centeredBloodWell;

		public static ConfigEntry<bool> oldBloodWell;

		public static ConfigEntry<bool> badass;

		public static ConfigEntry<bool> permanentCling;

		public static ConfigEntry<bool> allySucc;

		public static ConfigEntry<bool> bossGrab;

		public static ConfigEntry<bool> permanentBossCling;

		public static ConfigEntry<bool> clingToAllies;

		public static ConfigEntry<bool> cursed;

		public static ConfigEntry<bool> useless;

		internal static void ReadConfig()
		{
			//IL_0105: Unknown result type (might be due to invalid IL or missing references)
			//IL_012b: Unknown result type (might be due to invalid IL or missing references)
			//IL_0151: Unknown result type (might be due to invalid IL or missing references)
			centeredBloodWell = BindAndOptions("01 - General", "Centered Blood Well", defaultValue: false, "Puts the Blood Well gauge on top of the crosshair. Does nothing if Old Blood Well is enabled. Requires run restart.");
			oldBloodWell = BindAndOptions("01 - General", "Old Blood Well", defaultValue: false, "Uses the old Blood Well gauge below the health bar. Requires run restart.");
			badass = BindAndOptions("01 - General", "Badass Mode", defaultValue: false, "If set to true, Ravager becomes a total BadAss when selected.");
			permanentCling = BindAndOptions("01 - General", "Permanent Cling", defaultValue: false, "If set to true, you can cling onto walls indefinitely.");
			allySucc = BindAndOptions("01 - General", "Allow Ally Projectile Suck", defaultValue: true, "If set to false, Nullify stops absorbing ally projectiles.");
			bossGrab = BindAndOptions("01 - General", "Allow Boss Grab", defaultValue: true, "If set to false, empowered Brutalize will no longer grab bosses.");
			permanentBossCling = BindAndOptions("01 - General", "Permanent Boss Cling", defaultValue: false, "If set to true, Brutalize will cling onto bosses indefinitely.");
			cursed = BindAndOptions("01 - General", "Cursed", defaultValue: false, "Enables unfinished, stupid and old content.", restartRequired: true);
			useless = BindAndOptions("01 - General", "Useless", defaultValue: true, "Don't change this.");
			restKey = BindAndOptions<KeyboardShortcut>("02 - Keybinds", "Rest Emote", new KeyboardShortcut((KeyCode)49, Array.Empty<KeyCode>()), "Key used to Rest");
			tauntKey = BindAndOptions<KeyboardShortcut>("02 - Keybinds", "Taunt Emote", new KeyboardShortcut((KeyCode)50, Array.Empty<KeyCode>()), "Key used to Taunt");
			danceKey = BindAndOptions<KeyboardShortcut>("02 - Keybinds", "Dance Emote", new KeyboardShortcut((KeyCode)51, Array.Empty<KeyCode>()), "Key used to Dance");
		}

		public static void InitROO(Sprite modSprite, string modDescription)
		{
			if (MainPlugin.rooInstalled)
			{
				_InitROO(modSprite, modDescription);
			}
		}

		public static void _InitROO(Sprite modSprite, string modDescription)
		{
			ModSettingsManager.SetModIcon(modSprite);
			ModSettingsManager.SetModDescription(modDescription);
		}

		public static ConfigEntry<T> BindAndOptions<T>(string section, string name, T defaultValue, string description = "", bool restartRequired = false)
		{
			if (string.IsNullOrEmpty(description))
			{
				description = name;
			}
			if (restartRequired)
			{
				description += " (restart required)";
			}
			ConfigEntry<T> val = myConfig.Bind<T>(section, name, defaultValue, description);
			if (Chainloader.PluginInfos.ContainsKey("com.rune580.riskofoptions"))
			{
				TryRegisterOption<T>(val, restartRequired);
			}
			return val;
		}

		public static ConfigEntry<float> BindAndOptionsSlider(string section, string name, float defaultValue, string description = "", float min = 0f, float max = 20f, bool restartRequired = false)
		{
			if (string.IsNullOrEmpty(description))
			{
				description = name;
			}
			if (restartRequired)
			{
				description += " (restart required)";
			}
			ConfigEntry<float> val = myConfig.Bind<float>(section, name, defaultValue, description);
