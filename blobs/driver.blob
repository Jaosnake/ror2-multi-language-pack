					{
						reference.defaultMaterial = modelSwapInfo.material;
					}
				}
				childLocator.FindChildGameObject("PistolModel").SetActive(true);
				bool active = CharacterSelectSurvivorPreviewDisplayController.HasSkillVariantEnabled(base.currentLoadout, driverBodyIndex, skillLocator.utility.skillFamily, Skills.skateboardSkillDef);
				childLocator.FindChildGameObject("SkateboardBackModel").SetActive(active);
			}

