        "ACHIEVEMENT_EQUIPMENT_SANDSWEPT_FLAWLESS_DESIGN_NAME": "Ostatni",
        "ACHIEVEMENT_EQUIPMENT_SANDSWEPT_FLAWLESS_DESIGN_DESCRIPTION": "Ukończ grę z co najmniej jednym złomem każdej rzadkości.",
        "SS_RANGER_BODY_NAME": "Ranger",
        "SS_RANGER_BODY_SUBTITLE": "Piekielny Marszałek",
        "SS_RANGER_OUTRO": "...i tak odeszła, z więcej pytaniami niż odpowiedziami.",
        "SS_RANGER_FAIL": "...i tak zniknęła, pochłonięta przez wątpliwości.",
        "RANGER_SKIN_DEFAULT_NAME": "Default",
        "RANGER_SKIN_DEFAULT_DESC": "Domyślna skórka dla tego ocalałego.",
        "RANGER_SKIN_MAJOR_NAME": "Major",
        "RANGER_SKIN_MAJOR_DESC": "Mundur zarezerwowany dla wysoko postawionych wyznawców, wskazany przez jego niebieski kolor. Zawsze pamiętany, nigdy nie używany.",
        "RANGER_SKIN_RENEGADE_NAME": "Renegat",
        "RANGER_SKIN_RENEGADE_DESC": "Alternatywna ścieżka apostazji. Zawsze wyobrażana, nigdy nie używana.",
        "RANGER_SKIN_MILEZERO_NAME": "Mile Zero",
        "RANGER_SKIN_MILEZERO_DESC": "Jej kolory.",
        "RANGER_SKIN_SANDSWEPT_NAME": "Sandswept",
        "RANGER_SKIN_SANDSWEPT_DESC": "Szaty z fatalnej misji, której nigdy nie można cofnąć. Zawsze przechowywane, nigdy nie używane.",
        "ACHIEVEMENT_RANGERCLEARGAMEMONSOON_NAME": "Ranger: Mistrzostwo",
        "ACHIEVEMENT_RANGERCLEARGAMEMONSOON_DESCRIPTION": "Jako Ranger, ukończ grę lub dokonaj obliteracji na trudności Monsoon.",
        "SANDSWEPT_ELECTR_NAME": "VOL-T",
        "SANDSWEPT_ELECTR_SUBTITLE": "Moc w Nadmiarze",
        "SANDSWEPT_ELECTR_OUTRO": "I tak odeszła, spłaciwszy swój dług moralny.",
        "SANDSWEPT_ELECTR_FAIL": "I tak zniknęła, jej ostatnie iskry gasnąc.",
        "SANDSWEPT_ELECTR_PASSIVE_NAME": "Niestabilne Tarcze",
        "SANDSWEPT_ELECTR_PASSIVE_DESC": "<style=cIsUtility>Zaczyna z wrodzoną tarczą</style>. Gdy tarcza <style=cDeath>pęknie</style>, poraź pobliskie cele zadając <style=cIsDamage>2x250% obrażeń</style> i zyskaj <style=cIsUtility>+40% prędkości ruchu</style> na <style=cIsDamage>7</style> sekund.",
        "ACHIEVEMENT_ELECTRICIANCLEARGAMEMONSOON_NAME": "VOL-T: Mistrzostwo",
        "ACHIEVEMENT_ELECTRICIANCLEARGAMEMONSOON_DESCRIPTION": "Jako VOL-T, ukończ grę lub dokonaj obliteracji na trudności Monsoon.",
        "ACHIEVEMENT_ELECTRICIANREPAIR_NAME": "Technik",
        "ACHIEVEMENT_ELECTRICIANREPAIR_DESCRIPTION": "Napraw uszkodzonego robota w Pękniętym Lesie.",
        "SANDSWEPT_BROKENELEC_NAME": "Uszkodzony Robot",
        "SANDSWEPT_SWEPSWEP_NAME": "Zamiataj-Zamiataj Piaskowa",
        "SANDSWEPT_VOID_SHRINE_RUIN_NAME": "Sanktuarium Zniszczenia",
        "SANDSWEPT_VOID_SHRINE_RUIN_CONTEXT": "Złóż ofiarę Sanktuarium Zniszczenia",
        "SANDSWEPT_VOID_SHRINE_RUIN_USE_MESSAGE_2P": "<style=cShrine>Korupcja się rozprzestrzenia.</color>",
        "SANDSWEPT_VOID_SHRINE_RUIN_USE_MESSAGE": "<style=cShrine>Korupcja się rozprzestrzenia.</color>",
        "SANDSWEPT_SHRINE_OF_RUIN_DESCRIPTION": "Po aktywacji przez ocalałego, Sanktuarium Zniszczenia konsumuje 10 losowych białych przedmiotów z ekwipunku i zniekształca następny etap.",
        "SANDSWEPT_SHRINE_SACRIFICE_NAME": "Sanktuarium Ofiary",
        "SANDSWEPT_SHRINE_SACRIFICE_CONTEXT": "Złóż ofiarę Sanktuarium Ofiary",
        "SANDSWEPT_SHRINE_SACRIFICE_USE_MESSAGE_2P": "<style=cShrine>Twój czas został poświęcony.</color>",
        "SANDSWEPT_SHRINE_SACRIFICE_USE_MESSAGE": "<style=cShrine>Czas {0} został poświęcony.</color>",
        "SANDSWEPT_SHRINE_SACRIFICE_DESCRIPTION": "Po aktywacji, Sanktuarium Ofiary konsumuje {curseCost}% maksymalnego zdrowia ocalałego w zamian za {itemCount} kopii losowego zwykłego przedmiotu.",
        "SANDSWEPT_SHRINE_OF_SACRIFICE_DESCRIPTION": "Po aktywacji, Sanktuarium Ofiary konsumuje {curseCost}% maksymalnego zdrowia ocalałego w zamian za {itemCount} kopii losowego zwykłego przedmiotu.",
        "SANDSWEPT_SHRINE_FUTURE_NAME": "Sanktuarium Przyszłości",
        "SANDSWEPT_SHRINE_FUTURE_CONTEXT": "Złóż ofiarę Sanktuarium Przyszłości",
        "SANDSWEPT_SHRINE_FUTURE_USE_MESSAGE_2P": "<style=cShrine>Czas się zmienił.</color>",
        "SANDSWEPT_SHRINE_FUTURE_USE_MESSAGE": "<style=cShrine>Czas się wypaczył.</color>",
        "SANDSWEPT_SHRINE_OF_THE_FUTURE_DESCRIPTION": "Po aktywacji, Sanktuarium Przyszłości przywołuje losowego silnego elitarnego minibossa dla każdego gracza, który po pokonaniu upuszcza {itemCount} potencjalnych przedmiotów na gracza.",
        "SANDSWEPT_SHRINE_DEATH_NAME": "Sanktuarium Śmierci",
        "SANDSWEPT_SHRINE_DEATH_CONTEXT": "Złóż ofiarę Sanktuarium Śmierci",
        "SANDSWEPT_SHRINE_DEATH_DESCRIPTION": "Po aktywacji, Sanktuarium Śmierci konsumuje {percentHealthCost}% zdrowia ocalałego i wyłącza całe leczenie na {healingDisableDuration} sekund, ale ma {onKillProcChance}% szansy na aktywację efektów przy zabiciu i {onInteractProcChance}% szansy na aktywację efektów przy interakcji.",
        "SANDSWEPT_VOLTAIC_DRONE_BODY": "Dron Woltaiczny",
        "SANDSWEPT_VOLTAIC_DRONE_BROKEN_NAME": "Uszkodzony Dron Woltaiczny",
        "SANDSWEPT_VOLTAIC_DRONE_CONTEXT": "Naprawić?",
        "SANDSWEPT_VOLTAIC_DRONE_BROKEN_DESCRIPTION": "Towarzysz kupiony za złoto, który będzie podążał za ocalałym z krótkiego dystansu. Wystrzeliwuje elektryczny pocisk, który elektryzuje pobliskie cele.",
        "SANDSWEPT_VOLTAIC_PRIM_NAME": "Jump Start",
        "SANDSWEPT_VOLTAIC_PRIME_DESC": "Wystrzeliwuje pręt wprowadzający, który wielokrotnie elektryzuje cele za 200% obrażeń.",
        "SANDSWEPT_VOLTAIC_OPERATOR_DESC": "Wystrzeliwuje pręt wprowadzający, który wielokrotnie poraża cele za 600% obrażeń, utrzymując je w miejscu.",
        "SANDSWEPT_VOLTAIC_DESC": "Wystrzeliwuje pręty wprowadzające, które łukiem przenoszą elektryczność na pobliskie cele za 200% obrażeń.",
        "SANDSWEPT_VOLTAIC_PICKUP": "Wystrzeliwuje pręty wprowadzające, które elektryzują cele.",
        "SANDSWEPT_INFERNO_DRONE_BODY": "Dron Inferno",
        "SANDSWEPT_INFERNO_DRONE_BROKEN_NAME": "Uszkodzony Dron Inferno",
        "SANDSWEPT_INFERNO_DRONE_CONTEXT": "Naprawić?",
        "SANDSWEPT_INFERNO_DRONE_BROKEN_DESCRIPTION": "Towarzysz kupiony za złoto, który będzie podążał za ocalałym z krótkiego dystansu. Wystrzeliwuje koktajle Mołotowa.",
        "SANDSWEPT_INFERNO_PRIM_NAME": "Scorch",
        "SANDSWEPT_INFERNO_PRIM_DESC": "Wystrzeliwuje rakietę, która pozostawia kałuże napalmu za 3x300% obrażeń na sekundę.",
        "SANDSWEPT_INFERNO_OPERATOR_DESC": "Posuń się naprzód i pokryj ziemię, pozostawiając kałuże napalmu za 7x300% obrażeń. Skaluje się z prędkością ataku.",
        "SANDSWEPT_INFERNO_DESC": "Wystrzeliwuje rakiety w cele, które tworzą kałuże napalmu za 300% obrażeń na sekundę.",
        "SANDSWEPT_INFERNO_PICKUP": "Wystrzeliwuje rakiety w cele, które pozostawiają kałuże napalmu.",
        "SANDSWEPT_OBJECTIVE_CHARGE_TP_EARLY": "Znajdź i aktywuj <style=cDeath>Teleporter <sprite name=\"TP\" tint=1></style> w <style=cDeath>{0}s!</style>",
        "SANDSWEPT_OBJECTIVE_GET_UP_TO_X_ITEMS": "Zdobądź do <style=cIsUtility>{0} przedmiotów</style>.",
        "SANDSWEPT_INPUT_FEATHER": "Skok Wyrwanego Pióra",
        "ITEM_SANDSWEPT_CEREMONIAL_JAR_LORE": "We wczesnych dniach, żywicę można było znaleźć tylko w kilku małych miasteczkach i wioskach ludu wydm. Następnie wiedza o tym, jak ją wytwarzać, rozprzestrzeniła się. Zrób dzban ze specjalnego materiału. Napełnij go wodą, która jest warta poświęcenia. I wrzuć do niego trochę swojego własnego życia. Wtedy dzban wypełni się żywicą, która jest warta więcej niż złoto. Patrząc na ten dzban, czuję jak moje własne ciało się starzeje. Zastanawiam się, ile żyjących istot umarło, aby go napełnić. Mam nadzieję, że ten artefakt pomoże ci w walce. Został stworzony z zamiarem łączenia zarówno naszej natury, jak i naszych wrogów.",
        "ITEM_SANDSWEPT_GLACIAL_PLASMA_LORE": "Transkrypcja UES [ZATAJONE] o transporcie zamrożonego obcego sprzętu.\n\n«Pij.»\n\n«To jest... jakiś płyn.»\n\n«Tak. Teraz pij.»\n\n«Skąd to jest? Nigdy wcześniej tego nie widziałem.»\n\n«Wróciło z tajnej placówki na Antar, która została wysłana na górę. Zajęło to ponad rok, zanim wróciło.»\n\n«Dlaczego mamy to pić? Może to być trujące.»\n\n«Czy obcy, którzy to stworzyli, nie byliby w stanie łatwiej przystosować się do przetrwania na swoim sprzęcie? To prawdopodobnie bardziej bezpieczne niż woda, którą pijesz na co dzień.»\n\n«W porządku... Dobra.»\n\n«A.»\n\n«Co? Lepiej?»\n\n«Czuję się... chyba żywy. Zimny. Świetny.»\n\n«Daj mi to.»",
        "ITEM_SANDSWEPT_TORN_FEATHER_LORE": "<style=cMono>\n//--AUTO-transkrypcja Z ŁADOWNI UES 6 [ZATAJONE] --//\n</style>\n«Wow...»\n\n«Ładny, prawda? Nasz zespół znalazł to na jakiejś planecie. Było schowane w skale, prawie niemożliwe do znalezienia. Zajęło im trochę czasu, zanim to wyciągnęli. Wygląda jak pióro, tylko... nie wiem, masywne.»\n\n«Czy to naprawdę działa?»\n\n«Tak, właściwie to bardzo dobrze. Chcesz spróbować?»\n\n«Uhm...»\n\n«Po prostu weź to i pomyśl o ruchu.»\n\n«Łatwo mówić... Wow. To jak pływanie.»\n\n«Co?»\n\n«To się nazywa Skok. Po prostu płyniesz... jakbym mógł latać.»",
        "ITEM_SANDSWEPT_HALLOWED_ICHOR_LORE": "To będzie najpotężniejszy twór, jaki ci udostępnię. Stworzyłem wiele tych artefaktów, zanim się pojawiłeś. Każdy z nich ma własne intencje, własne przeznaczenie. Ten w szczególności został stworzony, aby pomóc ci w osiągnięciu celu. Jest jednak zepsuty. Niegdyś był słodki i kojący; teraz jest kwaśny i mściwy.\n\nWeź go i użyj go dobrze. Zniszcz wszystko, co stanie ci na drodze.\n\n«Zniszczę.»",
        "ITEM_SANDSWEPT_SEQUENCED_FATE_LORE": "Co to jest? Jakiś interfejs?\n\nRozumiem. To nie jest jeden z moich konstruktów, ale jest kompetentny. Choć nie dość kompetentny. Wiem, że nie będziesz w stanie osiągnąć celu, którego pragniesz. Mimo wszystko, życzę ci powodzenia. To urządzenie ma na celu przywołanie woli samej Przestrzeni. Wielu próbowało i nie udało im się utrzymać tego po prostu z powodu losu. Może tobie się uda.\n\n«Dziękuję ci.»\n\nWiedz, że twój los został już przesądzony.",
        "ITEM_SANDSWEPT_THEIR_PROMINENCE_LORE": "«Dwóch braci, na skraju studni. <style=cIsVoid>Obaj młodzi, obaj niewinni.</style>»\n\n«Robak wchodzi do ucha jednego i nagle starszy brat wariuje, prawie zabijając młodszego. Ich matka prowadzi obu na górę, ale znajduje ich krwawiących i zmarłych. Wychodzi z tego z krwawiącymi rękami i twarzą, z zalanymi łzami oczami, z synem na wpół żywym. Zwraca się do wiosek górskich, szukając schronienia. Odmawiają; to Pustka, ale nie ci ludzie mają Pustkę. Oni mają tchórzostwo. Pogardzają nią za... za prośbę o pomoc. Odpychają ją. Odchodzi. Idzie na targowisko, kiedy upada na ziemię i zaczyna płakać. Krwawiące serce. Wstaje, idzie do szamana i sprzedaje duszę starszego brata, aby wyleczyć młodszego. Szaman przyjmuje i leczy młodszego brata. Matka pozbywa się Robaka, ale szaman bierze starszego brata w zamian. Młodszy brat budzi się, nie pamiętając, co się stało, i pyta: «Gdzie jest mój brat?». Nikt mu nie mówi. Jest zbyt młody, aby wiedzieć.»\n\n«Dlaczego ta opowieść?»\n\n«Ponieważ to samo stanie się z tobą.»",
        "ITEM_SANDSWEPT_FESTERING_HUNGER_LORE": "<style=cMono>\nWitaj w DataScraper (v3.1.53 - wersja beta)\n$ Skanowanie pamięci... gotowe.\n$ Rozpoznawanie struktury pliku.\n$ Odtwarzanie... Proszę czekać...\n====================================\n</style>\n«W porządku, zawartość: ten plik jest do niczego. W ogóle nie mogę go odczytać.»\n\n«Czy próbowałeś drugiego pliku?»\n\n«Tak. To samo.»\n\n«Więc to tylko złom?»\n\n«Tak. Jak wszystko inne.»\n\n«Po co to mamy?»\n\n«Ponieważ dowódca każe nam to mieć. Myślę, że po prostu chcą się pozbyć tego.»",
        "ITEM_SANDSWEPT_MILLENIUM_LORE": "Transkrypcja ostatniego znanego nagrania UES 'Shimmer Mark'\n\n«Tam jest tak... tak fioletowo i tak bardzo... pusto. Jest naprawdę pięknie. Zaczynam rozumieć, dlaczego niektórzy kolonizują głęboką przestrzeń. To jak patrzenie na najciemniejszy obraz, ale... och, co to jest?»\n\n«Co jest?»\n\n«Widzę coś. To jest... duże. Bardzo duże. Och, to się porusza.»\n\n«Uciekaj stamtąd.»\n\n«Nie mogę. To tak... szybkie. Uderzyło w nas. Woda. Wszędzie woda. To potóp. Pochłania nas. Ściany się trzęsą. Tonę. Czekaj. To... to jest ładne. Jest tak cholernie niebieskie. Przywodzi mi na myśl... dom. Ciebie. Was wszystkich. Żegnajcie.»\n\n-- Koniec nagrania --",
        "ITEM_SANDSWEPT_CROWNS_DIAMOND_LORE": "«Nadal uważam, że nie powinniśmy tego brać. To był jakiś religijny artefakt...»\n\n«Religijny artefakt, który zamienia się w diament? Daj spokój. To na pewno ma jakąś większą wartość.»\n\n«No właśnie, dlatego powinniśmy go oddać. Wszystkie te artefakty mają tendencję do bycia przeklętymi przez boskie istoty, których nie znamy. Albo gorsze.»\n\n«Którzy bogowie? Ci z Pustki? Ci z Kontaktu? Są martwi. Nie ma się czego bać.»\n\n«Myślę, że właśnie dlatego powinniśmy się bać.»",
        "ITEM_SANDSWEPT_DRIFTING_PERCEPTION_LORE": "«Co się stało z [Redacted]?» dialog między członkami UES o zagubionym członku zespołu.\n\n«Nie wiemy. Po prostu... zniknął.»\n\n«Co masz na myśli mówiąc zniknął? To był jeden z naszych najlepszych żołnierzy.»\n\n«Krążą plotki, że zdezerterował. Musimy przyznać, że to możliwe. Miał dostęp do wielu tajnych materiałów i mógł po prostu... zniknąć, jeśli chciał.»\n\n«Więc nie żyje?»\n\n«Być może. Albo gorsze.»\n\n«Co może być gorszego?»\n\n«Wiele rzeczy. Lepiej nie myśleć o tym.»",
        "ITEM_SANDSWEPT_SUN_FRAGMENT_LORE": "«Co to do cholery jest?»\n\n«Technicznie? To skorupka jajka. Ukradłem ją z pozostałości jednego z tych wielkich stworzeń, które zaatakowały naszą starą bazę.»\n\n«Po co? To tylko skorupka.»\n\n«Nie tylko skorupka. Popatrz na nią uważnie. Widzisz, jak świeci?»\n\n«...tak.»\n\n«Więc wygląda na to, że wciąż jest w niej trochę energia. Chcę ją zachować na wypadek, gdybyśmy mogli ją wykorzystać.»\n\n«Jesteś szalony.»\n\n«Możliwe.»",
        "ITEM_SANDSWEPT_SMOULDERING_DOCUMENT_LORE": "Zamówienie: Poufny dokument UES\nNumer śledzenia: 244*****\nPrzewidywana dostawa: 09/14/2056\nMetoda wysyłki: Nocna\nAdres wysyłki: Kwatera Główna UES, Ziemia\nSzczegóły wysyłki:\n\nW załączeniu znajduje się poufny dokument dotyczący przeprojektowania systemów bezpieczeństwa w różnych placówkach. Zmiany te są wprowadzane po kilku incydentach, w których niektórzy członkowie zespołów badawczych zaginęli podczas korzystania z teleportacji. Uważa się, że są one spowodowane wadliwym sprzętem. Jednak nasze dalsze badania wykazały, że przyczyną był jak dotąd nieznany obcy organizm, który znalazł drogę do systemów stacji kosmicznych.\n\nZaleca się, aby cały personel unikał używania teleportacji, dopóki organizmy nie zostaną w pełni zbadane.",
        "ITEM_SANDSWEPT_SACRIFICIAL_BAND_LORE": "Transkrypcja - «Chyba znalazłem jednego z tych 'elitarnych' wrogów, o których wyżej mówią.»\n\n«Gdzie?»\n\n«Na planecie poniżej. Ten był większy od pozostałych. Miał na sobie jakąś złotą zbroję. I płonął.»\n\n«Jak go zabiłeś?»\n\n«Strzelałem w niego, dopóki nie przestał się ruszać.»\n\n«I co dostałeś?»\n\n«To. Ten pierścień.»\n\n«Co robi?»\n\n«Kiedy go noszę, czuję, jakby było mnie więcej. Jakbyśmy wszyscy mogli być... więcej.»",
        "ITEM_SANDSWEPT_NUCLEAR_SALVO_LORE": "«Bracie. PATRZ NA TO ARCHITEKTONICZNE ARCYDRZIEŁO.»\n\n«To z pewnością... imponujące. Ale do czego służy?»\n\n«DO ZABIJANIA, BRACIE. DO ZABIJANIA.»\n\n«Jesteś głodny?»\n\n«Zawsze.»\n\n«Myślę, że nadszedł czas, abyśmy wrócili na statek.»\n\n«Jeszcze nie. CHCĘ ZOBACZYĆ, JAK TO DZIAŁA.»\n\n«... w porządku. Tylko uważaj na to, czego dotykasz.»",
        "ITEM_SANDSWEPT_UNIVERSAL_VIP_PASS_LORE": "«Przepraszam pana, to jest strefa zastrzeżona. Nie możemy pana przepuścić.»\n\n«Specjalne zezwolenie UES. Lepiej uwierz, że musisz mnie przepuścić.»\n\n«Proszę pokazać dokumenty.»\n\n«Jasne. Oto one.»\n\n«...to jest przepustka VIP.»\n\n«Tak.»\n\n«Na siłownię.»\n\n«Tak.»\n\n«Proszę pana, to jest laboratorium badawcze. Nie ma tu siłowni.»\n\n«Posłuchaj, kolego. Mam przepustkę VIP. Albo mnie przepuścisz, albo zadzwonię do szefa.»\n\n«...»\n\n«Właśnie tak myślałem.»",
        "ITEM_SANDSWEPT_POCKET_PLUTONIUM_LORE": "«Słuchajcie, wy z górnego pokładu, jeśli nie chcecie słuchać: PRZESTAŃCIE SIĘ OBijać.» przemowa zespołu inżynieryjnego.\n\n«Robimy co możemy. To nie nasza wina, że dostajemy przestarzały sprzęt.»\n\n«Co mówisz o tym generatorze?»\n\n«...to jest radioaktywne.»\n\n«Tak, wiem. Dlatego mamy to.»\n\n«Po co?»\n\n«Na wypadek, gdybyśmy potrzebowali dużej ilości energii. Co będzie, i to szybko.»\n\n«To nie jest bezpieczne. Ci ludzie nie są przeszkoleni do obsługi materiałów radioaktywnych.»\n\n«Nie obchodzi mnie to. Mamy robotę do wykonania.»",
        "ITEM_SANDSWEPT_MAKESHIFT_PLATE_LORE": "«UES w końcu zbudowało prototyp bazy na Petrocor V.» raport z dialogu.\n\n«Najwyższy czas. Straciliśmy tam tylu ludzi. Mam nadzieję, że tym razem będzie lepiej.»\n\n«Tak, jak w przypadku pozostałych ośmiu baz, które próbowaliśmy zbudować?»\n\n«Cóż, tym razem się postarali. Mamy lepszy sprzęt, lepszą ochronę i lepsze zabezpieczenia.»\n\n«A co z elastycznością? Uderzyły nas tam stworzenia, których jeszcze nie widzieliśmy. Jak zamierzamy się przed nimi bronić?»\n\n«Specjalnie zaprojektowaną zbroją. Nazywa się płyta. Podobno może wytrzymać każdy atak.»\n\n«Mam nadzieję, że to prawda.»",
        "EQUIPMENT_SANDSWEPT_CORRUPTED_CATALYST_LORE": "Ciekawy konstrukt. Naturalny projekt, proste ale eleganckie proporcje. Wymaga silnej intencji, aby stworzyć. Jest niesamowicie stary. I jest zepsuty. Przez kogoś, kto był silniejszy niż ja. Zostawię to tutaj, abyś mógł sam zdecydować, co z tym zrobić. Twórca jest dawno nieżywy, ale ich duch wciąż żyje. Użyj go dobrze, mały robaku.",
        "EQUIPMENT_SANDSWEPT_FLAWLESS_DESIGN_LORE": "To był jej ostateczny projekt. Korona jej nauki. Sam projekt, cena warta końca wszystkiego. Poświęciła wszystko, aby go stworzyć: swój czas, swoją duszę, swoje ciało. I to jej się udało. Stworzyła coś, co mogłoby duplikować wszystko. Był w stanie odtworzyć nawet ją samą. I zrobił to. Ten projekt był ostatnią rzeczą, jaką kiedykolwiek stworzyła. Zostawiła go swojemu mistrzowi, który następnie go złomował. Dobrze. Niech tak zostanie. Zostawiam ten projekt tobie. Użyj go dobrze. Ale wiedz, że jest przeklęty. Przeklęty przez samą śmierć.",
        "SS_RANGER_DESCRIPTION": "Ranger to wszechstronny ocalały, który używa ciepła i ładunku do ulepszania swojego arsenału.\n\n< ! > Prąd Stały: Użyj Prądu Stałego do generowania ładunków, które mogą być użyte przez inne umiejętności.\n< ! > Uwolnij: Zwiększ obrażenia od Uwolnij, używając podstawowych umiejętności! Więcej ładunków = więcej obrażeń.\n< ! > Galwanizuj: Ulepsz Galwanizuj, uzupełniając ładunki z Prądu Stałego. Orbity dzielą się na więcej celów po dotknięciu celu.\n< ! > Ruch boczny: Użyj Ruchu Bocznego, abyś był zwinny; otrzymanie obrażeń podczas użycia Ruchu Bocznego resetuje jego czas odnowienia!\n< ! > Overdrive: Użyj Overdrive, aby przekształcić karabin i odblokować zupełnie nowy zestaw umiejętności. Zwiększ obrażenia od Overdrive, utrzymując niski poziom ciepła, wchodząc w Overdrive z niskim ciepłem.\n< ! > Podpalenie: Użyj Podpalenia, abyś był agresywny! Zmniejsz obecne ciepło, aby kontynuować walkę, odwadniając i paląc wrogów.\n< ! > Sygnatura Ciepła: Użyj Sygnatury Ciepła, aby być zwinnym i ogłuszającym. Zaatakuj wroga, który cię zaatakował, zwiększając obrażenia od Sygnatury Ciepła, unikając ataku.\n< ! > Chłodnica: Użyj Chłodnicy, aby być zwinnym i wyjść z Overdrive! Wyjście z Overdrive z większą ilością ciepła da ci większy buff do następnego Overdrive. Wybuchnij wrogów po wyjściu.\n< ! > Zatruty: Użyj Zatrutej Wody, aby być zwinnym i ogłuszającym. Zaatakuj wroga, który cię zaatakował, obrażenia od Zatrutej Wody są zwiększone, jeśli unikniesz ataku.\n\nThis mod was translated by: Jaosnake",
        "SS_RANGER_BODY_LORE": "Po Czystce, Sala Czci zainwestowała dużo we własną obronę. Większość grup wybrała prostsze zabezpieczenia, ale Sala Czci poszła dalej. Zaczęli szkolić własnych Żołnierzy, wybierając najlepszych z najlepszych spośród swoich wyznawców i trenując ich, aż stali się śmiertelną siłą. Ci żołnierze byli nazywani Strażnikami Sali. Pierwszym i ostatnim z tych żołnierzy był Major. Dostał to stanowisko ze względu na jego doświadczenie i się. Major był również znany z używania ciepła do zasilania swoich umiejętności, słynąc z używania swojej broni, aby utrzymać się w walce tak długo, jak to możliwe. Stał się legendą w Sali, a jego dziedzictwo żyje do dziś.",
        "SANDSWEPT_SKILL_DIRECTCURRENT_NAME": "Prąd Stały",
        "SANDSWEPT_SKILL_DIRECTCURRENT_DESC": "Wyrzut. Wystrzel łukowaty prąd elektryczny zadający 150% <style=cIsDamage>obrażeń</style>. Trafianie wrogów generuje 1 <color=#36D7A9>{Ładunek}</color>. Trafienie wroga z większą ilością zdrowia daje dodatkowe <color=#36D7A9>{ładunki}</color>.",
        "SANDSWEPT_SKILL_RELEASE_NAME": "Uwolnij",
        "SANDSWEPT_SKILL_RELEASE_DESC": "<color=#36D7A9>Zużywa wszystkie Ładunki</color>. Wystrzel przebijający podmuch zadający 600% obrażeń, zwiększając się do 2400% przy 20 Ładunkach.",
        "SANDSWEPT_SKILL_GALVANIZE_NAME": "Galwanizuj",
        "SANDSWEPT_SKILL_GALVANIZE_DESC": "<color=#36D7A9>Zużywa wszystkie Ładunki</color>. Wystrzel 3 kule elektryczności, zwiększając do 10 przy <color=#36D7A9>20 Ładunkach</color>. Kule odbijają się do 2 razy, zadając 5x100% <style=cIsDamage>obrażeń</style>.",
        "SANDSWEPT_SKILL_SIDESTEP_NAME": "Ruch Boczny",
        "SANDSWEPT_SKILL_SIDESTEP_DESC": "<style=cIsUtility>Zwinny.</style> Szybko zrób krok w bok na krótki dystans. Otrzymanie obrażeń podczas <style=cIsUtility>Ru Chu Bocznego</style> <color=#FF7F7F>resetuje</color> jego czas odnowienia.",
        "SANDSWEPT_SKILL_OVERDRIVEENTER_NAME": "Overdrive",
        "SANDSWEPT_SKILL_OVERDRIVEENTER_DESC": "<style=cIsUtility>Zwinny.</style> <style=cIsDamage>Przekształca twój karabin</style>, zastępując wszystkie umiejętności na 10 sekund. Wejście w Overdrive z <style=cIsDamage>mniej niż 50% ciepła</style> zwiększa obrażenia o 50%.",
        "SANDSWEPT_SKILL_ENFLAME_NAME": "Podpalenie",
        "SANDSWEPT_SKILL_ENFLAME_DESC": "Wystrzel szybki strumień pocisków zadających 90% <style=cIsDamage>obrażeń</style>. <style=cIsUtility>Szybki ogień</style> zwiększa obrażenia, utrzymując przycisk.",
        "SANDSWEPT_SKILL_EXHAUST_NAME": "Wydech",
        "SANDSWEPT_SKILL_EXHAUST_DESC": "<style=cIsDamage>Zapłon.</style> <style=cIsUtility>Zmniejsza obecne ciepło o 50%</style>. Wystrzel ciężki pocisk zadający 5x120% <style=cIsDamage>obrażeń</style>. Stosuje <style=cIsDamage>odwodnienie</style> i <style=cIsDamage>podpalenie</style>.",
        "SANDSWEPT_SKILL_CHAR_NAME": "żądło",
        "SANDSWEPT_SKILL_CHAR_DESC": "<style=cIsDamage>Zapłon.</style> <style=cIsUtility>Zmniejsza obecne ciepło o 50%</style>. Wystrzel strumień płomieni zadający 200% <style=cIsDamage>obrażeń</style> i stosuje <style=cIsDamage>podpalenie</style>.",
        "SANDSWEPT_SKILL_HEATSIGNATURE_NAME": "Sygnatura Ciepła",
        "SANDSWEPT_SKILL_HEATSIGNATURE_DESC": "<style=cIsUtility>Zwinny.</style> Zrób krok w bok na krótki dystans i wystrzel <style=cIsDamage>pocisk namierzający</style> zadający 4x150% <style=cIsDamage>obrażeń</style>. Jeśli unikniesz ataku pociskiem, obrażenia są zwiększone o 50%.",
        "SANDSWEPT_SKILL_HEATSINK_NAME": "Chłodnica",
        "SANDSWEPT_SKILL_HEATSINK_DESC": "<style=cIsUtility>Zwinny.</style> <style=cIsDamage>Zapłon.</style> <style=cIsUtility>Wychodzi z Overdrive</style> po Krótkim czasie. Buff do następnego Overdrive zależy od <style=cIsDamage>ciepęła w momencie wyjścia</style>. Wybuchnij, zadając 300% obrażeń.",
        "SANDSWEPT_KEYWORD_OVERDRIVE_PRIMARY": "<style=cKeywordName>Tryb Overdrive</style>Wystrzel szybki strumień pocisków zadających 90% <style=cIsDamage>obrażeń</style>. <style=cIsUtility>Szybki ogień</style> zwiększa obrażenia, utrzymując przycisk.",
        "SANDSWEPT_KEYWORD_OVERDRIVE_SECONDARY": "<style=cKeywordName>Tryb Overdrive</style><style=cIsDamage>Zapłon.</style> <style=cIsUtility>Zmniejsza obecne ciepło o 50%</style>. Wystrzel strumień płomieni zadający 200% <style=cIsDamage>obrażeń</style> i stosuje <style=cIsDamage>podpalenie</style>.",
        "SANDSWEPT_KEYWORD_OVERDRIVE_SECONDARY_ALT": "<style=cKeywordName>Tryb Overdrive</style><style=cIsDamage>Zapłon.</style> <style=cIsUtility>Zmniejsza obecne ciepło o 50%</style>. Wystrzel ciężki pocisk zadający 5x120% <style=cIsDamage>obrażeń</style>. Stosuje <style=cIsDamage>odwodnienie</style> i <style=cIsDamage>podpalenie</style>.",
        "SANDSWEPT_KEYWORD_OVERDRIVE_UTILITY": "<style=cKeywordName>Tryb Overdrive</style><style=cIsUtility>Zwinny.</style> <style=cIsDamage>Ogłuszający.</style> Zrób krok w bok na krótki dystans i wystrzel <style=cIsDamage>pocisk namierzający</style> zadający 4x150% <style=cIsDamage>obrażeń</style>. Jeśli unikniesz ataku pociskiem, obrażenia są zwiększone o 50%.",
        "SANDSWEPT_KEYWORD_OVERDRIVE_SPECIAL": "<style=cKeywordName>Tryb Overdrive</style><style=cIsUtility>Zwinny.</style> <style=cIsDamage>Zapłon.</style> <style=cIsUtility>Wychodzi z Overdrive</style> po Krótkim czasie. Buff do następnego Overdrive zależy od <style=cIsDamage>ciepła w momencie wyjścia</style>. Wybuchnij, zadając 300% obrażeń.",
        "SANDSWEPT_SKILL_OVERCHARGEDPROTECTION_NAME": "Przeładowany - Ochrona",
        "SANDSWEPT_SKILL_OVERCHARGEDPROTECTION_DESC": "Gromadź do 20 <color=#36D7A9>Ładunków</color>. <color=#36D7A9>Ładunek</color> zwiększa <style=cIsHealing>pancerz</style> o 1 na ładunek. Przy 20 ładunkach, otrzymanie obrażeń zadaje <style=cIsDamage>500% obrażeń</style> i ogłusza atakującego.",
        "SANDSWEPT_SKILL_OVERCHARGEDSPEED_NAME": "Przeładowany - Prędkość",
        "SANDSWEPT_SKILL_OVERCHARGEDSPEED_DESC": "Gromadź do 20 <color=#36D7A9>Ładunków</color>. <color=#36D7A9>Ładunek</color> zwiększa <style=cIsUtility>prędkość ruchu</style> o 1% na ładunek. Przy 20 ładunkach, otrzymanie obrażeń leczy cię o 10% <style=cIsHealing>maksymalnego zdrowia</style>.",
        "SANDSWEPT_ELECTR_DESC": "VOL-T to ocalała, która polega na kontroli terytorium, aby zrekompensować swoją kruchość.\n\n< ! > Bolt Galwaniczny: Wystrzel kulę galwaniczną, która przykleja się do powierzchni. Trafienie Boltą Galwaniczną w Pajęczę Pułapkę rozprzestrzenia elektryczność między nimi.\n< ! > Kula Burzy: Wyślij kulę energii, która uszkadza cele wewnątrz. Obrażenia skalują się z każdym celem wewnątrz.\n< ! > Pułapka Statyczna: Rozmieść pajęczę, która razi cele prądem. Mała, lekka i może być przenoszona przez Bolt Galwaniczny.\n< ! > Przeciążenie Sygnału: Opróźnia twoją tarczę, by wystrzelić potężny promień. Więcej tarczy = więcej obrażeń.",
        "SANDSWEPT_ELECTR_LORE": "Moja krew wypełnia i zaczyna krążyć. Budzę się. Czuję, jakbym spała przez wieki. Moje myśli są niespójne. Przez chwilę myślę, że wciąż jestem w łonie. Ale potem uświadamiam sobie, że leżę na stole. Jestem naga. Moje ciało jest inne. Obce. To nie jest moje ciało. Wtedy go widzę. Stoi w rogu. Patrzy na mnie. Uśmiecha się. Nie wydaje się być tutaj, aby mnie skrzywdzić. Ale nie ufam mu. Uśmiecha się jak kot. Mruga do mnie. Odwraca się i odchodzi. Zostawiając mnie samą. Z tym obcym ciałem. Z tymi obcymi myślami. Kim jestem? Czym jestem? Pamiętam tylko ból. I ogromne, przeszywające uczucie straty. Nie wiem, co się stało. Ale jestem pewna, że nie podoba mi się to, kim się stałam.",
        "SANDSWEPT_SKILL_GALVANICBOLT_NAME": "Bolt Galwaniczny",
        "SANDSWEPT_SKILL_GALVANICBOLT_DESC": "Wystrzel <style=cIsDamage>kulę galwaniczną</style>, która <style=cIsUtility>przykleja się</style> do powierzchni. Trafienie Pajęczej Pułapki Boltą Galwaniczną rozprzestrzenia elektryczność na pobliskie pułapki.",
        "SANDSWEPT_SKILL_TEMPESTSPHERE_NAME": "Kula Burzy",
        "SANDSWEPT_SKILL_TEMPESTSPHERE_DESC": "Wyślij kulę energii, która uszkadza cele wewnątrz zadając <style=cIsDamage>300% obrażeń na sekundę</style>. Obrażenia skalują się o 50% za każdy cel wewnątrz.",
        "SANDSWEPT_SKILL_STATICSNARE_NAME": "Pułapka Statyczna",
        "SANDSWEPT_SKILL_STATICSNARE_DESC": "<style=cIsUtility>Lekka.</style> Rozmieść pajęczę, która razi cele prądem zadając <style=cIsDamage>100% obrażeń na sekundę</style> przez 10 sekund. Może być przenoszona przez Bolt Galwaniczny.",
        "SANDSWEPT_SKILL_SIGNALOVERLOAD_NAME": "Przeciążenie Sygnału",
        "SANDSWEPT_SKILL_SIGNALOVERLOAD_DESC": "<style=cIsDamage>Uziemienie.</style> Opróźnia twoją <style=cIsHealing>tarczę</style> i po krótkiej chwili wystrzeliwuje promień zadający 100% opróżnionej tarczy jako <style=cIsDamage>obrażeń</style> celom przed tobą. 2x obrażenia przeciwko latającym celom.",
        "KEYWORD_LIGHTWEIGHT": "<style=cKeywordName>Lekka</style>Może być przenoszona przez Bolt Galwaniczny.",
        "KEYWORD_GROUNDING": "<style=cKeywordName>Uziemienie</style>Zadaje <style=cIsDamage>1.5x obrażeń</style> latającym celom i unieruchamia je.",
        "SANDSWEPT_THETACONSTRUCT_NAME": "Konstrukt Theta",
        "SANDSWEPT_THETACONSTRUCT_LORE": "<style=cMono>\n========================================\n====   MyBabel Automatic Translator   ====\n====   Wersja 3.1.53 (beta)          ====\n========================================\n\n$ Skanowanie pamięci... gotowe.\n$ Rozpoznawanie struktury pliku.\n$ Odtwarzanie... Proszę czekać...\n====================================\n</style>\n\nRozmowa między kapitanem UES a załogą statku o latającym konstrukcie.\n\n«Kapitanie, na radarze jest niezidentyfikowany obiekt.»\n\n«Zidentyfikować.»\n\n«Wygląda jak... latający posąg?»\n\n«Co?»\n\n«Na pewno się porusza. I nabiera prędkości.»\n\n«Uzbrój działka.»\n\n«Za późno. Jest tutaj.»\n\n«...to przestało się ruszać.»\n\n«Uważaj. To może być pułapka.»\n\n«To się poruszyło.»\n\n«Co to do cholery...»",
        "SANDSWEPT_GAMMA_BODY_NAME": "Konstrukt Gamma",
        "SANDSWEPT_GAMMA_BODY_LORE": "<style=cMono>\n========================================\n====   MyBabel Automatic Translator   ====\n====   Wersja 3.1.53 (beta)          ====\n========================================\n\n$ Skanowanie pamięci... gotowe.\n$ Rozpoznawanie struktury pliku.\n$ Odtwarzanie... Proszę czekać...\n====================================\n</style>\n\nTranskrypcja rozmowy UES na temat tajemniczego lądującego konstruktu na planecie Theia.\n\n«Kapitanie, powinniśmy to zbadać?»\n\n«Nie. Może to być niebezpieczne.»\n\n«Ale...»\n\n«Nie ma żadnych ale. Zostawiamy to.»",
        "SANDSWEPT_DELTA_NAME": "Konstrukt Delta",
        "SANDSWEPT_DELTA_LORE": "Bracie, zobacz, jak tworzę własnego strażnika.\nNajpierw wezmę masę, uformuję ją w kształty piramid, jak ty mnie nauczyłeś. Następnie wleję w nią swoje życie. Będzie ode mnie silniejszy. Będzie trwał dłużej niż ja. Będzie moim spadkobiercą. Będzie moim dziedzictwem.\n\nKoniec.",
        "SANDSWEPT_CANNONJELLY_NAME": "Meduza Balistyczna",
        "SANDSWEPT_CANNONJELLY_LORE": "<style=cMono>\nWitaj w DataScraper (v3.1.53 - wersja beta)\n$ Skanowanie pamięci... gotowe.\n$ Rozpoznawanie struktury pliku.\n$ Odtwarzanie... Proszę czekać...\n====================================\n</style>\n\n«Tutaj działo nr 7. Widzę latającą meduzę. I jest wielka.»\n\n«Zrozumiano. Strzelaj.»\n\n«Haha, z przyjemnością... Nie robi to... nic? Chyba po prostu ją zdenerwowałem.»\n\n«Wycofaj się. Teraz.»\n\n«Wycofuję się, wycofuję się... JEZU, TO SZYBKIE.»",
        "ELITE_MOTIVATING_MODIFIER": "Motywujący {0}",
        "ELITE_EQUIPMENT_MOTIVATING_NAME": "John Hopoo",
        "ELITE_OSMIUM_MODIFIER": "Osmowo-Pustka {0}",
        "ELITE_EQUIPMENT_OSMIUM_NAME": "Sztuczna Pustka",
        "SANDSWEPT_VOLATILECONTEXT": "Wymuś Wstawienie Baterii",
        "VOLT_SKIN_DEFAULT_NAME": "Default",
        "VOLT_SKIN_DEFAULT_DESC": "The default skin for this survivor.",
        "VOLT_SKIN_COVENANT_NAME": "Covenant",
        "VOLT_SKIN_COVENANT_DESC": "A successful experiment. The fury of storms, tamed.",
        "SANDSWEPT_VOLATILEINSERT": "<style=cDeath>[Voltage regulation offline. Rejecting unknown power source.]</style>",
