			public void HandleDelayedHeal(float healthSplit, float healthFraction, float curse)
			{
				float num = healthComponent.health;
				if (body.HasBuff(Buffs.MedkitHeal))
				{
					if (Object.op_Implicit((Object)(object)body.inventory))
					{
						medkitDisplay.SetActive(true);
						int itemCount = body.inventory.GetItemCount(Items.Medkit);
						num += 20f;
						num += healthComponent.fullHealth * 0.05f * (float)itemCount;
						medkitFill.fillAmount = Util.Remap(medkitTimer, 2f, 0f, 0f, 1f);
					}
				}
				else
				{
					medkitDisplay.SetActive(false);
				}
				if (num >= healthComponent.fullHealth)
				{
					num = healthComponent.fullHealth;
				}
				healthFraction = num / healthComponent.fullHealth;
				delayedHealFill.fillAmount = Util.Remap(healthSplit * healthFraction / curse, 0f, 1f, minFill, maxFill);
				if (MainPlugin.robItemsInstalled)
				{
					HandleFirstAid(healthSplit, healthFraction, curse, num);
					HandlePerfectApple();
					HandleFreshMeat();
				}
				else
				{
					firstAidDisplay.SetActive(false);
					appleDisplay.SetActive(false);
				}
			}

			private void HandlePerfectApple()
			{
				currentAppleCooldown -= Time.fixedDeltaTime;
				int itemCount = body.inventory.GetItemCount(((ItemBase)ItemBase<PerfectApple>.instance).ItemDef);
				if (itemCount > 0)
				{
					float num = 20f;
					if (itemCount > 1)
					{
						for (int i = 1; i < itemCount; i++)
						{
							num *= 0.7f;
						}
					}
					if (currentAppleCooldown <= 0f)
					{
						currentAppleCooldown = num;
					}
					appleFill.fillAmount = Util.Remap(currentAppleCooldown, num, 0f, 0f, 1f);
					appleDisplay.SetActive(true);
				}
				else
				{
					appleDisplay.SetActive(false);
				}
			}

			private void HandleFreshMeat()
			{
				if (body.HasBuff(FreshMeat.meatBuff))
				{
					((TMP_Text)meatText).text = body.GetBuffCount(FreshMeat.meatBuff).ToString();
					meatDisplay.SetActive(true);
				}
				else
				{
					meatDisplay.SetActive(false);
				}
			}

			private void HandleFirstAid(float healthSplit, float healthFraction, float curse, float predictedHealth)
			{
				if (body.HasBuff(FirstAidSpray.cooldownBuff))
				{
					if (firstAidTimer > 1f)
					{
						firstAidTimer = 0f;
					}
					if (Object.op_Implicit((Object)(object)body.inventory))
					{
						firstAidDisplay.SetActive(true);
						int itemCount = body.inventory.GetItemCount(((ItemBase)ItemBase<FirstAidSpray>.instance).ItemDef);
						predictedHealth += 10f;
						predictedHealth += healthComponent.fullHealth * 0.02f * (float)itemCount;
						firstAidFill.fillAmount = Mathf.Clamp01(firstAidTimer);
					}
				}
				else
				{
					firstAidDisplay.SetActive(false);
					firstAidTimer = 0f;
				}
				if (predictedHealth >= healthComponent.fullHealth)
				{
					predictedHealth = healthComponent.fullHealth;
				}
				healthFraction = predictedHealth / healthComponent.fullHealth;
				delayedHealFill.fillAmount = Util.Remap(healthSplit * healthFraction / curse, 0f, 1f, minFill, maxFill);
			}

			private void HandleElixir()
			{
				int itemCount = body.inventory.GetItemCount(Items.HealingPotion);
				if (itemCount > 0)
				{
					((TMP_Text)elixirText).text = itemCount.ToString();
					elixirDisplay.SetActive(true);
				}
				else
				{
					elixirDisplay.SetActive(false);
				}
			}

