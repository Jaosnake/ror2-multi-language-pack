                    "SS2_REMUNERATION_TERMINAL_NAME":  "PiÃ©destal",
                    "SS2_DRONE_CLONE_SKILL_DESCRIPTION":  "Analyse un objet proche. AprÃ¨s avoir fini, crÃ©e une \u003cstyle=cIsUtility\u003ecopie\u003c/style\u003e de cet objet.",
                    "SS2_ACHIEVEMENT_NEMESIS_MERCENARY_GRANDMASTERY_NAME":  "Nemesis Mercenary: Grand Mastery",
                    "SS2_ITEM_DORMANTFUNGUS_NAME":  "Fongus dormant",
