					return text;
				}
				CharacterBody val = default(CharacterBody);
				if (!bodyObject.TryGetComponent<CharacterBody>(ref val))
				{
					return text;
				}
				if (!val.HasBuff(infectedBuff) && !val.HasBuff(infectedBuff2) && !val.HasBuff(infectedBuff3) && !val.HasBuff(infectedBuff4) && !val.HasBuff(infectedBuff5))
				{
					return text;
				}
				return "Infected " + text;
			}

