		public void SynthesisBuy(int slotID)
		{
			switch (slotID)
			{
			default:
				Chat.AddMessage("Synthesis Error 1");
				break;
			case 0:
				SynthesisEquip(slotID);
				break;
			case 1:
				SynthesisDust(slotID);
				break;
			case 2:
				SynthesisItem(slotID);
				break;
			case 3:
				SynthesisSpell(slotID);
				break;
			case 4:
				SynthesisLimit(slotID);
				break;
			case 5:
				SynthesisFinisher(slotID);
				break;
			case 6:
				SynthesisSupport(slotID);
				break;
			}
		}

