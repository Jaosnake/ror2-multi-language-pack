				if (Object.op_Implicit((Object)(object)durationBarRed))
				{
					if (num >= 1f)
					{
						durationBarRed.fillAmount = 1f;
					}
					durationBarRed.fillAmount = Mathf.Lerp(durationBarRed.fillAmount, num, Time.deltaTime * 2f);
				}
				durationBar.fillAmount = num;
			}

			private void SetDisplay()
			{
				//IL_019c: Unknown result type (might be due to invalid IL or missing references)
				//IL_0195: Unknown result type (might be due to invalid IL or missing references)
				//IL_01c7: Unknown result type (might be due to invalid IL or missing references)
				if (!Object.op_Implicit((Object)(object)targetText) || !Object.op_Implicit((Object)(object)iDrive))
				{
					return;
				}
				if (iDrive.maxWeaponTimer <= 0f)
				{
					((TMP_Text)targetText).text = string.Empty;
					((Component)targetText).gameObject.SetActive(false);
					durationDisplay.SetActive(false);
				}
				else if (iDrive.passive.isPistolOnly)
				{
					((Component)targetText).gameObject.SetActive(true);
					if (iDrive.weaponTimer <= 0f)
					{
						((TMP_Text)targetText).text = "<color=#C80000>0 / " + Mathf.CeilToInt(iDrive.maxWeaponTimer) + "</color>";
					}
					else
					{
						((TMP_Text)targetText).text = Mathf.CeilToInt(iDrive.weaponTimer) + " / " + Mathf.CeilToInt(iDrive.maxWeaponTimer);
					}
				}
				else if (iDrive.HasSpecialBullets)
				{
					if (iDrive.weaponTimer <= 0f)
					{
						((TMP_Text)targetText).text = string.Empty;
						((Component)targetText).gameObject.SetActive(false);
						return;
					}
					durationDisplay.SetActive(true);
					((Component)targetText).gameObject.SetActive(true);
					((Graphic)durationBar).color = ((iDrive.AmmoPercent < 0.2f) ? Helpers.badColor : iDrive.currentBulletDef.trailColor);
					((TMP_Text)targetText).text = "<color=#" + ColorUtility.ToHtmlStringRGBA(iDrive.currentBulletDef.trailColor) + ">" + iDrive.currentBulletDef.bulletName + "</color>";
				}
				else if (iDrive.weaponTimer == iDrive.maxWeaponTimer)
				{
					durationDisplay.SetActive(false);
					((Component)targetText).gameObject.SetActive(false);
				}
				else
				{
					durationDisplay.SetActive(false);
					((Component)targetText).gameObject.SetActive(false);
				}
			}
		}
