			foreach (SkinnedMeshRenderer val2 in componentsInChildren)
			{
				((Renderer)val2).material.shaderKeywords = null;
			}
			val.GetComponentInChildren<Animator>().runtimeAnimatorController = Asset.MainAssetBundle.LoadAsset<RuntimeAnimatorController>("displayAnimator");
			return val;
		}

