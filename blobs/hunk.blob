							inventory.GiveItemPermanent(Flamethrower.regulator, 1);
							inventory.GiveItemPermanent(Flamethrower.premiumFuel, 1);
							AddWeaponItem(BaseWeapon<Flamethrower>.instance.weaponDef);
							lastEquippedIndex = 0;
						}
						else if (component.isSMG)
						{
							disableVirus = true;
							weaponData = new HunkWeaponData[1]
							{
								new HunkWeaponData
								{
									weaponDef = BaseWeapon<FakeSMG>.instance.weaponDef,
									totalAmmo = 60,
									currentAmmo = 60
								}
							};
							inventory.GiveItemPermanent(SMG.extendedMag, 1);
							inventory.GiveItemPermanent(SMG.laserSight, 1);
							inventory.GiveItemPermanent(SMG.moderator, 1);
							AddWeaponItem(BaseWeapon<FakeSMG>.instance.weaponDef);
							lastEquippedIndex = 0;
						}
						else if (component.isWeskah)
						{
							weaponData = new HunkWeaponData[1]
							{
								new HunkWeaponData
								{
									weaponDef = weaponDef,
									totalAmmo = weaponDef.magSize * 4,
									currentAmmo = weaponDef.magSize
