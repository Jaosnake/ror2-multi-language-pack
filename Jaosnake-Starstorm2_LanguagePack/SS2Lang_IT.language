        "SS2_PLAYER_ARMOR_100_INCREASE_BODY_TOKEN": "I giocatori subiscono il 200% di danni.",
        "SS2_PLAYER_ARMOR_25_DECREASE_NAME_TOKEN": "-25% Danni ricevuti",
        "SS2_PLAYER_ARMOR_25_DECREASE_BODY_TOKEN": "I giocatori subiscono il 75% dei danni.",
        "SS2_PLAYER_ARMOR_50_DECREASE_NAME_TOKEN": "-50% Danni ricevuti",
        "SS2_PLAYER_ARMOR_50_DECREASE_BODY_TOKEN": "I giocatori subiscono il 50% di danni.",
        "SS2_PLAYER_ARMOR_75_DECREASE_NAME_TOKEN": "-75% Danni ricevuti",
        "SS2_PLAYER_ARMOR_75_DECREASE_BODY_TOKEN": "I giocatori subiscono il 25% di danni.",
