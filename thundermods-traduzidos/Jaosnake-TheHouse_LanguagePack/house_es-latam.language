        "JAVANGLE_HOUSE_DIVINATION_NAME": "Baraja: Adivinación",
        "JAVANGLE_HOUSE_DIVINATION_DESCRIPTION": "Un mazo complejo que te permite controlar la composición de las cartas.\n<style=cSub>[Consulta la pestaña Cartas para ver las cartas de este mazo]</style>",
        "JAVANGLE_HOUSE_BULLETARTSEMPTY_NAME": "BulletArts: Vacío",
        "JAVANGLE_HOUSE_BULLETARTSEMPTY_DESCRIPTION": "Dispara un tiro cargado al azar.\nCuando no tienes tiros: no hace nada.",
        "JAVANGLE_HOUSE_BULLETARTSQUICKDRAW_NAME": "BulletArts: Disparo rápido",
        "JAVANGLE_HOUSE_BULLETARTSQUICKDRAW_DESCRIPTION": "Dispara rápidamente <style=cIsUtility>Disparos estándar</style>.\nCuando no hay disparos: no hace nada.",
        "JAVANGLE_HOUSE_RELOADSTANDARD_NAME": "ReloadArts: Estándar",
        "JAVANGLE_HOUSE_RELOADSTANDARD_DESCRIPTION": "Jugar cualquier carta recarga la ruleta.\n50%/25% de probabilidad de obtener 1/2 municiones especiales aleatorias según el tipo de carta usada (rojo = Perforante/Perdigón/Explosivo, morado = Vacío/Serpiente, gris/verde = cualquiera de las anteriores).\n<style=cSub>[Consulta la pestaña Cartas para ver los disparos y sus efectos]</style>",
        "JAVANGLE_HOUSE_RELOADALLIN_NAME": "ReloadArts: todo incluido",
        "JAVANGLE_HOUSE_RELOADALLIN_DESCRIPTION": "Jugar cualquier carta recarga la rueda.\nCarga 0-6 disparos perforantes/de plomo/explosivos, <style=cArtifact>todos los disparos restantes son Cobra</style>.",
        "JAVANGLE_HOUSE_CARDARTSHOP_NAME": "CardArts: Salto",
        "JAVANGLE_HOUSE_CARDARTSHOP_DESCRIPTION": "Jugar cualquier carta en el aire: te impulsa hacia adelante.",
        "JAVANGLE_HOUSE_CARDARTSSWEEP_NAME": "CardArts: Escanear",
        "JAVANGLE_HOUSE_CARDARTSSWEEP_DESCRIPTION": "Siempre que te quedes sin cartas: vuelve a barajar el mazo y colócalo en la pila de robo.",
