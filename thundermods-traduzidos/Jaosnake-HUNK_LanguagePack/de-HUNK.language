        "ROB_HUNK_WRISTBAND_NAME": "Identifikationsarmband",
        "ROB_HUNK_WRISTBAND_DESC": "Ein elektronischer Schlüssel zur Verwendung in Einrichtungen der <color=#C80202>Umbrella Corporation</color>. Wird verwendet, um einen <style=cIsUtility>speziellen Waffenkoffer</style> zu öffnen.",
        "ROB_HUNK_SPADE_KEYCARD_NAME": "U.C. Schlüsselkarte (Spaten)",
