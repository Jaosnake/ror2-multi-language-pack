{
    "eo": {
        "ROB_DRIVER_BODY_NAME": "Sxoforo",
        "ROB_DRIVER_BODY_DESCRIPTION": "La Sxoforo estas lauxlitere mi.<color=#CCD3E0></i>",
        "ROB_DRIVER_BODY_SUBTITLE": "Sxoforo? Apenaux konas sxin!",
        "ROB_DRIVER_BODY_LORE": "Dorso al la muro kaj kontraux la sxancoj\nKun la forto de volo kaj kauxzo\nViaj agoj estas nomataj rimarkindaj\nVi estas emocie kompleksa\n\nKontraux la fluo de dystopiaj asertoj\nNe la pensoj, kiujn viaj agoj amuzas\nKaj vi montrigxis esti\n\n\nVera homa estajxo kaj vera heroo\n\n\"Do, kion vi faras?\"\n\n\"Mi sxoforas.\"",
        "ROB_DRIVER_BODY_OUTRO_FLAVOR": "..kaj poste li foriris, ankoraux la sama kiel kiam li komencis.",
        "ROB_DRIVER_BODY_OUTRO_FAILURE": "..kaj poste li malaperis, neniam farigxinte vera homa estajxo.",
        "ROB_DRIVER_BODY_DEFAULT_SKIN_NAME": "Defauxlta",
        "ROB_DRIVER_BODY_MONSOON_SKIN_NAME": "Jako",
