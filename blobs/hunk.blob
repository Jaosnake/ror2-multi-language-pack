				skillDef.keywordTokens = skillDefInfo.keywordTokens;
			}

			public static SkillDef CreatePrimarySkillDef(SerializableEntityStateType state, string stateMachine, string skillNameToken, string skillDescriptionToken, Sprite skillIcon, bool agile)
			{
				//IL_0006: Unknown result type (might be due to invalid IL or missing references)
				SkillDefInfo skillDefInfo = new SkillDefInfo(skillNameToken, skillNameToken, skillDescriptionToken, skillIcon, state, stateMachine, agile);
				skillDefInfo.requiredStock = 1;
				return CreateSkillDef(skillDefInfo);
			}
		}
		public static class Skins
		{
			public static SkinDef NewSkinDef(GameObject rootObject, string skinName, Sprite skinIcon, RendererInfo[] rendererInfos)
			{
				return NewSkinDef(rootObject, skinName, skinIcon, rendererInfos, null);
			}

			public static SkinDef NewSkinDef(GameObject rootObject, string skinName, Sprite skinIcon, RendererInfo[] rendererInfos, UnlockableDef unlockableDef)
			{
				SkinDef val = ScriptableObject.CreateInstance<SkinDef>();
				val.nameToken = skinName;
				val.icon = skinIcon;
				val.rootObject = rootObject;
				val.unlockableDef = unlockableDef;
				SkinDefParams val2 = ScriptableObject.CreateInstance<SkinDefParams>();
				val2.rendererInfos = rendererInfos;
				val2.minionSkinReplacements = (MinionSkinReplacement[])(object)new MinionSkinReplacement[0];
				val2.projectileGhostReplacements = (ProjectileGhostReplacement[])(object)new ProjectileGhostReplacement[0];
				val2.meshReplacements = (MeshReplacement[])(object)new MeshReplacement[0];
				val2.gameObjectActivations = (GameObjectActivation[])(object)new GameObjectActivation[0];
				val.skinDefParams = val2;
				return val;
			}

			public static SkinDef CreateSkinDef(string skinName, Sprite skinIcon, RendererInfo[] rendererInfos, SkinnedMeshRenderer mainRenderer, GameObject root)
			{
				return CreateSkinDef(skinName, skinIcon, rendererInfos, mainRenderer, root, null);
			}

			public static SkinDef CreateSkinDef(string skinName, Sprite skinIcon, RendererInfo[] rendererInfos, SkinnedMeshRenderer mainRenderer, GameObject root, UnlockableDef unlockableDef)
			{
				return NewSkinDef(root, skinName, skinIcon, rendererInfos, unlockableDef);
			}
		}
