	[RegisterAchievement("HABIBI_TESLA_BODY_SHIELDZAPUNLOCKABLE_ACHIEVEMENT_ID", "HABIBI_TESLA_BODY_SHIELDZAPUNLOCKABLE_REWARD_ID", null, 3u, typeof(TeslaShieldZapKillAchievementServer))]
	public class TeslaShieldZapKillAchievement : BaseAchievement
	{
		public class TeslaShieldZapKillAchievementServer : BaseServerAchievement
		{
			private bool hasFiredShieldZap;

			public override void OnInstall()
			{
				((BaseServerAchievement)this).OnInstall();
				RoR2Application.onFixedUpdate += OnFixedUpdate;
				GlobalEventManager.onCharacterDeathGlobal += OnCharacterDeath;
				ShieldZapReleaseDamage.onShieldZap += OnShieldZap;
			}

			private void OnShieldZap()
			{
				hasFiredShieldZap = true;
			}

			public override void OnUninstall()
			{
				GlobalEventManager.onCharacterDeathGlobal -= OnCharacterDeath;
				RoR2Application.onFixedUpdate -= OnFixedUpdate;
				((BaseServerAchievement)this).OnUninstall();
			}

			private void OnFixedUpdate()
			{
				hasFiredShieldZap = false;
			}

			private void OnCharacterDeath(DamageReport damageReport)
			{
