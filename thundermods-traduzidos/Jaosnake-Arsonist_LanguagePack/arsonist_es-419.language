{
    "es-419": {
        "POPCORN_ARSONIST_BODY_NAME": "Arsonista",
        "POPCORN_ARSONIST_BODY_SUBTITLE": "Pirómano Maníaco",
        "POPCORN_ARSONIST_BODY_PASSIVE_NORMAL_GAUGE_NAME": "Medidor Normal",
        "POPCORN_ARSONIST_BODY_PASSIVE_NORMAL_GAUGE_DESCRIPTION": "Causa <style=cIsDamage>100%</style> de daño en la porción blanca. El Medidor Base es resistente al Sobrecalentamiento.",
        "POPCORN_ARSONIST_BODY_PASSIVE_BLUE_GAUGE_NAME": "Medidor Crítico",
        "POPCORN_ARSONIST_BODY_PASSIVE_BLUE_GAUGE_DESCRIPTION": "Causa <style=cIsDamage>70%</style> de daño en la porción blanca y <style=cIsDamage>250%</style> de daño en la porción azul. El calor máximo es fijo.",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_NAME": "Aliento de dragón",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_DESCRIPTION": "Dispara un rayo de fuego que causa <style=cIsDamage>90% de daño</style>. Probabilidad de ignición aumentada cuanto más cerca del objetivo.",
        "POPCORN_ARSONIST_BODY_PRIMARY_FIRESPRAY_NAME": "bola de fuego",
        "POPCORN_ARSONIST_BODY_PRIMARY_FIRESPRAY_DESCRIPTION": "<style=cIsUtility>Calor. </style>Dispara una bola de fuego que causa <style=cIsDamage>225% de daño e incendia</style> a los enemigos al impactar.",
        "POPCORN_ARSONIST_BODY_SECONDARY_PUNCH_NAME": "Explosión de punto cero",
        "POPCORN_ARSONIST_BODY_SECONDARY_PUNCH_DESCRIPTION": "<style=cIsUtility>Ágil. Calor. </style>Impúlsate hacia adelante, explotando enemigos detrás de ti por <style=cIsDamage>200% de daño</style>. Colisionar justo después del lanzamiento con el primer enemigo causa <style=cIsDamage>200% de daño</style> en una explosión circundante.",
        "POPCORN_ARSONIST_BODY_SECONDARY_FLAREGUN_NAME": "Bengala",
        "POPCORN_ARSONIST_BODY_SECONDARY_FLAREGUN_DESCRIPTION": "Dispara una bengala que causa <style=cIsDamage>400% de daño</style> durante 5 segundos, luego explota causando <style=cIsDamage>400% de daño</style>, lanzando 5 bengalas que causan <style=cIsDamage>200% de daño</style> cada una.",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHIST_NAME": "Masoquismo",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHIST_DESCRIPTION": "<style=cIsUtility>Ágil. Calor. </style>El daño de ser <style=cIsDamage>incendiado</style> se transforma en <style=cIsHealing>curación</style> por 6.5 segundos. Aumenta la Velocidad de Ataque en <style=cIsDamage>125%</style>.",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_NAME": "Masoquismo",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_DESCRIPTION": "Al alcanzar el límite de <style=cKeywordName>Anticipación</style>, periódicamente te causas daño a cambio de <style=cIsHealing>Robo de Vida</style> en área y quemadura. Después de 10 segundos como máximo, <style=cIsDamage>Detona</style>, luego <style=cIsUtility>Sobrecarga</style>.",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_SURGE_NAME": "Despecho",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_SURGE_DESCRIPTION": "Al alcanzar el límite de <style=cKeywordName>Anticipación</style>, te mueves más rápido y obtienes <style=cKeywordName>Doble Disparo</style> y <style=cIsHealing>Robo de Vida</style>. Después de 10 segundos como máximo, <style=cIsDamage>Detona</style>, luego <style=cIsUtility>Sobrecarga</style>.",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_SCEPTER_NAME": "La reprimenda de Dante",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_SCEPTER_DESCRIPTION": "Dispara un rayo intenso que causa <style=cIsDamage>140% de daño</style>. Probabilidad de ignición aumentada cuanto más cerca del objetivo. Si se mantiene por 2 segundos o más, dispara un rayo final al soltar para <style=cIsDamage>150% de daño</style>.",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_ANTICIPATION": "<style=cKeywordName>Anticipación</style>Por cada 100 de calor perdido y/o ganado, Arsonista gana 1 carga de Anticipación; Después de ganar 5 cargas, puede activar Masoquismo; Las cargas adicionales aumentan el daño y la duración; Todas las cargas se consumen al final.",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_DETONATE": "<style=cKeywordName>Detonar</style>Arsonista explota, causando <style=cIsDamage>150% de daño</style> por la cantidad de Cargas de Anticipación acumuladas.",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_LIFESTEAL": "<style=cKeywordName>Robo de Vida</style>Arsonista cura <style=cIsHealing>18%</style> del daño causado mientras Masoquismo esté activo.",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_SURGE_LIFESTEAL": "<style=cKeywordName>Robo de Vida</style>Arsonista cura <style=cIsHealing>5%</style> del daño causado mientras Despecho esté activo.",
        "POPCORN_ARSONIST_BODY_KEYWORD_OVERHEAT_MASO": "<style=cKeywordName>Sobrecalentamiento: Masoquismo</style>Si Arsonista sale de Masoquismo debido a acumulación excesiva de calor, se aplica Sobrecalentamiento EX, reduciendo su Velocidad de Movimiento y Daño al 70%. Cancelar o dejar que la habilidad siga su curso aplica Sobrecalentamiento, reduciendo su Velocidad de Ataque al 50%.",
        "POPCORN_ARSONIST_BODY_OVERHEAT_TEXT": "¡SOBRECALENTAMIENTO!",
        "POPCORN_ARSONIST_BODY_COOLING_TEXT": "¡ENFRIANDO...!",
        "POPCORN_ARSONIST_BODY_OVERHEAT_EX_TEXT": "¡SOBRECALENTAMIENTO:EX!",
        "POPCORN_ARSONIST_BODY_PASSIVE_NAME": "Piromanía",
        "POPCORN_ARSONIST_BODY_PASSIVE_DESCRIPTION": "Resiste el daño de fuego de todas las fuentes. Convierte un ataque que inflija más del <style=cIsDamage>30%</style> de la salud total en <style=cIsDamage>50%</style> de daño de fuego con el tiempo.",
        "POPCORN_ARSONIST_BODY_KEYWORD_PYROMANIAPASSIVE": "Piromanía no afecta el daño por caída a menos que Fragilidad esté activa.",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_NAME": "Arsonist: Mastery",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_DESCRIPTION": "Como Arsonist, completa el juego u oblitérate en Monsoon.",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_ECLIPSE5UNLOCKABLE_ACHIEVEMENT_NAME": "Arsonist: Grandmastery",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_ECLIPSE5UNLOCKABLE_ACHIEVEMENT_DESCRIPTION": "Como Arsonist, completa el juego en Eclipse 5 o superior, O gana en Typhoon (requiere Starstorm 2).",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_ECLIPSE8UNLOCKABLE_ACHIEVEMENT_NAME": "Arsonist: Survival",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_ECLIPSE8UNLOCKABLE_ACHIEVEMENT_DESCRIPTION": "Como Arsonist, completa el juego en Eclipse 8, O gana en Inferno (requiere Inferno).",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_FLAMETHROWERUNLOCKABLE_ACHIEVEMENT_NAME": "Arsonist: Pyromaniac",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_FLAMETHROWERUNLOCKABLE_ACHIEVEMENT_DESCRIPTION": "Como Arsonist, completa una etapa sin sobrecalentarte.",
