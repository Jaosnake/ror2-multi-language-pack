{
    "es-419": {
        "ROB_HUNK_BODY_NAME": "HUNK",
        "ROB_HUNK_BODY_DESCRIPTION": "HUNK es un infiltrador de \u00e9lite que carga un gran arsenal de armas obtenidas mediante OSP (On-Site Procurement).<color=#CCD3E0>\n\n< ! > Usa tu Cuchillo de Combate contra enemigos m\u00e1s d\u00e9biles para conservar municiones.\n\n< ! > Obtener la Muestra de G-Virus te dar\u00e1 una tarjeta de acceso, permitiendo acceder a estuches de armas en cada Etapa.\n\n< ! > Usa Quickstep cerca de un enemigo o proyectil atacante para realizar una Esquiva Perfecta, y luego contraataca con tu Primario.\n\n< ! > La municiones escasean, pero se pueden encontrar en ba\u00fales abiertos. Las existencias del Secundario y la reducci\u00f3n de recarga tambi\u00e9n afectan las municiones.\n\n< ! > Esto es guerra. La supervivencia es tu responsabilidad. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SUBTITLE": "El Segador",
        "ROB_HUNK_BODY_OUTRO_FLAVOR": "..y as\u00ed parti\u00f3, todo bien.",
        "ROB_HUNK_BODY_OUTRO_FAILURE": "..y as\u00ed desapareci\u00f3, unidad humana ahora neutralizada.",
        "ROB_HUNK_BODY_DEFAULT_SKIN_NAME": "Predeterminado",
        "ROB_HUNK_BODY_CLASSIC_SKIN_NAME": "RE2make",
        "ROB_HUNK_BODY_TOFU_SKIN_NAME": "Tofu",
        "ROB_HUNK_BODY_SUPER_SKIN_NAME": "<color=#FFFF00>Early Supporter</color>",
        "ROB_HUNK_BODY_LIGHTWEIGHT_SKIN_NAME": "Ligero",
        "ROB_HUNK_BODY_GUERRILLA_SKIN_NAME": "Tropa",
        "ROB_HUNK_BODY_ROOKIE_SKIN_NAME": "Recluta",
        "ROB_HUNK_BODY_SWAT_SKIN_NAME": "Pacificador",
        "ROB_HUNK_BODY_LEON_SKIN_NAME": "Specialist",
        "ROB_HUNK_BODY_LEONSHIRT_SKIN_NAME": "Specialist EX",
        "ROB_HUNK_BODY_ENFORCER_SKIN_NAME": "Bulldozer",
        "ROB_HUNK_BODY_WESKER_SKIN_NAME": "Mastermind",
        "ROB_HUNK_BODY_DOOM_SKIN_NAME": "Slayer",
        "ROB_HUNK_BODY_COMMANDO_SKIN_NAME": "Commando",
        "ROB_HUNK_BODY_JACKET_SKIN_NAME": "Chaqueta",
        "ROB_HUNK_BODY_PPASSIVE_NAME": "OSP (On-Site Procurement)",
        "ROB_HUNK_BODY_PPASSIVE_DESCRIPTION": "HUNK puede recolectar <color=#FFFF00>U.C. Keycards</color> para abrir <style=cIsDamage>estuches de armas</style> y expandir su arsenal. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_PPASSIVE2_NAME": "Soldado Olvidado",
        "ROB_HUNK_BODY_PPASSIVE2_DESCRIPTION": "El primer <style=cIsHealth>jefe</style> en morir en cada Etada deja caer un <style=cIsDamage>paquete de suministros</style> que contiene un arma o accesorio. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_PASSIVE_NAME": "Lucha Sombr\u00eda",
        "ROB_HUNK_BODY_PASSIVE_DESCRIPTION": "Comienza con una <style=cIsDamage>LE 5</style> y un <style=cIsDamage>arma secundaria</style>. Puedes <style=cIsDamage>hurgar</style> <style=cIsUtility>ba\u00fales</style> en busca de municiones. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_PASSIVE2_NAME": "Temor Inminente",
        "ROB_HUNK_BODY_PASSIVE2_DESCRIPTION": "Comienza con un <style=cIsDamage>arsenal completo</style>, <style=cIsHealth>PERO</style> no puedes <style=cIsHealth>obtener municiones adicionales</style>. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_RANDOMPASSIVE_NAME": "New Game+",
        "ROB_HUNK_BODY_RANDOMPASSIVE_DESCRIPTION": "Comienza con una <style=cIsDamage>LE 5</style> y un <style=cIsDamage>arma secundaria</style>. Puedes <style=cIsDamage>hurgar</style> <style=cIsUtility>ba\u00fales</style> en busca de municiones. <style=cIsHealth>Todo el contenido de los estuches de armas es aleatorio.</style> <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SHOTGUNPASSIVE_NAME": "Autoridad Suprema",
        "ROB_HUNK_BODY_SHOTGUNPASSIVE_DESCRIPTION": "Comienza con una <style=cIsDamage>W-870</style> y un <style=cIsDamage>arma secundaria</style>. Puedes <style=cIsDamage>hurgar</style> <style=cIsUtility>ba\u00fales</style> en busca de municiones. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SMGPASSIVE_NAME": "Mercenario Supremo",
        "ROB_HUNK_BODY_SMGPASSIVE_DESCRIPTION": "Comienza <style=cIsHealth>SOLO</style> con una <style=cIsDamage>LE 5 totalmente mejorada</style>. Puedes <style=cIsDamage>hurgar</style> <style=cIsUtility>ba\u00fales</style> en busca de municiones. El <style=cIsDamage>Especial</style> es reemplazado por <color=#C80202>Modo Caos</color>. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_WPASSIVE_NAME": "Saturaci\u00f3n Global Completa",
        "ROB_HUNK_BODY_WPASSIVE_DESCRIPTION": "Comienza <style=cIsHealth>SOLO</style> con un <style=cIsDamage>arma secundaria</style>. Puedes <style=cIsDamage>hurgar</style> <style=cIsUtility>ba\u00fales</style> en busca de municiones. La <style=cIsDamage>Utilidad</style> es reemplazada por <color=#C80202>Uroboros</color>. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_FLAMERPASSIVE_NAME": "Piroman\u00eda",
        "ROB_HUNK_BODY_FLAMERPASSIVE_DESCRIPTION": "Comienza <style=cIsHealth>SOLO</style> con un <style=cIsDamage>Lanzallamas Qu\u00edmico</style>. Puedes <style=cIsDamage>hurgar</style> <style=cIsUtility>ba\u00fales</style> en busca de municiones. <style=cIsHealth>Solo UN estuche de armas aparece por Etapa.</style> <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_PRIMARY_KNIFE_NAME": "Cuchillo de Combate",
        "ROB_HUNK_BODY_PRIMARY_KNIFE_DESCRIPTION": "<style=cIsUtility>Saque.</style> <style=cIsDamage>Corta</style> combatientes cercanos para <style=cIsDamage>200% de da\u00f1o</style>, infligiendo <style=cIsHealth>Mutilar</style>. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_PRIMARY_CQC_NAME": "CQC (Combate Cuerpo a Cuerpo)",
        "ROB_HUNK_BODY_PRIMARY_CQC_DESCRIPTION": "<style=cIsUtility>Saque.</style> <style=cIsDamage>Patea dos veces</style> para <style=cIsDamage>200% y 250% de da\u00f1o</style>. Si la <style=cIsUtility>segunda patada</style> conecta, contin\u00faa con un <style=cIsDamage>Contraataque</style>. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_PRIMARY_RELOAD_NAME": "Recargar",
        "ROB_HUNK_BODY_RELOAD_DESCRIPTION": "Recarga tu arma actual. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SECONDARY_AIM_NAME": "Apuntar Firme",
        "ROB_HUNK_BODY_SECONDARY_AIM_DESCRIPTION": "Apunta, <style=cIsUtility>exponiendo puntos d\u00e9biles del enemigo</style>. <style=cIsDamage>Usar el primario mientras apuntas dispara tu arma equipada.</style> <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_UTILITY_DODGE_NAME": "Quickstep",
        "ROB_HUNK_BODY_UTILITY_DODGE_DESCRIPTION": "<style=cIsUtility>Avanza</style> una corta distancia. Si se usa preventivamente para <style=cIsUtility>evitar un ataque</style>, realiza una <style=cIsDamage>Esquiva Perfecta</style>. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_UTILITY_DODGE_SCEPTER_NAME": "Uroboros",
        "ROB_HUNK_BODY_UTILITY_DODGE_SCEPTER_DESCRIPTION": "<style=cIsUtility>Avanza</style> una corta distancia. Si se usa preventivamente para <style=cIsUtility>evitar un ataque</style>, realiza una <style=cIsDamage>Esquiva Perfecta</style>. El poder de Uroboros fluye a trav\u00e9s de ti. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_UTILITY_PARRY_NAME": "Aparar",
        "ROB_HUNK_BODY_UTILITY_PARRY_DESCRIPTION": "<style=cIsUtility>Bloquea</style> un ataque, <style=cIsDamage>anulando</style> el da\u00f1o y <style=cIsUtility>reembolsando la recarga</style>. Si se usa preventivamente, realiza una <style=cIsDamage>Aparici\u00f3n Perfecta</style>. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_UTILITY_BASH_NAME": "Embestida de Hombro",
        "ROB_HUNK_BODY_UTILITY_BASH_DESCRIPTION": "<style=cIsUtility>Golpea</style> a enemigos cercanos con el hombro, <style=cIsUtility>atudi\u00e9ndolos</style> para <style=cIsDamage>400% de da\u00f1o</style>. Si se usa preventivamente para <style=cIsUtility>cancelar un ataque</style>, realiza una <style=cIsDamage>Deflexi\u00f3n Perfecta</style>. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SPECIAL_SWAP_NAME": "Legi\u00f3n",
        "ROB_HUNK_BODY_SPECIAL_SWAP_DESCRIPTION": "<style=cIsUtility>Cambia</style> a un <style=cIsDamage>arma diferente</style>. Toca para cambiar a tu <style=cIsUtility>\u00faltima arma usada</style>. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SPECIAL_MAYHEM_NAME": "Modo Caos",
        "ROB_HUNK_BODY_SPECIAL_MAYHEM_DESCRIPTION": "Entra en <style=cIsDamage>Modo Caos</style>, aumentando dr\u00e1sticamente el rendimiento del arma. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_CONFIRM_NAME": "Confirmar",
        "ROB_HUNK_BODY_CONFIRM_DESCRIPTION": "Proceder con la habilidad actual. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_CANCEL_NAME": "Cancelar",
        "ROB_HUNK_BODY_CANCEL_DESCRIPTION": "Cancelar la habilidad actual. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_KNIFE_DEFAULT_NAME": "Cuchillo de Combate",
        "ROB_HUNK_BODY_KNIFE_DEFAULT_DESCRIPTION": "Un cuchillo militar est\u00e1ndar. Ciertamente \u00fatil en momentos dif\u00edciles. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_KNIFE_INFINITE_NAME": "Cuchillo de Combate EX",
        "ROB_HUNK_BODY_KNIFE_INFINITE_DESCRIPTION": "Un cuchillo militar especialmente tratado que ha sido endurecido a un grado incre\u00edble. Se dice que est\u00e1 hecho para durar realmente. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_KNIFE_HIDDEN_NAME": "Hoja Oculta",
        "ROB_HUNK_BODY_KNIFE_HIDDEN_DESCRIPTION": "Una hoja retr\u00e1ctil de bajo perfil escondida en la manga. Ideal para operaciones sigilosas. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_KNIFE_WESKER_NAME": "Cuchillo Personalizado",
        "ROB_HUNK_BODY_KNIFE_WESKER_DESCRIPTION": "Una hoja cruel con borde dentado para ayudar a desgarrar a tus oponentes. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_KNIFE_MACHETE_NAME": "Machete",
        "ROB_HUNK_BODY_KNIFE_MACHETE_DESCRIPTION": "Una hoja enorme destinada principalmente a t\u00e1cticas de guerrilla. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_KNIFE_RE4_NAME": "Cuchillo Primario",
        "ROB_HUNK_BODY_KNIFE_RE4_DESCRIPTION": "Un cuchillo forjado con infinitas posibilidades. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_KNIFE_BLOODY_NAME": "Hoja Ensangrentada",
        "ROB_HUNK_BODY_KNIFE_BLOODY_DESCRIPTION": "Una hoja ensangrentada con un borde dentado que ya ha desgarrado a muchos oponentes. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_KNIFE_HOTDOGGER_NAME": "HOT DOGGER",
        "ROB_HUNK_BODY_KNIFE_HOTDOGGER_DESCRIPTION": "Como el nombre indica, este cuchillo anti-bioweapon desarrollado por Umbrella es usado por aquellos que les gusta presumir. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_KNIFE_STUNROD_NAME": "Vara Aturdidora",
        "ROB_HUNK_BODY_KNIFE_STUNROD_DESCRIPTION": "ADVERTENCIA: No aturde realmente. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_KNIFE_KITCHEN_NAME": "Cuchillo de Cocina",
        "ROB_HUNK_BODY_KNIFE_KITCHEN_DESCRIPTION": "Un cuchillo hecho para cocinar. Su hoja se astilla f\u00e1cilmente. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SHOOT_SMG_NAME": "Disparar",
        "ROB_HUNK_BODY_SHOOT_SMG_DESCRIPTION": "Dispara para <style=cIsDamage>110% de da\u00f1o</style>. <style=cIsUtility>25% de bonificaci\u00f3n en disparos a la cabeza.</style> <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SHOOT_M19_NAME": "Disparar",
        "ROB_HUNK_BODY_SHOOT_M19_DESCRIPTION": "Dispara para <style=cIsDamage>500% de da\u00f1o</style>. <style=cIsUtility>100% de bonificaci\u00f3n en disparos a la cabeza.</style> <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SHOOT_SG09_NAME": "Disparar",
        "ROB_HUNK_BODY_SHOOT_SG09_DESCRIPTION": "Dispara para <style=cIsDamage>500% de da\u00f1o</style>. <style=cIsUtility>50% de bonificaci\u00f3n en disparos a la cabeza.</style> <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SHOOT_BROOMHC_NAME": "Disparar",
        "ROB_HUNK_BODY_SHOOT_BROOMHC_DESCRIPTION": "Dispara para <style=cIsDamage>180% de da\u00f1o</style>. <style=cIsUtility>25% de bonificaci\u00f3n en disparos a la cabeza.</style> <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SHOOT_MAGNUM_NAME": "Disparar",
        "ROB_HUNK_BODY_SHOOT_MAGNUM_DESCRIPTION": "Dispara para <style=cIsDamage>1.200% de da\u00f1o</style>. <style=cIsUtility>50% de bonificaci\u00f3n en disparos a la cabeza.</style> <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SHOOT_GOLDGUN_NAME": "Disparar",
        "ROB_HUNK_BODY_SHOOT_GOLDGUN_DESCRIPTION": "Dispara para <style=cIsDamage>99.999% de da\u00f1o</style>. <style=cIsUtility>50% de bonificaci\u00f3n en disparos a la cabeza.</style> <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SHOOT_MUP_NAME": "Disparar",
        "ROB_HUNK_BODY_SHOOT_MUP_DESCRIPTION": "Dispara para <style=cIsDamage>320% de da\u00f1o</style>. <style=cIsUtility>25% de bonificaci\u00f3n en disparos a la cabeza.</style> <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SHOOT_REVOLVER_NAME": "Disparar",
        "ROB_HUNK_BODY_SHOOT_REVOLVER_DESCRIPTION": "Dispara para <style=cIsDamage>1.200% de da\u00f1o</style>. <style=cIsUtility>50% de bonificaci\u00f3n en disparos a la cabeza.</style> <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SHOOT_COLT_NAME": "Disparar",
        "ROB_HUNK_BODY_SHOOT_COLT_DESCRIPTION": "Dispara para <style=cIsDamage>2.000% de da\u00f1o</style>. <style=cIsUtility>50% de bonificaci\u00f3n en disparos a la cabeza.</style> <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SHOOT_SPARKSHOT_NAME": "Disparar",
        "ROB_HUNK_BODY_SHOOT_SPARKSHOT_DESCRIPTION": "Dispara una aguja electrificada para <style=cIsDamage>1.000% de da\u00f1o</style>. <style=cIsUtility>Rebota hasta 3 enemigos para <style=cIsDamage>2.000% de da\u00f1o</style>.</style> <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SHOOT_BLUEROSE_NAME": "Disparar",
        "ROB_HUNK_BODY_SHOOT_BLUEROSE_DESCRIPTION": "Dispara para <style=cIsDamage>2x3.800% de da\u00f1o</style>. <style=cIsUtility>50% de bonificaci\u00f3n en disparos a la cabeza.</style> <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SHOOT_SHOTGUN_NAME": "Disparar",
        "ROB_HUNK_BODY_SHOOT_SHOTGUN_DESCRIPTION": "Dispara para <style=cIsDamage>14x150% de da\u00f1o</style>. <style=cIsUtility>50% de bonificaci\u00f3n en disparos a la cabeza.</style> <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SHOOT_M3_NAME": "Disparar",
        "ROB_HUNK_BODY_SHOOT_M3_DESCRIPTION": "Dispara para <style=cIsDamage>10x130% de da\u00f1o</style>. <style=cIsUtility>50% de bonificaci\u00f3n en disparos a la cabeza.</style> <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SHOOT_SSG_NAME": "Disparar",
        "ROB_HUNK_BODY_SHOOT_SSG_DESCRIPTION": "Dispara para <style=cIsDamage>16x200% de da\u00f1o</style>. <style=cIsUtility>50% de bonificaci\u00f3n en disparos a la cabeza.</style> <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SHOOT_STREETSWEEPER_NAME": "Disparar",
        "ROB_HUNK_BODY_SHOOT_STREETSWEEPER_DESCRIPTION": "Dispara para <style=cIsDamage>14x24% de da\u00f1o</style>. <style=cIsUtility>25% de bonificaci\u00f3n en disparos a la cabeza.</style> <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SHOOT_SLUGGER_NAME": "Disparar",
        "ROB_HUNK_BODY_SHOOT_SLUGGER_DESCRIPTION": "Dispara para <style=cIsDamage>3.000% de da\u00f1o</style>. <style=cIsUtility>50% de bonificaci\u00f3n en disparos a la cabeza.</style> <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SHOOT_AR_NAME": "Disparar",
        "ROB_HUNK_BODY_SHOOT_AR_DESCRIPTION": "Dispara para <style=cIsDamage>385% de da\u00f1o</style>. <style=cIsUtility>50% de bonificaci\u00f3n en disparos a la cabeza.</style> <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SHOOT_MINIGUN_NAME": "Disparar",
        "ROB_HUNK_BODY_SHOOT_MINIGUN_DESCRIPTION": "Dispara para <style=cIsDamage>2x250% de da\u00f1o</style>. <style=cIsUtility>El da\u00f1o escala con la velocidad de ataque.</style> <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SHOOT_ATM_NAME": "Disparar",
        "ROB_HUNK_BODY_SHOOT_ATM_DESCRIPTION": "Dispara para <style=cIsDamage>8.000% de da\u00f1o</style>. <style=cIsUtility>Causa m\u00e1s da\u00f1o en impactos directos.</style> <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SHOOT_ATM2_NAME": "Disparar",
        "ROB_HUNK_BODY_SHOOT_ATM2_DESCRIPTION": "Dispara para <style=cIsDamage>8.000% de da\u00f1o</style>. <style=cIsUtility>Causa m\u00e1s da\u00f1o en impactos directos.</style> <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SHOOT_RPG_NAME": "Disparar",
        "ROB_HUNK_BODY_SHOOT_RPG_DESCRIPTION": "Dispara para <style=cIsDamage>8.000% de da\u00f1o</style>. <style=cIsUtility>Causa m\u00e1s da\u00f1o en impactos directos.</style> <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SHOOT_ROCKETLAUNCHER_NAME": "Disparar",
        "ROB_HUNK_BODY_SHOOT_ROCKETLAUNCHER_DESCRIPTION": "Dispara para <style=cIsDamage>12.000% de da\u00f1o</style>. <style=cIsDamage>Incendiario.</style> <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SHOOT_GRENADELAUNCHER_NAME": "Disparar",
        "ROB_HUNK_BODY_SHOOT_GRENADELAUNCHER_DESCRIPTION": "Dispara para <style=cIsDamage>3.200% de da\u00f1o</style>. <style=cIsDamage>Incendiario.</style> <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SHOOT_MGL_NAME": "Disparar",
        "ROB_HUNK_BODY_SHOOT_MGL_DESCRIPTION": "Dispara para <style=cIsDamage>2.400% de da\u00f1o</style>. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SHOOT_RAILGUN_NAME": "Disparar",
        "ROB_HUNK_BODY_SHOOT_RAILGUN_DESCRIPTION": "Dispara para <style=cIsDamage>20.000% de da\u00f1o</style>. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SHOOT_FLAMETHROWER_NAME": "Disparar",
        "ROB_HUNK_BODY_SHOOT_FLAMETHROWER_DESCRIPTION": "Dispara un chorro de llamas para <style=cIsDamage>toneladas de da\u00f1o</style>. <style=cIsUtility>Incendia.</style> <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SHOOT_SCANNER_NAME": "Escanear",
        "ROB_HUNK_BODY_SHOOT_SCANNER_DESCRIPTION": "Escanea en busca de <style=cIsUtility>estuches de armas no abiertos</style>. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_HUNK_BODY_SHOOT_HOOKSHOT_NAME": "Gancho",
        "ROB_HUNK_BODY_SHOOT_HOOKSHOT_DESCRIPTION": "Dispara un gancho a un <style=cIsUtility>punto distante</style>, luego <style=cIsUtility>j\u00e1late hacia \u00e9l</style>. <style=cIsDamage>Puedes contraatacar despu\u00e9s de aterrizar.</style> <i>Translated by: Jaosnake. Original mod by rob</i>",
