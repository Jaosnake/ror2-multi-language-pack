        "ROB_RAVAGER_BODY_MAHORAGA_SKIN_NAME": "Божественний",
        "ROB_RAVAGER_BODY_MINECRAFT_SKIN_NAME": "Minecraft",
        "ROB_RAVAGER_BODY_BLOODWELL_NAME": "Кривава криниця",
        "ROB_RAVAGER_BODY_BLOODWELL_DESCRIPTION": "Ravager накопичує запаси<style=cIsHealth>кров</style>з його ударами, виснажуючи, коли повний, щоб зцілити вас<style=cIsHealing>75% відсутнього здоров'я</style>і<style=cIsDamage>розширити свої навички</style>тимчасово.",
        "ROB_RAVAGER_BODY_BLOODWELL2_NAME": "Іхор Каністра",
        "ROB_RAVAGER_BODY_BLOODWELL2_DESCRIPTION": "Ravager накопичує запаси<style=cIsHealth>кров</style>з його ударами, виснажуючи, коли повний, щоб зцілити вас<style=cIsHealing>100% максимального здоров'я</style>і<style=cIsDamage>розширити свої навички</style>тимчасово.<style=cIsHealth>Зливається швидше під час атаки.</style>",
        "ROB_RAVAGER_BODY_PARASITE_NAME": "Паразит",
        "ROB_RAVAGER_BODY_PARASITE_DESCRIPTION": "<style=cIsHealth>Це голод....</style>",
        "ROB_RAVAGER_BODY_PASSIVE_NAME": "Фізична майстерність",
        "ROB_RAVAGER_BODY_PASSIVE_DESCRIPTION": "Спустошитель може<style=cIsUtility>стрибати зі стін</style>і<style=cIsHealth>вороги</style>. використання<style=cIsUtility>Первинний</style>під час заряджання, щоб ввести a<style=cIsDamage>тримати позицію</style>.",
        "ROB_RAVAGER_BODY_PASSIVE2_NAME": "Викручена мутація",
        "ROB_RAVAGER_BODY_PASSIVE2_DESCRIPTION": "<style=cIsHealth>10% HP</style>. Стрибнути в повітрі, щоб зарядити a<style=cIsUtility>блимання вперед</style>, один раз за стрибок. Посадка<style=cIsDamage>удари ближнього бою</style>освіжає цю здатність.",
        "ROB_RAVAGER_BODY_PASSIVE3_NAME": "Викривлена ​​мутація (спадок)",
        "ROB_RAVAGER_BODY_PASSIVE3_DESCRIPTION": "<style=cIsHealth>Коштує 5% поточного здоров'я.</style>Стрибнути в повітрі до<style=cIsUtility>моргати вперед</style>, один раз за стрибок. Посадка<style=cIsDamage>удари ближнього бою</style>освіжає цю здатність.",
        "ROB_RAVAGER_BODY_CONFIRM_NAME": "Підтвердити",
