		private void SetCoreTransform()
		{
			ChildLocator componentInChildren = bodyPrefab.GetComponentInChildren<ChildLocator>();
			GameObject gameObject = ((Component)componentInChildren).gameObject;
			CharacterBody component = bodyPrefab.GetComponent<CharacterBody>();
			Transform coreTransform = componentInChildren.FindChild("BaseBone");
			gameObject.GetComponent<CharacterModel>().coreTransform = coreTransform;
			component.coreTransform = coreTransform;
		}

