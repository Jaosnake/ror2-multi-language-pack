			public override string equipSoundString => "sfx_hunk_equip_smg";

			public override void Init()
			{
				base.Init();
				modelPrefab.AddComponent<ARBehavior>();
				bayonet = Object.Instantiate<ItemDef>(HunkAssets.voidItemBase);
				((Object)bayonet).name = "ROB_HUNK_WEAPON_ADDON_" + weaponNameToken + "_NAME";
				bayonet.nameToken = "ROB_HUNK_WEAPON_ADDON_" + weaponNameToken + "_NAME";
				bayonet.descriptionToken = "ROB_HUNK_WEAPON_ADDON_" + weaponNameToken + "_DESC";
				bayonet.pickupToken = "ROB_HUNK_WEAPON_ADDON_" + weaponNameToken + "_DESC";
				bayonet.loreToken = "ROB_HUNK_WEAPON_ADDON_" + weaponNameToken + "_DESC";
				bayonet.canRemove = false;
				bayonet.hidden = false;
				bayonet.pickupIconSprite = HunkAssets.mainAssetBundle.LoadAsset<Sprite>("texBayonetIcon");
				bayonet.requiredExpansion = null;
				ItemDef obj = bayonet;
				ItemTag[] array = new ItemTag[6];
				RuntimeHelpers.InitializeArray(array, (RuntimeFieldHandle)/*OpCode not supported: LdMemberToken*/);
				obj.tags = (ItemTag[])(object)array;
				bayonet.unlockableDef = null;
				bayonet.pickupModelPrefab = HunkAssets.mainAssetBundle.LoadAsset<GameObject>("mdlBayonet");
				HunkAssets.ConvertAllRenderersToHopooShader(bayonet.pickupModelPrefab);
				HunkWeaponCatalog.itemDefs.Add(bayonet);
				LanguageAPI.Add("ROB_HUNK_WEAPON_ADDON_" + weaponNameToken + "_NAME", "Bayonet (CQBR)");
				LanguageAPI.Add("ROB_HUNK_WEAPON_ADDON_" + weaponNameToken + "_DESC", "A custom part for the CQBR that replaces your Combat Knife and deals 600% damage.");
			}
		}
