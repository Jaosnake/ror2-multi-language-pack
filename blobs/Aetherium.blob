namespace Aetherium.Compatability
{
	internal static class ModCompatability
	{
		internal static class ArtifactOfTheKingCompat
		{
			public static bool IsArtifactOfTheKingInstalled => Chainloader.PluginInfos.ContainsKey("com.Blobface.ArtifactKing");
		}

		internal static class ModdedCharacterDisplayCompat
		{
			public struct ModdedCharacterItemDisplayRuleInfo
			{
				public string BodyPrefabName;

				public ItemDisplayRule[] ItemDisplayRules;

				public Object KeyAsset;

				public ModdedCharacterItemDisplayRuleInfo(string bodyPrefabName, ItemDisplayRule[] itemDisplayRules, Object keyAsset)
				{
					BodyPrefabName = bodyPrefabName;
					ItemDisplayRules = itemDisplayRules;
					KeyAsset = keyAsset;
				}
			}

			public static List<ModdedCharacterItemDisplayRuleInfo> ModdedCharacterItemDisplayInfos = new List<ModdedCharacterItemDisplayRuleInfo>();

			public static void Init()
			{
				RoR2Application.onLoad = (Action)Delegate.Combine(RoR2Application.onLoad, new Action(PerformModdedDisplayAdditions));
			}

			private static void PerformModdedDisplayAdditions()
			{
				//IL_00e6: Unknown result type (might be due to invalid IL or missing references)
				//IL_00fd: Unknown result type (might be due to invalid IL or missing references)
				//IL_0110: Unknown result type (might be due to invalid IL or missing references)
				//IL_0112: Unknown result type (might be due to invalid IL or missing references)
				//IL_0117: Unknown result type (might be due to invalid IL or missing references)
				HashSet<CharacterModel> hashSet = new HashSet<CharacterModel>();
				foreach (ModdedCharacterItemDisplayRuleInfo moddedCharacterItemDisplayInfo in ModdedCharacterItemDisplayInfos)
				{
					GameObject val = BodyCatalog.FindBodyPrefab(moddedCharacterItemDisplayInfo.BodyPrefabName);
					if (!Object.op_Implicit((Object)(object)val))
					{
						AetheriumPlugin.ModLogger.LogDebug((object)("Didn't find BodyPrefab for " + moddedCharacterItemDisplayInfo.BodyPrefabName));
						continue;
					}
					ModelLocator component = val.GetComponent<ModelLocator>();
					if (!Object.op_Implicit((Object)(object)component) || !Object.op_Implicit((Object)(object)component.modelTransform))
					{
						AetheriumPlugin.ModLogger.LogDebug((object)$"ModelLocator for {val} was not found.");
						continue;
					}
					CharacterModel component2 = ((Component)component.modelTransform).gameObject.GetComponent<CharacterModel>();
					if (Object.op_Implicit((Object)(object)component2))
					{
						hashSet.Add(component2);
						List<KeyAssetRuleGroup> list = component2.itemDisplayRuleSet.keyAssetRuleGroups.ToList();
						list.Add(new KeyAssetRuleGroup
						{
							keyAsset = moddedCharacterItemDisplayInfo.KeyAsset,
							displayRuleGroup = new DisplayRuleGroup
							{
								rules = moddedCharacterItemDisplayInfo.ItemDisplayRules
							}
						});
						component2.itemDisplayRuleSet.keyAssetRuleGroups = list.ToArray();
						AetheriumPlugin.ModLogger.LogDebug((object)("Successfully added modded display " + moddedCharacterItemDisplayInfo.KeyAsset.name + " for " + ((Object)val).name));
					}
				}
				foreach (CharacterModel item in hashSet)
				{
					item.itemDisplayRuleSet.GenerateRuntimeValues();
				}
			}

			public static void AddModdedCharacterItemDisplayInfo(string bodyPrefabName, ItemDisplayRule[] itemDisplayRules, Object keyAsset)
			{
				if (!string.IsNullOrWhiteSpace(bodyPrefabName) && itemDisplayRules.Length != 0 && (!(((object)keyAsset).GetType() != typeof(ItemDef)) || !(((object)keyAsset).GetType() != typeof(EquipmentDef))))
				{
					ModdedCharacterItemDisplayInfos.Add(new ModdedCharacterItemDisplayRuleInfo
					{
						BodyPrefabName = bodyPrefabName,
						ItemDisplayRules = itemDisplayRules,
						KeyAsset = keyAsset
					});
				}
			}
		}
	}
}
namespace Aetherium.Artifacts
{
	public abstract class ArtifactBase<T> : ArtifactBase where T : ArtifactBase<T>
	{
		public static T instance { get; private set; }

