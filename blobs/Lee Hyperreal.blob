		private void SetUpNotification(NotificationInfo notificationInfo)
		{
			currentNotification = Object.Instantiate<GameObject>(genericNotificationPrefab).GetComponent<LeeHyperrealNotification>();
			StaticValues.CustomItemEffect customItemEffect = (StaticValues.CustomItemEffect)notificationInfo.data;
			if (customItemEffect != null)
			{
				currentNotification.SetText(customItemEffect.titleToken, customItemEffect.descToken, targetMaster);
			}
			((Transform)((Component)currentNotification).GetComponent<RectTransform>()).SetParent((Transform)(object)((Component)this).GetComponent<RectTransform>(), false);
		}

		private void OnCurrentNotificationChanged(LeeHyperrealNotificationQueue notificationQueue)
		{
			ShowCurrentNotification(notificationQueue);
		}

		private void ShowCurrentNotification(LeeHyperrealNotificationQueue notificationQueue)
		{
			DestroyCurrentNotification();
			NotificationInfo val = notificationQueue.GetCurrentNotification();
			if (val != (NotificationInfo)null)
			{
				SetUpNotification(val);
			}
		}

		private void DestroyCurrentNotification()
		{
			if (Object.op_Implicit((Object)(object)currentNotification))
			{
				Object.Destroy((Object)(object)((Component)currentNotification).gameObject);
				currentNotification = null;
			}
		}

		private void SetTargetMaster(CharacterMaster newMaster)
		{
			DestroyCurrentNotification();
			CleanUpCurrentMaster();
			targetMaster = newMaster;
			if (Object.op_Implicit((Object)(object)newMaster))
			{
				notificationQueue = LeeHyperrealNotificationQueue.GetNotificationQueueForMaster(newMaster);
				notificationQueue.onCurrentNotificationChanged += OnCurrentNotificationChanged;
				ShowCurrentNotification(notificationQueue);
			}
		}

		private void OnCharacterMasterLost(CharacterMaster master)
		{
			if ((Object)(object)master == (Object)(object)targetMaster)
			{
				CleanUpCurrentMaster();
			}
		}

		private void CleanUpCurrentMaster()
		{
			if (Object.op_Implicit((Object)(object)notificationQueue))
			{
				notificationQueue.onCurrentNotificationChanged -= OnCurrentNotificationChanged;
			}
			notificationQueue = null;
			targetMaster = null;
		}
	}
}
