        "ACHIEVEMENT_ROB_HUNK_COMPLETION_UNLOCKABLE_ACHIEVEMENT_ID_NAME": "HUNK：收割者",
        "ACHIEVEMENT_ROB_HUNK_COMPLETION_UNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "作为HUNK，通关游戏或湮灭。 <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_MONSOON_UNLOCKABLE_ACHIEVEMENT_ID_NAME": "HUNK：精通",
        "ACHIEVEMENT_ROB_HUNK_MONSOON_UNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "作为HUNK，在季风难度下通关或湮灭。 <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_TYPHOON_UNLOCKABLE_ACHIEVEMENT_ID_NAME": "HUNK：大师级",
        "ACHIEVEMENT_ROB_HUNK_TYPHOON_UNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "作为HUNK，在台风或日食难度下通关或湮灭。\n<color=#8888>(计算任何台风或更高难度)</color> <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_SUPPORTER_ACHIEVEMENT_ID_NAME": "HUNK：Early Supporter",
        "ACHIEVEMENT_ROB_HUNK_SUPPORTER_ACHIEVEMENT_ID_DESCRIPTION": "在正式发布前以HUNK进行游戏。 <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_LIGHTWEIGHT_ACHIEVEMENT_ID_NAME": "HUNK：极简主义者",
        "ACHIEVEMENT_ROB_HUNK_LIGHTWEIGHT_ACHIEVEMENT_ID_DESCRIPTION": "作为HUNK，在没有物品的情况下完成阶段1。\n<color=#8888>(武器和工具不计入)</color> <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_GUERRILLA_ACHIEVEMENT_ID_NAME": "HUNK：锁弹上膛",
        "ACHIEVEMENT_ROB_HUNK_GUERRILLA_ACHIEVEMENT_ID_DESCRIPTION": "作为HUNK，获得完整军火库。 <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_ROOKIE_ACHIEVEMENT_ID_NAME": "HUNK：上班第一天",
        "ACHIEVEMENT_ROB_HUNK_ROOKIE_ACHIEVEMENT_ID_DESCRIPTION": "作为HUNK，获得一把新武器。 <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_SWAT_ACHIEVEMENT_ID_NAME": "HUNK：维和者",
        "ACHIEVEMENT_ROB_HUNK_SWAT_ACHIEVEMENT_ID_DESCRIPTION": "作为HUNK，完全升级MUP。 <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_CQC_ACHIEVEMENT_ID_NAME": "HUNK：CQC（近距离战斗）",
        "ACHIEVEMENT_ROB_HUNK_CQC_ACHIEVEMENT_ID_DESCRIPTION": "作为HUNK，在一个阶段内完成10次成功反击。 <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_INFINITEKNIFE_ACHIEVEMENT_ID_NAME": "HUNK：黑桃A",
        "ACHIEVEMENT_ROB_HUNK_INFINITEKNIFE_ACHIEVEMENT_ID_DESCRIPTION": "作为HUNK，同时携带两张黑桃钥匙卡。 <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_WESKERKNIFE_UNLOCKABLE_ACHIEVEMENT_ID_NAME": "HUNK：枪械爱好者",
        "ACHIEVEMENT_ROB_HUNK_WESKERKNIFE_UNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "作为HUNK，用新配件升级一把武器。 <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_MACHETE_UNLOCKABLE_ACHIEVEMENT_ID_NAME": "HUNK：不需要枪",
        "ACHIEVEMENT_ROB_HUNK_MACHETE_UNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "作为HUNK，在不发射任何武器的情况下完成一个阶段。 <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_RE4KNIFE_ACHIEVEMENT_ID_NAME": "HUNK：前方的路",
        "ACHIEVEMENT_ROB_HUNK_RE4KNIFE_ACHIEVEMENT_ID_DESCRIPTION": "作为HUNK，到达阶段6。 <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_HOTDOGGER_ACHIEVEMENT_ID_NAME": "HUNK：基础化学",
        "ACHIEVEMENT_ROB_HUNK_HOTDOGGER_ACHIEVEMENT_ID_DESCRIPTION": "作为HUNK，获得化学火焰喷射器。 <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_STUNROD_ACHIEVEMENT_ID_NAME": "HUNK：三合一优惠",
        "ACHIEVEMENT_ROB_HUNK_STUNROD_ACHIEVEMENT_ID_DESCRIPTION": "作为HUNK，获得Spark Shot。 <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_SSG_ACHIEVEMENT_ID_NAME": "HUNK：主宰者",
        "ACHIEVEMENT_ROB_HUNK_SSG_ACHIEVEMENT_ID_DESCRIPTION": "作为HUNK，获得SSG。 <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_FLAMER_ACHIEVEMENT_ID_NAME": "HUNK：纵火狂",
        "ACHIEVEMENT_ROB_HUNK_FLAMER_ACHIEVEMENT_ID_DESCRIPTION": "作为HUNK，完全升级化学火焰喷射器。 <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_SURVIVALKIT_ACHIEVEMENT_ID_NAME": "HUNK：运气全无",
        "ACHIEVEMENT_ROB_HUNK_SURVIVALKIT_ACHIEVEMENT_ID_DESCRIPTION": "作为HUNK，在Commencement耗尽弹药。 <i>Translated by: Jaosnake</i>",
        "ACHIEVEMENT_ROB_HUNK_JUMPPACK_ACHIEVEMENT_ID_NAME": "HUNK：除了向上无处可去",
        "ACHIEVEMENT_ROB_HUNK_JUMPPACK_ACHIEVEMENT_ID_DESCRIPTION": "作为HUNK，成为跳伞事故的受害者。 <i>Translated by: Jaosnake</i>",
        "ROB_NEMESIS_BODY_NAME": "Nemesis T-Type",
        "ROB_NEMESIS_BODY_DESCRIPTION": "Nemesis T-Type是一种不可阻挡的生物武器，旨在承受任何程度的惩罚并轻松中和目标。<color=#CCD3E0>\n\n< ! > 跳跃可以蓄力以获得更远距离。\n\n< ! > 吞噬敌人会使你变得脆弱，所以在吞噬前请找到一个安全的地方。\n\n< ! > 生物质在满时增加你的伤害。 <i>Translated by: Jaosnake</i>",
        "ROB_NEMESIS_BODY_SUBTITLE": "不可阻挡的生物武器",
        "ROB_NEMESIS_BODY_OUTRO_FLAVOR": "..然后他离开了，一切安好。",
        "ROB_NEMESIS_BODY_OUTRO_FAILURE": "..然后他消失了，人类单位现已中和。",
        "ROB_NEMESIS_BODY_DEFAULT_SKIN_NAME": "默认",
        "ROB_NEMESIS_BODY_CLASSIC_SKIN_NAME": "经典",
        "ROB_NEMESIS_BODY_VENOM_SKIN_NAME": "共生体",
        "ROB_NEMESIS_BODY_SUPER_SKIN_NAME": "<color=#FFFF00>Early Supporter</color>",
        "ROB_NEMESIS_BODY_MAHORAGA_SKIN_NAME": "Big Raga The Opp Stoppa",
        "ROB_NEMESIS_BODY_MINOS_SKIN_NAME": "King of Men",
        "ROB_NEMESIS_BODY_PASSIVE_NAME": "至高生命形态",
        "ROB_NEMESIS_BODY_PASSIVE_DESCRIPTION": "<style=cIsDamage>造成伤害</style>储存<style=cIsHealth>生物质</style>，满时增加你的<style=cIsDamage>伤害</style>。跳跃可以<style=cIsDamage>蓄力</style>以进行<style=cIsUtility>强力跳跃</style>。 <i>Translated by: Jaosnake</i>",
        "ROB_NEMESIS_BODY_PASSIVE2_NAME": "生物武装",
        "ROB_NEMESIS_BODY_PASSIVE2_DESCRIPTION": "Nemesis T-Type可以通过吞噬<style=cIsDamage>感兴趣的人</style>来<style=cIsHealth>变异</style>，获得<style=cIsDamage>新的和改进的能力</style>。 <i>Translated by: Jaosnake</i>",
        "ROB_NEMESIS_BODY_PASSIVE22_NAME": "肌肉质量提升",
        "ROB_NEMESIS_BODY_PASSIVE22_DESCRIPTION": "<style=cIsUtility>近战攻击</style>造成<style=cIsDamage>20%</style>额外伤害，<style=isHealth>但盟友可能受到伤害</style>。 <i>Translated by: Jaosnake</i>",
        "ROB_NEMESIS_BODY_MELEE_NAME": "野蛮攻击",
        "ROB_NEMESIS_BODY_MELEE_DESCRIPTION": "拳击造成<style=cIsDamage>350%伤害</style>。<style=cIsUtility>静止</style>时使用可践踏造成<style=cIsDamage>800%伤害</style>。<style=cIsUtility>奔跑</style>时使用可肩撞造成<style=cIsDamage>600%伤害</style>。 <i>Translated by: Jaosnake</i>",
        "ROB_NEMESIS_BODY_GRAB_NAME": "致命触及",
        "ROB_NEMESIS_BODY_GRAB_DESCRIPTION": "抓住一名敌人。使用主武器吞噬并恢复10%最大生命值，或使用副武器蓄力投掷造成高达2,400%伤害。 <i>Translated by: Jaosnake</i>",
        "ROB_NEMESIS_BODY_DASH_NAME": "生化危机冲刺",
        "ROB_NEMESIS_BODY_DASH_DESCRIPTION": "<style=cIsUtility>在空中</style>使用可空中冲刺<style=cIsDamage>一次</style>。 <i>Translated by: Jaosnake</i>",
        "ROB_NEMESIS_BODY_ULTIMATE_NAME": "临界质量",
        "ROB_NEMESIS_BODY_ULTIMATE_DESCRIPTION": "按住以缓慢消耗<style=cIsHealth>生物质</style>，恢复最多<style=cIsHealing>100%最大生命值</style>。 <i>Translated by: Jaosnake</i>",
        "ROB_NEMESIS_ITEM_EFFECT_TITLE": "额外效果",
        "ROB_NEMESIS_ITEM_EFFECT_BANDOLIER": "弹药包恢复<style=cIsHealth>10%生物质</style>。",
        "ROB_NEMESIS_ITEM_EFFECT_ALIENHEAD": "增加从<style=cIsDamage>吞噬</style>敌人获得的<style=cIsHealth>生物质</style>。",
        "ROB_NEMESIS_ITEM_EFFECT_BRAINSTALKS": "激活时，<style=cIsHealth>生物质</style><style=cIsUtility>无限</style>。",
        "ROB_NEMESIS_ITEM_EFFECT_PURITY": "增加<style=cIsDamage>击中</style>时获得的<style=cIsHealth>生物质</style>。",
        "ROB_ARTIFACT_PURSUER_NAME": "追踪者神器",
        "ROB_ARTIFACT_PURSUER_DESC": "玩家开始游戏时携带S.T.A.R.S.徽章。",
        "ROB_ARTIFACT_CONTAMINATION_NAME": "污染神器",
        "ROB_ARTIFACT_CONTAMINATION_DESC": "每个玩家每个阶段会收到一个随机病毒事件。",
        "ROB_ARTIFACT_STRIKETEAM_NAME": "突击队神器",
        "ROB_ARTIFACT_STRIKETEAM_DESC": "玩家偶尔会有突击队被派遣来消灭他们。",
