		public class AwesomeSauceSkillDef : SkillDef
		{
			public override EntityState InstantiateNextState([NotNull] GenericSkill skillSlot)
			{
				if (Object.op_Implicit((Object)(object)skillSlot) && Object.op_Implicit((Object)(object)skillSlot.characterBody) && Object.op_Implicit((Object)(object)skillSlot.characterBody.characterMotor) && !skillSlot.characterBody.characterMotor.isGrounded)
				{
					EntityState val = EntityStateCatalog.InstantiateState(((SerializableEntityStateType)(ref Hunk.airDodgeState)).stateType);
					ISkillState val2;
					if ((val2 = (ISkillState)(object)((val is ISkillState) ? val : null)) != null)
					{
						val2.activatorSkillSlot = skillSlot;
					}
					return val;
				}
				return ((SkillDef)this).InstantiateNextState(skillSlot);
			}
		}
		public class BiomassSkillDef : SkillDef
		{
			protected class InstanceData : BaseSkillInstanceData
			{
				public NemesisController nemesis;
			}

			public override BaseSkillInstanceData OnAssigned([NotNull] GenericSkill skillSlot)
			{
				return (BaseSkillInstanceData)(object)new InstanceData
				{
					nemesis = ((Component)skillSlot).GetComponent<NemesisController>()
				};
			}

			private static bool HasBiomass([NotNull] GenericSkill skillSlot)
			{
				NemesisController nemesis = ((InstanceData)(object)skillSlot.skillInstanceData).nemesis;
				if (!Object.op_Implicit((Object)(object)nemesis))
				{
					return false;
				}
				if (nemesis.biomass > 0)
				{
					if (nemesis.HasMutation(Nemesis.mutationTendrilBarrageDevastator) && nemesis.biomass >= 100)
					{
						return true;
					}
					if (nemesis.characterBody.healthComponent.health < nemesis.characterBody.healthComponent.fullHealth)
					{
						return true;
					}
				}
				return false;
			}

			public override bool CanExecute([NotNull] GenericSkill skillSlot)
			{
				return HasBiomass(skillSlot) && ((SkillDef)this).CanExecute(skillSlot);
			}

			public override bool IsReady([NotNull] GenericSkill skillSlot)
			{
				return ((SkillDef)this).IsReady(skillSlot) && HasBiomass(skillSlot);
			}
		}
		public class BullseyeSearch2
		{
			private struct CandidateInfo
			{
				[StructLayout(LayoutKind.Sequential, Size = 1)]
				public struct EntityEqualityComparer : IEqualityComparer<CandidateInfo>
				{
					public bool Equals(CandidateInfo a, CandidateInfo b)
					{
						return (Object)(object)a.hurtBox.healthComponent == (Object)(object)b.hurtBox.healthComponent;
					}

					public int GetHashCode(CandidateInfo obj)
					{
						return ((object)obj.hurtBox.healthComponent).GetHashCode();
					}
				}

				public HurtBox hurtBox;

				public Vector3 position;

				public float dot;

				public float distanceSqr;
			}

			public enum SortMode
			{
				None,
				Distance,
				Angle,
				DistanceAndAngle
			}

			private delegate CandidateInfo Selector(HurtBox hurtBox);

			public CharacterBody viewer;

			public bool onlyBullseyes;

			public Vector3 searchOrigin;

			public Vector3 searchDirection;

			private float minThetaDot = -1f;

			private float maxThetaDot = 1f;

			public float minDistanceFilter;

