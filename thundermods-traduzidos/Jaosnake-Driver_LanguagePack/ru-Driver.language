        "ROB_DRIVER_WEAPON_REVOLVER_NAME": "Револьвер",
        "ROB_DRIVER_WEAPON_REVOLVER_DESC": "Удары с высоким уроном и смертельным финишером.</i>",
        "ROB_DRIVER_WEAPON_SMG_NAME": "Пистолет-пулемет",
