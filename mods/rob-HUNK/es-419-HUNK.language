        "ROB_HUNK_GHOST_ACHIEVEMENT_NAME": "HUNK: El Soldado Olvidado",
        "ROB_HUNK_GHOST_ACHIEVEMENT_DESC": "",
        "ROB_HUNK_CONTAMINATION_UNLOCKABLE_NAME": "Zona Cero",
        "ROB_HUNK_CONTAMINATION_ACHIEVEMENT_NAME": "Zona Cero",
        "ROB_HUNK_CONTAMINATION_ACHIEVEMENT_DESC": "Entrega una muestra de virus a la Umbrella Corporation.",
