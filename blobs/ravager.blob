					impactEffect = (EffectIndex)(-1),
					losType = (LoSType)0,
					damageColorIndex = (DamageColorIndex)0,
					damageType = DamageTypeCombo.op_Implicit((DamageType)0),
					procCoefficient = 1f,
					bonusForce = Vector3.zero,
					baseForce = 0f,
					baseDamage = damage,
					falloffModel = (FalloffModel)0,
					radius = 0.3f,
					position = targetTransform.position,
					attackerFiltering = (AttackerFiltering)2,
					teamIndex = projectileController.teamFilter.teamIndex,
					inflictor = attacker,
					crit = isCrit
				}.Fire();
			}
			EffectManager.SpawnEffect(Assets.punchImpactEffect, new EffectData
			{
				origin = targetTransform.position,
				scale = 3f
			}, false);
			Util.PlaySound("sfx_ravager_punch_barrage", ((Component)this).gameObject);
		}
	}
	public class SlamComponent : MonoBehaviour
	{
		public CharacterBody attackerBody;

		private CharacterMotor characterMotor;

		private bool hasFired;

		private void Awake()
		{
			characterMotor = ((Component)this).GetComponent<CharacterMotor>();
			hasFired = false;
		}

		private void FixedUpdate()
		{
			if (Object.op_Implicit((Object)(object)characterMotor) && characterMotor.isGrounded)
			{
				Fire();
			}
		}

		private void OnCollisionEnter(Collision collision)
		{
			if (!Object.op_Implicit((Object)(object)characterMotor))
			{
				Fire();
			}
		}

		private void Fire()
		{
