			private void HandleFlameEffect()
			{
				if (flamethrowerLifetime <= 0f)
				{
					StopFlame();
				}
				else if ((Object)(object)weaponDef == (Object)(object)BaseWeapon<Flamethrower>.instance.weaponDef)
				{
					if (flameIsPlaying)
					{
						return;
					}
					flameIsPlaying = true;
					if (!flamethrowerEffectInstance.activeSelf)
					{
						flamethrowerEffectInstance.SetActive(true);
					}
					if (Object.op_Implicit((Object)(object)characterBody) && Object.op_Implicit((Object)(object)characterBody.inventory) && characterBody.inventory.GetItemCount(Flamethrower.premiumFuel) > 0)
					{
						if (!blueFlamethrowerEffectInstance.activeSelf)
						{
							blueFlamethrowerEffectInstance.SetActive(true);
						}
						ParticleSystem[] componentsInChildren = blueFlamethrowerEffectInstance.GetComponentsInChildren<ParticleSystem>();
						foreach (ParticleSystem val in componentsInChildren)
						{
							val.Play();
						}
					}
					else
					{
						if (!flamethrowerEffectInstance2.activeSelf)
						{
							flamethrowerEffectInstance2.SetActive(true);
						}
						ParticleSystem[] componentsInChildren2 = flamethrowerEffectInstance2.GetComponentsInChildren<ParticleSystem>();
						foreach (ParticleSystem val2 in componentsInChildren2)
						{
							val2.Play();
						}
					}
					ParticleSystem[] componentsInChildren3 = flamethrowerEffectInstance.GetComponentsInChildren<ParticleSystem>();
					foreach (ParticleSystem val3 in componentsInChildren3)
					{
						val3.Play();
					}
					flamethrowerLight.SetActive(true);
					flamethrowerPlayID = Util.PlaySound("sfx_hunk_flamethrower_loop", ((Component)this).gameObject);
				}
				else
				{
					StopFlame();
				}
			}

			private void StopFlame()
			{
				if (flameIsPlaying)
				{
					flameIsPlaying = false;
					ParticleSystem[] componentsInChildren = flamethrowerEffectInstance.GetComponentsInChildren<ParticleSystem>();
					foreach (ParticleSystem val in componentsInChildren)
					{
						val.Stop();
					}
					ParticleSystem[] componentsInChildren2 = flamethrowerEffectInstance2.GetComponentsInChildren<ParticleSystem>();
					foreach (ParticleSystem val2 in componentsInChildren2)
					{
						val2.Stop();
					}
					ParticleSystem[] componentsInChildren3 = blueFlamethrowerEffectInstance.GetComponentsInChildren<ParticleSystem>();
					foreach (ParticleSystem val3 in componentsInChildren3)
					{
						val3.Stop();
					}
					flamethrowerLight.SetActive(false);
					AkSoundEngine.StopPlayingID(flamethrowerPlayID);
					if (flameInit)
					{
						Util.PlaySound("sfx_hunk_flamethrower_end", ((Component)this).gameObject);
					}
					flameInit = true;
				}
			}

			public void TriggerDodge(bool special = false)
