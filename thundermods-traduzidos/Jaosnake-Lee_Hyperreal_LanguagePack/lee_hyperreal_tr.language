        "POPCORN_LEE_HYPERREAL_BODY_ALT_SKIN_NAME": "Lee: Gerçek",
        "POPCORN_LEE_HYPERREAL_BODY_SCARLET_SKIN_NAME": "Lee: Kızıl Kurtarıcı",
        "POPCORN_LEE_HYPERREAL_BODY_PROSPECTOR_SKIN_NAME": "Arayıcı",
        "POPCORN_LEE_HYPERREAL_BODY_PROSPECTOR_ALT_SKIN_NAME": "Yoldaş",
        "POPCORN_LEE_HYPERREAL_BODY_YI_SKIN_NAME": "Yi",
        "POPCORN_LEE_HYPERREAL_BODY_BK_SKIN_NAME": "erkek öpücü",
        "POPCORN_LEE_HYPERREAL_BODY_PASSIVE_ORB_AND_AMMO_NAME": "Küre ve Cephane Sistemi",
        "POPCORN_LEE_HYPERREAL_BODY_PASSIVE_ORB_AND_AMMO_DESCRIPTION": "Lee: Hyperreal, benzersiz becerilerin uygulanmasına izin veren <style=cIsUtility>[Orbs]</style> kullanıyor. <style=cIsUtility>[Cephane Sayacı]</style>, <style=cIsUtility>[Keskin Nişancı Duruşu]</style>.</i> için benzersiz etkiler sağlar.",
        "POPCORN_LEE_HYPERREAL_BODY_PASSIVE_DOMAIN_NAME": "Hipermatris Sistemi",
        "POPCORN_LEE_HYPERREAL_BODY_PASSIVE_DOMAIN_DESCRIPTION": "Lee: Hyperreal'in, <style=cIsUtility>[Güç Göstergesi]</style> doluyken Birincil düğmeyi basılı tuttuğunda <style=cIsUtility>[Hypermatrix]</style>'ye erişimi var. Lee: Hyperreal, saldırı hızı yerine daha fazla vuruş kazanıyor ancak Keskin Nişancı Duruşu normal şekilde ölçekleniyor.</i>",
        "POPCORN_LEE_HYPERREAL_BODY_PASSIVE_VFX_COLOR_NAME": "VFX Rengi",
        "POPCORN_LEE_HYPERREAL_BODY_PASSIVE_DEFAULT_VFX_NAME": "Varsayılan VFX",
        "POPCORN_LEE_HYPERREAL_BODY_PASSIVE_DEFAULT_VFX_DESCRIPTION": "Görünüm seçimine bağlı olarak VFX rengini varsayılana değiştirir.</i>",
        "POPCORN_LEE_HYPERREAL_BODY_PASSIVE_RED_VFX_NAME": "Kırmızı VFX",
        "POPCORN_LEE_HYPERREAL_BODY_PASSIVE_RED_VFX_DESCRIPTION": "VFX rengini Kırmızı olarak değiştirir.</i>",
        "POPCORN_LEE_HYPERREAL_BODY_PASSIVE_ORANGE_VFX_NAME": "Turuncu VFX",
        "POPCORN_LEE_HYPERREAL_BODY_PASSIVE_ORANGE_VFX_DESCRIPTION": "VFX rengini Turuncu olarak değiştirir.</i>",
        "POPCORN_LEE_HYPERREAL_BODY_PASSIVE_YELLOW_VFX_NAME": "Sarı VFX",
        "POPCORN_LEE_HYPERREAL_BODY_PASSIVE_YELLOW_VFX_DESCRIPTION": "VFX rengini Sarı olarak değiştirir.</i>",
        "POPCORN_LEE_HYPERREAL_BODY_PASSIVE_GREEN_VFX_NAME": "Yeşil VFX",
        "POPCORN_LEE_HYPERREAL_BODY_PASSIVE_GREEN_VFX_DESCRIPTION": "VFX rengini Yeşil olarak değiştirir.</i>",
        "POPCORN_LEE_HYPERREAL_BODY_PASSIVE_BLUE_VFX_NAME": "Mavi VFX",
        "POPCORN_LEE_HYPERREAL_BODY_PASSIVE_BLUE_VFX_DESCRIPTION": "VFX rengini Mavi olarak değiştirir.</i>",
        "POPCORN_LEE_HYPERREAL_BODY_PASSIVE_LIGHTBLUE_VFX_NAME": "Açık Mavi VFX",
        "POPCORN_LEE_HYPERREAL_BODY_PASSIVE_LIGHTBLUE_VFX_DESCRIPTION": "VFX rengini Açık Mavi olarak değiştirir.</i>",
        "POPCORN_LEE_HYPERREAL_BODY_PASSIVE_VIOLET_VFX_NAME": "Menekşe VFX",
        "POPCORN_LEE_HYPERREAL_BODY_PASSIVE_VIOLET_VFX_DESCRIPTION": "VFX rengini Menekşe olarak değiştirir.</i>",
        "POPCORN_LEE_HYPERREAL_BODY_PASSIVE_PINK_VFX_NAME": "Pembe VFX",
        "POPCORN_LEE_HYPERREAL_BODY_PASSIVE_PINK_VFX_DESCRIPTION": "VFX rengini Pembe olarak değiştirir.</i>",
        "POPCORN_LEE_HYPERREAL_BODY_PASSIVE_RAINBOW_VFX_NAME": "Gökkuşağı VFX'i",
        "POPCORN_LEE_HYPERREAL_BODY_PASSIVE_RAINBOW_VFX_DESCRIPTION": "Bir VFX rengini rastgele seçer.</i>",
        "POPCORN_LEE_HYPERREAL_BODY_PRIMARY_NAME": "Silah Barajı",
        "POPCORN_LEE_HYPERREAL_BODY_PRIMARY_DESCRIPTION": "5 vuruşluk kombo saldırı başlatın. 1. ve 3. vuruşlarda, kısa bir süre boyunca aktif bir <style=cIsUtility>[Savuşturma]</style> gerçekleştirin. Havada aşağı doğru çarparak <style=cIsDamage>400% hasar</style> verir ve gidilen mesafeye bağlı olarak <style=cIsDamage>3x</style> değerine kadar artar. <style=cIsUtility>[Hypermatrix]</style>.</style>0__ girmek için <style=cIsUtility>[Güç Göstergesi]</style> doluyken istediğiniz zaman düğmeyi basılı tutun.",
        "POPCORN_LEE_HYPERREAL_BODY_ENTER_SNIPE_NAME": "Keskin Nişancı Duruşu",
        "POPCORN_LEE_HYPERREAL_BODY_ENTER_SNIPE_DESCRIPTION": "<style=cIsUtility>[Keskin Nişancı Duruşu]</style> girin, sizi olduğu yerde hareketsiz hale getirerek <style=cIsDamage>%400 hasar için Snipe'ı Birincil ile kullanmanıza olanak tanır</style>.</i>",
        "POPCORN_LEE_HYPERREAL_BODY_EXIT_SNIPE_NAME": "Keskin Nişancı Duruşundan Çık",
        "POPCORN_LEE_HYPERREAL_BODY_EXIT_SNIPE_DESCRIPTION": "<style=cIsUtility>[Keskin Nişancı Duruşu]</style>'den çıkın, tekrar hareket etmenizi sağlar.</i>",
        "POPCORN_LEE_HYPERREAL_BODY_SECONDARY_SNIPE_NAME": "Su çulluğu",
        "POPCORN_LEE_HYPERREAL_BODY_SECONDARY_SNIPE_DESCRIPTION": "<style=cIsDamage>%400 hasar veren bir mermi ateşleyin</style>.</i>",
        "POPCORN_LEE_HYPERREAL_BODY_DASH_NAME": "Gerçeklik Gezgini",
        "POPCORN_LEE_HYPERREAL_BODY_DASH_DESCRIPTION": "<style=cIsUtility>Dodge</style>, kısa süreliğine zarar görmez hale geliyor.</i>",
        "POPCORN_LEE_HYPERREAL_BODY_ULTIMATE_NAME": "Zamanın Sonu",
        "POPCORN_LEE_HYPERREAL_BODY_ULTIMATE_DESCRIPTION": "Kısa bir hücumdan sonra <style=cIsDamage>%6.500 hasar</style> verecek şekilde geniş bir yarıçaptaki düşmanları patlatan bir top çekerek hasar görmez hale gelin. <style=cIsUtility>[Hypermatrix]</style>.</i> içindeyken hamleleriniz değişir.",
        "POPCORN_LEE_HYPERREAL_BODY_ULTIMATE_DOMAIN_NAME": "Çöken Diyar",
        "POPCORN_LEE_HYPERREAL_BODY_ULTIMATE_DOMAIN_DESCRIPTION": "<style=cIsUtility>[Hypermatrix]</style>'yi çökerterek kısa süreliğine hasar almaz hale gelir ve arkanızda <style=cIsDamage>1.500% hasar</style> verirsiniz. Hypermatrix sırasındaki her 3-Ping, <style=cIsUtility>[Çöken Diyar]</style>'ye <style=cIsDamage>%200 hasar</style> içeren 3 vuruş ekler. 12 ekstra vuruş için maksimum 4 kez.</i>",
        "POPCORN_LEE_HYPERREAL_BODY_ITEM_EFFECT_TITLE": "Hiper Etki",
        "POPCORN_LEE_HYPERREAL_BODY_ITEM_EFFECT_BACKUPMAG_DESC": "<style=cIsDamage>Lee: Hipergerçek</style>, <style=cIsUtility>+1</style> <style=cStack>(yığın başına +1)</style> Her başarılı <style=cIsUtility>[Savuşturma]</style> için güçlendirilmiş mermi(ler) kazanır.",
        "POPCORN_LEE_HYPERREAL_BODY_ITEM_EFFECT_ALIEN_HEAD_DESC": "<style=cIsDamage>Lee: Hyperreal'in</style> küreleri <style=cIsUtility>25% daha hızlı</style> şarj eder.",
        "POPCORN_LEE_HYPERREAL_BODY_ITEM_EFFECT_PURITY_DESC": "<style=cIsDamage>Lee: Hyperreal'in</style> küre şarj hızı <style=cIsUtility>2</style> <style=cStack>(yığın başına +1)</style> saniye azalır.",
        "POPCORN_LEE_HYPERREAL_BODY_ITEM_EFFECT_ATTACK_SPEED_DESC": "<style=cIsDamage>Lee: Hyperreal'in</style> birincil saldırı hızı yerine daha fazla <style=cIsUtility>hits</style> kazanır. Örnek: %250 saldırı hızı = 2 vuruş ve yarım hasar vuruşu.",
        "POPCORN_LEE_HYPERREAL_BODY_ITEM_EFFECT_LUMINOUS_SHOT_DESC": "<style=cIsDamage>Lee: Hyperreal'in</style> Keskin Nişancı Duruşu atışları, İkincil kullanmak yerine atış başına <style=cIsUtility>1 Yığın</style> sağlar.",
        "POPCORN_LEE_HYPERREAL_BODY_KEYWORD_ORBS": "<style=cKeywordName>Orb Sistemi</style>\nLee: Hyperreal, ekstra beceriler kullanmak için farklı renklerde 3 Küre kullanır. Basit Modda, soldan sağa ilk renkli küre grubunu kullanmak için belirlenen tuşları kullanarak <style=cIsUtility>Blue</style>, <style=cIsUtility>Red</style> ve <style=cIsUtility>Yellow</style> kürelerini etkinleştirin. <style=cIsUtility>[3-ping]</style> olarak bilinen, aynı renkteki 3 bitişik küreyi kullanmak, küre becerisinin hasarını</style>0__4x</style>1__ artırır, ayrıca</style>2__Red</style>3__ için ekstra saldırılar sağlar ve</style>4__Sarı</style>5__ Küreler.",
        "POPCORN_LEE_HYPERREAL_BODY_KEYWORD_AMMO": "<style=cKeywordName>Cephane Sistemi</style>\nLee: Hyperreal, <style=cIsUtility>[Güç Göstergesi]</style> üzerinde belirtilen çeşitli <style=cIsUtility>Cephane</style> depolayabilir ve kullanabilir. Bir <style=cIsUtility>[3-ping]</style> kullanmak, bir <style=cIsUtility>[Renkli Kurşun]</style> saklar; bu,</style>0__[Hypermatrix]</style>1__ içinde</style>2__[Orb'unuza o renkten 3 Küre eklemek için kullanılabilir. Sistem]</style>3__ Snipe'ı kullanırken. Başarılı bir</style>4__[Savuşturma]</style>5__,</style>6__[Güçlendirilmiş Mermiler]</style>7__ verilir ve</style>8__[Keskin Nişancı Duruşu]</style>9__ içindeki bir sonraki atışınızın hasarı<style=cIsUtility>0__2x<style=cIsUtility>1__ ile artar.",
        "POPCORN_LEE_HYPERREAL_BODY_KEYWORD_SNIPE_STANCE": "<style=cKeywordName>Keskin Nişancı Duruşu</style>\nSizi hareketsiz bırakan bir duruşa girin ve Birincil Becerinizi, atış başına <style=cIsDamage>%400 hasar</style> veren hassas bir atışla değiştirin. Yardımcı Beceriyi herhangi bir yön girişi olmadan kullanmak, <style=cIsDamage>%400 hasar</style> veren bir mermi ateşlerken geriye doğru kaçmanıza olanak tanır. Aksi takdirde bu beceriyi kullanmak duruşu iptal eder.",
        "POPCORN_LEE_HYPERREAL_BODY_KEYWORD_POWER_GAUGE": "<style=cKeywordName>Güç Göstergesi</style>\nSağlık Çubuğunun üzerinde bulunan Güç Göstergesi, <style=cIsUtility>[Hypermatrix]</style>'e ne zaman girebileceğinizi ve çıkmadan önce ne kadar süre kalacağını belirler. <style=cIsUtility>[Hypermatrix]</style>'e girmek için Birincil Beceriye sahip olun.",
        "POPCORN_LEE_HYPERREAL_BODY_KEYWORD_PARRY": "<style=cKeywordName>Parry</style>\nBaşarılı bir savuşturmada, hasar veren düşmanı, eğer sersemletilebilecekse, sersemletir. Savuşturulan herhangi bir mermi, hedeflediğiniz yöne doğru geri fırlatılacaktır. Başarılı bir savuşturma, yeniden savuşturmak için kullanılan hareketten başlayarak <style=cIsUtility>[Silah Salvosu]</style>'yi sıfırlar.",
        "POPCORN_LEE_HYPERREAL_BODY_KEYWORD_DOMAIN": "<style=cKeywordName>Hypermatrix Sistemi</style>\nSağlığınızın üstünde <style=cIsUtility>[Hypermatrix Sistem Göstergesi]</style> bulunur. Gösterge dolduğunda, Birincil Beceriyi herhangi bir zamanda <style=cIsUtility>[Silah Salvosu]</style> içinde tutmak sizi <style=cIsUtility>[Hypermatrix]</style>'ye taşıyacaktır. Bu durumda, <style=cIsUtility>Red</style> ve</style>0__Yellow</style>1__ küreleri tamamen değişir ve Özeliniz</style>2__[Çöken Diyar]</style>3__ olur. Göstergenin süresi bu durumda dolarsa,</style>4__[Çöken Bölge]</style>5__ otomatik olarak etkinleştirilecek ve</style>6__[Hypermatrix]</style>7__'den çıkılacaktır.",
        "POPCORN_LEE_HYPERREAL_BODY_KEYWORD_DOMAIN_ULT": "<style=cKeywordName>Çöken Bölge</style>\n<style=cIsUtility>[Hypermatrix]</style>'ü daraltın, kısa bir süre için hasar görmez hale gelir ve arkanızda <style=cIsDamage>1.500% hasar</style> verir. Hipermatriste <style=cIsUtility>[3-ping]</style> kullandığınız her defasında <style=cIsDamage>%200 hasar</style> ile 3 vuruş ekleyin. 12 ekstra vuruş için maksimum 4 kez.",
        "LEE_HYPERREAL_BODY_BROTHER_RESPONSE_ENTRY": "Buraya nasıl geldin?",
        "LEE_HYPERREAL_BODY_BROTHER_RESPONSE_ON_DEATH_1": "Kendi boyutunuzda dua edin.",
        "LEE_HYPERREAL_BODY_BROTHER_RESPONSE_ON_DEATH_2": "Başka bir gerçeklik seni benden kurtaramayacak.",
        "LEE_HYPERREAL_BODY_BROTHER_RESPONSE_ON_DEATH_3": "Senin her kopyanı ezeceğim.",
        "ACHIEVEMENT_POPCORN_LEE_HYPERREAL_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_DESCRIPTION": "Lee: Hyperreal olarak oyunu yenin veya Muson'da kendinizi yok edin.",
        "POPCORN_LEE_HYPERREAL_BODY_MASTERYUNLOCKABLE_UNLOCKABLE_NAME": "Lee: Hipergerçek: Ustalık",
        "ACHIEVEMENT_POPCORN_LEE_HYPERREAL_BODY_BLUESKIN_ACHIEVEMENT_DESCRIPTION": "Lee: Hyperreal olarak, Muson'da oyunu Transcendence ile yenin veya Orta veya daha yüksek bir sandıktan %5 şans atın.",
        "POPCORN_LEE_HYPERREAL_BODY_BLUESKIN_UNLOCKABLE_NAME": "Lee: Hipergerçek: Gerçek",
        "ACHIEVEMENT_POPCORN_LEE_HYPERREAL_BODY_SCARLET_ACHIEVEMENT_DESCRIPTION": "Lee: Hyperreal olarak, Muson'da oyunu saat eşyaları ve kanama olmadan yenin veya Efsanevi bir sandıktan %5 şans elde edin.",
        "POPCORN_LEE_HYPERREAL_BODY_SCARLET_UNLOCKABLE_NAME": "Lee: Hipergerçek: Kızıl",
        "ACHIEVEMENT_POPCORN_LEE_HYPERREAL_BODY_YELLOW_VFX_ACHIEVEMENT_DESCRIPTION": "Lee: Hyperreal olarak, Muson'da oyunu 5'ten fazla Boss öğesiyle yenin veya herhangi bir sandıktan %2 şans atın.",
        "POPCORN_LEE_HYPERREAL_BODY_YELLOW_VFX_UNLOCKABLE_NAME": "Lee: Hipergerçek: Sarı VFX",
        "ACHIEVEMENT_POPCORN_LEE_HYPERREAL_BODY_GREEN_VFX_ACHIEVEMENT_DESCRIPTION": "Lee: Hyperreal olarak, Muson'da oyunu 15'ten fazla iyileştirici öğeyle yenin veya herhangi bir sandıktan %2 şans atın.",
        "POPCORN_LEE_HYPERREAL_BODY_GREEN_VFX_UNLOCKABLE_NAME": "Lee: Hipergerçek: Yeşil VFX",
        "ACHIEVEMENT_POPCORN_LEE_HYPERREAL_BODY_PINK_VFX_ACHIEVEMENT_DESCRIPTION": "Lee: Hyperreal olarak Işınlayıcı boss'u End of Times maksimum güçteyken öldürün veya herhangi bir sandıktan %2 şans atın.",
        "POPCORN_LEE_HYPERREAL_BODY_PINK_VFX_UNLOCKABLE_NAME": "Lee: Hipergerçek: Pembe VFX",
        "ACHIEVEMENT_POPCORN_LEE_HYPERREAL_BODY_VIOLET_VFX_ACHIEVEMENT_DESCRIPTION": "Lee: Hyperreal olarak oyunu Eclipse 8'de yenin veya Efsanevi sandıktan %1 şans elde edin.",
        "POPCORN_LEE_HYPERREAL_BODY_VIOLET_VFX_UNLOCKABLE_NAME": "Lee: Hipergerçek: Menekşe VFX"
