				case 2:
					virusType = VirusType.CVirus;
					break;
				case 3:
					virusType = VirusType.Uroboros;
					break;
				case 4:
					virusType = VirusType.Plagas;
					break;
				}
				if (virusType == VirusType.TVirus)
				{
					Scene activeScene = SceneManager.GetActiveScene();
					if (((Scene)(ref activeScene)).name == "arena")
					{
						virusType = VirusType.CVirus;
					}
				}
				if (NetworkServer.active)
				{
					((MonoBehaviour)this).Invoke("SpawnKeycard", Random.Range(5f, 30f));
				}
			}

			private void Start()
			{
				inventory.onItemAddedClient += Inventory_onItemAddedClient;
				inventory.onInventoryChanged += Inventory_onInventoryChanged;
			}

