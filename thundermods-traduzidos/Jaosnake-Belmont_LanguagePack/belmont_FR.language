        "ROB_GREAT_GARGOYLE_NAME": "Crocs bleus",
        "KEYWORD_WHIP_SLAM": "<style=cKeywordName>Coup de fouet</style><style=cSub>Appuyez deux fois pendant que vous êtes verrouillé sur un<style=cIsUtility>aéroporté</style>ennemi de<style=cIsDamage>claquer</style>les à terre pour<style=cIsDamage>1800% de dégâts</style>."
