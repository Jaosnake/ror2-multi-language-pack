			{
				for (int i = 0; i < notifications.Length; i++)
				{
					if (Object.op_Implicit((Object)(object)notifications[i]) && notifications[i].stopwatch > 0f && (Object)(object)notifications[i].itemDef == (Object)(object)itemDef)
					{
