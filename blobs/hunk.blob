	internal static class Helpers
	{
		internal const string agilePrefix = "<style=cIsUtility>Agile.</style> ";

		internal const string blackHex = "000000";

		internal const string uroborosHex = "140E0E";

		internal const string whiteItemHex = "00FF66";

		internal const string greenItemHex = "00FF66";

		internal const string redItemHex = "FF0033";

		internal const string yellowItemHex = "FFFF00";

		internal const string lunarItemHex = "0066FF";

		internal const string voidItemHex = "C678B4";

		internal const string umbrellaHex = "C80202";

		internal const string colorSuffix = "</color>";

		internal static Color whiteItemColor = new Color(1f, 1f, 1f);

		internal static Color greenItemColor = new Color(0f, 1f, 0.4f);

		internal static Color redItemColor = new Color(1f, 0f, 0.2f);

		internal static Color foodItemColor = new Color(1f, 0.5f, 0f);

		internal static Color yellowItemColor = new Color(1f, 1f, 0f);

		internal static Color lunarItemColor = new Color(0f, 0.4f, 1f);

		internal static Color voidItemColor = new Color(66f / 85f, 0.47058824f, 0.7058824f);

		internal static Color badColor = new Color(0.49803922f, 0f, 0f);

		internal static string[] virusStageBlacklist = new string[22]
		{
			"moon", "moon2", "bazaar", "voidraid", "artifactworld", "artifactworld01", "artifactworld02", "artifactworld03", "limbo", "mysteryspace",
			"testscene", "meridian", "itancientloft", "itdampcave", "itfrozenwall", "itgolemplains", "itgoolake", "itmoon", "itskymeadow", "solutionalhaunt",
			"computationalexchange", "solusweb"
		};

		internal static bool canVirusSpawn
		{
			get
			{
				//IL_0001: Unknown result type (might be due to invalid IL or missing references)
				//IL_0006: Unknown result type (might be due to invalid IL or missing references)
				Scene activeScene = SceneManager.GetActiveScene();
				string name = ((Scene)(ref activeScene)).name;
				for (int i = 0; i < virusStageBlacklist.Length; i++)
				{
					if (virusStageBlacklist[i] == name)
					{
						return false;
					}
				}
				return true;
			}
		}

		internal static bool isSimulacrum
		{
			get
			{
				//IL_0001: Unknown result type (might be due to invalid IL or missing references)
				//IL_0006: Unknown result type (might be due to invalid IL or missing references)
				Scene activeScene = SceneManager.GetActiveScene();
				string name = ((Scene)(ref activeScene)).name;
				int result;
				switch (name)
				{
				default:
					result = ((name == "itskymeadow") ? 1 : 0);
					break;
				case "itancientloft":
				case "itdampcave":
				case "itfrozenwall":
				case "itgolemplains":
				case "itgoolake":
				case "itmoon":
					result = 1;
					break;
				}
				return (byte)result != 0;
