					{
						component.currentEnemy.gameObject = ((Component)body).gameObject;
					}
				}
			}

			private void SetCooldown(float? customCooldown = null)
			{
				if (!customCooldown.HasValue)
				{
					retargetTimer = LunarChimeraRetargetingCooldown;
				}
				else
				{
					retargetTimer = customCooldown.Value;
				}
			}
		}

