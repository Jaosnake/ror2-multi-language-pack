	 "ROB_BELMONT_BODY_UTILITY2_NAME": "Adjudicate",
	 "ROB_BELMONT_BODY_UTILITY2_DESCRIPTION": "Perform a devastating uppercut for <style=cIsDamage>1200% damage</style>.",

	 "ROB_BELMONT_BODY_SPECIAL_HOLYWATER_NAME": "Ancient Flame",
	 "ROB_BELMONT_BODY_SPECIAL_HOLYWATER_DESCRIPTION": "Throw a jar of <style=cIsUtility>wisp fragments</style>, exploding and unleashing <style=cIsUtility>pillars of flame</style> for <style=cIsDamage>800% damage</style>.",

	 "ROB_BELMONT_BODY_SPECIAL_HOLYWATER_SCEPTER_NAME": "Hellfire",
	 "ROB_BELMONT_BODY_SPECIAL_HOLYWATER_SCEPTER_DESCRIPTION": "Throw a jar of <style=cIsUtility>wisp fragments</style>, exploding and unleashing <style=cIsUtility>pillars of flame</style> for <style=cIsDamage>800 damage</style>.\n<color=#d299ff>SCEPTER: Flames are larger, deal 1200% damage and leave a trail of fire on the ground.</color>",

	 "ROB_BELMONT_BODY_SPECIAL_CROSS_NAME": "Battle Cross",
	 "ROB_BELMONT_BODY_SPECIAL_CROSS_DESCRIPTION": "Throw a <style=cIsUtility>piercing cross</style> that hits multiple times for <style=cIsDamage>250% damage</style>.",

	 "ROB_BELMONT_BODY_SPECIAL_CROSS_SCEPTER_NAME": "Triple Cross",
