			cancelling = true;
			((EntityState)this).outer.SetNextState((EntityState)(object)new ThrowBomb
			{
				charge = iDrive.chargeValue
			});
		}

		public override void OnExit()
		{
			base.OnExit();
			AkSoundEngine.StopPlayingID(chargePlayID);
			if (Object.op_Implicit((Object)(object)chargeEffectInstance))
			{
				EntityState.Destroy((Object)(object)chargeEffectInstance);
			}
			if (Object.op_Implicit((Object)(object)iDrive))
			{
				iDrive.chargeValue = 0f;
			}
		}

