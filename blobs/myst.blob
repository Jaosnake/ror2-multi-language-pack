		private string GetKeybind(UserProfile uP, int num)
		{
			if (((ControllerMap)uP.keyboardMap).GetFirstButtonMapWithAction(num) != null)
			{
				return ((ControllerMap)uP.keyboardMap).GetFirstButtonMapWithAction(num).elementIdentifierName;
			}
			if (((ControllerMap)uP.mouseMap).GetFirstButtonMapWithAction(num) != null)
			{
				return ((ControllerMap)uP.mouseMap).GetFirstButtonMapWithAction(num).elementIdentifierName;
			}
			return null;
		}

