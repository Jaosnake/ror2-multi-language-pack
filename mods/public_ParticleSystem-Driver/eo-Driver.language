        "ROB_DRIVER_BODY_SPECIAL_GRENADE_NAME": "Fulmogrenado",
        "ROB_DRIVER_BODY_SPECIAL_GRENADE_DESCRIPTION": "Jxetu grenadon, kiu <style=cIsUtility>stuporigas</style> malamikojn por 500% da damagxo. <style=cIsUtility>Stuporigitaj malamikoj celas en hazardaj direktoj dum 10 sekundoj.</style></i>",
        "ROB_DRIVER_BODY_SPECIAL_GRENADE_SCEPTER_NAME": "Molotova Koktelo",
        "ROB_DRIVER_BODY_SPECIAL_GRENADE_SCEPTER_DESCRIPTION": "Jxetu grenadon, kiu <style=cIsUtility>stuporigas</style> malamikojn por 500% da damagxo. <style=cIsUtility>Stuporigitaj malamikoj celas en hazardaj direktoj dum 10 sekundoj.</style>\n<style=cIsUtility>Scepter: Jxetu molotovan koktelon, kiu eksplodas en flamojn.</style></i>",
        "ROB_DRIVER_BODY_SPECIAL_SUPPLY_DROP_NAME": "Provizfalo",
        "ROB_DRIVER_BODY_SPECIAL_SUPPLY_DROP_DESCRIPTION": "Alvoku keston enhavantan <color=#00FF66>hazardan armilon</color>. <style=cIsHealth>La armilo venas nur kun duona municione.</style></i>",
        "ROB_DRIVER_BODY_SPECIAL_SUPPLY_DROP_LEGACY_NAME": "Provizfalo (Antikva)",
        "ROB_DRIVER_BODY_SPECIAL_SUPPLY_DROP_LEGACY_DESCRIPTION": "Alvoku keston enhavantan <color=#FFFF00>Prototipan Raketlancxilon</color>. <style=cIsUtility>Vi povas alvoki nur unu po etapo.</style></i>",
        "ROB_DRIVER_BODY_SPECIAL_SUPPLY_DROP_SCEPTER_NAME": "Vakua Alvoko",
        "ROB_DRIVER_BODY_SPECIAL_SUPPLY_DROP_SCEPTER_DESCRIPTION": "Alvoku keston enhavantan <color=#00FF66>hazardan armilon</color>. <style=cIsHealth>La armilo venas nur kun duona municione.</style>\n<style=cIsUtility>Scepter: Alvoku vakuan armilon.</style></i>",
        "ROB_DRIVER_BODY_SPECIAL_SUPPLY_DROP_LEGACY_SCEPTER_NAME": "Vakua Alvoko",
        "ROB_DRIVER_BODY_SPECIAL_SUPPLY_DROP_LEGACY_SCEPTER_DESCRIPTION": "Alvoku keston enhavantan <color=#FFFF00>Prototipan Raketlancxilon</color>.\n<style=cIsUtility>Scepter: Alvoku vakuan armilon.</style></i>",
        "ROB_DRIVER_BODY_SPECIAL_HEAL_NAME": "Memzorgado",
        "ROB_DRIVER_BODY_SPECIAL_HEAL_DESCRIPTION": "Elprenu <style=cIsUtility>Medkeston</style> kaj iom-post-iome resanigxu al maksimuma sano.</i>",
        "ROB_DRIVER_BODY_SPECIAL_KNIFE_NAME": "Batala Trancxilo",
        "ROB_DRIVER_BODY_SPECIAL_KNIFE_DESCRIPTION": "Trancxu proksimajn malamikojn per denteca klingo, kauxzante 470% da damagxo kaj <style=cIsHealth>vundante</style> ilin, <style=cIsDamage>malaltigante kirason</style> dum <style=cIsUtility>4 sekundoj</style>.</i>",
        "ROB_DRIVER_BODY_SPECIAL_KNIFE_SCEPTER_NAME": "Batala Trancxilo (Scepter)",
        "ROB_DRIVER_BODY_SPECIAL_KNIFE_SCEPTER_DESCRIPTION": "Trancxu proksimajn malamikojn per denteca klingo, kauxzante 470% da damagxo kaj <style=cIsHealth>vundante</style> ilin, <style=cIsDamage>malaltigante kirason</style> dum <style=cIsUtility>4 sekundoj</style>.\n<style=cIsUtility>Scepter: Duona resxargotempo kaj ekstra sxargo.</style></i>",
        "ROB_DRIVER_BODY_SPECIAL_SYRINGE_NAME": "Eksperimenta Seringilo",
        "ROB_DRIVER_BODY_SPECIAL_SYRINGE_DESCRIPTION": "Injektu vin per <style=cIsUtility>seringilo</style>, donante ekstra <style=cIsDamage>atakrapidecon</style>, <style=cIsUtility>movrapidecon</style> kaj <style=cIsHealing>sana-regeneron</style> dum la sekvaj <style=cIsUtility>6 sekundoj</style>.</i>",
        "ROB_DRIVER_BODY_SPECIAL_SYRINGE_SCEPTER_NAME": "Plifortigita Seringilo",
