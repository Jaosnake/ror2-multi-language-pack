			{
				EffectData val = new EffectData
				{
					origin = characterBody.corePosition,
					scale = 1f
				};
				EffectManager.SpawnEffect(buffOnEffect, val, true);
				isMaxed = true;
				buffOverlay = TemporaryOverlayManager.AddOverlay(((Component)this).gameObject);
				buffOverlay.animateShaderAlpha = true;
				buffOverlay.alphaCurve = AnimationCurve.EaseInOut(0f, 1f, 1f, 0f);
				buffOverlay.destroyComponentOnEnd = true;
				buffOverlay.duration = float.PositiveInfinity;
				buffOverlay.originalMaterial = overlayMat;
				buffOverlay.AddToCharacterModel(characterModel);
				((Component)sparkEffect).gameObject.SetActive(true);
				Util.PlaySound(maxStartString, ((Component)this).gameObject);
				endLoopID = Util.PlaySound(loopString, ((Component)this).gameObject);
			}
			if (characterBody.GetBuffCount(Buffs.damageGrowth) < 10 && isMaxed)
			{
				isMaxed = false;
				EffectData val2 = new EffectData
				{
					origin = characterBody.corePosition,
					scale = 1f
				};
				EffectManager.SpawnEffect(buffOffEffect.gameObject, val2, true);
				AkSoundEngine.StopPlayingID(endLoopID);
				Util.PlaySound(maxEndString, ((Component)this).gameObject);
				if (buffOverlay != null)
				{
					buffOverlay.Destroy();
				}
				if (((Component)sparkEffect).gameObject.activeInHierarchy)
				{
					((Component)sparkEffect).gameObject.SetActive(false);
				}
			}
