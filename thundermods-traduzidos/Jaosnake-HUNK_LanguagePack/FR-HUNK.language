        "ROB_HUNK_BODY_SHOOT_ATM2_NAME": "Tirer",
        "ROB_HUNK_BODY_SHOOT_ATM2_DESCRIPTION": "Tire pour <style=cIsDamage>8.000% de dégâts</style>. <style=cIsUtility>Inflige plus de dégâts sur les coups directs.</style>",
        "ROB_HUNK_BODY_SHOOT_RPG_NAME": "Tirer",
        "ROB_HUNK_BODY_SHOOT_RPG_DESCRIPTION": "Tire pour <style=cIsDamage>8.000% de dégâts</style>. <style=cIsUtility>Inflige plus de dégâts sur les coups directs.</style>",
        "ROB_HUNK_BODY_SHOOT_ROCKETLAUNCHER_NAME": "Tirer",
        "ROB_HUNK_BODY_SHOOT_ROCKETLAUNCHER_DESCRIPTION": "Tire pour <style=cIsDamage>12.000% de dégâts</style>. <style=cIsDamage>Incendiaire.</style>",
        "ROB_HUNK_BODY_SHOOT_GRENADELAUNCHER_NAME": "Tirer",
        "ROB_HUNK_BODY_SHOOT_GRENADELAUNCHER_DESCRIPTION": "Tire pour <style=cIsDamage>3.200% de dégâts</style>. <style=cIsDamage>Incendiaire.</style>",
        "ROB_HUNK_BODY_SHOOT_MGL_NAME": "Tirer",
        "ROB_HUNK_BODY_SHOOT_MGL_DESCRIPTION": "Tire pour <style=cIsDamage>2.400% de dégâts</style>.",
        "ROB_HUNK_BODY_SHOOT_RAILGUN_NAME": "Tirer",
        "ROB_HUNK_BODY_SHOOT_RAILGUN_DESCRIPTION": "Tire pour <style=cIsDamage>20.000% de dégâts</style>.",
        "ROB_HUNK_BODY_SHOOT_FLAMETHROWER_NAME": "Tirer",
        "ROB_HUNK_BODY_SHOOT_FLAMETHROWER_DESCRIPTION": "Tire un jet de flammes pour <style=cIsDamage>des tonnes de dégâts</style>. <style=cIsUtility>Enflamme.</style>",
        "ROB_HUNK_BODY_SHOOT_SCANNER_NAME": "Scanner",
        "ROB_HUNK_BODY_SHOOT_SCANNER_DESCRIPTION": "Scanne pour <style=cIsUtility>les mallettes d'armes non ouvertes</style>.",
        "ROB_HUNK_BODY_SHOOT_HOOKSHOT_NAME": "Grappin",
        "ROB_HUNK_BODY_SHOOT_HOOKSHOT_DESCRIPTION": "Tirez un grappin vers un <style=cIsUtility>point éloigné</style>, puis <style=cIsUtility>tirez-vous vers lui</style>. <style=cIsDamage>Vous pouvez contre-attaquer après l'atterrissage.</style>",
        "ROB_HUNK_KEYWORD_MANGLED": "Mutilé",
        "ROB_HUNK_KEYWORD_COUNTER": "Contre-attaque",
        "ROB_HUNK_KEYWORD_PERFECTDODGE": "Esquive Parfaite",
        "ROB_HUNK_KEYWORD_PERFECTBASH": "Déflexion Parfaite",
        "ROB_HUNK_KEYWORD_PERFECTPARRY": "Parade Parfaite",
        "ROB_HUNK_KEYWORD_CVIRUS": "C-Virus",
        "ROB_HUNK_KEYWORD_GVIRUS": "G-Virus",
        "ROB_HUNK_KEYWORD_TVIRUS": "T-Virus",
        "ROB_HUNK_KEYWORD_VIRUS": "Virus",
        "ROB_HUNK_KEYWORD_LOOTING": "Pillage",
        "ROB_HUNK_JETPACK_NAME": "Pack de Saut Expérimental",
        "ROB_HUNK_JETPACK_DESC": "Un outil fabriqué par Umbrella qui vous permet de vous propulser dans n'importe quelle direction en appuyant sur saut dans les airs.",
        "ROB_HUNK_SURVIVALKIT_NAME": "Kit de Survie d'Urgence",
        "ROB_HUNK_SURVIVALKIT_DESC": "Un kit de survie qui augmente à la fois votre capacité à fouiller pour des munitions et l'efficacité de votre couteau.",
        "ROB_HUNK_TRANSCEIVER_NAME": "Émetteur-récepteur Usé",
        "ROB_HUNK_TRANSCEIVER_DESC": "Appelle un coéquipier pour aider dans votre opération.",
        "ROB_HUNK_INFROCKET_NAME": "ATM-4",
        "ROB_HUNK_INFROCKET_DESC": "Un lance-roquettes avec <style=cIsHealing>des munitions infinies</style>. Récompense pour le succès <color=#FFFF00>Early Supporter</color>.",
        "ROB_HUNK_TYPEWRITER_NAME": "Machine à Écrire",
        "ROB_HUNK_TYPEWRITER_DESC": "Accorde <style=cIsUtility>2</style> <color=#C80202>mallettes d'armes Umbrella</color> supplémentaires par Étape.",
        "ROB_HUNK_CRYSTALSKULL_NAME": "Crâne de Cristal",
        "ROB_HUNK_CRYSTALSKULL_DESC": "Un trésor rare. Peut être échangé dans n'importe quel <style=cIsUtility>Chaudron</style> pour recevoir un objet.",
        "ROB_HUNK_WRISTBAND_NAME": "Bracelet d'Identification",
        "ROB_HUNK_WRISTBAND_DESC": "Une clé électronique pour utilisation dans les installations de <color=#C80202>Umbrella Corporation</color>. Utilisée pour ouvrir une <style=cIsUtility>mallette d'arme spéciale</style>.",
        "ROB_HUNK_SPADE_KEYCARD_NAME": "U.C. Keycard (Piques)",
        "ROB_HUNK_CLUB_KEYCARD_NAME": "U.C. Keycard (Trèfles)",
        "ROB_HUNK_HEART_KEYCARD_NAME": "U.C. Keycard (Cœurs)",
        "ROB_HUNK_DIAMOND_KEYCARD_NAME": "U.C. Keycard (Carreaux)",
        "ROB_HUNK_GOLD_KEYCARD_NAME": "U.C. Keycard (Étoile)",
        "ROB_HUNK_MASTER_KEYCARD_NAME": "U.C. Keycard (Maître)",
        "ROB_HUNK_KEYCARD_DESC": "Utilisé pour ouvrir les <color=#C80202>mallettes d'armes</color> de <style=cIsUtility>Umbrella Corporation</style>.",
        "ROB_HUNK_KEYCARD_MASTER_DESC": "Utilisé pour ouvrir les <color=#C80202>mallettes d'armes</color> de <style=cIsUtility>Umbrella Corporation</style>. Ouvre <style=cIsHealing>toutes les mallettes</style> et transforme les autres keycards en <style=cIsUtility>ferraille</style>.",
        "ROB_HUNK_STARSBADGE_NAME": "Badge S.T.A.R.S.",
        "ROB_HUNK_STARSBADGE_DESC": "Un badge spécial de la division des forces spéciales du R.P.D., <color=#F20443>S.T.A.R.S.</color> <style=cIsHealth>Peut-être que prendre cela était une mauvaise idée?</style>",
        "ROB_HUNK_STARSBADGE_DESCFULL": "Chaque Étape, une mallette spéciale <color=#F20443>S.T.A.R.S.</color> apparaît qui ne peut être ouverte qu'avec ce badge. Cependant, le <style=cIsHealth>Nemesis T-Type</style> vous traquera impitoyablement.",
        "ROB_HUNK_STARSBADGE2_NAME": "Clé USB Dongle",
