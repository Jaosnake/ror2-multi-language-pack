		public override void Hooks()
		{
			//IL_0008: Unknown result type (might be due to invalid IL or missing references)
			//IL_0012: Expected O, but got Unknown
			//IL_001a: Unknown result type (might be due to invalid IL or missing references)
			//IL_0024: Expected O, but got Unknown
			CharacterBody.RecalculateStats += new hook_RecalculateStats(AddAttackSpeedMult);
			GlobalEventManager.OnHitEnemy += new hook_OnHitEnemy(AddAttackSpeedBuff);
		}

		private void AddAttackSpeedMult(orig_RecalculateStats orig, CharacterBody self)
		{
			orig.Invoke(self);
			int count = GetCount(self);
			if (count > 0)
			{
				float num = CalculateSpeedMult(self);
				self.attackSpeed *= num;
			}
		}

		public int CalculateMaxBuffStacks(CharacterBody characterBody)
		{
			int itemCountPermanent = characterBody.inventory.GetItemCountPermanent(ItemBase<ZenithAccelerator>.instance.ItemDef);
			double num = Math.Pow((float)ExponentialBaseMultiplier, itemCountPermanent);
			ConfigOption<float> percentageIncreasePerHit = PercentageIncreasePerHit;
			float num2 = (float)BaseMaximumPercentageCap + (float)(itemCountPermanent - 1) * (float)AdditionalMaximumPercentageCap;
			return (int)Math.Ceiling(((double)num2 - num) / (double)(float)percentageIncreasePerHit);
		}

		public float CalculateSpeedMult(CharacterBody characterBody)
		{
			int buffCount = characterBody.GetBuffCount(ZenithAccelerationBuff);
			int itemCountPermanent = characterBody.inventory.GetItemCountPermanent(ItemBase<ZenithAccelerator>.instance.ItemDef);
			float num = Mathf.Pow((float)ExponentialBaseMultiplier, (float)itemCountPermanent);
			ConfigOption<float> percentageIncreasePerHit = PercentageIncreasePerHit;
			float num2 = (float)BaseMaximumPercentageCap + (float)(itemCountPermanent - 1) * (float)AdditionalMaximumPercentageCap;
			return Mathf.Min(num + (float)percentageIncreasePerHit * (float)buffCount, num2);
		}

		private void AddAttackSpeedBuff(orig_OnHitEnemy orig, GlobalEventManager self, DamageInfo damageInfo, GameObject victim)
		{
			GameObject attacker = damageInfo.attacker;
			if (Object.op_Implicit((Object)(object)attacker))
			{
				CharacterBody component = attacker.GetComponent<CharacterBody>();
				CharacterBody component2 = victim.GetComponent<CharacterBody>();
				if (Object.op_Implicit((Object)(object)component) && Object.op_Implicit((Object)(object)component2))
				{
					int count = GetCount(component);
					if (count > 0)
					{
						int buffCount = component.GetBuffCount(ZenithAccelerationBuff);
						int num = CalculateMaxBuffStacks(component);
						ItemHelpers.RefreshTimedBuffs(component, ZenithAccelerationBuff, 1f + 0.5f * (float)(count - 1), 0.25f / (float)count);
						if (buffCount < num)
						{
							component.AddTimedBuff(ZenithAccelerationBuff, (float)DurationOfTimedBuffPerStack);
						}
					}
				}
			}
			orig.Invoke(self, damageInfo, victim);
		}
	}
