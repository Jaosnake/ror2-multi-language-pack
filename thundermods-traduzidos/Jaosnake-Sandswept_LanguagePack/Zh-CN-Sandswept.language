        "SANDSWEPT_VOID_SHRINE_RUIN_USE_MESSAGE_2P": "<style=cShrine>腐败蔓延。</color>",
        "SANDSWEPT_VOID_SHRINE_RUIN_USE_MESSAGE": "<style=cShrine>腐败蔓延。</color>",
        "SANDSWEPT_SHRINE_OF_RUIN_DESCRIPTION": "当幸存者激活时,毁灭神殿会消耗库存中的 10 件随机白色物品并腐蚀下一阶段。",
        "SANDSWEPT_SHRINE_SACRIFICE_NAME": "祭祀神殿",
        "SANDSWEPT_SHRINE_SACRIFICE_CONTEXT": "献祭神殿",
        "SANDSWEPT_SHRINE_SACRIFICE_USE_MESSAGE_2P": "<style=cShrine>你的时间已经牺牲了。</color>",
