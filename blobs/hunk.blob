					switch (name)
					{
					default:
						if (!(name == "meridian"))
						{
							return (int)SceneCatalog.mostRecentSceneDef.sceneType == 1;
						}
						goto case "moon";
					case "moon":
					case "moon2":
					case "bazaar":
					case "arena":
					case "artifactworld":
					case "voidraid":
						return false;
					}
