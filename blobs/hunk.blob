			private static void InitializeScepterSkills()
			{
				ItemBase<AncientScepterItem>.instance.RegisterScepterSkill(scepterDodgeSkillDef, "RobHunkBody", (SkillSlot)2, 0);
				ItemBase<AncientScepterItem>.instance.RegisterScepterSkill(scepterDodgeSkillDef, "RobHunkBody", (SkillSlot)2, 1);
			}

