				LanguageAPI.Add("ROB_HUNK_KEYWORD_PERFECTPARRY", "<style=cKeywordName>Perfect Parry</style><style=cSub>Deal <style=cIsDamage>800% damage</style> and become briefly invulnerable. Allows you to perform a <style=cIsDamage>Counterattack</style>.");
