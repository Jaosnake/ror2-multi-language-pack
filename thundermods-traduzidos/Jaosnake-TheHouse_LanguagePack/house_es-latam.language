        "JAVANGLE_HOUSE_7KING_NAME": "rey de bastos",
        "JAVANGLE_HOUSE_7KING_DESCRIPTION": "Lleva disparos: Explosivo, Perforante, Plomo, Serpiente, Vacío y Misterioso.",
        "JAVANGLE_HOUSE_7ACE_NAME": "As de espadas",
        "JAVANGLE_HOUSE_7ACE_DESCRIPTION": "Solo carga 1 disparo único que causa <style=cIsDamage>daño masivo</style> después de un largo retraso.",
        "JAVANGLE_HOUSE_WILDCARD_NAME": "Tarjeta comodín",
        "JAVANGLE_HOUSE_WILDCARD_DESCRIPTION": "Haz algo impredecible. Podría ser bueno, podría ser malo, podría ser ninguno de los dos... ¿tal vez ambos?\n<style=cIsUtility>[Indestructible]</style>.",
        "JAVANGLE_HOUSE_RROULETTE_NAME": "Ruleta Rusa",
        "JAVANGLE_HOUSE_RROULETTE_DESCRIPTION": "1/6 de probabilidad de <style=cDeath> de morir</style>, 4/6 de probabilidad de no hacer nada y otorgar acumulaciones máximas de 'Estaca', 1/6 de probabilidad de <style=cIsDamage>matar todo en el mapa</style> y ganar cantidades absurdas de oro.",
        "JAVANGLE_HOUSE_FORTUNE_NAME": "Rueda de la fortuna",
        "JAVANGLE_HOUSE_FORTUNE_DESCRIPTION": "50% de probabilidad de <style=cShrine>duplicar el oro actual</style>, 50% de probabilidad de <style=cArtifact>perder todo el oro</style> y <style=cIsUtility>lanzar un objeto aleatorio</style> por cada 10 de oro perdido.",
        "JAVANGLE_HOUSE_THREEOFAKIND_NAME": "trinca",
        "JAVANGLE_HOUSE_THREEOFAKIND_DESCRIPTION": "Compra y <style=cIsUtility>juega la mano completa</style> a la vez.",
        "JAVANGLE_HOUSE_GCLUBS_NAME": "Clubs",
        "JAVANGLE_HOUSE_GCLUBS_DESCRIPTION": "Cargue <style=cIsUtility>3 disparos positivos aleatorios</style> en la rueda de la ruleta.\nE <style=cIsUtility>garantiza</style> que su próxima bala es <style=cIsUtility>Positiva</style>.",
        "JAVANGLE_HOUSE_GSPADES_NAME": "espadas",
        "JAVANGLE_HOUSE_GSPADES_DESCRIPTION": "Obtiene <style=cIsUtility>Velocidad de movimiento aumentada</style> por un tiempo. \nY <style=cIsUtility>garantiza</style> que su próxima bala sea <style=cIsUtility>Positiva</style>.",
        "JAVANGLE_HOUSE_GHEARTS_NAME": "tazas",
        "JAVANGLE_HOUSE_GHEARTS_DESCRIPTION": "<style=cIsHealing>Te cura el 50% de tu salud máxima</style>.",
        "JAVANGLE_HOUSE_GJACK_NAME": "Jacobo",
        "JAVANGLE_HOUSE_GJACK_DESCRIPTION": "No hace nada.",
        "JAVANGLE_HOUSE_CRAZYCARD_NAME": "Cartalouca",
        "JAVANGLE_HOUSE_CRAZYCARD_DESCRIPTION": "Activa otra carta del Deck Estándar al azar.",
        "JAVANGLE_HOUSE_CASHOUT_NAME": "Retiro",
        "JAVANGLE_HOUSE_CASHOUT_DESCRIPTION": "1/3 de probabilidad de que <style=cArtifact>perda todo el dinero</style>, 1/3 de probabilidad de no hacer nada, 1/3 de probabilidad de que <style=cIsDamage>inflija daño a todos los enemigos en el mapa</style> y gane oro.",
        "JAVANGLE_HOUSE_THESUN_NAME": "el sol",
        "JAVANGLE_HOUSE_THESUN_DESCRIPTION": "<style=cIsUtility>Crea un duplicado de todas las demás cartas en la mano</style> y las roba en la siguiente mano.\n<style=cSub>(No funciona con cartas 'Indestructibles')</style>",
        "JAVANGLE_HOUSE_THEMOON_NAME": "la luna",
        "JAVANGLE_HOUSE_THEMOON_DESCRIPTION": "<style=cIsUtility>Destruye todas las demás cartas en la mano</style>, eliminándolas del mazo.\n<style=cSub>(No funciona con cartas 'Indestructibles')</style>",
        "JAVANGLE_HOUSE_THESTAR_NAME": "la estrella",
        "JAVANGLE_HOUSE_THESTAR_DESCRIPTION": "<style=cIsUtility>Crea tres cartas aleatorias y las roba inmediatamente</style>. La tarjeta utilizada se conserva, <style=cArtifact>las otras dos se destruyen</style>.",
        "JAVANGLE_HOUSE_THEWORLD_NAME": "El mundo",
        "JAVANGLE_HOUSE_THEWORLD_DESCRIPTION": "<style=cIsUtility>Destruye todas las cartas 'El Sol', 'La Luna', 'La Estrella' y 'El Mundo'</style> de la pila de robo, mano y pila de descarte, eliminándolas del mazo.\n<style=cSub>(Esta carta no puede ser destruida por otros)</style>.",
        "JAVANGLE_HOUSE_JUDGEMENT_NAME": "Juicio",
        "JAVANGLE_HOUSE_JUDGEMENT_DESCRIPTION": "<style=cIsUtility>Reemplaza completamente el mazo con la versión original</style>, deshaciendo cualquier cambio realizado en él.\n<style=cSub>(como si acabaras de comenzar el juego)</style>.",
        "JAVANGLE_HOUSE_KINGOFWANDS_NAME": "rey de bastos",
        "JAVANGLE_HOUSE_KINGOFWANDS_DESCRIPTION": "<style=cIsUtility>Consume hasta 3 acumulaciones de 'Apuesta'</style>, y <style=cIsHealing>proporciona curación</style> por cada acumulación consumida.",
        "JAVANGLE_HOUSE_QUEENOFCUPS_NAME": "Reina de corazones",
        "JAVANGLE_HOUSE_QUEENOFCUPS_DESCRIPTION": "<style=cIsUtility>Consume hasta 3 acumulaciones de 'Estacas'</style> y proporciona un beneficio que permite a La Casa <style=cIsUtility> rodar tablas de elementos aleatorios al causar daño</style>.",
        "JAVANGLE_HOUSE_KNIGHTOFSWORDS_NAME": "Caballero de espadas",
        "JAVANGLE_HOUSE_KNIGHTOFSWORDS_DESCRIPTION": "<style=cIsUtility>Consume hasta 3 acumulaciones de 'Apuestas'</style>, y <style=cIsUtility>lleva tiros positivos en la ruleta</style>.",
        "JAVANGLE_HOUSE_PAGEOFPENTACLES_NAME": "Sota de diamantes",
        "JAVANGLE_HOUSE_PAGEOFPENTACLES_DESCRIPTION": "<style=cIsUtility>Consume hasta 3 acumulaciones de 'Apuesta'</style> e invoca a <style=cIsUtility>Lunar Chimeras</style> para que luchen por ti.",
        "JAVANGLE_HOUSE_ANTEUP_NAME": "¡Sube la apuesta!",
        "JAVANGLE_HOUSE_ANTEUP_DESCRIPTION": "<style=cIsUtility>Da 2 acumulaciones de 'Gamble'</style>.\nCada acumulación de Stake reduce la armadura y aumenta la velocidad de movimiento y el daño. Las pilas decaen con el tiempo y son consumidas por otras cartas.",
        "JAVANGLE_HOUSE_ANCIENTACE_NAME": "Los Ancestros",
        "JAVANGLE_HOUSE_ANCIENTACE_DESCRIPTION": "Carga <style=cIsUtility>6 Mystery Shots</style> en la rueda de la ruleta. \nE <style=cIsUtility>da un beneficio aleatorio</style>.",
        "JAVANGLE_HOUSE_NULL_NAME": "Nulo",
        "JAVANGLE_HOUSE_NULL_DESCRIPTION": "No hace nada, ni siquiera recarga.\nLo hiciste. Destruiste todo. Lo redujiste a nada. Y ahora queda nada y todo.",
        "ARTIFACT_OF_WILDROOM_NAME": "Artefacto del cuarto salvaje",
        "ARTIFACT_OF_WILDROOM_DESCRIPTION": "Invoca un Wildroom al comienzo de cada etapa.\nWildroom ya no puede eliminarse y ahora afecta a jugadores que no pertenecen a The House."
    }
