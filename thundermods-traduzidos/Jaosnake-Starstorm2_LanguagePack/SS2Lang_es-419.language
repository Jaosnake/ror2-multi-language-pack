    "SS2_WARDEN_BODY_NAME": "Guardián",
    "SS2_WARDEN_BODY_SUBTITLE": "El crimen tiene un nuevo enemigo",
    "SS2_WARDEN_DESCRIPTION": "El futuro de la aplicación de la ley. Warden es un",
