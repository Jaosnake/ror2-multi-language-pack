		public class VirusEventMasterHandler : MonoBehaviour
		{
			private enum VirusType
			{
				GVirus,
				TVirus,
				CVirus,
				Uroboros,
				Plagas
			}

			public bool wtfTheFuck = false;

			public bool ignoreFlag = false;

