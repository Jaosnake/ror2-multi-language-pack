			public void ValidateWeapons()
			{
				HunkWeaponDef[] weaponDefs = HunkWeaponCatalog.weaponDefs;
				foreach (HunkWeaponDef hunkWeaponDef in weaponDefs)
				{
					if (inventory.GetItemCount(hunkWeaponDef.itemDef) > 0)
					{
						AddWeapon(hunkWeaponDef);
					}
					if (inventory.GetItemCount(hunkWeaponDef.itemDef) <= 0)
					{
						RemoveWeapon(hunkWeaponDef);
					}
				}
				if ((float)weaponData.Length <= 1f)
				{
					lastEquippedIndex = 0;
					equippedIndex = 0;
					return;
				}
				if (lastEquippedIndex >= weaponData.Length)
				{
					lastEquippedIndex = weaponData.Length - 1;
				}
				if (equippedIndex >= weaponData.Length)
				{
					equippedIndex = weaponData.Length - 1;
				}
			}

			private void Init()
			{
				((Component)this).gameObject.AddComponent<HunkNotificationQueue>();
				if (Object.op_Implicit((Object)(object)hunk))
				{
					if (Object.op_Implicit((Object)(object)variantHandler))
