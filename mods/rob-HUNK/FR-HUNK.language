        "ROB_HUNK_GRENADE_NAME": "Grenade",
        "ROB_HUNK_C4_NAME": "C4",
        "ROB_HUNK_SUPPLYPACK_NAME": "Provisions",
        "ROB_HUNK_T_VIRUS_NAME": "T-Virus",
        "ROB_HUNK_T_VIRUS_DESC": "Un \u00e9chantillon du T-Virus.",
        "ROB_HUNK_G_VIRUS_NAME": "G-Virus",
        "ROB_HUNK_G_VIRUS_DESC": "Un \u00e9chantillon du G-Virus.",
        "ROB_HUNK_G_VIRUS2_NAME": "G-Virus 2",
        "ROB_HUNK_C_VIRUS_NAME": "C-Virus",
        "ROB_HUNK_C_VIRUS_DESC": "Un \u00e9chantillon du C-Virus.",
        "ROB_HUNK_G_VIRUSFINAL_NAME": "G-Virus Final",
        "ROB_HUNK_PLAGAS_NAME": "Plagas",
        "ROB_HUNK_PLAGAS_DESC": "Un \u00e9chantillon de Plagas.",
        "ROB_HUNK_URO_SAMPLE_NAME": "\u00c9chantillon Uroboros",
        "ROB_HUNK_URO_SAMPLE_DESC": "Un \u00e9chantillon d'Uroboros.",
        "ROB_HUNK_G_VIRUS_SAMPLE_NAME": "\u00c9chantillon de G-Virus",
        "ROB_HUNK_G_VIRUS_SAMPLE_DESC": "Un \u00e9chantillon du G-Virus.",
        "ROB_HUNK_T_VIRUS_SAMPLE_NAME": "\u00c9chantillon de T-Virus",
        "ROB_HUNK_T_VIRUS_SAMPLE_DESC": "Un \u00e9chantillon du T-Virus.",
        "ROB_HUNK_C_VIRUS_SAMPLE_NAME": "\u00c9chantillon de C-Virus",
        "ROB_HUNK_C_VIRUS_SAMPLE_DESC": "Un \u00e9chantillon du C-Virus.",
        "ROB_HUNK_PLAGAS_SAMPLE_NAME": "\u00c9chantillon de Plagas",
        "ROB_HUNK_PLAGAS_SAMPLE_DESC": "Un \u00e9chantillon de Plagas.",
        "ROB_HUNK_ITEM_EFFECT_TITLE": "Effet Bonus",
        "ROB_HUNK_ITEM_EFFECT_BACKUPMAG": "Gagnez des <color=#00FF66>Munitions Factices</color> apr\u00e8s un rechargement r\u00e9ussi.",
        "ROB_HUNK_ITEM_EFFECT_BANDOLIER": "Les paquets de munitions rechargent votre chargeur avec des <color=#00FF66>Munitions Factices</color>.",
        "ROB_HUNK_ITEM_EFFECT_ALIENHEAD": "Gagnez <style=cIsUtility>plus de munitions</style> en en collectant.",
        "ROB_HUNK_ITEM_EFFECT_BRAINSTALKS": "Lorsqu'actif, tirer avec votre arme <style=cIsUtility>ne consomme pas de munitions</style>.",
        "ROB_HUNK_ITEM_EFFECT_LYSATECELL": "Gagnez des <color=#00FF66>Munitions Factices</color> en \u00e9quipant une arme.",
        "ROB_HUNK_ITEM_EFFECT_PURITY": "Double la <style=cIsUtility>taille du chargeur</style>. La consommation de munitions ne change pas.",
        "ROB_HUNK_ITEM_EFFECT_LUMINOUSSHOT": "Gagnez un cumul apr\u00e8s avoir vis\u00e9 pendant <style=cIsUtility>1 seconde</style>. <style=cIsHealth>Perd tous les cumuls en tirant ou en arr\u00eatant de viser.</style>",
        "ACHIEVEMENT_ROB_HUNK_COMPLETION_UNLOCKABLE_ACHIEVEMENT_ID_NAME": "HUNK : Faucheur",
        "ACHIEVEMENT_ROB_HUNK_COMPLETION_UNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "En tant que HUNK, battez le jeu ou oblit\u00e9rez-vous. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ACHIEVEMENT_ROB_HUNK_MONSOON_UNLOCKABLE_ACHIEVEMENT_ID_NAME": "HUNK : Ma\u00eetrise",
        "ACHIEVEMENT_ROB_HUNK_MONSOON_UNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "En tant que HUNK, battez le jeu ou oblit\u00e9rez-vous en Mousson. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ACHIEVEMENT_ROB_HUNK_TYPHOON_UNLOCKABLE_ACHIEVEMENT_ID_NAME": "HUNK : Grande Ma\u00eetrise",
        "ACHIEVEMENT_ROB_HUNK_TYPHOON_UNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "En tant que HUNK, battez le jeu ou oblit\u00e9rez-vous en Typhon ou \u00c9clipse.\n<color=#8888>(Compte toute difficult\u00e9 Typhon ou sup\u00e9rieure)</color> <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ACHIEVEMENT_ROB_HUNK_SUPPORTER_ACHIEVEMENT_ID_NAME": "HUNK : Early Supporter",
        "ACHIEVEMENT_ROB_HUNK_SUPPORTER_ACHIEVEMENT_ID_DESCRIPTION": "Jouez en tant que HUNK avant la sortie officielle. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ACHIEVEMENT_ROB_HUNK_LIGHTWEIGHT_ACHIEVEMENT_ID_NAME": "HUNK : Minimaliste",
        "ACHIEVEMENT_ROB_HUNK_LIGHTWEIGHT_ACHIEVEMENT_ID_DESCRIPTION": "En tant que HUNK, compl\u00e9tez l'\u00c9tape 1 sans objets.\n<color=#8888>(Les armes et outils ne comptent pas contre vous)</color> <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ACHIEVEMENT_ROB_HUNK_GUERRILLA_ACHIEVEMENT_ID_NAME": "HUNK : Verrouill\u00e9 et Charg\u00e9",
        "ACHIEVEMENT_ROB_HUNK_GUERRILLA_ACHIEVEMENT_ID_DESCRIPTION": "En tant que HUNK, obtenez un arsenal complet. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ACHIEVEMENT_ROB_HUNK_ROOKIE_ACHIEVEMENT_ID_NAME": "HUNK : Premier Jour au Boulot",
        "ACHIEVEMENT_ROB_HUNK_ROOKIE_ACHIEVEMENT_ID_DESCRIPTION": "En tant que HUNK, obtenez une nouvelle arme. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ACHIEVEMENT_ROB_HUNK_SWAT_ACHIEVEMENT_ID_NAME": "HUNK : Pacificateur",
        "ACHIEVEMENT_ROB_HUNK_SWAT_ACHIEVEMENT_ID_DESCRIPTION": "En tant que HUNK, am\u00e9liorez compl\u00e8tement la MUP. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ACHIEVEMENT_ROB_HUNK_CQC_ACHIEVEMENT_ID_NAME": "HUNK : CQC (Combat de Proximit\u00e9)",
        "ACHIEVEMENT_ROB_HUNK_CQC_ACHIEVEMENT_ID_DESCRIPTION": "En tant que HUNK, effectuez 10 contre-attaques r\u00e9ussies en une \u00c9tape. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ACHIEVEMENT_ROB_HUNK_INFINITEKNIFE_ACHIEVEMENT_ID_NAME": "HUNK : As de Piques",
        "ACHIEVEMENT_ROB_HUNK_INFINITEKNIFE_ACHIEVEMENT_ID_DESCRIPTION": "En tant que HUNK, portez deux Keycards de Piques en m\u00eame temps. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ACHIEVEMENT_ROB_HUNK_WESKERKNIFE_UNLOCKABLE_ACHIEVEMENT_ID_NAME": "HUNK : Passionn\u00e9 d'Armes \u00e0 Feu",
        "ACHIEVEMENT_ROB_HUNK_WESKERKNIFE_UNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "En tant que HUNK, am\u00e9liorez une arme avec un nouvel accessoire. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ACHIEVEMENT_ROB_HUNK_MACHETE_UNLOCKABLE_ACHIEVEMENT_ID_NAME": "HUNK : Pas Besoin d'Armes",
        "ACHIEVEMENT_ROB_HUNK_MACHETE_UNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "En tant que HUNK, compl\u00e9tez une \u00c9tape sans tirer aucune arme. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ACHIEVEMENT_ROB_HUNK_RE4KNIFE_ACHIEVEMENT_ID_NAME": "HUNK : La Route \u00e0 Venir",
        "ACHIEVEMENT_ROB_HUNK_RE4KNIFE_ACHIEVEMENT_ID_DESCRIPTION": "En tant que HUNK, atteignez l'\u00c9tape 6. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ACHIEVEMENT_ROB_HUNK_HOTDOGGER_ACHIEVEMENT_ID_NAME": "HUNK : Chimie de Base",
        "ACHIEVEMENT_ROB_HUNK_HOTDOGGER_ACHIEVEMENT_ID_DESCRIPTION": "En tant que HUNK, obtenez le Lance-flammes Chimique. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ACHIEVEMENT_ROB_HUNK_STUNROD_ACHIEVEMENT_ID_NAME": "HUNK : Offre Trois pour Un",
        "ACHIEVEMENT_ROB_HUNK_STUNROD_ACHIEVEMENT_ID_DESCRIPTION": "En tant que HUNK, obtenez le Spark Shot. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ACHIEVEMENT_ROB_HUNK_SSG_ACHIEVEMENT_ID_NAME": "HUNK : Dominateur",
        "ACHIEVEMENT_ROB_HUNK_SSG_ACHIEVEMENT_ID_DESCRIPTION": "En tant que HUNK, obtenez la SSG. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ACHIEVEMENT_ROB_HUNK_FLAMER_ACHIEVEMENT_ID_NAME": "HUNK : Pyromane",
        "ACHIEVEMENT_ROB_HUNK_FLAMER_ACHIEVEMENT_ID_DESCRIPTION": "En tant que HUNK, am\u00e9liorez compl\u00e8tement le Lance-flammes Chimique. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ACHIEVEMENT_ROB_HUNK_SURVIVALKIT_ACHIEVEMENT_ID_NAME": "HUNK : Pas de Chance du Tout",
        "ACHIEVEMENT_ROB_HUNK_SURVIVALKIT_ACHIEVEMENT_ID_DESCRIPTION": "En tant que HUNK, manquez de munitions au Commencement. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ACHIEVEMENT_ROB_HUNK_JUMPPACK_ACHIEVEMENT_ID_NAME": "HUNK : Nulle Part O\u00f9 Aller Sauf en Haut",
        "ACHIEVEMENT_ROB_HUNK_JUMPPACK_ACHIEVEMENT_ID_DESCRIPTION": "En tant que HUNK, soyez victime d'un accident de parachutisme. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_NEMESIS_BODY_NAME": "Nemesis T-Type",
        "ROB_NEMESIS_BODY_DESCRIPTION": "Le Nemesis T-Type est une arme biologique imparable construite pour r\u00e9sister \u00e0 n'importe quelle quantit\u00e9 de punition et neutraliser ses cibles avec facilit\u00e9.<color=#CCD3E0>\n\n< ! > Les sauts peuvent \u00eatre charg\u00e9s pour une plus grande distance.\n\n< ! > Consommer des ennemis vous rend vuln\u00e9rable, alors trouvez un endroit s\u00fbr avant de le faire.\n\n< ! > La Biomasse augmente vos d\u00e9g\u00e2ts quand elle est pleine. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_NEMESIS_BODY_SUBTITLE": "Arme Biologique Imparable",
        "ROB_NEMESIS_BODY_OUTRO_FLAVOR": "..et ainsi il partit, tout va bien.",
        "ROB_NEMESIS_BODY_OUTRO_FAILURE": "..et ainsi il disparut, unit\u00e9 humaine maintenant neutralis\u00e9e.",
        "ROB_NEMESIS_BODY_DEFAULT_SKIN_NAME": "Par d\u00e9faut",
        "ROB_NEMESIS_BODY_CLASSIC_SKIN_NAME": "Classique",
        "ROB_NEMESIS_BODY_VENOM_SKIN_NAME": "Symbiote",
        "ROB_NEMESIS_BODY_SUPER_SKIN_NAME": "<color=#FFFF00>Early Supporter</color>",
        "ROB_NEMESIS_BODY_MAHORAGA_SKIN_NAME": "Big Raga The Opp Stoppa",
        "ROB_NEMESIS_BODY_MINOS_SKIN_NAME": "King of Men",
        "ROB_NEMESIS_BODY_PASSIVE_NAME": "Forme de Vie Supr\u00eame",
        "ROB_NEMESIS_BODY_PASSIVE_DESCRIPTION": "<style=cIsDamage>Infliger des d\u00e9g\u00e2ts</style> accumule de la <style=cIsHealth>Biomasse</style>, augmentant vos <style=cIsDamage>d\u00e9g\u00e2ts</style> quand elle est pleine. Les sauts peuvent \u00eatre <style=cIsDamage>charg\u00e9s</style> pour <style=cIsUtility>des bonds puissants</style>. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_NEMESIS_BODY_PASSIVE2_NAME": "Armement Biologique",
        "ROB_NEMESIS_BODY_PASSIVE2_DESCRIPTION": "Le Nemesis T-Type peut <style=cIsHealth>muter</style> en consommant des <style=cIsDamage>personnes d'int\u00e9r\u00eat</style>, gagnant des <style=cIsDamage>comp\u00e9tences nouvelles et am\u00e9lior\u00e9es</style>. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_NEMESIS_BODY_PASSIVE22_NAME": "Augmentation de la Masse Musculaire",
        "ROB_NEMESIS_BODY_PASSIVE22_DESCRIPTION": "<style=cIsUtility>Les attaques de m\u00eal\u00e9e</style> infligent <style=cIsDamage>20%</style> plus de d\u00e9g\u00e2ts, <style=isHealth>MAIS les alli\u00e9s peuvent subir des d\u00e9g\u00e2ts</style>. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_NEMESIS_BODY_MELEE_NAME": "Agression Brutale",
        "ROB_NEMESIS_BODY_MELEE_DESCRIPTION": "Coup de poing pour <style=cIsDamage>350% de d\u00e9g\u00e2ts</style>. Utilisez \u00e0 l'<style=cIsUtility>arr\u00eat</style> pour pi\u00e9tiner pour <style=cIsDamage>800% de d\u00e9g\u00e2ts</style>. Utilisez en <style=cIsUtility>courant</style> pour donner un coup d'\u00e9paule pour <style=cIsDamage>600% de d\u00e9g\u00e2ts</style>. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_NEMESIS_BODY_GRAB_NAME": "Port\u00e9e Mortelle",
        "ROB_NEMESIS_BODY_GRAB_DESCRIPTION": "Attrapez un ennemi. Utilisez le Primaire pour le consommer et soigner 10% de la sant\u00e9 maximale, ou le Secondaire pour charger un lancer allant jusqu'\u00e0 2.400% de d\u00e9g\u00e2ts. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_NEMESIS_BODY_DASH_NAME": "Ruade de Risque Biologique",
        "ROB_NEMESIS_BODY_DASH_DESCRIPTION": "Utilisez <style=cIsUtility>en l'air</style> pour vous propulser <style=cIsDamage>une fois</style>. <i>Translated by: Jaosnake. Original mod by rob</i>",
        "ROB_NEMESIS_BODY_ULTIMATE_NAME": "Masse Critique",
        "ROB_NEMESIS_BODY_ULTIMATE_DESCRIPTION": "Maintenez pour consommer lentement de la <style=cIsHealth>Biomasse</style>, restaurant jusqu'\u00e0 <style=cIsHealing>100% de la sant\u00e9 maximale</style>. <i>Translated by: Jaosnake. Original mod by rob</i>",
