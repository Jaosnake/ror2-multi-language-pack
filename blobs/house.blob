	internal class Ace : BaseCardSkill
	{
		public override void OnEnter()
		{
			cardTypeActivationVFX = Assets.NeutralCardActivation;
			cardSweepVFX = Assets.CardSweepNeutral;
			base.OnEnter();
			cardActivationVFX = Assets.VFXcardAce;
			cardActivationSFX = "HouseCard_Ace";
			if (((EntityState)this).isAuthority)
			{
				passiveManager.roulleteAmmo = new int[6];
				passiveManager.roulletePriorityShot = 8;
				if (((EntityState)this).characterBody.isPlayerControlled)
				{
					HouseHUDManager.instance.UpdateAmmo(passiveManager.roulletePriorityShot, passiveManager.roulleteAmmo);
				}
			}
		}

		public override void OnActivate()
		{
			base.OnActivate();
		}
	}
