		private void ChaseTarget_FixedUpdate(ILContext il)
		{
			//IL_0001: Unknown result type (might be due to invalid IL or missing references)
			//IL_0007: Expected O, but got Unknown
			//IL_008c: Unknown result type (might be due to invalid IL or missing references)
			//IL_00ab: Unknown result type (might be due to invalid IL or missing references)
			//IL_00b7: Unknown result type (might be due to invalid IL or missing references)
			ILCursor val = new ILCursor(il);
			ILLabel val2 = default(ILLabel);
			val.GotoNext((MoveType)2, new Func<Instruction, bool>[3]
			{
				(Instruction instruction) => ILPatternMatchingExt.MatchBrtrue(instruction, ref val2),
				(Instruction instruction) => ILPatternMatchingExt.MatchLdloc(instruction, 2),
				(Instruction instruction) => ILPatternMatchingExt.MatchLdsfld<ChaseTarget>(instruction, "triggerRadius")
			});
			int index = val.Index;
			val.Index = index - 1;
			val.Emit(OpCodes.Ldarg_0);
			val.EmitDelegate<Func<float, ChaseTarget, float>>((Func<float, ChaseTarget, float>)fuckWithMagnitude);
			val.Emit(OpCodes.Stloc_2);
			val.Emit(OpCodes.Ldloc_2);
		}

		private float fuckWithMagnitude(float origMagnitude, ChaseTarget self)
		{
			if (((EntityState)self).outer.customName.Contains("ConscriptTerrorDroneESM"))
			{
				return origMagnitude - 10f;
			}
			return origMagnitude;
		}

		private void Detonate_OnEnter(orig_OnEnter orig, Detonate self)
		{
			if (!((EntityState)self).outer.customName.Contains("ConscriptTerrorDroneESM"))
			{
				orig.Invoke(self);
			}
			((EntityState)self).outer.SetNextState((EntityState)(object)new JumpOnEnemy());
		}

		private void RecalculateStatsAPI_GetStatCoefficients(CharacterBody sender, StatHookEventArgs args)
		{
			if (sender.HasBuff(ConscriptBuffs.armorBuff))
			{
				args.armorAdd += 100f;
				args.moveSpeedMultAdd += 0.5f;
			}
			if (sender.HasBuff(ConscriptBuffs.chargeBuff))
			{
				args.armorAdd += (float)ConscriptConfig.M3_March_Armor;
				args.moveSpeedMultAdd += (float)ConscriptConfig.M3_March_Speed;
			}
			if (sender.HasBuff(ConscriptBuffs.magazineBuff) || sender.HasBuff(ConscriptBuffs.garrisonBuff))
			{
				args.regenMultAdd += (float)ConscriptConfig.M4_Garrison_Regen;
			}
		}
	}
