		public override void Hooks()
		{
			//IL_0008: Unknown result type (might be due to invalid IL or missing references)
			//IL_0012: Expected O, but got Unknown
			//IL_001a: Unknown result type (might be due to invalid IL or missing references)
			//IL_0024: Expected O, but got Unknown
			//IL_003e: Unknown result type (might be due to invalid IL or missing references)
			//IL_0048: Expected O, but got Unknown
			RecalculateStatsAPI.GetStatCoefficients += new StatHookEventHandler(GrantBonuses);
			CharacterBody.OnInventoryChanged += new hook_OnInventoryChanged(OnInventoryChanged);
			CharacterBody.onBodyStartGlobal += OnBodyStart;
			HealthComponent.ServerFixedUpdate += new hook_ServerFixedUpdate(TrackShieldState);
		}

		private void OnBodyStart(CharacterBody body)
		{
			if (GetCount(body) > 0)
			{
				((Component)body).gameObject.AddComponent<ShieldedCoreComponent>();
			}
		}

		private void OnInventoryChanged(orig_OnInventoryChanged orig, CharacterBody self)
		{
			orig.Invoke(self);
			if (!Object.op_Implicit((Object)(object)self))
			{
				return;
			}
			ShieldedCoreComponent component = ((Component)self).GetComponent<ShieldedCoreComponent>();
			int count = GetCount(self);
			if (count > 0 && !Object.op_Implicit((Object)(object)component))
			{
				component = ((Component)self).gameObject.AddComponent<ShieldedCoreComponent>();
				component.cachedInventoryCount = count;
			}
			else if (Object.op_Implicit((Object)(object)component) && component.cachedInventoryCount != count)
			{
				component.cachedInventoryCount = count;
				self.statsDirty = true;
				if (count == 0)
				{
					Object.Destroy((Object)(object)component);
				}
			}
		}

		private void TrackShieldState(orig_ServerFixedUpdate orig, HealthComponent self, float deltaTime)
		{
			orig.Invoke(self, deltaTime);
			if (!Object.op_Implicit((Object)(object)self.body))
			{
				return;
			}
			ShieldedCoreComponent component = ((Component)self.body).GetComponent<ShieldedCoreComponent>();
			if (Object.op_Implicit((Object)(object)component))
			{
				bool flag = self.shield > 0f;
				if (component.cachedIsShielded != flag)
				{
					component.cachedIsShielded = flag;
					self.body.statsDirty = true;
				}
			}
		}

		private void GrantBonuses(CharacterBody sender, StatHookEventArgs args)
		{
			ShieldedCoreComponent component = ((Component)sender).GetComponent<ShieldedCoreComponent>();
			if (Object.op_Implicit((Object)(object)component) && component.cachedInventoryCount != 0)
			{
				if (Object.op_Implicit((Object)(object)sender.healthComponent))
				{
					args.baseShieldAdd += sender.maxHealth * (float)BaseGrantShieldMultiplier;
				}
				if (component.cachedIsShielded)
				{
					args.armorAdd += (float)BaseShieldingCoreArmorGrant + (float)AdditionalShieldingCoreArmorGrant * (float)(component.cachedInventoryCount - 1);
				}
			}
		}
	}
}
namespace Aetherium.Items.Tier1
{
	public class FeatheredPlume : ItemBase<FeatheredPlume>
	{
		public static ConfigOption<bool> UseNewIcons;

		public static ConfigOption<float> BaseDurationOfBuffInSeconds;

		public static ConfigOption<float> AdditionalDurationOfBuffInSeconds;

		public static ConfigOption<int> BuffStacksPerFeatheredPlume;

		public static ConfigOption<float> MoveSpeedPercentageBonusPerBuffStack;

		public static GameObject ItemBodyModelPrefab;

		public override string ItemName => "Feathered Plume";

		public override string ItemLangTokenName => "FEATHERED_PLUME";

		public override string ItemPickupDesc => "After taking damage, gain a boost in speed.";

		public override string ItemFullDescription => $"Gain a temporary <style=cIsUtility>{MathHelpers.FloatToPercentageString(MoveSpeedPercentageBonusPerBuffStack)} speed boost</style> upon taking damage that stacks {BuffStacksPerFeatheredPlume} times for {BaseDurationOfBuffInSeconds} seconds. <style=cStack>(+{BuffStacksPerFeatheredPlume} stacks and +{AdditionalDurationOfBuffInSeconds} second duration per additional Feathered Plume.)</style>";

		public override string ItemLore => ItemHelpers.OrderManifestLoreFormatter(ItemName, "05/05/2077", "Unmarked Drop Point #951", "591********", ItemPickupDesc, "Bio-metal / Bio-Hazardous / Light", "A couple feathers from a legendary alloy vulture. Scans show that the quills generate a powerful muscle stimulant upon taking an impact. Our field testers have also reported this, albeit their exact words is that the feathers allow them to 'haul ass' out of danger, and that they had a need.\nA need for speed.");

		public override ItemTier Tier => (ItemTier)0;

		public override ItemTag[] ItemTags => (ItemTag[])(object)new ItemTag[1] { (ItemTag)3 };

		public override string CorruptsItem => "ITEM_NAIL_BOMB_NAME";

		public override GameObject ItemModel => AetheriumPlugin.MainAssets.LoadAsset<GameObject>("FeatheredPlume.prefab");

		public override Sprite ItemIcon => UseNewIcons ? AetheriumPlugin.MainAssets.LoadAsset<Sprite>("FeatheredPlumeIconAlt.png") : AetheriumPlugin.MainAssets.LoadAsset<Sprite>("FeatheredPlumeIcon.png");

		public BuffDef SpeedBuff { get; private set; }

		public override void Init(ConfigFile config)
		{
			CreateConfig(config);
			CreateLang();
			CreateBuff();
			CreateItem();
			Hooks();
		}

		private void CreateConfig(ConfigFile config)
		{
			UseNewIcons = config.ActiveBind("Item: " + ItemName, "Use Alternative Icon Art?", defaultValue: false, "If set to true, will use the new icon art drawn by WaltzingPhantom, else it will use the old icon art.");
			BaseDurationOfBuffInSeconds = config.ActiveBind("Item: " + ItemName, "Base Duration of Buff with One Feathered Plume", 5f, "How many seconds should feathered plume's buff last with a single feathered plume?");
			AdditionalDurationOfBuffInSeconds = config.ActiveBind("Item: " + ItemName, "Additional Duration of Buff per Feathered Plume Stack", 0.5f, "How many additional seconds of buff should each feathered plume after the first give?");
			BuffStacksPerFeatheredPlume = config.ActiveBind("Item: " + ItemName, "Stacks of Buff per Feathered Plume", 3, "How many buff stacks should each feather give?");
			MoveSpeedPercentageBonusPerBuffStack = config.ActiveBind("Item: " + ItemName, "Movement speed per Feathered Plume Buff Stack", 0.07f, "How much movement speed in percent should each stack of Feathered Plume's buff give? (0.07 = 7%)");
		}

		private void CreateBuff()
		{
			//IL_0024: Unknown result type (might be due to invalid IL or missing references)
			//IL_0029: Unknown result type (might be due to invalid IL or missing references)
			SpeedBuff = ScriptableObject.CreateInstance<BuffDef>();
			((Object)SpeedBuff).name = "Aetherium: Feathered Plume Speed";
			SpeedBuff.buffColor = Color.green;
			SpeedBuff.canStack = true;
			SpeedBuff.isDebuff = false;
			SpeedBuff.iconSprite = AetheriumPlugin.MainAssets.LoadAsset<Sprite>("FeatheredPlumeBuffIcon.png");
			ContentAddition.AddBuffDef(SpeedBuff);
		}

