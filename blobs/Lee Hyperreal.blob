			Sprite modIcon = LeeHyperrealAssets.mainAssetBundle.LoadAsset<Sprite>("LeeCharacterIcon");
			ModSettingsManager.SetModIcon(modIcon);
			ModSettingsManager.SetModDescription("Hypermatrix Traverser");
			ModSettingsManager.AddOption((BaseOption)new CheckBoxOption(isSimple));
			ModSettingsManager.AddOption((BaseOption)new CheckBoxOption(useOrbAltTrigger));
			ModSettingsManager.AddOption((BaseOption)new KeyBindOption(orb1Trigger));
			ModSettingsManager.AddOption((BaseOption)new KeyBindOption(orb2Trigger));
