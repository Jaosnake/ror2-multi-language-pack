				LanguageAPI.Add(text + "UTILITY_DODGE_DESCRIPTION", "<style=cIsUtility>Dash</style> a short distance. If used preemptively to <style=cIsUtility>avoid an attack</style>, perform a <style=cIsDamage>Perfect Dodge</style>.");
				LanguageAPI.Add(text + "UTILITY_DODGE_SCEPTER_NAME", "Uroboros");
				LanguageAPI.Add(text + "UTILITY_DODGE_SCEPTER_DESCRIPTION", "<style=cIsUtility>Dash</style> a short distance. If used preemptively to <style=cIsUtility>avoid an attack</style>, perform a <style=cIsDamage>Perfect Dodge</style>." + Helpers.ScepterDescription("The power of Uroboros flows through you."));
				LanguageAPI.Add(text + "UTILITY_PARRY_NAME", "Parry");
				LanguageAPI.Add(text + "UTILITY_PARRY_DESCRIPTION", "<style=cIsUtility>Block</style> an attack, <style=cIsDamage>negating</style> damage and <style=cIsUtility>refunding the cooldown</style>. If used preemptively, perform a <style=cIsDamage>Perfect Parry</style>.");
				LanguageAPI.Add(text + "UTILITY_BASH_NAME", "Shoulder Bash");
				LanguageAPI.Add(text + "UTILITY_BASH_DESCRIPTION", "<style=cIsUtility>Bash</style> nearby enemies, <style=cIsUtility>stunning them</style> for <style=cIsDamage>400% damage</style>. If used preemptively to <style=cIsUtility>cancel an attack</style>, perform a <style=cIsDamage>Perfect Bash</style>.");
				LanguageAPI.Add(text + "SPECIAL_SWAP_NAME", "Legion");
				LanguageAPI.Add(text + "SPECIAL_SWAP_DESCRIPTION", "<style=cIsUtility>Swap</style> to a different <style=cIsDamage>gun</style>. Tap to swap to your <style=cIsUtility>last held gun</style>.");
				LanguageAPI.Add(text + "KNIFE_DEFAULT_NAME", "Combat Knife");
				LanguageAPI.Add(text + "KNIFE_DEFAULT_DESCRIPTION", "A standard military-grade knife. Sure to come in handy in a pinch.");
				LanguageAPI.Add(text + "KNIFE_INFINITE_NAME", "Combat Knife EX");
				LanguageAPI.Add(text + "KNIFE_INFINITE_DESCRIPTION", "A specially-treated military-grade knife that's been hardened to an unbelievable degree. They say it's been made to really last.");
				LanguageAPI.Add(text + "KNIFE_HIDDEN_NAME", "Hidden Blade");
				LanguageAPI.Add(text + "KNIFE_HIDDEN_DESCRIPTION", "A low profile retractable blade hidden in the sleeve. Ideal for stealth operations.");
				LanguageAPI.Add(text + "KNIFE_WESKER_NAME", "Customized Knife");
				LanguageAPI.Add(text + "KNIFE_WESKER_DESCRIPTION", "A vicious blade with a serrated edge to aid in tearing up your opponents.");
				LanguageAPI.Add(text + "KNIFE_MACHETE_NAME", "Machete");
				LanguageAPI.Add(text + "KNIFE_MACHETE_DESCRIPTION", "A huge blade meant primarily for guerrilla tactics.");
