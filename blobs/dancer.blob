		public override void OnInstall()
		{
			base.OnInstall();
			Run.onClientGameOverGlobal += OnClientGameOverGlobal;
		}

		public override void OnUninstall()
		{
			((BaseAchievement)this).OnGranted();
			Run.onClientGameOverGlobal -= OnClientGameOverGlobal;
		}

