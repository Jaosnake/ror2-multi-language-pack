			private static void CreateKnifeSkins()
			{
				knifeSkins.Add(defaultKnifeDef, HunkAssets.LoadKnife("CombatKnife"));
				knifeSkins.Add(infiniteKnifeDef, HunkAssets.LoadKnife("InfiniteKnife"));
				knifeSkins.Add(bloodyKnifeDef, HunkAssets.LoadKnife("BloodyKnife"));
				knifeSkins.Add(weskerKnifeDef, HunkAssets.LoadKnife("WeskerKnife"));
				knifeSkins.Add(macheteKnifeDef, HunkAssets.LoadKnife("Machete"));
				knifeSkins.Add(re4KnifeDef, HunkAssets.LoadKnife("LeonKnife"));
				knifeSkins.Add(hotDoggerKnifeDef, HunkAssets.LoadKnife("HotDogger", "matHotDogger"));
				knifeSkins.Add(stunRodKnifeDef, HunkAssets.LoadKnife("StunRod"));
				knifeSkins.Add(kitchenKnifeDef, HunkAssets.LoadKnife("KitchenKnife"));
			}

			private static void InitializeItemDisplays(GameObject prefab)
			{
				CharacterModel componentInChildren = prefab.GetComponentInChildren<CharacterModel>();
				if ((Object)(object)itemDisplayRuleSet == (Object)null)
				{
					itemDisplayRuleSet = ScriptableObject.CreateInstance<ItemDisplayRuleSet>();
					((Object)itemDisplayRuleSet).name = "idrsRobHunkBody";
				}
				componentInChildren.itemDisplayRuleSet = itemDisplayRuleSet;
				componentInChildren.itemDisplayRuleSet.keyAssetRuleGroups = Resources.Load<GameObject>("Prefabs/CharacterBodies/CommandoBody").GetComponentInChildren<CharacterModel>().itemDisplayRuleSet.keyAssetRuleGroups;
				itemDisplayRules = itemDisplayRuleSet.keyAssetRuleGroups.ToList();
			}

