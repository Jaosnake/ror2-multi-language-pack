				else if (((EntityState)this).isAuthority)
				{
					((EntityState)this).outer.SetNextStateToMain();
				}
			}
			base.OnWeaponChanged(weaponDef);
		}

		public override void OnSerialize(NetworkWriter writer)
		{
			((EntityState)this).OnSerialize(writer);
			SkillStateMethods.Serialize((ISkillState)(object)this, ((EntityState)this).skillLocator, writer);
		}

		public override void OnDeserialize(NetworkReader reader)
		{
			((EntityState)this).OnDeserialize(reader);
			SkillStateMethods.Deserialize((ISkillState)(object)this, ((EntityState)this).skillLocator, reader);
		}

		public bool IsKeyDownAuthority()
		{
			return SkillStateMethods.IsKeyDownAuthority((ISkillState)(object)this, ((EntityState)this).skillLocator, ((EntityState)this).inputBank);
		}
	}
	public abstract class BaseDriverState : BaseState
	{
		protected DriverController iDrive;

		protected ChildLocator childLocator;

		protected DriverWeaponDef cachedWeaponDef;

		protected bool cancelling;

		protected virtual bool holsterGun => false;

		protected virtual string showProp => string.Empty;

		public override void OnEnter()
		{
			((BaseState)this).OnEnter();
			RefreshState();
			DriverController driverController = iDrive;
			driverController.onWeaponChanged = (Action<DriverWeaponDef>)Delegate.Combine(driverController.onWeaponChanged, new Action<DriverWeaponDef>(OnWeaponChanged));
			if (holsterGun)
			{
				iDrive.SetHolsteredWeaponInstance(cachedWeaponDef);
			}
			if (!string.IsNullOrEmpty(showProp))
			{
				childLocator.FindChildGameObject(showProp).SetActive(true);
			}
		}

		protected void RefreshState()
		{
			if (!Object.op_Implicit((Object)(object)childLocator))
			{
				childLocator = ((EntityState)this).GetModelChildLocator();
			}
			if (!Object.op_Implicit((Object)(object)iDrive))
			{
				iDrive = ((EntityState)this).GetComponent<DriverController>();
			}
			cachedWeaponDef = iDrive.weaponDef;
		}

		protected virtual void OnWeaponChanged(DriverWeaponDef weaponDef)
		{
			cachedWeaponDef = weaponDef;
			if (iDrive.HolsteredWeapon)
			{
				iDrive.SetHolsteredWeaponInstance(weaponDef);
			}
		}

		public virtual void AddRecoil(float x, float y)
		{
			if (Config.enableRecoil.Value)
			{
				((BaseState)this).AddRecoil(-0.5f * x, -1f * x, -1f * y, y);
			}
		}

		public override void ModifyNextState(EntityState nextState)
		{
			((EntityState)this).ModifyNextState(nextState);
			if (nextState is BaseDriverState baseDriverState)
			{
				baseDriverState.iDrive = iDrive;
				baseDriverState.childLocator = childLocator;
			}
		}

		public override void OnExit()
		{
			((EntityState)this).OnExit();
			if (Object.op_Implicit((Object)(object)iDrive))
			{
				DriverController driverController = iDrive;
				driverController.onWeaponChanged = (Action<DriverWeaponDef>)Delegate.Remove(driverController.onWeaponChanged, new Action<DriverWeaponDef>(OnWeaponChanged));
				if (holsterGun)
				{
					iDrive.DestroyHolsteredWeaponInstance();
				}
			}
			if (!Object.op_Implicit((Object)(object)childLocator))
			{
				return;
			}
			GameObject obj = childLocator.FindChildGameObject("PistolModel");
			if (obj != null)
			{
				obj.SetActive(true);
			}
			if (!string.IsNullOrEmpty(showProp))
			{
				GameObject obj2 = childLocator.FindChildGameObject(showProp);
				if (obj2 != null)
				{
					obj2.SetActive(false);
				}
			}
		}
	}
}
