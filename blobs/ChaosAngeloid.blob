				overlay.originalMaterial = Prefabs.masterHighlight;
				overlay.duration = float.MaxValue;
				overlay.destroyComponentOnEnd = true;
				overlay.animateShaderAlpha = true;
				overlay.alphaCurve = AnimationCurve.Constant(0f, 1f, 1f);
				overlay.AddToCharacterModel(component);
			}
		}
	}

	private void FixedUpdate()
	{
		if (Object.op_Implicit((Object)(object)body) && NetworkServer.active && !body.HasBuff(Prefabs.masterMarkBuff))
		{
