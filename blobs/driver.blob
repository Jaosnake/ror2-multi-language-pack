			[MethodImpl(MethodImplOptions.NoInlining | MethodImplOptions.NoOptimization)]
			private static void InitializeScepterSkills()
			{
				ItemBase<AncientScepterItem>.instance.RegisterScepterSkill(Skills.scepterGrenadeSkillDef, "RobDriverBody", (SkillSlot)3, 0);
				ItemBase<AncientScepterItem>.instance.RegisterScepterSkill(Skills.scepterSupplyDropSkillDef, "RobDriverBody", (SkillSlot)3, 1);
				if (Config.cursed.Value)
				{
					ItemBase<AncientScepterItem>.instance.RegisterScepterSkill(Skills.scepterSupplyDropLegacySkillDef, "RobDriverBody", (SkillSlot)3, 2);
					ItemBase<AncientScepterItem>.instance.RegisterScepterSkill(Skills.scepterKnifeSkillDef, "RobDriverBody", (SkillSlot)3, 3);
					ItemBase<AncientScepterItem>.instance.RegisterScepterSkill(Skills.scepterSyringeSkillDef, "RobDriverBody", (SkillSlot)3, 4);
					ItemBase<AncientScepterItem>.instance.RegisterScepterSkill(Skills.scepterSyringeLegacySkillDef, "RobDriverBody", (SkillSlot)3, 5);
					ItemBase<AncientScepterItem>.instance.RegisterScepterSkill(Skills.scepterCoinSkillDef, "RobDriverBody", (SkillSlot)3, 6);
				}
				else
				{
					ItemBase<AncientScepterItem>.instance.RegisterScepterSkill(Skills.scepterKnifeSkillDef, "RobDriverBody", (SkillSlot)3, 2);
					ItemBase<AncientScepterItem>.instance.RegisterScepterSkill(Skills.scepterSyringeSkillDef, "RobDriverBody", (SkillSlot)3, 3);
					ItemBase<AncientScepterItem>.instance.RegisterScepterSkill(Skills.scepterCoinSkillDef, "RobDriverBody", (SkillSlot)3, 4);
				}
			}

