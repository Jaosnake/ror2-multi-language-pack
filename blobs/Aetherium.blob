				{
					CharacterBody currentTarget = GetCurrentTarget();
					if (Object.op_Implicit((Object)(object)currentTarget))
					{
						if (EnableExhaustionAndOverdriveMechanic)
						{
							if (ExhaustionStacks == 0)
							{
								TimeBetweenJumps = (((float)BlinkStateDuration >= 2f) ? ((float)BlinkStateDuration) : 2f);
							}
							if (ExhaustionStacks < ExhaustionLimit)
							{
								float num = Vector3.Distance(currentTarget.corePosition, Body.corePosition);
								if (num >= 40f)
								{
									TimeBetweenJumps = (((float)BlinkStateDuration <= 0.1f) ? ((float)BlinkStateDuration) : 0.1f);
									ExhaustionStacks++;
								}
								else
								{
									TimeBetweenJumps = (((float)BlinkStateDuration >= 2f) ? ((float)BlinkStateDuration) : 2f);
								}
							}
							else
							{
								TimeBetweenJumps = (((float)BlinkStateDuration >= 10f) ? ((float)BlinkStateDuration) : 10f);
								Body.AddTimedBuff(Buffs.Slow80, ((float)BlinkStateDuration >= 10f) ? ((float)BlinkStateDuration) : 10f);
								ExhaustionStacks = 0;
							}
						}
						Vector3 val = LastPosition - Body.corePosition;
						if (((Vector3)(ref val)).magnitude > 0.1f)
						{
							AbyssalDash abyssalDash = new AbyssalDash();
							abyssalDash.duration = BlinkStateDuration;
							abyssalDash.blinkDistance = BlinkDistance;
							bool flag = BodyStateMachine.SetInterruptState((EntityState)(object)abyssalDash, (InterruptPriority)0);
							if (flag)
							{
								LastPosition = Body.corePosition;
							}
							if (!flag && ExhaustionStacks > 0)
							{
								ExhaustionStacks--;
							}
						}
						else
						{
							TimeBetweenJumps = 2f;
						}
					}
					else
					{
