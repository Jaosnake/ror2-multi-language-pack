	internal class SpecialCommandSkillDef : SkillDef
	{
		protected class InstanceData : BaseSkillInstanceData
		{
			public CommandTracker commandTracker;

			public FalconerComponent falconerComponent;
		}

		public override BaseSkillInstanceData OnAssigned([NotNull] GenericSkill skillSlot)
		{
			InstanceData instanceData = new InstanceData
			{
				commandTracker = ((Component)skillSlot).GetComponent<CommandTracker>(),
				falconerComponent = ((Component)skillSlot).GetComponent<FalconerComponent>()
			};
			if (Object.op_Implicit((Object)(object)instanceData.falconerComponent))
			{
				SquallController squallController = instanceData.falconerComponent.squallController;
				if (Object.op_Implicit((Object)(object)squallController))
				{
					SkillLocator skillLocator = squallController.skillLocator;
					if (Object.op_Implicit((Object)(object)skillLocator))
					{
						skillSlot.stock = skillLocator.special.stock;
						skillSlot.rechargeStopwatch = skillLocator.special.rechargeStopwatch;
					}
				}
			}
			return (BaseSkillInstanceData)(object)instanceData;
		}

		private static bool HasTarget([NotNull] GenericSkill skillSlot)
		{
			CommandTracker commandTracker = ((InstanceData)(object)skillSlot.skillInstanceData).commandTracker;
			return Object.op_Implicit((Object)(object)(((Object)(object)commandTracker != (Object)null) ? commandTracker.GetTrackingTarget() : null));
		}

		public override bool CanExecute([NotNull] GenericSkill skillSlot)
		{
			return HasTarget(skillSlot) && ((SkillDef)this).CanExecute(skillSlot);
		}

		public override bool IsReady([NotNull] GenericSkill skillSlot)
		{
			return ((SkillDef)this).IsReady(skillSlot) && HasTarget(skillSlot);
		}
	}
	internal class AttackCommandSkillDef : SkillDef
	{
		protected class InstanceData : BaseSkillInstanceData
		{
			public CommandTracker commandTracker;
		}

		public override BaseSkillInstanceData OnAssigned([NotNull] GenericSkill skillSlot)
		{
			return (BaseSkillInstanceData)(object)new InstanceData
			{
				commandTracker = ((Component)skillSlot).GetComponent<CommandTracker>()
			};
		}

		private static bool HasTarget([NotNull] GenericSkill skillSlot)
		{
			CommandTracker commandTracker = ((InstanceData)(object)skillSlot.skillInstanceData).commandTracker;
			return Object.op_Implicit((Object)(object)(((Object)(object)commandTracker != (Object)null) ? commandTracker.GetTrackingTarget() : null));
		}

		public override bool CanExecute([NotNull] GenericSkill skillSlot)
		{
			return ((SkillDef)this).CanExecute(skillSlot) && HasTarget(skillSlot);
		}

		public override bool IsReady([NotNull] GenericSkill skillSlot)
		{
			return ((SkillDef)this).IsReady(skillSlot) && HasTarget(skillSlot);
		}
	}
