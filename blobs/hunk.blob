			}

			private void TryPickupNotification(bool force = false)
			{
				if (!Object.op_Implicit((Object)(object)notificationQueue) && Object.op_Implicit((Object)(object)characterBody.master))
				{
					notificationQueue = ((Component)characterBody.master).GetComponent<WeaponNotificationQueue>();
				}
				if (!Object.op_Implicit((Object)(object)notificationQueue))
				{
					return;
				}
				if (force)
				{
					WeaponNotificationQueue.PushWeaponNotification(characterBody.master, weaponDef.index);
					lastWeaponDef = weaponDef;
					return;
				}
				if ((Object)(object)weaponDef != (Object)(object)lastWeaponDef)
				{
					WeaponNotificationQueue.PushWeaponNotification(characterBody.master, weaponDef.index);
				}
				lastWeaponDef = weaponDef;
			}

