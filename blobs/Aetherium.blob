				if (!Object.op_Implicit((Object)(object)blasterSwordBehavior))
				{
					blasterSwordBehavior = ((Component)self).gameObject.AddComponent<BlasterSwordBehavior>();
				}
				blasterSwordBehavior.RecalculateStats();
			}
		}

