                    "SS2_ITEM_BABYTOYS_DESC":  "\u003cstyle=cIsUtility\u003e{0} \u003cstyle=cStack\u003e(+{0} birikim baÅŸÄ±na)\u003c/style\u003e seviyeye\u003c/style\u003e kadar kaybet \u003cstyle=cIsUtility\u003etÃ¼m istatistiklerini koruyarak\u003c/style\u003e.",
                    "SS2_ITEM_GREENCHOCOLATE_PICKUP":  "AlÄ±nan hasarÄ± azaltÄ±n ve aÄŸÄ±r hasar aldÄ±ÄŸÄ±nÄ±zda bÃ¼yÃ¼k bir hasar ve kritik ÅŸans bonusu kazanÄ±n.",
                    "SS2_CHIRR_DESCRIPTION":  "CÄ±vÄ±l, gezegenle saf bir baÄŸlantÄ±sÄ± olan mistik bir yaratÄ±ktÄ±r..\u003ccolor=#CCD3E0\u003e\n\n\u003c ! \u003e DoÄŸal BaÄŸ, bir dÃ¼ÅŸmanla arkadaÅŸ olmanÄ±zÄ± saÄŸlar ve ona envanterinizin bir kopyasÄ±nÄ± verir.\n\n\u003c ! \u003e MÃ¼ttefikiniz, saldÄ±rdÄ±ÄŸÄ±nÄ±z dÃ¼ÅŸmanÄ± hedef alacak - ve Hayat Dikenleri, dÃ¼ÅŸmanlarÄ± \u0027iÅŸaretlemek\u0027 iÃ§in harika bir araÃ§tÄ±r..\n\n\u003c ! \u003e Åžifasal Buhar, kendinizi ve mÃ¼ttefiklerinizi canlÄ± tutmak iÃ§in kullanÄ±labilir; bu, hasarÄ± paylaÅŸmak iÃ§in DoÄŸal BaÄŸ kullanÄ±rken Ã¶zellikle deÄŸerlidir..\n\n\u003c ! \u003e Kafa atma, kuÅŸatÄ±ldÄ±ÄŸÄ±nda dÃ¼ÅŸmanlardan kaÃ§mak iÃ§in CÄ±vÄ±l\u0027Ä±n zÄ±plama yeteneklerinin yanÄ± sÄ±ra kullanÄ±labilir..\u003c/color\u003e\n\nThis mod was translated by: Jaosnake",
                    "SS2_ARTIFACT_DEVIATION_NAME":  "Sapma Eseri",
