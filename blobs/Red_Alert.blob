	internal class VanishDriver : CastVanishTether
	{
		private DriverWeaponDef cachedWeaponDef;

		private DriverController iDrive;

		public override float damageCoefficient => ChronoDriverCompat.Driver_M2_Damage.Value;

		public override float baseTickInterval => ChronoDriverCompat.Driver_M2_TickInterval.Value;

		public override float baseDuration => ChronoDriverCompat.Driver_M2_Duration.Value;

		public override int damageTicksPerDebuffStack => 1;

		public override void OnEnter()
		{
			if (((EntityState)this).gameObject.TryGetComponent<DriverController>(ref iDrive))
			{
				DriverController obj = iDrive;
				cachedWeaponDef = ((obj != null) ? obj.weaponDef : null);
			}
			base.OnEnter();
			((EntityState)this).PlayAnimation("Gesture, Override", "FireMachineGun", "Shoot.playbackRate", 1000f, 0f);
			muzzleTransform = ((BaseState)this).FindModelChild("ShotgunMuzzle");
			if ((Object)(object)muzzleTransform == (Object)null)
			{
				muzzleTransform = ((EntityState)this).transform;
			}
			SetTetherPoints();
			if (targetingAlly && Object.op_Implicit((Object)(object)iDrive))
			{
				iDrive.ConsumeAmmo(1f, true);
			}
		}

		public override void DoDamage()
		{
			if (Object.op_Implicit((Object)(object)iDrive))
			{
				iDrive.ConsumeAmmo(tickInterval / baseDuration * 4f, true);
			}
			base.DoDamage();
		}

		public override void OnExit()
		{
			base.OnExit();
			((EntityState)this).PlayAnimation("Gesture, Override", "FireMachineGun", "Shoot.playbackRate", 1f, 0f);
		}

		public override void FixedUpdate()
		{
			if (Object.op_Implicit((Object)(object)iDrive) && (Object)(object)cachedWeaponDef != (Object)(object)iDrive.weaponDef)
			{
				((EntityState)this).outer.SetNextStateToMain();
			}
			else
			{
				base.FixedUpdate();
			}
		}
	}
