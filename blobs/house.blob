				SceneCatalog.GetSceneDefFromSceneName("arena"),
				SceneCatalog.GetSceneDefFromSceneName("blackbeach"),
				SceneCatalog.GetSceneDefFromSceneName("blackbeach2"),
				SceneCatalog.GetSceneDefFromSceneName("dampcavesimple"),
				SceneCatalog.GetSceneDefFromSceneName("foggyswamp"),
				SceneCatalog.GetSceneDefFromSceneName("frozenwall"),
				SceneCatalog.GetSceneDefFromSceneName("golemplains"),
				SceneCatalog.GetSceneDefFromSceneName("golemplains2"),
				SceneCatalog.GetSceneDefFromSceneName("goolake"),
				SceneCatalog.GetSceneDefFromSceneName("rootjungle"),
				SceneCatalog.GetSceneDefFromSceneName("shipgraveyard"),
				SceneCatalog.GetSceneDefFromSceneName("skymeadow"),
				SceneCatalog.GetSceneDefFromSceneName("snowyforest"),
				SceneCatalog.GetSceneDefFromSceneName("sulfurpools"),
				SceneCatalog.GetSceneDefFromSceneName("wispgraveyard"),
