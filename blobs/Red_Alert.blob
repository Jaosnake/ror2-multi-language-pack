		public static Sprite[] rangeSprites;

		public static Sprite allySprite;

		public static Sprite towerSprite;

		public static List<IEnumerator> loads => ContentPacks.asyncLoadCoroutines;

		internal static List<IEnumerator> GetAssetBundleInitializedCoroutines(AssetBundle assetBundle)
		{
			return null;
		}

		internal static void OnCharacterInitialized(AssetBundle assetBundle)
		{
			loads.Add(assetBundle.LoadAssetCoroutine<GameObject>("TeslaCoilBlueprint", (Action<GameObject>)delegate(GameObject result)
			{
				TeslaCoilBlueprintGamOb = result;
			}));
			loads.Add(assetBundle.LoadAssetCoroutine<GameObject>("TeslaCoilBlueprint", (Action<GameObject>)delegate(GameObject result)
			{
				TeslaCoilBlueprintGamOb = result;
			}));
			loads.Add(Asset.LoadAssetCoroutine<GameObject>((object)"RoR2/Base/TeslaTrooper/TeslaCoilBlueprint.prefab", (Action<GameObject>)delegate(GameObject result)
			{
				TeslaCoilBlueprintGamOb = result;
			}));
			assetBundle.LoadAssetAsync<GameObject>("TeslaCoilBlueprint", (Action<GameObject>)delegate(GameObject result)
			{
				TeslaCoilBlueprintGamOb = result;
			});
			Asset.LoadAssetAsync<GameObject>("RoR2/Base/TeslaTrooper/TeslaCoilBlueprint.prefab", (Action<GameObject>)delegate(GameObject result)
			{
				TeslaCoilBlueprintGamOb = result;
			});
			assetBundle.LoadAssetAsync<GameObject>("TeslaCoilBlueprint", (Action<GameObject>)delegate(GameObject result)
			{
				TeslaCoilBlueprintGamOb = result;
			});
			Asset.LoadAssetAsync<GameObject>("RoR2/Base/TeslaTrooper/TeslaCoilBlueprint.prefab", (Action<GameObject>)delegate(GameObject result)
			{
				TeslaCoilBlueprintGamOb = result;
			});
			new AsyncAsset<GameObject>(assetBundle, "TeslaCoilBlueprint", delegate(GameObject result)
			{
				TeslaCoilBlueprintGamOb = result;
			}).AddCoroutine();
			new AsyncAsset<GameObject>("RoR2/Base/TeslaTrooper/TeslaCoilBlueprint.prefab", delegate(GameObject result)
			{
				TeslaCoilBlueprintGamOb = result;
			}).AddCoroutine();
			assetBundle.AddAsyncAsset<GameObject>("TeslaCoilBlueprint", (Action<GameObject>)delegate(GameObject result)
			{
