		protected void CreateElite()
		{
			//IL_00bd: Unknown result type (might be due to invalid IL or missing references)
			//IL_00c2: Unknown result type (might be due to invalid IL or missing references)
			//IL_00e3: Unknown result type (might be due to invalid IL or missing references)
			//IL_00e9: Expected O, but got Unknown
			EliteDef = ScriptableObject.CreateInstance<EliteDef>();
			((Object)EliteDef).name = "AETHERIUM_ELITE_" + EliteAffixToken;
			EliteDef.modifierToken = "AETHERIUM_ELITE_" + EliteAffixToken + "_MODIFIER";
			EliteDef.eliteEquipmentDef = EliteEquipmentDef;
			EliteDef.healthBoostCoefficient = HealthMultiplier;
			EliteDef.damageBoostCoefficient = DamageMultiplier;
			IEnumerable<EliteTierDef> vanillaEliteTierDef = GetVanillaEliteTierDef(EliteTierDef);
			if (vanillaEliteTierDef == null)
			{
				AetheriumPlugin.ModLogger.LogError((object)"Failed to get vanilla elite tier definitions.");
				return;
			}
			CustomElite val = new CustomElite("AETHERIUM_ELITE_" + EliteAffixToken, EliteEquipmentDef, Color32.op_Implicit(EliteColor), "AETHERIUM_ELITE_" + EliteAffixToken + "_MODIFIER", vanillaEliteTierDef, EliteRamp);
			if (EliteTierDef < EliteTier.T2)
			{
				val.EliteDef.healthBoostCoefficient = 4f;
				val.EliteDef.damageBoostCoefficient = 2f;
			}
			else
			{
				val.EliteDef.healthBoostCoefficient = 18f;
				val.EliteDef.damageBoostCoefficient = 6f;
			}
			EliteAPI.Add(val);
			EliteBuffDef.eliteDef = val.EliteDef;
			ContentAddition.AddBuffDef(EliteBuffDef);
		}

		private IEnumerable<EliteTierDef> GetVanillaEliteTierDef(EliteTier tier)
		{
			if (tier == EliteTier.Invalid)
			{
				AetheriumPlugin.ModLogger.LogError((object)"Invalid tier");
				AetheriumPlugin.ModLogger.LogDebug((object)new StackTrace());
				return null;
			}
			List<EliteTierDef> list = new List<EliteTierDef> { EliteAPI.VanillaEliteTiers[(int)tier] };
			EliteTier eliteTierDef = EliteTierDef;
			if ((uint)(eliteTierDef - 1) <= 1u)
			{
				list.Add(EliteAPI.VanillaEliteTiers[(int)(tier + 2)]);
			}
			return list;
		}

		protected bool PerformEquipmentAction(orig_PerformEquipmentAction orig, EquipmentSlot self, EquipmentDef equipmentDef)
		{
			if ((Object)(object)equipmentDef == (Object)(object)EliteEquipmentDef)
			{
				return ActivateEquipment(self);
			}
			return orig.Invoke(self, equipmentDef);
		}

		protected abstract bool ActivateEquipment(EquipmentSlot slot);

