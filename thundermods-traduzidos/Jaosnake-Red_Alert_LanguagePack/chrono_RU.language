        "HABIBI_CHRONO_OUTRO_FLAVOR": "..и он ушёл, не оставив следа.",
        "HABIBI_CHRONO_OUTRO_FAILURE": "..и он исчез, словно никогда не существовал.",
        "HABIBI_CHRONO_MASTERY_SKIN_NAME": "Альтернативный",
        "HABIBI_CHRONO_PASSIVE_SPRINT_NAME": "Уже Там",
