    "SANDSWEPT_VOID_SHRINE_RUIN_USE_MESSAGE_2P": "<style=cShrine>Yolsuzluk yayılıyor.</color>",
    "SANDSWEPT_VOID_SHRINE_RUIN_USE_MESSAGE": "<style=cShrine>Yolsuzluk yayılıyor.</color>",
    "SANDSWEPT_SHRINE_OF_RUIN_DESCRIPTION": "Hayatta kalan biri tarafından etkinleştirildiğinde Harabe Tapınağı, envanterden rastgele 10 beyaz eşya tüketir ve bir sonraki aşamayı bozar.",
    "SANDSWEPT_SHRINE_SACRIFICE_NAME": "Kurban Tapınağı",
