			//IL_0057: Expected O, but got Unknown
			CharacterMaster.onStartGlobal += AttachInspiringBehavior;
			RecalculateStatsAPI.GetStatCoefficients += new StatHookEventHandler(ApplyDroneStats);
			CharacterBody.GetDisplayName += new hook_GetDisplayName(AddInspiredPrefix);
			if ((bool)EnableDeathExplosion)
			{
				GlobalEventManager.OnCharacterDeath += new hook_OnCharacterDeath(DetonateInspiredDrone);
			}
		}

		private void AttachInspiringBehavior(CharacterMaster master)
		{
			//IL_0065: Unknown result type (might be due to invalid IL or missing references)
			if (!NetworkServer.active)
			{
				return;
			}
			MinionOwnership minionOwnership = master.minionOwnership;
			if (!Object.op_Implicit((Object)(object)minionOwnership) || !Object.op_Implicit((Object)(object)minionOwnership.ownerMaster))
			{
				return;
			}
			GameObject bodyPrefab = master.bodyPrefab;
			if (!Object.op_Implicit((Object)(object)bodyPrefab))
			{
				return;
			}
			CharacterBody component = bodyPrefab.GetComponent<CharacterBody>();
			if (!Object.op_Implicit((Object)(object)component) || !((Enum)component.bodyFlags).HasFlag((Enum)(object)(BodyFlags)2))
			{
				return;
			}
			InspiringDroneMinionBehavior component2 = ((Component)master).GetComponent<InspiringDroneMinionBehavior>();
			if (!Object.op_Implicit((Object)(object)component2))
			{
				component2 = ((Component)master).gameObject.AddComponent<InspiringDroneMinionBehavior>();
				bool flag = ((Object)bodyPrefab).name.Contains("Turret") || component.baseNameToken.Contains("TURRET");
				if ((bool)EnableDeathExplosion && !flag)
				{
					component2.KamikazeDriver = AddKamikazeDriver(master);
				}
			}
		}

		private AISkillDriver AddKamikazeDriver(CharacterMaster master)
		{
			//IL_0038: Unknown result type (might be due to invalid IL or missing references)
			//IL_00a9: Unknown result type (might be due to invalid IL or missing references)
			//IL_00b0: Unknown result type (might be due to invalid IL or missing references)
