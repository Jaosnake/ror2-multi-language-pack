		}

		private void Start()
		{
			//IL_0001: Unknown result type (might be due to invalid IL or missing references)
			//IL_0006: Unknown result type (might be due to invalid IL or missing references)
			Scene activeScene = SceneManager.GetActiveScene();
			if (((Scene)(ref activeScene)).name == "bazaar")
			{
				isBazaar = true;
			}
		}

		private void TeleporterInteraction_onTeleporterFinishGlobal(TeleporterInteraction obj)
		{
			RedGuyController.onStageCompleted?.Invoke(wasBloodWellFilled);
		}

		private void FixedUpdate()
		{
			//IL_01f8: Unknown result type (might be due to invalid IL or missing references)
			//IL_01fe: Unknown result type (might be due to invalid IL or missing references)
			if (isBazaar)
			{
				HandleWallStare();
			}
			decay = Mathf.Clamp(decay + decayGrowth * Time.fixedDeltaTime, 0f, maxDecayRate);
			hopoFeatherTimer -= Time.fixedDeltaTime;
			if (!permaBossCling)
			{
				clingTimer -= Time.fixedDeltaTime;
			}
			if (draining)
			{
				decay = drainRate;
				if (passive.isAltBloodWell)
				{
					decay = altDrainRate;
				}
			}
			bool flag = true;
			if (!passive.isBlink && isWallClinging)
			{
				flag = false;
			}
			if (flag)
			{
				meter = Mathf.Clamp(meter - decay * Time.fixedDeltaTime, 0f, 100f);
			}
			if (meter <= 0f && !inGrab)
			{
				if (draining)
				{
					steamEffect.Stop();
					chargeEffect.Stop();
					blackElectricityEffect.Stop();
					if (NetworkServer.active)
					{
						characterBody.RemoveBuff(RedGuy.bloodRushBuff);
					}
					AkSoundEngine.StopPlayingID(playID);
					Util.PlaySound("sfx_ravager_steam", ((Component)this).gameObject);
				}
				draining = false;
			}
			if (draining && !isWallClinging)
			{
				storedHealth -= iDontEvenKnowAnymore * Time.fixedDeltaTime;
				if (NetworkServer.active && storedHealth >= 0f)
				{
					healthComponent.Heal(iDontEvenKnowAnymore * Time.fixedDeltaTime, default(ProcChainMask), true);
				}
			}
			if (characterBody.characterMotor.jumpCount < characterBody.maxJumpCount)
			{
				blinkReady = true;
			}
			if (blinkCount > 0)
			{
				if (!handElectricityEffect.isPlaying)
				{
					handElectricityEffect.Play();
				}
			}
			else if (handElectricityEffect.isPlaying)
			{
				handElectricityEffect.Stop();
			}
			if (Object.op_Implicit((Object)(object)animator))
			{
				animator.SetBool("isEmpowered", draining);
			}
		}

		private void HandleWallStare()
		{
			//IL_001d: Unknown result type (might be due to invalid IL or missing references)
			//IL_0022: Unknown result type (might be due to invalid IL or missing references)
			Vector3 val = default(Vector3);
