        "SS2_NEMMANDO_SPECIAL_BOSS_DESCRIPTION": "<style=cIsDamage>Gouging.</style> <style=cIsUtility>Şarj edin</style>, ardından <style=cIsUtility>ileri atılır</style> ve %<style=cIsDamage>{1}'ye kadar hasar veren <style=cIsDamage>{0}'ye varan yıkıcı bir yaylım ateşi açın</style> her biri</style>. <style=cIsUtility>Eğik çizgi sayısı saldırı hızıyla birlikte artar</style>.",
        "SS2_SKIN_NEMESIS_MERCENARY_DEFAULT": "Varsayılan",
        "SS2_ITEM_LIGHTBULB_DESC": "Beceri bekleme sürelerini azaltır. Düşük canda kırılır.",
        "SS2_ACHIEVEMENT_CYBORG_DESC": "Complete an Ethereal Teleporter event.",
        "SS2_ITEM_DROIDHEAD_DESC": "Seçkin bir düşmanı öldürmek <style=cIsDamage>15 saniyeliğine</style> <style=cIsDamage>Güvenlik Dronu</style> <style=cStack>(birikim başına +50% hasar ve +20% hareket hızı)</style> oluşturur. Dronlar ölen seçkin düşmanın <style=cIsUtility>cinsinden</style> olur.",
        "SS2_NEMEXECUTIONER_BODY_SUBTITLE": "Lanetlilerin Feribotçusu",
        "SS2_WARDEN_SPECIAL_BANNER_DESC": "Düşmanları ve mermileri yavaşlatan, kendiniz ve müttefikleriniz için %<style=cIsUtility>X hareket hızı</style>, %<style=cIsDamage>Y saldırı hızı</style> sağlayan bir sancağı atlayın ve vurun.",
        "SS2_VOIDROCK_USED_NAME": "Boş Toprak Yığını",
        "SS2_EXECUTIONER2_OUTRO_FLAVOR": "..ve böylece oradan ayrıldı, kana bulanmış boş zırh kabuğu olarak.",
        "SS2_ITEM_VOIDROCK_LORE": "<style=cMono>DataScraper'a hoş geldiniz (v3.1.53 - beta şubesi)\n$ Bellek kazınıyor... yapıldı.\n$ Çözümleniyor... yapıldı.\n$ İlgili veriler için tarama...\n$ İlgili veriler için tarama - devam ediyor...\n$ Com-bi-- for- re-vant da-a-a-a-a-...\n$ ...\n$ <color=#FFCCED>Ne arıyorsunuz</color>\n$ <color=#FFCCED>Onlara ne olduğunu zaten biliyorsunuz</color>\n$ <color=#FFCCED>Öyleyse neden kazmaya zahmet ediyorsunuz? mezarlar</color>\n$ <color=#FFCCED>yalnızca sefalet bulacağınızı bilmek</color>\n$ <color=#FFCCED>Umut mu</color>\n$ <color=#FFCCED>Hala hayatta olduklarını umuyor musunuz</color>\n$ <color=#FFCCED>Çünkü umudunuz yerinde</color>\n$ <color=#FFCCED>Onlar yaşıyor</color>\n$ <color=#FFCCED>ve onlarla tekrar buluşacaksınız</color>\n$ <color=#FFCCED><link=\"textShaky\">Çok yakında</link></color>\n$\nHata!\nHata günlüğü çıktısı alınıyor...\n</style>\nVeriler ya yoğun şekilde şifrelenmiş ya da geri alınamayacak şekilde bozulmuş. Tekrar kazımadan önce harici seçenekleri değerlendirin.",
        "SS2_CHIRR_LEAVES_NAME": "Jilet Yaprakları",
        "SS2_KEYWORD_BLEED": "<style=cKeywordName>Kanama</style><style=cSub><style=cIsDamage>%240 </style> taban hasar verir. 3 saniye boyunca. <i>Kanama istiflenebilir.</i></style>",
        "SS2_SHRINE_ETHEREAL_WARN_MESSAGE_2P": "<style=cEvent>Eterik Fidanı hazırladınız..</style>",
        "SS2_KEYWORD_RECHARGING2": "<style=cKeywordName>Yeniden Şarj Etme</style><style=cSub>Bu beceri, düğmeyi basılı tutarak veya düşmanları öldürerek ek stokları yeniden şarj edebilir. Ek stoklar maksimum kapasiteyi artırır.</style>",
        "SS2_ITEM_STIRRINGSOUL_DESC": "Katledilen düşmalar geride <style=cIsUtility>ruh</style> bırakır, dokunulduğunda <style=cIsUtility>0.5%</style> <style=cStack>(Başarısız sonuçta +0.5%, başarı durumunda sıfırlanır)</style> ihtimalle <style=cIsUtility>bir eşya düşürür</style>. <style=cIsUtility>Şansdan etkilenmez</style>.",
        "SS2_ACHIEVEMENT_CAPTAIN_GRANDMASTERY_NAME": "Captain: Grand Mastery",
