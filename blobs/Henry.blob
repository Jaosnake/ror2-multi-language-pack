		private static void CreateHitboxes(GameObject prefab)
		{
			ChildLocator componentInChildren = prefab.GetComponentInChildren<ChildLocator>();
			GameObject gameObject = ((Component)componentInChildren).gameObject;
			Transform hitboxTransform = componentInChildren.FindChild("PunchHitbox");
			Prefabs.SetupHitbox(gameObject, hitboxTransform, "Punch");
		}

