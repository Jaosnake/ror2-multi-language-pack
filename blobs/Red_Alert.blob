			Driver_M1_Damage = Config.BindAndOptionsSlider(section, "Driver_M1_Damage", 2f);
			Driver_M1_Duration = Config.BindAndOptionsSlider(section, "Driver_M1_Duration", 0.4f, 0f, 5f);
			Driver_M2_Damage = Config.BindAndOptionsSlider(section, "Driver_M2_Damage", 0.3f, 0f, 10f);
			Driver_M2_TickInterval = Config.BindAndOptionsSlider(section, "Driver_M2_TickInterval", 0.08f, 0f, 10f);
			Driver_M2_Duration = Config.BindAndOptionsSlider(section, "Driver_M2_Duration", 1f);
		}

