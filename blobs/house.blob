			//IL_00f3: Unknown result type (might be due to invalid IL or missing references)
			//IL_0118: Unknown result type (might be due to invalid IL or missing references)
			Lucky7buff = AddNewBuff("All Lucky Sevens", Assets.mainAssetBundle.LoadAsset<Sprite>("JackpotFull"), Color.white, canStack: false, isDebuff: false);
			Spadesbuff = AddNewBuff("Ace of Spades", Assets.mainAssetBundle.LoadAsset<Sprite>("SpadesFull"), Color.white, canStack: false, isDebuff: false);
			Ante = AddNewBuff("Ante", Assets.mainAssetBundle.LoadAsset<Sprite>("AnteUpBuffIcon"), Color.green, canStack: true, isDebuff: false);
			StarBuff = AddNewBuff("AstralStar", Assets.mainAssetBundle.LoadAsset<Sprite>("StarBuffIcon"), Color.yellow, canStack: false, isDebuff: false);
			CupsBuff = AddNewBuff("Queen of Cups", Assets.mainAssetBundle.LoadAsset<Sprite>("CupsBuffIcon"), Color.red, canStack: false, isDebuff: false);
			Deuces = AddNewBuff("Deuces", Assets.mainAssetBundle.LoadAsset<Sprite>("DeucesBuffIcon"), Color.blue, canStack: false, isDebuff: false);
			Flush = AddNewBuff("Flush", Assets.mainAssetBundle.LoadAsset<Sprite>("FlushBuffIcon"), Color.green, canStack: false, isDebuff: false);
			TabulaRasa = AddNewBuff("Tabula Rasa", Assets.mainAssetBundle.LoadAsset<Sprite>("StarBuffIcon"), Color.black, canStack: false, isDebuff: false);
			ASUp = Buffs.GenericASPlus;
			ASDown = Buffs.GenericASMinus;
			MSUp = Buffs.GenericMSPlus;
			MSDown = Buffs.GenericMSMinus;
			DamageUp = Buffs.GenericDamagePlus;
			DamageDown = Buffs.GenericDamageMinus;
			ArmorUp = Buffs.GenericArmorPlus;
			ArmorDown = Buffs.GenericArmorMinus;
			RegenUp = Buffs.GenericRegenPlus;
			RegenDown = Buffs.GenericRegenMinus;
			Polymorphed = Buffs.Polymorphed;
		}

		internal static BuffDef AddNewBuff(string buffName, Sprite buffIcon, Color buffColor, bool canStack, bool isDebuff)
		{
			//IL_0010: Unknown result type (might be due to invalid IL or missing references)
			//IL_0011: Unknown result type (might be due to invalid IL or missing references)
			BuffDef val = ScriptableObject.CreateInstance<BuffDef>();
			((Object)val).name = buffName;
			val.buffColor = buffColor;
			val.canStack = canStack;
			val.isDebuff = isDebuff;
			val.eliteDef = null;
			val.iconSprite = buffIcon;
			buffDefs.Add(val);
			return val;
		}

		public static void RemoveStacksOfAnte(CharacterBody body, int stacksToRemove)
		{
			int buffCount = body.GetBuffCount(Ante);
			body.ClearTimedBuffs(Ante);
			buffCount -= stacksToRemove;
			for (int i = 0; i < buffCount; i++)
			{
				body.AddTimedBuff(Ante, 60f, 20);
			}
		}
	}
