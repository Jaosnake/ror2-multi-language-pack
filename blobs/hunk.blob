						lowHealthMask.fillAmount = 0f;
					}
					TeamIndex teamIndex = healthComponent.body.teamComponent.teamIndex;
					ulong teamCurrentLevelExperience = TeamManager.instance.GetTeamCurrentLevelExperience(teamIndex);
					ulong teamExperience = TeamManager.instance.GetTeamExperience(teamIndex);
					ulong teamNextLevelExperience = TeamManager.instance.GetTeamNextLevelExperience(teamIndex);
					teamExperience -= teamCurrentLevelExperience;
					teamNextLevelExperience -= teamCurrentLevelExperience;
					float num9 = Util.Remap((float)teamExperience, 0f, (float)teamNextLevelExperience, 0f, 0.77f);
					if (num9 < expFill.fillAmount)
					{
