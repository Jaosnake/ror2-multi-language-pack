        "ROB_HUNK_BODY_JACKET_SKIN_NAME": "재킷",
        "ROB_HUNK_BODY_PPASSIVE_NAME": "OSP(현장조달)",
        "ROB_HUNK_BODY_PPASSIVE_DESCRIPTION": "HUNK는 <color=#FFFF00>U.C를 수집할 수 있습니다. 키카드</color>로 <style=cIsDamage>무기 케이스</style>를 열고 무기고를 확장하세요.",
        "ROB_HUNK_BODY_PPASSIVE2_NAME": "잊혀진 병사",
        "ROB_HUNK_BODY_PPASSIVE2_DESCRIPTION": "각 스테이지에서 처음으로 죽는 <style=cIsHealth>boss</style>은 무기나 액세서리가 포함된 <style=cIsDamage>공급 패키지</style>을 떨어뜨립니다.",
        "ROB_HUNK_BODY_PASSIVE_NAME": "섀도우 파이트",
        "ROB_HUNK_BODY_PASSIVE_DESCRIPTION": "<style=cIsDamage>LE 5</style> 및 <style=cIsDamage>보조 무기</style>로 시작하세요. 탄약을 위해 <style=cIsDamage>scavenge</style> <style=cIsUtility>chests</style>을 사용할 수 있습니다.",
        "ROB_HUNK_BODY_PASSIVE2_NAME": "임박한 공포",
        "ROB_HUNK_BODY_PASSIVE2_DESCRIPTION": "<style=cIsDamage>완전한 무기고</style>, <style=cIsHealth>BUT</style>로 시작하면 더 이상 <style=cIsHealth>추가 탄약</style>을 얻을 수 없습니다.",
        "ROB_HUNK_BODY_RANDOMPASSIVE_NAME": "새 게임+",
        "ROB_HUNK_BODY_RANDOMPASSIVE_DESCRIPTION": "<style=cIsDamage>LE 5</style> 및 <style=cIsDamage>보조 무기</style>로 시작하세요. 탄약을 위해 <style=cIsDamage>scavenge</style> <style=cIsUtility>chests</style>을 사용할 수 있습니다. <style=cIsHealth>모든 무기 케이스 내용물은 무작위입니다.</style>",
        "ROB_HUNK_BODY_SHOTGUNPASSIVE_NAME": "최고 권위",
        "ROB_HUNK_BODY_SHOTGUNPASSIVE_DESCRIPTION": "<style=cIsDamage>W-870</style> 및 <style=cIsDamage>보조 무기</style>로 시작하세요. 탄약을 위해 <style=cIsDamage>scavenge</style> <style=cIsUtility>chests</style>을 사용할 수 있습니다.",
        "ROB_HUNK_BODY_SMGPASSIVE_NAME": "최고 용병",
        "ROB_HUNK_BODY_SMGPASSIVE_DESCRIPTION": "<style=cIsHealth>ONLY</style>을 <style=cIsDamage>완전히 업그레이드된 LE 5</style>로 시작하세요. 탄약을 위해 <style=cIsDamage>scavenge</style> <style=cIsUtility>chests</style>을 사용할 수 있습니다. <style=cIsDamage>Special</style>은</style>0__Chaos 모드</style>1__로 대체되었습니다.",
        "ROB_HUNK_BODY_WPASSIVE_NAME": "완전한 전역 포화",
        "ROB_HUNK_BODY_WPASSIVE_DESCRIPTION": "<style=cIsHealth>ONLY</style>을 <style=cIsDamage>보조 무기</style>로 시작하세요. 탄약을 위해 <style=cIsDamage>scavenge</style> <style=cIsUtility>chests</style>을 사용할 수 있습니다. <style=cIsDamage>Utility</style>는</style>0__Uroboros</style>1__로 대체되었습니다.",
        "ROB_HUNK_BODY_FLAMERPASSIVE_NAME": "파이로매니아",
        "ROB_HUNK_BODY_FLAMERPASSIVE_DESCRIPTION": "<style=cIsDamage>화학 화염방사기</style>로 <style=cIsHealth>ONLY</style>을 시작하세요. 탄약을 위해 <style=cIsDamage>scavenge</style> <style=cIsUtility>chests</style>을 사용할 수 있습니다. <style=cIsHealth>스테이지당 하나의 무기 상자만 생성됩니다.</style>",
        "ROB_HUNK_BODY_PRIMARY_KNIFE_NAME": "전투용 칼",
        "ROB_HUNK_BODY_PRIMARY_KNIFE_DESCRIPTION": "<style=cIsUtility>무승부.</style> <style=cIsDamage>컷</style> 근처 전투원에게 <style=cIsDamage>200% 피해</style>를 입히고 <style=cIsHealth>Mangled</style>을 입힙니다.",
        "ROB_HUNK_BODY_PRIMARY_CQC_NAME": "CQC(근접전투)",
        "ROB_HUNK_BODY_PRIMARY_CQC_DESCRIPTION": "<style=cIsUtility>무승부.</style> <style=cIsDamage>두 번 킥</style> <style=cIsDamage>200% 및 250% 데미지</style>. <style=cIsUtility>두 번째 kick</style>이 연결되면 <style=cIsDamage>Counterattack</style>으로 후속 조치를 취합니다.",
        "ROB_HUNK_BODY_PRIMARY_RELOAD_NAME": "새로고침",
        "ROB_HUNK_BODY_RELOAD_DESCRIPTION": "현재 무기를 다시 장전하세요.",
        "ROB_HUNK_BODY_SECONDARY_AIM_NAME": "꾸준히 조준하세요",
        "ROB_HUNK_BODY_SECONDARY_AIM_DESCRIPTION": "<style=cIsUtility>적의 약점을 노출</style>하는 것을 목표로 하세요. <style=cIsDamage>조준하는 동안 기본을 사용하면 장착된 무기가 발사됩니다.</style>",
        "ROB_HUNK_BODY_UTILITY_DODGE_NAME": "퀵스텝",
        "ROB_HUNK_BODY_UTILITY_DODGE_DESCRIPTION": "<style=cIsUtility>Advance</style> 짧은 거리. <style=cIsUtility>공격을 피하기</style> 위해 선제적으로 사용되는 경우 <style=cIsDamage>완벽한 회피</style>를 수행합니다.",
        "ROB_HUNK_BODY_UTILITY_DODGE_SCEPTER_NAME": "우로보로스",
        "ROB_HUNK_BODY_UTILITY_DODGE_SCEPTER_DESCRIPTION": "<style=cIsUtility>Advance</style> 짧은 거리. <style=cIsUtility>공격을 피하기</style> 위해 선제적으로 사용되는 경우 <style=cIsDamage>완벽한 회피</style>를 수행합니다. 우로보로스의 힘이 당신을 통해 흐릅니다.",
        "ROB_HUNK_BODY_UTILITY_PARRY_NAME": "패리",
        "ROB_HUNK_BODY_UTILITY_PARRY_DESCRIPTION": "<style=cIsUtility>차단</style> 공격, <style=cIsDamage>무효화</style> 피해, <style=cIsUtility>재사용 대기시간 환불</style>. 선제적으로 사용하는 경우 <style=cIsDamage>Perfect Parry</style>을 수행합니다.",
        "ROB_HUNK_BODY_UTILITY_BASH_NAME": "어깨 강타",
        "ROB_HUNK_BODY_UTILITY_BASH_DESCRIPTION": "<style=cIsUtility>주변 적들을 어깨로 때리면</style> <style=cIsUtility>기절</style>하여 <style=cIsDamage>400% 피해를 줍니다</style>. <style=cIsUtility>공격을 취소</style>하기 위해 선제적으로 사용되는 경우 <style=cIsDamage>완벽한 편향</style>을 수행합니다.",
        "ROB_HUNK_BODY_SPECIAL_SWAP_NAME": "군단",
        "ROB_HUNK_BODY_SPECIAL_SWAP_DESCRIPTION": "<style=cIsUtility></style>을 <style=cIsDamage>다른 무기</style>로 교체합니다. 탭하여 <style=cIsUtility>마지막으로 사용한 무기</style>로 교체하세요.",
        "ROB_HUNK_BODY_SPECIAL_MAYHEM_NAME": "카오스 모드",
        "ROB_HUNK_BODY_SPECIAL_MAYHEM_DESCRIPTION": "<style=cIsDamage>카오스 모드</style>을 시작하면 무기 성능이 대폭 향상됩니다.",
