				string text8 = "<style=cKeywordName>G-Virus</style><style=cSub>Once every stage, a random monster becomes <color=#C678B4>Infected</color>. It mutates, <style=cIsHealth>growing stronger over time</style>, and killing it drops a <color=#FFFF00>G-Virus Sample</color>.";
				text8 += "\n\n<style=cKeywordName>T-Virus</style><style=cSub>Once every stage, several monsters become <color=#0066FF>Infected</color>. This <style=cIsHealth>revives</style> them twice, and killing all of them nets you a <color=#FFFF00>T-Virus Sample</color>.";
				text8 += "\n\n<style=cKeywordName>C-Virus</style><style=cSub>Once every stage, several monsters become <color=#FF0033>Infected</color>. Upon death these monsters go on a <style=cIsDamage>frenzy</style> for <style=cIsUtility>5</style> seconds and then <style=cIsHealth>explode</style>, and killing all of them nets you a <color=#FFFF00>C-Virus Sample</color>.";
				LanguageAPI.Add("ROB_HUNK_KEYWORD_VIRUS", text8);
				LanguageAPI.Add("ROB_HUNK_KEYWORD_GVIRUS", "<style=cKeywordName>G-Virus</style><style=cSub>Once every stage, a random monster becomes <color=#C678B4>Infected</color>. It mutates, <style=cIsHealth>growing stronger over time</style>, and killing it drops a <color=#FFFF00>G-Virus Sample</color>.");
				LanguageAPI.Add("ROB_HUNK_KEYWORD_TVIRUS", "<style=cKeywordName>T-Virus</style><style=cSub>Once every stage, several monsters become <color=#0066FF>Infected</color>. This <style=cIsHealth>revives</style> them twice, and killing all of them nets you a <color=#FFFF00>T-Virus Sample</color>.");
