        "ROB_HUNK_BODY_SHOOT_MINIGUN_NAME": "Tirer",
        "ROB_HUNK_BODY_SHOOT_MINIGUN_DESCRIPTION": "Tire pour <style=cIsDamage>2x250% de dégâts</style>. <style=cIsUtility>Les dégâts augmentent avec la vitesse d'attaque.</style>",
        "ROB_HUNK_BODY_SHOOT_ATM_NAME": "Tirer",
