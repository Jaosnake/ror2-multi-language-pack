			skillDefInfo.skillDescriptionToken = text + "_HENRY_BODY_SECONDARY_GUN_DESCRIPTION";
			skillDefInfo.skillIcon = Asset.mainAssetBundle.LoadAsset<Sprite>("texSecondaryIcon");
