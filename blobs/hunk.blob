					{
						notifications[i].Init(itemDef, 1);
						return;
					}
				}
				if (queue.Count > 0)
				{
					QueuedItem[] array = queue.ToArray();
					for (int j = 0; j < array.Length; j++)
					{
						if (Object.op_Implicit((Object)(object)array[j].itemDef) && (Object)(object)array[j].itemDef == (Object)(object)itemDef)
						{
							array[j].amount++;
							queue = array.ToList();
							return;
						}
					}
				}
				queue.Add(new QueuedItem
				{
					itemDef = itemDef,
					amount = 1
				});
			}

