		public void SetAllImageType(bool activateable)
		{
			//IL_003d: Unknown result type (might be due to invalid IL or missing references)
			//IL_0036: Unknown result type (might be due to invalid IL or missing references)
			for (int i = 0; i < stockObjects.Count; i++)
			{
				stockObjects[i].sprite = (activateable ? AssetsArsonist.activatedStackSprite : AssetsArsonist.deactivatedStackSprite);
				((Graphic)stockObjects[i]).color = (activateable ? Color.white : opacityColor);
			}
		}

		public void Update()
		{
			if (Object.op_Implicit((Object)(object)masochismController))
			{
				for (int i = 0; i < stockObjects.Count; i++)
				{
					if (i <= masochismController.masoStacks - 1)
					{
						((Component)stockObjects[i]).gameObject.SetActive(true);
					}
					else
					{
						((Component)stockObjects[i]).gameObject.SetActive(false);
					}
				}
				if (masochismController.masoStacks >= Config.masochismMinimumRequiredToActivate.Value)
				{
					if (!activateable)
					{
						SetAllImageType(activateable: true);
						activateable = true;
					}
				}
				else if (activateable)
				{
					SetAllImageType(activateable: false);
					activateable = false;
				}
			}
			if (!Object.op_Implicit((Object)(object)masochismSurgeController))
			{
				return;
			}
			for (int j = 0; j < stockObjects.Count; j++)
			{
				if (j <= masochismSurgeController.masoStacks - 1)
				{
					((Component)stockObjects[j]).gameObject.SetActive(true);
				}
				else
				{
					((Component)stockObjects[j]).gameObject.SetActive(false);
				}
			}
			if (masochismSurgeController.masoStacks >= Config.masochismMinimumRequiredToActivate.Value)
			{
				if (!activateable)
				{
					SetAllImageType(activateable: true);
					activateable = true;
				}
			}
			else if (activateable)
			{
				SetAllImageType(activateable: false);
				activateable = false;
			}
		}

		public void OnDestroy()
		{
			for (int i = 0; i < stockObjects.Count; i++)
			{
				Object.Destroy((Object)(object)((Component)stockObjects[i]).gameObject);
			}
			Object.Destroy((Object)(object)crosshairStockContainer.gameObject);
		}
	}
	internal class ArsonistDisplayController : MonoBehaviour
	{
		internal float stopwatch;

		internal float duration;

		internal static float igniteFraction = 0.38f;

		internal static float flameParticleTrigger = 0.55f;

		internal bool ignited;

		internal bool sizzling;

		public ParticleSystem fireParticle;

		public ParticleSystem sparkParticle;

		private void Start()
		{
			//IL_0088: Unknown result type (might be due to invalid IL or missing references)
			//IL_009d: Unknown result type (might be due to invalid IL or missing references)
			//IL_00b2: Unknown result type (might be due to invalid IL or missing references)
			//IL_00c7: Unknown result type (might be due to invalid IL or missing references)
			stopwatch = 0f;
			ignited = false;
			sizzling = false;
			duration = 1.7f;
			ChildLocator componentInChildren = ((Component)this).GetComponentInChildren<ChildLocator>();
			if ((Object)(object)componentInChildren != (Object)null)
			{
				fireParticle = ((Component)componentInChildren.FindChild("FireParticle")).gameObject.GetComponent<ParticleSystem>();
				sparkParticle = ((Component)componentInChildren.FindChild("SparkParticle")).gameObject.GetComponent<ParticleSystem>();
			}
			if (AkSoundEngine.IsInitialized())
			{
				AkSoundEngine.SetRTPCValue("Volume_ArsonistVoice", Config.arsonistVoicelineVolume.Value);
				AkSoundEngine.SetRTPCValue("Volume_ArsonistVoice_Arsonist", Config.arsonistVoicelineVolumeArsonist.Value);
				AkSoundEngine.SetRTPCValue("Volume_ArsonistVoice_Firebug", Config.arsonistVoicelineVolumeFirebug.Value);
				AkSoundEngine.SetRTPCValue("Volume_ArsonistSFX", Config.arsonistSFXVolume.Value);
			}
		}

		private void Update()
		{
			stopwatch += Time.deltaTime;
			if (stopwatch >= duration * igniteFraction && !ignited)
			{
				Util.PlaySound("Arsonist_Menu_Match_Strike", ((Component)this).gameObject);
				ignited = true;
				fireParticle.Play();
				sparkParticle.Play();
			}
		}
	}
