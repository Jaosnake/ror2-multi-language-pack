	public static class Config
	{
		public static void ReadConfig()
		{
			ClusterFire.useLaser = ((BaseUnityPlugin)PilotPlugin.instance).Config.Bind<bool>("Settings", "Cluster Fire - Piercing Shot", false, "Cluster Fire pierces on the 3rd shot like in Returns.");
			ClusterFire.useLaser.SettingChanged += UseLaser_SettingChanged;
			DeployParachute.enableParachuteFade = ((BaseUnityPlugin)PilotPlugin.instance).Config.Bind<bool>("Settings", "Parachute Fade", true, "Pilot's parachute becomes transparent when looking downwards.");
			DeployParachute.holdToAscend = ((BaseUnityPlugin)PilotPlugin.instance).Config.Bind<bool>("Controls", "Rapid Deployment - Hold to Ascend", false, "Rapid Deployment requires you to hold the Utility button to ascend, and ends early if you let go.");
			DeployParachute.cameraMode = ((BaseUnityPlugin)PilotPlugin.instance).Config.Bind<DeployParachute.CameraModes>("Controls", "Rapid Deployment - Camera Mode", DeployParachute.CameraModes.Shoulder, "Camera position while using this skill.");
			DashGround.onlyDashBackwards = ((BaseUnityPlugin)PilotPlugin.instance).Config.Bind<bool>("Controls", "Air Strike - Only Dash Backwards", false, "Air Strike ground dash only moves backwards like in Returns.");
			PlaceAirstrikeAlt.useShorthop = ((BaseUnityPlugin)PilotPlugin.instance).Config.Bind<bool>("Controls", "Aerial Support - Shorthop", true, "Using this skill midair gives a vertical boost.");
			ModCompat.SetupOptions();
		}

		private static void UseLaser_SettingChanged(object sender, EventArgs e)
		{
			if (Object.op_Implicit((Object)(object)PilotSurvivor.SkillDefs.Primaries.ClusterFire))
			{
				((SkillDef)PilotSurvivor.SkillDefs.Primaries.ClusterFire).skillDescriptionToken = (ClusterFire.useLaser.Value ? "MOFFEIN_PILOT_BODY_PRIMARY_RETURNS_DESCRIPTION" : "MOFFEIN_PILOT_BODY_PRIMARY_DESCRIPTION");
			}
		}

		public static ConfigEntry<bool> CharacterEnableConfig(string characterName, string description = "Set to false to disable this character", bool enabledDefault = true)
		{
			return ((BaseUnityPlugin)PilotPlugin.instance).Config.Bind<bool>("General", "Enable " + characterName, enabledDefault, description);
		}
	}
