		public void PingSpecificOrb(int index)
		{
			if (!isInitialized || failedToInitialize)
			{
				return;
			}
			try
			{
				orbAnimators[index].SetTrigger("isPinged");
			}
			catch (IndexOutOfRangeException ex)
			{
				Debug.Log((object)ex);
			}
		}

		public void UpdateOrbList(List<OrbController.OrbType> orbsList)
		{
			if (!isInitialized || failedToInitialize)
			{
				return;
			}
			if (orbsList.Count == 0)
			{
				for (int i = 0; i < orbAnimators.Count; i++)
				{
					orbAnimators[i].SetBool("spawned", false);
					orbAnimators[i].SetBool("hidden", true);
				}
				return;
			}
			int num = Mathf.Min(maxShownOrbs, orbsList.Count);
			for (int j = 0; j < maxShownOrbs; j++)
			{
				if (j < num)
				{
					((Graphic)orbImages[j]).material = SelectOrbMaterial(orbsList[j]);
					orbAnimators[j].SetBool("spawned", true);
					orbAnimators[j].SetBool("hidden", false);
				}
				else
				{
					orbAnimators[j].SetBool("hidden", true);
					orbAnimators[j].SetBool("spawned", false);
				}
			}
		}

		public Material SelectOrbMaterial(OrbController.OrbType orb)
		{
			return (Material)(orb switch
			{
				OrbController.OrbType.RED => LeeHyperrealAssets.redOrbMat, 
				OrbController.OrbType.YELLOW => LeeHyperrealAssets.yellowOrbMat, 
				OrbController.OrbType.BLUE => LeeHyperrealAssets.blueOrbMat, 
				_ => null, 
			});
		}

		private void HandleBulletUIChange()
		{
			if (Object.op_Implicit((Object)(object)IncomingExtraParryBullet) && Object.op_Implicit((Object)(object)IncomingParryBullet))
			{
				if (targetBulletState.parryBulletCount > 19)
				{
					IncomingExtraParryBullet.SetActive(true);
				}
				else if (Object.op_Implicit((Object)(object)IncomingExtraParryBullet))
				{
					IncomingExtraParryBullet.SetActive(false);
				}
				if (targetBulletState.parryBulletCount > 4)
				{
					IncomingParryBullet.SetActive(true);
				}
				else
				{
					IncomingParryBullet.SetActive(false);
				}
			}
		}

		internal void UpdateBulletStateTarget(BulletState state)
		{
			targetBulletState = state;
			SetFiringSpeed(state.bulletAnimationSpeed);
		}

		internal void AdvanceBulletState(BulletState state)
		{
			targetBulletState = state;
			SetFiringSpeed(state.bulletAnimationSpeed);
			if (state.isColouredBulletMoving)
			{
				TriggerBulletFire();
			}
			if (state.isEnhancedBulletMoving)
			{
				TriggerParryBulletReload();
			}
		}

		public void InitializeBulletUI()
		{
			Transform transform = powerMeterUIObject.transform;
			trigger = ((Component)transform).gameObject.AddComponent<BulletTriggerComponent>();
			trigger.body = characterBody;
			trigger.uiController = this;
			bulletObjects = new List<GameObject>();
			for (int i = bulletIndex; i <= endBulletIndex; i++)
			{
				bulletObjects.Add(((Component)transform.GetChild(0).GetChild(1).GetChild(i)).gameObject);
			}
			parryBullets = new List<GameObject>();
			for (int j = parryPoweredIndex; j <= endParryPoweredIndex; j++)
			{
				parryBullets.Add(((Component)transform.GetChild(0).GetChild(1).GetChild(j)).gameObject);
			}
			extraParryBullets = new List<GameObject>();
			for (int k = extraParryPoweredIndex; k <= endExtraParryPoweredIndex; k++)
			{
				extraParryBullets.Add(((Component)transform.GetChild(0).GetChild(1).GetChild(k)).gameObject);
			}
			IncomingExtraParryBullet = ((Component)transform.GetChild(0).GetChild(1).GetChild(incomingExtraParryPoweredIndex)).gameObject;
			IncomingParryBullet = ((Component)transform.GetChild(0).GetChild(1).GetChild(incomingParryBulletIndex)).gameObject;
			foreach (GameObject bulletObject in bulletObjects)
			{
				bulletObject.SetActive(false);
			}
			foreach (GameObject parryBullet in parryBullets)
			{
				parryBullet.SetActive(false);
			}
			foreach (GameObject extraParryBullet in extraParryBullets)
			{
				extraParryBullet.SetActive(false);
			}
			IncomingExtraParryBullet.SetActive(false);
			IncomingParryBullet.SetActive(false);
		}

		public void TriggerBulletFire()
		{
			if (Object.op_Implicit((Object)(object)meterAnimator))
			{
				meterAnimator.SetTrigger("Fire Bullet");
			}
		}

		public void TriggerParryBulletReload()
		{
			if (Object.op_Implicit((Object)(object)meterAnimator))
			{
				meterAnimator.SetTrigger("Fire Enhance Bullet");
			}
		}

		public void SetFiringSpeed(float firingSpeed)
		{
			if (Object.op_Implicit((Object)(object)meterAnimator))
			{
				meterAnimator.SetFloat("firing speed", firingSpeed);
			}
		}

		public void SetBulletStates(List<BulletController.BulletType> bulletTypes)
		{
			//IL_002b: Unknown result type (might be due to invalid IL or missing references)
			//IL_0030: Unknown result type (might be due to invalid IL or missing references)
			if (baseAIPresent || !isInitialized || failedToInitialize)
			{
				return;
			}
			AnimatorStateInfo currentAnimatorStateInfo = meterAnimator.GetCurrentAnimatorStateInfo(1);
			if (((AnimatorStateInfo)(ref currentAnimatorStateInfo)).IsName("Fire Bullet"))
			{
				return;
			}
			if (bulletTypes.Count <= 5)
			{
				for (int i = 0; i < bulletTypes.Count; i++)
				{
					SetBulletType(bulletObjects[i], bulletTypes[i]);
				}
			}
			else
			{
				for (int j = 0; j < 5; j++)
				{
					SetBulletType(bulletObjects[j], bulletTypes[j]);
				}
			}
			for (int k = 0; k < bulletObjects.Count; k++)
			{
				bulletObjects[k].SetActive(k < bulletTypes.Count);
			}
		}

		public void SetBulletType(GameObject bullet, BulletController.BulletType type)
		{
			switch (type)
			{
			case BulletController.BulletType.RED:
				bullet.SetActive(true);
				((Component)bullet.transform.GetChild(0)).gameObject.SetActive(true);
				((Component)bullet.transform.GetChild(1)).gameObject.SetActive(false);
				((Component)bullet.transform.GetChild(2)).gameObject.SetActive(false);
				break;
			case BulletController.BulletType.BLUE:
				bullet.SetActive(true);
				((Component)bullet.transform.GetChild(0)).gameObject.SetActive(false);
				((Component)bullet.transform.GetChild(1)).gameObject.SetActive(true);
				((Component)bullet.transform.GetChild(2)).gameObject.SetActive(false);
				break;
			case BulletController.BulletType.YELLOW:
				bullet.SetActive(true);
				((Component)bullet.transform.GetChild(0)).gameObject.SetActive(false);
				((Component)bullet.transform.GetChild(1)).gameObject.SetActive(false);
				((Component)bullet.transform.GetChild(2)).gameObject.SetActive(true);
				break;
			}
		}

		public void SetEnhancedBulletState(int bulletCount)
		{
			if (baseAIPresent || !isInitialized || failedToInitialize)
			{
				return;
			}
			if (bulletCount < 6)
			{
				foreach (GameObject extraParryBullet in extraParryBullets)
				{
					extraParryBullet.SetActive(false);
				}
				for (int i = 0; i < parryBullets.Count; i++)
				{
					parryBullets[i].SetActive(i < bulletCount);
				}
				return;
			}
			foreach (GameObject parryBullet in parryBullets)
			{
				parryBullet.SetActive(true);
			}
			for (int j = 0; j < extraParryBullets.Count; j++)
			{
				extraParryBullets[j].SetActive(j < bulletCount - 5);
			}
		}

		public void TriggerUpdateOnEnhanced()
		{
			SetEnhancedBulletState(targetBulletState.parryBulletCount);
		}

		public void TriggerUpdateOnColour()
		{
			SetBulletStates(targetBulletState.bulletTypes);
		}

