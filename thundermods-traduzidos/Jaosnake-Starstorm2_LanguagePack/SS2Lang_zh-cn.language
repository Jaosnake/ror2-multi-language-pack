        "SS2_ELITE_AFFIXGILDED_PICKUP": "成为普罗维登斯的门徒。",
        "SS2_ITEM_SCRAPFROMCHEST_NAME": "额外废料",
        "SS2_HERO_BODY_SUBTITLE": "堡垒幽影",
        "SS2_ACHIEVEMENT_MALICE_DESC": "Complete the Stage 3 Teleporter Event on Typhoon difficulty.",
        "SS2_ITEM_STRANGECAN_DESC": "命中时有<style=cIsDamage>{0}%</style><style=cStack>(每层+{1}%)</style>的几率<style=cIsDamage>致醉</style>敌人,每秒造成<style=cIsDamage>{2}%伤害</style>。<style=cIsDamage>致醉</style>效果最多可叠加10层。击杀敌人时,根据其身上的<style=cIsDamage>致醉</style>层数<style=cIsHealing>回复生命值</style>,每层<style=cIsHealing>回复</style><style=cIsHealing>{3}</style><style=cStack>(每层+{4})</style><style=cIsHealing>点生命值</style>。",
        "SS2_SKIN_NEMCOMMANDO_GRANDMASTERY": "米努阿诺",
