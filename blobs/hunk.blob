				int num = inventory.GetItemCountPermanent(Hunk.gVirusSample) + inventory.GetItemCountPermanent(Hunk.tVirusSample) + inventory.GetItemCountPermanent(Hunk.cVirusSample) + inventory.GetItemCountPermanent(Hunk.uroborosSample) + inventory.GetItemCountPermanent(Hunk.plagasSample);
				if (num >= cost)
