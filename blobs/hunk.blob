		public class HunkGaugeSkillDef : SkillDef
		{
			protected class InstanceData : BaseSkillInstanceData
			{
				public HunkController hunk;
			}

			public override BaseSkillInstanceData OnAssigned([NotNull] GenericSkill skillSlot)
			{
				return (BaseSkillInstanceData)(object)new InstanceData
				{
					hunk = ((Component)skillSlot).GetComponent<HunkController>()
				};
			}

			private static bool IsFull([NotNull] GenericSkill skillSlot)
			{
				HunkController hunk = ((InstanceData)(object)skillSlot.skillInstanceData).hunk;
				if (!Object.op_Implicit((Object)(object)hunk))
				{
					return false;
				}
				return hunk.gauge >= hunk.maxGauge;
			}

			public override bool CanExecute([NotNull] GenericSkill skillSlot)
			{
				return IsFull(skillSlot) && ((SkillDef)this).CanExecute(skillSlot);
			}

			public override bool IsReady([NotNull] GenericSkill skillSlot)
			{
				return ((SkillDef)this).IsReady(skillSlot) && IsFull(skillSlot);
			}
		}
