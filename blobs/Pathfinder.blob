		public override void InitializeSkins()
		{
			//IL_0143: Unknown result type (might be due to invalid IL or missing references)
			//IL_015f: Unknown result type (might be due to invalid IL or missing references)
			//IL_0161: Unknown result type (might be due to invalid IL or missing references)
			GameObject gameObject = ((Component)bodyPrefab.GetComponentInChildren<ModelLocator>().modelTransform).gameObject;
			CharacterModel component = gameObject.GetComponent<CharacterModel>();
			ModelSkinController val = gameObject.AddComponent<ModelSkinController>();
			ChildLocator component2 = gameObject.GetComponent<ChildLocator>();
			SkinnedMeshRenderer mainSkinnedMeshRenderer = component.mainSkinnedMeshRenderer;
			RendererInfo[] baseRendererInfos = component.baseRendererInfos;
			List<SkinDef> list = new List<SkinDef>();
			SkinDef val2 = Skins.CreateSkinDef("BOG_SQUALL_BODY_DEFAULT_SKIN_NAME", PathfinderAssets.mainAssetBundle.LoadAsset<Sprite>("texMainSkin"), baseRendererInfos, mainSkinnedMeshRenderer, gameObject);
			string text = "mesh";
			val2.meshReplacements = Skins.getMeshReplacements(baseRendererInfos, text + "Squall");
			list.Add(val2);
			Material val3 = Materials.CreateHopooMaterial("matHeadhunter");
			Material[] array = (Material[])(object)new Material[baseRendererInfos.Length];
			for (int i = 0; i < array.Length; i++)
			{
				array[i] = val3;
			}
			RendererInfo[] rendererMaterials = Skins.getRendererMaterials(baseRendererInfos, array);
			SkinDef val4 = Skins.CreateSkinDef("BOG_SQUALL_BODY_MASTERY_SKIN_NAME", PathfinderAssets.mainAssetBundle.LoadAsset<Sprite>("texMasteryAchievement"), rendererMaterials, mainSkinnedMeshRenderer, gameObject, null);
			string text2 = "HeadHunter";
			val4.meshReplacements = Skins.getMeshReplacements(rendererMaterials, text2 + "Squall");
			val4.rendererInfos[0].defaultMaterial = val3;
			HHSquallSkin = val4;
			MinionSkinReplacement hHSquallReplacements = default(MinionSkinReplacement);
			hHSquallReplacements.minionBodyPrefab = bodyPrefab;
			hHSquallReplacements.minionSkin = val4;
			HHSquallReplacements = hHSquallReplacements;
			list.Add(val4);
			val.skins = list.ToArray();
		}
	}
}
namespace Pathfinder.Modules.Survivors
