					barrier2Fill.fillAmount = fillAmount;
					float num8 = Mathf.Clamp(Util.Remap(healthComponent.fullCombinedHealth / cursePenalty, healthComponent.fullCombinedHealth, 1f, 0f, 1f), 0f, 1f);
