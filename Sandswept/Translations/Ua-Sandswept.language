        "SANDSWEPT_VOID_SHRINE_RUIN_NAME": "Вівтар Руїни",
        "SANDSWEPT_VOID_SHRINE_RUIN_CONTEXT": "Пожертвувати Вівтарю Руїни",
        "SANDSWEPT_VOID_SHRINE_RUIN_USE_MESSAGE_2P": "<style=cShrine>Корупція поширюється.</color>",
        "SANDSWEPT_VOID_SHRINE_RUIN_USE_MESSAGE": "<style=cShrine>Корупція поширюється.</color>",
        "SANDSWEPT_SHRINE_OF_RUIN_DESCRIPTION": "При активації бійцем Вівтар Руїни споживає 10 випадкових білих предметів з інвентарю та псує наступний етап.",

        "SANDSWEPT_SHRINE_SACRIFICE_NAME": "Вівтар Жертвоприношення",
        "SANDSWEPT_SHRINE_SACRIFICE_CONTEXT": "Пожертвувати Вівтарю Жертвоприношення",
        "SANDSWEPT_SHRINE_SACRIFICE_USE_MESSAGE_2P": "<style=cShrine>Ваш час було пожертвувано.</color>",
