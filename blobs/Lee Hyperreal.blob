		private static GameObject ModifyEffect(GameObject newEffect, string soundName, bool parentToTransform, float duration, VFXPriority priority = 2, bool shouldNotPool = false)
		{
			//IL_0064: Unknown result type (might be due to invalid IL or missing references)
			//IL_0066: Unknown result type (might be due to invalid IL or missing references)
			DestroyOnTimer component = newEffect.GetComponent<DestroyOnTimer>();
			if (!Object.op_Implicit((Object)(object)component))
			{
				newEffect.AddComponent<DestroyOnTimer>().duration = duration;
			}
			NetworkIdentity component2 = newEffect.GetComponent<NetworkIdentity>();
			if (!Object.op_Implicit((Object)(object)component2))
			{
				component2 = newEffect.AddComponent<NetworkIdentity>();
			}
			VFXAttributes val = newEffect.GetComponent<VFXAttributes>();
			if (!Object.op_Implicit((Object)(object)val))
			{
				val = newEffect.AddComponent<VFXAttributes>();
			}
			val.vfxPriority = priority;
			val.DoNotPool = shouldNotPool;
			EffectComponent val2 = newEffect.GetComponent<EffectComponent>();
			if (!Object.op_Implicit((Object)(object)val2))
			{
				val2 = newEffect.AddComponent<EffectComponent>();
			}
			val2.applyScale = true;
			val2.parentToReferencedTransform = parentToTransform;
			val2.positionAtReferencedTransform = true;
			val2.soundName = soundName;
			AddNewEffectDef(newEffect, soundName);
			return newEffect;
		}

