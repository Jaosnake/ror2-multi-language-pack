{
    "zh-CN": {
        "BOG_DEPUTY_BODY_NAME": "副警长",
        "BOG_DEPUTY_BODY_DESCRIPTION": "副警长是一名超激进的极速恶魔,用她的双持左轮手枪和致命踢技来伸张正义。",
        "BOG_DEPUTY_BODY_SUBTITLE": "闪电正义",
        "BOG_DEPUTY_BODY_OUTRO_FLAVOR": "..于是她离去了,在雷鸣般的掌声中。",
        "BOG_DEPUTY_BODY_OUTRO_FAILURE": "..于是她消失了,她的表演终于落下了帷幕。",
        "BOG_DEPUTY_BODY_DEFAULT_SKIN_NAME": "默认",
        "BOG_DEPUTY_BODY_MASTERY_SKIN_NAME": "精通",
        "BOG_DEPUTY_BODY_PASSIVE_NAME": "不懈追击",
        "BOG_DEPUTY_BODY_PASSIVE_DESCRIPTION": "副警长可以向任何方向冲刺。用技能击中敌人会获得可叠加的<style=cIsUtility>移动速度</style>增益。",
        "BOG_DEPUTY_BODY_PRIMARY_SHOOT_NAME": "精准射击",
        "BOG_DEPUTY_BODY_PRIMARY_SHOOT_DESCRIPTION": "<style=cIsUtility>灵巧</style>。用中距离左轮手枪射击,造成<style=cIsDamage>150%伤害</style>。",
        "BOG_DEPUTY_BODY_SECONDARY_SLING_NAME": "投掷",
        "BOG_DEPUTY_BODY_SECONDARY_SLING_DESCRIPTION": "<style=cIsUtility>灵巧</style>。投掷两把左轮手枪。每把左轮手枪会射击附近的敌人造成<style=cIsDamage>6x100%伤害</style>,然后爆炸造成<style=cIsDamage>300%伤害</style>。",
        "BOG_DEPUTY_BODY_UTILITY_SHOOTINGSTAR_NAME": "流星",
        "BOG_DEPUTY_BODY_UTILITY_SHOOTINGSTAR_DESCRIPTION": "<style=cIsDamage>眩晕</style>。向前跳跃并向身下的敌人射击,造成<style=cIsDamage>4x150%伤害</style>。",
        "BOG_DEPUTY_BODY_SPECIAL_SKULLBREAKER_NAME": "碎颅者",
        "BOG_DEPUTY_BODY_SPECIAL_SKULLBREAKER_DESCRIPTION": "<style=cIsUtility>沉重</style>。<style=cIsUtility>猛冲</style>并从敌人身上弹开,造成<style=cIsDamage>800%伤害</style>。<style=cIsUtility>击杀重置你的辅助技能冷却时间</style>。",
        "BOG_DEPUTY_BODY_SPECIAL_BULLETHEAVEN_NAME": "弹幕天堂",
        "BOG_DEPUTY_BODY_SPECIAL_BULLETHEAVEN_DESCRIPTION": "高高跃入空中,疯狂向下倾泻子弹,每发造成<style=cIsDamage>150%伤害</style>。射击次数随攻击速度提升。",
        "BOG_DEPUTY_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_NAME": "The Deputy: Mastery",
        "BOG_DEPUTY_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_DESC": "作为副手，击败游戏或消灭季风。",
        "BOG_DEPUTY_BODY_MASTERYUNLOCKABLE_UNLOCKABLE_NAME": "副手：精通"
    }
}
