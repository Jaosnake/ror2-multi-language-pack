			//IL_0036: Expected O, but got Unknown
			Run.Start += new hook_Start(ChangeStageOrderToRandom);
			BazaarController.SetUpSeerStations += new hook_SetUpSeerStations(ChangeSeersToRandom);
			SceneDirector.PlaceTeleporter += new hook_PlaceTeleporter(ChangeTeleporter);
		}

		private void ChangeTeleporter(orig_PlaceTeleporter orig, SceneDirector self)
		{
			if (base.ArtifactEnabled && (Object)(object)self.teleporterSpawnCard != (Object)null)
			{
				if (Run.instance.NetworkstageClearCount % 5 == 4)
				{
					self.teleporterSpawnCard = (SpawnCard)(object)LegacyResourcesAPI.Load<InteractableSpawnCard>(TeleporterNames[0]);
				}
				else
				{
					self.teleporterSpawnCard = (SpawnCard)(object)LegacyResourcesAPI.Load<InteractableSpawnCard>(TeleporterNames[1]);
				}
			}
			orig.Invoke(self);
		}

		private void ChangeSeersToRandom(orig_SetUpSeerStations orig, BazaarController self)
		{
			//IL_0034: Unknown result type (might be due to invalid IL or missing references)
			if (base.ArtifactEnabled)
			{
				SceneDef nextStageScene = Run.instance.nextStageScene;
				List<SceneDef> list = new List<SceneDef>();
				if ((Object)(object)nextStageScene != (Object)null)
				{
					int stageOrder = nextStageScene.stageOrder;
					list = new List<SceneDef>((IEnumerable<SceneDef>)(object)SceneCatalog.allSceneDefs).Where((SceneDef sd) => sd.destinationsGroup.sceneEntries.Length > 0 && (!Object.op_Implicit((Object)(object)sd.requiredExpansion) || Run.instance.IsExpansionEnabled(sd.requiredExpansion))).ToList();
				}
				SeerStationController[] seerStations = self.seerStations;
				foreach (SeerStationController val in seerStations)
				{
					if (list.Count == 0)
					{
						((Component)val).GetComponent<PurchaseInteraction>().SetAvailable(false);
						continue;
					}
					Util.ShuffleList<SceneDef>(list, self.rng);
					int index = list.Count - 1;
					SceneDef targetScene = list[index];
					list.RemoveAt(index);
					if (self.rng.nextNormalizedFloat < 0.05f)
					{
						targetScene = SceneCatalog.GetSceneDefFromSceneName("goldshores");
					}
					val.SetTargetScene(targetScene);
				}
			}
			else
			{
				orig.Invoke(self);
			}
		}

		private void ChangeStageOrderToRandom(orig_Start orig, Run self)
		{
			if (base.ArtifactEnabled)
			{
				self.ruleBook.ApplyChoice(RuleCatalog.FindChoiceDef("Misc.StageOrder.Random"));
			}
			orig.Invoke(self);
		}
	}
