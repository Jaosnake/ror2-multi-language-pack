	internal class TheWorld : BaseCardSkill
	{
		public override void OnEnter()
		{
			cardTypeActivationVFX = Assets.NeutralCardActivation;
			cardSweepVFX = Assets.CardSweepNeutral;
			base.OnEnter();
			cardActivationVFX = Assets.VFXcardTheWorld;
			cardActivationSFX = "House_Shuffle";
			if (!((EntityState)this).isAuthority || isCombo)
			{
				return;
			}
			for (int i = 0; i < 3; i++)
			{
				int num = passiveManager.handCards[i];
				if (num == 25 || num == 26 || num == 27 || num == 28)
				{
					passiveManager.handCards[i] = 0;
				}
			}
			passiveManager.gameDeck.RemoveAll(isCardIDs);
			passiveManager.gameDeckDiscardPile.RemoveAll(isCardIDs);
			passiveManager.NextHand();
		}

		private static bool isCardIDs(int input)
		{
