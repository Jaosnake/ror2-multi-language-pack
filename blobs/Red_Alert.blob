	public static class ChronoCompat
	{
		public static bool AutoSprintInstalled;

		[MethodImpl(MethodImplOptions.NoInlining | MethodImplOptions.NoOptimization)]
		public static void Init()
		{
			if (GeneralCompat.driverInstalled)
			{
				new ChronoDriverCompat().Init();
			}
			if (AutoSprintInstalled = Chainloader.PluginInfos.ContainsKey("com.johnedwa.RTAutoSprintEx"))
			{
				((MonoBehaviour)RA2Plugin.instance).StartCoroutine(AutoSprintCompat());
			}
			if (Chainloader.PluginInfos.ContainsKey("com.weliveinasociety.CustomEmotesAPI"))
			{
				ChronoMemeCompat.init();
			}
		}

		private static IEnumerator AutoSprintCompat()
		{
			yield return null;
			((Component)RA2Plugin.instance).GetComponent<RTAutoSprintEx>().RT_SprintDisableMessage("RA2Mod.Survivors.Chrono.States.ChronoCharacterMain");
			((Component)RA2Plugin.instance).GetComponent<RTAutoSprintEx>().RT_SprintDisableMessage("RA2Mod.Survivors.Chrono.States.PhaseState");
			((Component)RA2Plugin.instance).GetComponent<RTAutoSprintEx>().RT_SprintDisableMessage("RA2Mod.Survivors.Chrono.States.AimChronosphere1");
			((Component)RA2Plugin.instance).GetComponent<RTAutoSprintEx>().RT_SprintDisableMessage("RA2Mod.Survivors.Chrono.States.AimChronosphere2");
			((Component)RA2Plugin.instance).GetComponent<RTAutoSprintEx>().RT_SprintDisableMessage("RA2Mod.Survivors.Chrono.States.PlaceChronosphere2");
		}
	}
