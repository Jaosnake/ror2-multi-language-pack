{
    "FR": {
        "POPCORN_ARSONIST_BODY_NAME": "Arsoniste",
        "POPCORN_ARSONIST_BODY_SUBTITLE": "Pyromane Maniaque",
        "POPCORN_ARSONIST_BODY_PASSIVE_NORMAL_GAUGE_NAME": "Jauge Normale",
        "POPCORN_ARSONIST_BODY_PASSIVE_NORMAL_GAUGE_DESCRIPTION": "Inflige <style=cIsDamage>100%</style> de dégâts sur la portion blanche. La Jauge de Base résiste à la Surchauffe.",
        "POPCORN_ARSONIST_BODY_PASSIVE_BLUE_GAUGE_NAME": "Jauge Critique",
        "POPCORN_ARSONIST_BODY_PASSIVE_BLUE_GAUGE_DESCRIPTION": "Inflige <style=cIsDamage>70%</style> de dégâts sur la portion blanche et <style=cIsDamage>250%</style> de dégâts sur la portion bleue. La chaleur maximale est fixe.",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_NAME": "Le Souffle du Dragon",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_DESCRIPTION": "Tire un rayon de flammes infligeant <style=cIsDamage>90% de dégâts</style>. Chance d'ignition augmentée plus vous êtes proche de la cible.",
        "POPCORN_ARSONIST_BODY_PRIMARY_FIRESPRAY_NAME": "Boule de feu",
        "POPCORN_ARSONIST_BODY_PRIMARY_FIRESPRAY_DESCRIPTION": "<style=cIsUtility>Chaleur. </style>Tire une boule de feu qui inflige <style=cIsDamage>225% de dégâts et enflamme</style> les ennemis touchés.",
        "POPCORN_ARSONIST_BODY_SECONDARY_PUNCH_NAME": "Explosion du point zéro",
        "POPCORN_ARSONIST_BODY_SECONDARY_PUNCH_DESCRIPTION": "<style=cIsUtility>Agile. Chaleur. </style>Propulsez-vous vers l'avant, faisant exploser les ennemis derrière vous pour <style=cIsDamage>200 % de dégâts</style>. Entrer en collision immédiatement après le lancement avec le premier ennemi provoque <style=cIsDamage>200 % de dégâts</style> dans une explosion environnante.",
        "POPCORN_ARSONIST_BODY_SECONDARY_FLAREGUN_NAME": "Fusée éclairante",
        "POPCORN_ARSONIST_BODY_SECONDARY_FLAREGUN_DESCRIPTION": "Tire une fusée qui inflige <style=cIsDamage>400% de dégâts</style> sur 5 secondes, puis explose infligeant <style=cIsDamage>400% de dégâts</style>, lançant 5 fusées infligeant <style=cIsDamage>200% de dégâts</style> chacune.",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHIST_NAME": "Masochisme",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHIST_DESCRIPTION": "<style=cIsUtility>Agile. Chaleur. </style>Les dégâts causés par l'allumage de <style=cIsDamage></style> se transforment en <style=cIsHealing>healing</style> pendant 6,5 secondes. Augmente la vitesse d'attaque de <style=cIsDamage>125%</style>.",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_NAME": "Masochisme",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_DESCRIPTION": "En atteignant la limite d'<style=cKeywordName>Anticipation</style>, infligez périodiquement des dégâts à vous-même en échange de <style=cIsHealing>Vol de Vie</style> de zone et de brûlure. Après 10 secondes maximum, <style=cIsDamage>Détonation</style>, puis <style=cIsUtility>Surchauffe</style>.",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_SURGE_NAME": "Dépit",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_SURGE_DESCRIPTION": "En atteignant la limite d'<style=cKeywordName>Anticipation</style>, vous vous déplacez plus vite et obtenez <style=cKeywordName>Tir Double</style> et <style=cIsHealing>Vol de Vie</style>. Après 10 secondes maximum, <style=cIsDamage>Détonation</style>, puis <style=cIsUtility>Surchauffe</style>.",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_SCEPTER_NAME": "La réprimande de Dante",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_SCEPTER_DESCRIPTION": "Tire un rayon intense infligeant <style=cIsDamage>140% de dégâts</style>. Chance d'ignition augmentée plus vous êtes proche de la cible. Si maintenu 2 secondes ou plus, tire un rayon final au relâchement pour <style=cIsDamage>150% de dégâts</style>.",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_ANTICIPATION": "<style=cKeywordName>Anticipation</style>Pour chaque 100 de chaleur perdue et/ou gagnée, Arsoniste gagne 1 charge d'Anticipation; Après 5 charges, il peut activer Masochisme; Les charges supplémentaires augmentent les dégâts et la durée; Toutes les charges sont consommées à la fin.",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_DETONATE": "<style=cKeywordName>Détonation</style>Arsoniste explose, infligeant <style=cIsDamage>150% de dégâts</style> multiplié par le nombre de Charges d'Anticipation accumulées.",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_LIFESTEAL": "<style=cKeywordName>Vol de Vie</style>Arsoniste soigne <style=cIsHealing>18%</style> des dégâts infligés tant que Masochisme est actif.",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_SURGE_LIFESTEAL": "<style=cKeywordName>Vol de Vie</style>Arsoniste soigne <style=cIsHealing>5%</style> des dégâts infligés tant que Dépit est actif.",
        "POPCORN_ARSONIST_BODY_KEYWORD_OVERHEAT_MASO": "<style=cKeywordName>Surchauffe: Masochisme</style>Si Arsoniste quitte Masochisme à cause d'un excès de chaleur, la Surchauffe EX est appliquée, réduisant sa Vitesse de Déplacement et ses Dégâts à 70%. Annuler ou laisser la compétence suivre son cours applique Surchauffe, réduisant sa Vitesse d'Attaque à 50%.",
        "POPCORN_ARSONIST_BODY_OVERHEAT_TEXT": "SURCHAUFFE!",
        "POPCORN_ARSONIST_BODY_COOLING_TEXT": "REFROIDISSEMENT...!",
        "POPCORN_ARSONIST_BODY_OVERHEAT_EX_TEXT": "SURCHAUFFE:EX!",
        "POPCORN_ARSONIST_BODY_PASSIVE_NAME": "Pyromanie",
        "POPCORN_ARSONIST_BODY_PASSIVE_DESCRIPTION": "Résiste aux dégâts de feu de toutes les sources. Convertit une attaque infligeant plus de <style=cIsDamage>30%</style> de la santé totale en <style=cIsDamage>50%</style> de dégâts de feu sur la durée.",
        "POPCORN_ARSONIST_BODY_KEYWORD_PYROMANIAPASSIVE": "Pyromanie n'affecte pas les dégâts de chute, sauf si Fragilité est active.",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_NAME": "Arsonist: Mastery",
        "ACHIEVEMENT_POPCORN_ARSONIST_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_DESCRIPTION": "As Arsonist, beat the game or obliterate on Monsoon.",
