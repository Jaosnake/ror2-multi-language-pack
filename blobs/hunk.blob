									totalAmmo = BaseWeapon<SMG>.instance.magSize * 6,
									currentAmmo = BaseWeapon<SMG>.instance.magSize
								},
								new HunkWeaponData
								{
									weaponDef = weaponDef,
									totalAmmo = weaponDef.magSize * 2,
									currentAmmo = weaponDef.magSize
								}
