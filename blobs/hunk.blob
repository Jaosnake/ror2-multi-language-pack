								premiumTank.SetActive(false);
								baseTank.SetActive(true);
							}
						}
						else
						{
							regulator.SetActive(false);
							premiumTank.SetActive(false);
							baseTank.SetActive(true);
						}
					}
					else
					{
						regulator.SetActive(false);
						premiumTank.SetActive(false);
						baseTank.SetActive(true);
					}
				}
				else
				{
					regulator.SetActive(false);
					premiumTank.SetActive(false);
					baseTank.SetActive(true);
