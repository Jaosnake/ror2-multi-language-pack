        "ROB_BELMONTKEYCOST": "Dietrich",
        "ROB_BELMONT_KEYFRAGMENT_NAME": "Schlüsselfragment",
        "ROB_BELMONT_KEYFRAGMENT_DESC": "Gebrochenes Stück eines Schlüssels. Sammle 3, um einen ganzen Schlüssel zu bilden.",
        "ROB_BELMONT_KEYFRAGMENT_PICKUP": "Gebrochenes Stück eines Schlüssels. Sammle 3, um einen ganzen Schlüssel zu bilden.",
        "ROB_BELMONT_KEYFRAGMENT_LORE": "",
        "ROB_BELMONT_KEY_NAME": "Dietrich",
        "ROB_BELMONT_KEY_DESC": "Wird verwendet, um eine <color=#FFFF00>Schatztruhe</color> zu öffnen. Diese Truhen enthalten ein <color=#FF0033>heiliges Relikt</color> und erscheinen in jeder <style=cIsUtility>vierten</style> Stufe an einem <style=cIsDamage>festen Ort</style>.",
        "ROB_BELMONT_KEY_PICKUP": "Wird zum Öffnen einer Schatztruhe verwendet. Leuchtet in der Nähe.",
        "ROB_BELMONT_KEY_LORE": "",
        "ROB_BELMONT_MORNINGSTAR_NAME": "Morgenstern",
        "ROB_BELMONT_MORNINGSTAR_DESC": "Jeder Peitschenschlag löst eine <style=cIsUtility>folgende Explosion</style> mit <style=cIsDamage>600 % Schaden</style> aus.",
        "ROB_BELMONT_MORNINGSTAR_PICKUP": "Die Peitsche, die alle vernichten wird, die mit der Sippe der Nacht verwandt sind.",
        "ROB_BELMONT_MORNINGSTAR_LORE": "",
        "ROB_BELMONT_CRISSAEGRIM_NAME": "Crissaegrim",
        "ROB_BELMONT_CRISSAEGRIM_DESC": "Jeder Schwertschwung verursacht <style=cIsUtility>3 zusätzliche Male</style> und verursacht jeweils <style=cIsDamage>300 % Schaden</style>.",
        "ROB_BELMONT_CRISSAEGRIM_PICKUP": "Unzählige Klingen vernichten den Feind.",
        "ROB_BELMONT_CRISSAEGRIM_LORE": "",
        "ROB_BELMONT_WINGEDBOOTS_NAME": "Pegasus-Stiefel",
        "ROB_BELMONT_WINGEDBOOTS_DESC": "Nach <style=cIsUtility>1</style> Sekunden Sprint, während <style=cIsUtility> am Boden liegt</style>, erhalte <style=cIsDamage>12 Bewegungsgeschwindigkeit</style>. Wenn du einen Feind mit <style=cIsDamage>Rush</style> triffst, trittst du ihn <style=cIsUtility>in die Luft</style> und dann weg, was <style=cIsDamage>4x200%</style> und <style=cIsDamage>300%</style> Schaden zufügt.",
        "ROB_BELMONT_WINGEDBOOTS_PICKUP": "Stiefel, die deine sekundären Fähigkeiten verbessern und es dir ermöglichen, wie der Wind zu laufen.",
        "ROB_BELMONT_WINGEDBOOTS_LORE": "",
        "ROB_BELMONT_HOLYCROSS_NAME": "Schal des Erlösers",
        "ROB_BELMONT_HOLYCROSS_DESC": "Ersetzen Sie alle <style=cIsUtility>3</style> Minuten Ihre <style=cIsDamage>Spezialfähigkeit</style> durch <color=#FF0033>Heilige Flamme</color>.",
        "ROB_BELMONT_HOLYCROSS_PICKUP": "Erhalten Sie Zugang zu einem mächtigen ultimativen Angriff.",
        "ROB_BELMONT_HOLYCROSS_LORE": "",
        "ROB_BELMONT_BROTHERSOUL_NAME": "Seele des Königs",
        "ROB_BELMONT_BROTHERSOUL_DESC": "Jeder <style=cIsUtility>Peitschenhieb</style> erzeugt eine <style=cIsDamage>Mondflammensäule</style>, jeder <style=cIsUtility>Schwertschwung</style> erzeugt einen <style=cIsDamage>Mondsplitter</style>, jeder <style=cIsUtility>Peitschenhieb</style> entfesselt <style=cIsDamage>Boden Stoßwellen</style> und jeder <style=cIsUtility>dash</style> erzeugt <style=cIsHealing>20 % Barriere</style>.",
        "ROB_BELMONT_BROTHERSOUL_PICKUP": "Nutzen Sie die Macht des Königs des Nichts als Ihre eigene.",
