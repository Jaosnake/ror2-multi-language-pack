		public override void FixedUpdate()
		{
			((EntityState)this).FixedUpdate();
			((EntityState)this).characterBody.outOfCombatStopwatch = 0f;
			((EntityState)this).characterBody.SetAimTimer(0.2f);
			iDrive.chargeValue = Mathf.Clamp01(((EntityState)this).fixedAge / duration);
			if (!cancelling && ((EntityState)this).isAuthority)
			{
				if (((EntityState)this).fixedAge >= duration)
				{
					cancelling = true;
				}
				if (((EntityState)this).fixedAge >= minChargeDuration && !IsKeyDownAuthority())
				{
					cancelling = true;
				}
				if (cancelling)
				{
					((EntityState)this).outer.SetNextState((EntityState)(object)new ThrowBomb
					{
						charge = iDrive.chargeValue
					});
				}
			}
		}

