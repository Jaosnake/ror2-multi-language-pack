{
    "ja": {
        "POPCORN_ARSONIST_BODY_NAME": "アーソニスト",
        "POPCORN_ARSONIST_BODY_SUBTITLE": "マニアックな放火狂",
        "POPCORN_ARSONIST_BODY_PASSIVE_NORMAL_GAUGE_NAME": "通常ゲージ",
        "POPCORN_ARSONIST_BODY_PASSIVE_NORMAL_GAUGE_DESCRIPTION": "白い部分に<style=cIsDamage>100%</style>のダメージを与える。基本ゲージは過熱に耐性がある。",
        "POPCORN_ARSONIST_BODY_PASSIVE_BLUE_GAUGE_NAME": "クリティカルゲージ",
        "POPCORN_ARSONIST_BODY_PASSIVE_BLUE_GAUGE_DESCRIPTION": "白い部分に<style=cIsDamage>70%</style>、青い部分に<style=cIsDamage>250%</style>のダメージを与える。最大熱量は固定。",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_NAME": "Dragon's Breath",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_DESCRIPTION": "炎のビームを発射し<style=cIsDamage>90%ダメージ</style>を与える。目標に近いほど着火確率が上昇。",
        "POPCORN_ARSONIST_BODY_PRIMARY_FIRESPRAY_NAME": "Fireball",
        "POPCORN_ARSONIST_BODY_PRIMARY_FIRESPRAY_DESCRIPTION": "<style=cIsUtility>熱量。</style>火の玉を発射し、命中時に<style=cIsDamage>225%ダメージと着火</style>を与える。",
        "POPCORN_ARSONIST_BODY_SECONDARY_PUNCH_NAME": "Zero Point Blast",
        "POPCORN_ARSONIST_BODY_SECONDARY_PUNCH_DESCRIPTION": "<style=cIsUtility>敏捷。熱量。</style>前方に推進し、後方の敵を爆発させ<style=cIsDamage>200%ダメージ</style>を与える。発射直後に最初の敵に衝突すると周囲に爆発を起こし<style=cIsDamage>200%ダメージ</style>。",
        "POPCORN_ARSONIST_BODY_SECONDARY_FLAREGUN_NAME": "信号銃",
        "POPCORN_ARSONIST_BODY_SECONDARY_FLAREGUN_DESCRIPTION": "信号弾を発射し、5秒間で<style=cIsDamage>400%ダメージ</style>を与え、その後爆発して<style=cIsDamage>400%ダメージ</style>、5つの信号弾を放ちそれぞれ<style=cIsDamage>200%ダメージ</style>。",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHIST_NAME": "Masochism",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHIST_DESCRIPTION": "<style=cIsUtility>敏捷。熱量。</style><style=cIsDamage>着火</style>によるダメージが<style=cIsHealing>回復</style>に変わる(6.5秒間)。攻撃速度が<style=cIsDamage>125%</style>上昇。",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_NAME": "マゾヒズãƒ",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_DESCRIPTION": "<style=cKeywordName>予測</style>限界に達すると、定期的に自分にダメージを与え、代わりに範囲<style=cIsHealing>ライフスティール</style>と火傷を得る。最大10秒後、<style=cIsDamage>爆発</style>、その後<style=cIsUtility>過熱</style>。",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_SURGE_NAME": "遺恨",
        "POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_SURGE_DESCRIPTION": "<style=cKeywordName>予測</style>限界に達すると、移動が速くなり、<style=cKeywordName>二重射撃</style>と<style=cIsHealing>ライフスティール</style>を得る。最大10秒後、<style=cIsDamage>爆発</style>、その後<style=cIsUtility>過熱</style>。",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_SCEPTER_NAME": "Dante's Rebuke",
        "POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_SCEPTER_DESCRIPTION": "強力なビームを発射し<style=cIsDamage>140%ダメージ</style>を与える。目標に近いほど着火確率が上昇。2秒以上溜めると、離した時に最終ビームを発射し<style=cIsDamage>150%ダメージ</style>。",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_ANTICIPATION": "<style=cKeywordName>予測</style>100の熱量を失うか得るごとに、アーソニストは予測チャージを1获得;5チャージ獲得後、マゾヒズムを発動可能;追加チャージはダメージと持続時間を増加;終了時に全チャージを消費。",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_DETONATE": "<style=cKeywordName>爆発</style>アーソニストが爆発し、蓄積された予測チャージ数×<style=cIsDamage>150%ダメージ</style>。",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_LIFESTEAL": "<style=cKeywordName>ライフスティール</style>アーソニストはマゾヒズム発動中、与ダメージの<style=cIsHealing>18%</style>を回復。",
        "POPCORN_ARSONIST_BODY_KEYWORD_MASO_SURGE_LIFESTEAL": "<style=cKeywordName>ライフスティール</style>アーソニストは遺恨発動中、与ダメージの<style=cIsHealing>5%</style>を回復。",
        "POPCORN_ARSONIST_BODY_KEYWORD_OVERHEAT_MASO": "<style=cKeywordName>過熱:マゾヒズム</style>アーソニストが過剰な熱量蓄積によりマゾヒズムを離脱した場合、EX過熱が適用され、移動速度とダメージが70%に低下。キャンセルまたはスキルを完了させると過熱が適用され、攻撃速度が50%に低下。",
        "POPCORN_ARSONIST_BODY_OVERHEAT_TEXT": "過熱!",
        "POPCORN_ARSONIST_BODY_COOLING_TEXT": "冷却中...!",
        "POPCORN_ARSONIST_BODY_OVERHEAT_EX_TEXT": "過熱:EX!"
    }
}
