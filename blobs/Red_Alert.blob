	internal class DesolatorSkillsPlusCompat
	{
		[SkillLevelModifier("Desolator_Primary_Beam", new Type[] { typeof(RadBeam) })]
		internal class DesolatorPrimaryModifier : BaseSkillModifier
		{
			public override void OnSkillEnter(BaseState skillState, int level)
			{
				((BaseSkillModifier)this).OnSkillEnter(skillState, level);
				if (skillState is RadBeam radBeam)
				{
					radBeam.skillsPlusDurationMultiplier = BaseSkillModifier.MultScaling(1f, -0.1f, level);
				}
			}
		}

		[MethodImpl(MethodImplOptions.NoInlining | MethodImplOptions.NoOptimization)]
		public static void init()
		{
			SkillModifierManager.LoadSkillModifiers();
		}
	}
