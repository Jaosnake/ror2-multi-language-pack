			public HunkWeaponDef weaponDef;

			public GameObject pickupEffect;

			public bool cutAmmo = false;

			public bool isAmmoBox = false;

			private bool alive = true;

			private void Awake()
			{
				BeginRapidlyActivatingAndDeactivating componentInChildren = ((Component)((Component)this).transform.parent).GetComponentInChildren<BeginRapidlyActivatingAndDeactivating>();
				if (!Object.op_Implicit((Object)(object)componentInChildren))
				{
					return;
				}
				bool flag = false;
				ReadOnlyCollection<LocalUser> readOnlyLocalUsersList = LocalUserManager.readOnlyLocalUsersList;
				foreach (LocalUser item in readOnlyLocalUsersList)
				{
					if (item.cachedBody.baseNameToken == Hunk.bodyNameToken)
					{
						flag = true;
					}
				}
				if (!flag)
				{
					componentInChildren.blinkingRootObject.SetActive(false);
					Object.Destroy((Object)(object)componentInChildren);
				}
			}

			private void Start()
			{
				SetWeapon(weaponDef, cutAmmo, isAmmoBox);
			}

			public void ServerSetWeapon(HunkWeaponDef newWeaponDef)
			{
				//IL_0033: Unknown result type (might be due to invalid IL or missing references)
				weaponDef = newWeaponDef;
				if (NetworkServer.active)
				{
					NetworkIdentity componentInChildren = ((Component)((Component)this).transform.root).GetComponentInChildren<NetworkIdentity>();
					if (Object.op_Implicit((Object)(object)componentInChildren))
					{
						NetMessageExtensions.Send((INetMessage)(object)new SyncWeaponPickup(componentInChildren.netId, weaponDef.index, cutAmmo), (NetworkDestination)1);
					}
				}
			}

			public void SetWeapon(HunkWeaponDef newWeapon, bool _cutAmmo = false, bool _isAmmoBox = false)
			{
				//IL_008b: Unknown result type (might be due to invalid IL or missing references)
				//IL_0076: Unknown result type (might be due to invalid IL or missing references)
				weaponDef = newWeapon;
				cutAmmo = _cutAmmo;
				isAmmoBox = _isAmmoBox;
				LanguageTextMeshController componentInChildren = ((Component)((Component)this).transform.parent).GetComponentInChildren<LanguageTextMeshController>();
				if (!Object.op_Implicit((Object)(object)componentInChildren))
				{
					return;
				}
				if (!Object.op_Implicit((Object)(object)weaponDef))
				{
					componentInChildren.token = "FUCK YOU FUCK YOU FUCK/nYOU FUCK YOU FUCK YOU";
					return;
				}
				componentInChildren.token = weaponDef.nameToken;
				if (cutAmmo)
				{
					((Graphic)componentInChildren.textMeshPro).color = Helpers.badColor;
				}
				else
				{
					((Graphic)componentInChildren.textMeshPro).color = Helpers.yellowItemColor;
				}
			}

			private void OnTriggerStay(Collider collider)
			{
				//IL_0055: Unknown result type (might be due to invalid IL or missing references)
				//IL_005a: Unknown result type (might be due to invalid IL or missing references)
				if (NetworkServer.active && alive)
				{
					HunkController component = ((Component)collider).GetComponent<HunkController>();
					if (Object.op_Implicit((Object)(object)component))
					{
						alive = false;
						component.ServerPickUpWeapon(weaponDef, cutAmmo, component, isAmmoBox);
						EffectManager.SimpleEffect(pickupEffect, ((Component)this).transform.position, Quaternion.identity, true);
						Object.Destroy((Object)(object)baseObject);
					}
				}
			}
		}
