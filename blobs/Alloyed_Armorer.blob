	[BepInPlugin("com.Tatertotticus.ArmorerMod", "ArmorerMod", "0.5.1")]
	public class ArmorerPlugin : BaseUnityPlugin
	{
		public const string MODUID = "com.Tatertotticus.ArmorerMod";

		public const string MODNAME = "ArmorerMod";

		public const string MODVERSION = "0.5.1";

		public const string DEVELOPER_PREFIX = "Tatertotticus";

		public static ArmorerPlugin instance;

		private void Awake()
		{
			instance = this;
			Log.Init(((BaseUnityPlugin)this).Logger);
			Language.Init();
			new ArmorerSurvivor().Initialize();
			new ContentPacks().Initialize();
		}
	}
