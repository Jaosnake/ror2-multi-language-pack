				if (context.activatorMaster.inventory.GetItemCountPermanent(Hunk.gVirusSample) > 0)
				{
					context.activatorMaster.inventory.RemoveItemPermanent(Hunk.gVirusSample, 1);
					Helpers.CreateItemTakenOrb(context.activatorBody.corePosition, context.purchasedObject, Hunk.gVirusSample.itemIndex);
					Helpers.TryPlayTerminalAnimation(context.purchasedObject);
				}
				else if (context.activatorMaster.inventory.GetItemCountPermanent(Hunk.tVirusSample) > 0)
				{
					context.activatorMaster.inventory.RemoveItemPermanent(Hunk.tVirusSample, 1);
