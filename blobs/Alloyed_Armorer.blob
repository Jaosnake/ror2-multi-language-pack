		{
			Content.AddEntityState(typeof(Blaster));
			Content.AddEntityState(typeof(SuperDreadnoughtRailCannonGustavMax));
			Content.AddEntityState(typeof(Thruster));
			Content.AddEntityState(typeof(PulseEmitter));
			Content.AddEntityState(typeof(NanoMachines));
		}
	}
