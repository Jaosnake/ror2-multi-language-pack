        "ROB_DRIVER_BODY_SECONDARY_NEMMANDO_NAME": "Soumission",
        "ROB_DRIVER_BODY_SECONDARY_NEMMANDO_DESCRIPTION": "<style=cIsDamage>Superbe</style>. Tirez à plusieurs reprises pour 6x250 % de dégâts par tir. Le nombre de tirs augmente avec la vitesse d'attaque.</i>",
        "ROB_DRIVER_BODY_SECONDARY_NEMMERC_NAME": "Frapper",
