				if (newSkillUsed != null && lastSkillUsed != null && ((object)newSkillUsed).GetType().Name != ((object)lastSkillUsed).GetType().Name && prevTime != -1f && prevTime < comboTime)
				{
					repeatTimer = 0f;
					isInCombo = true;
					prevTime = -1f;
					if (growthBuffCount < maxBuffStacks)
					{
						body.AddBuff(Buffs.damageGrowth);
					}
				}
				if (repeatTimer > comboTime && body.GetBuffCount(Buffs.damageGrowth) > 0)
				{
					comboTimer += Time.fixedDeltaTime;
					RemoveBuffTimed();
				}
			}
			lastSkillUsed = newSkillUsed;
			if (overlayController == null)
			{
				CreateOverlay();
			}
			else
			{
				UpdateValues();
			}
		}

