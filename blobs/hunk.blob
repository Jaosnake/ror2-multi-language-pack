				Hunk.requiredKillsC = 4;
				((MonoBehaviour)this).CancelInvoke();
				switch (Random.Range(0, 4))
				{
				default:
					virusType = VirusType.GVirus;
					break;
				case 0:
					virusType = VirusType.GVirus;
					break;
				case 1:
					virusType = VirusType.TVirus;
					break;
				case 2:
					virusType = VirusType.CVirus;
					break;
				case 3:
					virusType = VirusType.Uroboros;
					break;
				case 4:
					virusType = VirusType.Plagas;
					break;
				}
				if (virusType == VirusType.TVirus)
				{
					Scene activeScene = SceneManager.GetActiveScene();
