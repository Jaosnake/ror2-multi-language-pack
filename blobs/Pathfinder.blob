				val2.color = Color.red;
			}
			CommandTracker.trackerPrefab = val;
			GameObject val3 = PrefabAPI.InstantiateClone(Addressables.LoadAssetAsync<GameObject>((object)"RoR2/Base/Engi/EngiPaintCrosshair.prefab").WaitForCompletion(), "CommandCrosshair");
			Image component = ((Component)val3.transform.Find("Holder").Find("Square")).GetComponent<Image>();
			((Graphic)component).color = Color.red;
			Transform val4 = val3.transform.Find("Holder");
			((Component)val4.Find("AmmoArea")).gameObject.SetActive(false);
			((Component)val4.Find("ReadyContainer").Find("Text")).gameObject.SetActive(false);
			((Graphic)((Component)val4.Find("ReadyContainer").Find("Square, Outer")).GetComponent<Image>()).color = new Color(0.579f, 0f, 0f);
			PathfinderAssets.commandCrosshair = val3;
		}

