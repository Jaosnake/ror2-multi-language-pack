        "ROB_HUNK_KEYWORD_LOOTING": "Saque",
        "ROB_HUNK_JETPACK_NAME": "Jump Pack Experimental",
        "ROB_HUNK_JETPACK_DESC": "Uma ferramenta feita pela Umbrella que permite impulsionar-se em qualquer direcao pressionando pulo no ar.",
        "ROB_HUNK_SURVIVALKIT_NAME": "Kit de Sobrevivencia de Emergencia",
        "ROB_HUNK_SURVIVALKIT_DESC": "Um kit de sobrevivencia que aumenta tanto sua habilidade de vasculhar por municao quanto a eficacia da sua faca.",
        "ROB_HUNK_TRANSCEIVER_NAME": "Transmissor Desgastado",
        "ROB_HUNK_TRANSCEIVER_DESC": "Chama um companheiro de esquadrao para ajudar na sua operacao.",
        "ROB_HUNK_INFROCKET_NAME": "ATM-4",
        "ROB_HUNK_INFROCKET_DESC": "Um lancador de foguetes com <style=cIsHealing>municao infinita</style>. Recompensa pela conquista <color=#FFFF00>Early Supporter</color>.",
        "ROB_HUNK_TYPEWRITER_NAME": "Maquina de Escrever",
        "ROB_HUNK_TYPEWRITER_DESC": "Concede <style=cIsUtility>2</style> <color=#C80202>cases de armas da Umbrella</color> adicionais por Fase.",
        "ROB_HUNK_CRYSTALSKULL_NAME": "Caveira de Cristal",
        "ROB_HUNK_CRYSTALSKULL_DESC": "Um tesouro raro. Pode ser trocado em qualquer <style=cIsUtility>Caldeirao</style> para receber um item.",
        "ROB_HUNK_WRISTBAND_NAME": "Pulseira de Identificacao",
        "ROB_HUNK_WRISTBAND_DESC": "Uma chave eletronica para uso nas instalacoes da <color=#C80202>Umbrella Corporation</color>. Usada para abrir uma <style=cIsUtility>case de arma especial</style>.",
        "ROB_HUNK_SPADE_KEYCARD_NAME": "U.C. Keycard (Espadas)",
        "ROB_HUNK_CLUB_KEYCARD_NAME": "U.C. Keycard (Paus)",
        "ROB_HUNK_HEART_KEYCARD_NAME": "U.C. Keycard (Copas)",
        "ROB_HUNK_DIAMOND_KEYCARD_NAME": "U.C. Keycard (Ouros)",
        "ROB_HUNK_GOLD_KEYCARD_NAME": "U.C. Keycard (Estrela)",
        "ROB_HUNK_MASTER_KEYCARD_NAME": "U.C. Keycard (Mestre)",
        "ROB_HUNK_KEYCARD_DESC": "Usado para abrir <color=#C80202>cases de armas</color> da <style=cIsUtility>Umbrella Corporation</style>.",
        "ROB_HUNK_KEYCARD_MASTER_DESC": "Usado para abrir <color=#C80202>cases de armas</color> da <style=cIsUtility>Umbrella Corporation</style>. Abre <style=cIsHealing>todas as cases</style> e transforma outros keycards em <style=cIsUtility>sucata</style>.",
        "ROB_HUNK_STARSBADGE_NAME": "Distintivo S.T.A.R.S.",
        "ROB_HUNK_STARSBADGE_DESC": "Um distintivo especial da divisao de forcas especiais da R.P.D., <color=#F20443>S.T.A.R.S.</color> <style=cIsHealth>Talvez pegar isso tenha sido uma ma ideia?</style>",
        "ROB_HUNK_STARSBADGE_DESCFULL": "A cada Fase, uma caixa especial da <color=#F20443>S.T.A.R.S.</color> surge que so pode ser aberta usando este distintivo. No entanto, o <style=cIsHealth>Nemesis T-Type</style> ira cacar voce implacavelmente.",
        "ROB_HUNK_STARSBADGE2_NAME": "Chave USB Dongle",
        "ROB_HUNK_STARSBADGE2_DESC": "Usada para acessar um <style=cIsUtility>bau especial</style> em cada Fase.",
        "ROB_HUNK_STARSBADGE2_DESCFULL": "A cada Fase, uma caixa especial da <color=#F20443>S.T.A.R.S.</color> surge que so pode ser aberta usando este distintivo. No entanto, o <style=cIsHealth>Nemesis T-Type</style> ira cacar voce implacavelmente.",
        "ROB_HUNK_HEARTCHEST_NAME": "Bau do Coracao",
        "ROB_HUNK_NEMICASE_NAME": "Case Nemi",
        "ROB_HUNK_NEMICASE_DESC": "Uma case misteriosa.",
        "ROB_HUNK_AMMO_NAME": "Municao",
        "ROB_HUNK_AMMOITEM_NAME": "Municao",
        "ROB_HUNK_CHEST_NAME": "Bau",
        "ROB_HUNK_TERMINAL_NAME": "Terminal",
        "ROB_HUNK_GRENADE_NAME": "Granada",
        "ROB_HUNK_C4_NAME": "C4",
        "ROB_HUNK_SUPPLYPACK_NAME": "Suprimentos",
        "ROB_HUNK_T_VIRUS_NAME": "T-Virus",
        "ROB_HUNK_T_VIRUS_DESC": "Uma amostra do T-Virus.",
        "ROB_HUNK_G_VIRUS_NAME": "G-Virus",
        "ROB_HUNK_G_VIRUS_DESC": "Uma amostra do G-Virus.",
        "ROB_HUNK_G_VIRUS2_NAME": "G-Virus 2",
