			//IL_0056: Unknown result type (might be due to invalid IL or missing references)
			SkinDefParamsInfo val = default(SkinDefParamsInfo);
			val.Name = name;
			val.NameToken = name;
			val.Icon = icon;
			val.UnlockableDef = unlock;
			val.RendererInfos = rendererInfos ?? Array.Empty<RendererInfo>();
			val.RootObject = modelObject;
			val.MeshReplacements = meshes ?? Array.Empty<MeshReplacement>();
			return Skins.CreateNewSkinDef(val);
		}

