	public static class ConscriptStates
	{
		public static void Init()
		{
			Content.AddEntityState(typeof(ShootConscriptGun));
			Content.AddEntityState(typeof(Reload));
			Content.AddEntityState(typeof(ReloadFast));
			Content.AddEntityState(typeof(ShootFlak));
			Content.AddEntityState(typeof(FlakReload));
			Content.AddEntityState(typeof(ThrowMolotov));
			Content.AddEntityState(typeof(ThrowTerrorDrone));
			Content.AddEntityState(typeof(HellMarch));
			Content.AddEntityState(typeof(HellMarchStompJump));
			Content.AddEntityState(typeof(HellMarchStompStomp));
			Content.AddEntityState(typeof(BasicBitchBuff));
			Content.AddEntityState(typeof(SpawnGarrison));
			Content.AddEntityState(typeof(JumpOnEnemy));
			Content.AddEntityState(typeof(StickOnEnemy));
		}
	}
	public static class ConscriptTokens
	{
		public static void Init()
		{
			AddHenryTokens();
		}

		public static void AddHenryTokens()
		{
			string text = "HABIBI_CONSCRIPT_";
			string text2 = "ra2 quote.<color=#CCD3E0>" + Environment.NewLine + Environment.NewLine + "< ! > ra2 quote." + Environment.NewLine + Environment.NewLine + "< ! > ra2 quote." + Environment.NewLine + Environment.NewLine + "< ! > ra2 quote." + Environment.NewLine + Environment.NewLine + "< ! > ra2 quote." + Environment.NewLine + Environment.NewLine;
			string text3 = "..and so he left, ra2 quote.";
			string text4 = "..and so he vanished, ra2 quote.";
			Language.Add(text + "NAME", "Conscript (Beta)");
			Language.Add(text + "DESCRIPTION", text2);
			Language.Add(text + "SUBTITLE", "ra2 quote");
			Language.Add(text + "LORE", "ra2 quote");
			Language.Add(text + "OUTRO_FLAVOR", text3);
			Language.Add(text + "OUTRO_FAILURE", text4);
			Language.Add(text + "PRIMARY_GUN_NAME", "Gun");
			Language.Add(text + "PRIMARY_GUN_DESCRIPTION", "Fire gun for " + Tokens.DamageValueText(ConscriptConfig.M1_Gun_Damage) + ". Has to reload");
			Language.Add(text + "PRIMARY_FLAK_NAME", "Flak Cannon");
			Language.Add(text + "PRIMARY_FLAK_DESCRIPTION", "Shoot an instant blast for " + Tokens.DamageValueText(ConscriptConfig.M1_Flak_Damage) + ". Has to reload");
			Language.Add(text + "SECONDARY_MOLOTOV_NAME", "Molotov");
			Language.Add(text + "SECONDARY_MOLOTOV_DESCRIPTION", "Throw a molotov that leaves a pool of fire on the ground in a " + Tokens.UtilityText("wide area") + " for dealing " + Tokens.DamageText("320% damage") + " over 4 seconds. Can be shot mid-air to explode for " + Tokens.DamageValueText(ConscriptConfig.M2_Molotov_BaseDamage) + " in a " + Tokens.UtilityText("smaller area") + ".");
			Language.Add(text + "SECONDARY_TERROR_NAME", "Terror Drone");
			Language.Add(text + "SECONDARY_TERROR_DESCRIPTION", "Throw a small drone that seeks and attaches to enemies. " + Tokens.DamageText("Explodes when hit") + " for " + Tokens.DamageValueText(ConscriptConfig.M2_TerrorDrone_BlastDamage) + ".");
			Language.Add(text + "UTILITY_MARCH_NAME", "Hell March");
			Language.Add(text + "UTILITY_MARCH_DESCRIPTION", "Gain " + Tokens.UtilityText("200 armor") + ", and charge through enemies for " + Tokens.DamageValueText(ConscriptConfig.M3_March_ChargeDamage) + ", " + Tokens.UtilityText("stunning them") + " and " + Tokens.UtilityText("knocking them up") + ". Stomp at the end for " + Tokens.DamageValueText(ConscriptConfig.M3_March_StompDamage) + ". Repositions Garrisons");
			Language.Add(text + "SPECIAL_GARRISON_NAME", "Garrison");
			Language.Add(text + "SPECIAL_GARRISON_DESCRIPTION", "Deploy a small garrison for " + Tokens.UtilityText($"{ConscriptConfig.M4_Garrison_Duration.Value} seconds") + " that " + Tokens.UtilityText("removes the cooldown") + " of primary and " + Tokens.UtilityText("refreshes stocks") + " of secondary. Provides cover from damage but " + Tokens.HealthText("can be destroyed"));
			Language.Add(Tokens.GetAchievementNameToken("HABIBI_CONSCRIPT_masteryAchievement"), "Conscript : Mastery");
			Language.Add(Tokens.GetAchievementDescriptionToken("HABIBI_CONSCRIPT_masteryAchievement"), "As Conscript, beat the game or obliterate on Monsoon.");
		}
	}
	public static class ConscriptUnlockables
	{
		public static UnlockableDef characterUnlockableDef;

		public static UnlockableDef masterySkinUnlockableDef;

