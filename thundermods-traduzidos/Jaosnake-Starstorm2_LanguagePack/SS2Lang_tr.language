        "SS2_ITEM_OPTIONFROMCHEST_DESC": "Sandıkların <style=cIsUtility>%50</style> şansla <style=cIsUtility>3</style> eşya arasından seçim hakkı verme şansı vardır. <style=cStack>(Eşya nadirliği birikim başına artar)</style>",
        "SS2_ACHIEVEMENT_EXECUTIONER_WASTELANDER_NAME": "Executioner: Crack the Vault",
        "SS2_NEMMANDO_SECONDARY_CONCUSSION_NAME": "Uzak Yara",
        "SS2_CHIRR_BEFRIEND_DESCRIPTION": "<style=cIsUtility>Arkadaş edinmek</style> için canı 50% altında olan bir düşman bul. <style=cIsUtility>Arkadaş edinilmiş düşmanlar eşyalarını paylaşır</style>.",
        "SS2_DIFFICULTY_SUPERTYPHOON1_NAME": "Süper Tayfun +1",
        "SS2_BORG_SPECIAL_TELEPORTB_DESCRIPTION": "Yerleştirilmiş fenerinize ışınlanmak için bir kere basın. Yerleştirilmiş fenerinizi kaldırmak için basılı tutun.",
        "SS2_NEMCOMMANDO_SECONDARY_CONCUSSION_NAME": "Uzak Yara Sarsıntısı Aroması",
        "SS2_SHRINE_ETHEREAL_HINT_BLACKBEACH2": "Sütunlar arasında gizlenmiş.",
