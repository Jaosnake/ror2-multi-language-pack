        "ROB_DRIVER_BODY_PRIMARY_REVOLVER_NAME": "Feuer",
        "ROB_DRIVER_BODY_PRIMARY_REVOLVER_DESCRIPTION": "Feuern Sie Ihre Pistole ab und verursachen Sie 500 % Schaden.<style=cIsDamage>Kritische Treffer werden zweimal abgefeuert.</style></i>",
        "ROB_DRIVER_BODY_PRIMARY_SHOTGUN_NAME": "Explosion",
