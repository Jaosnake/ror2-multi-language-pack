        "SANDSWEPT_VOID_SHRINE_RUIN_NAME": "Sanctuaire de la Ruine",
        "SANDSWEPT_VOID_SHRINE_RUIN_CONTEXT": "Offrir au Sanctuaire de la Ruine",
        "SANDSWEPT_VOID_SHRINE_RUIN_USE_MESSAGE_2P": "<style=cShrine>La corruption se propage.</color>",
        "SANDSWEPT_VOID_SHRINE_RUIN_USE_MESSAGE": "<style=cShrine>La corruption se propage.</color>",
        "SANDSWEPT_SHRINE_OF_RUIN_DESCRIPTION": "Quand il est activ\u00e9 par un survivant, le Sanctuaire de la Ruine consomme 10 objets blancs al\u00e9atoires de l'inventaire et corrompt l'\u00e9tape suivante.",

        "SANDSWEPT_SHRINE_SACRIFICE_NAME": "Sanctuaire du Sacrifice",
        "SANDSWEPT_SHRINE_SACRIFICE_CONTEXT": "Offrir au Sanctuaire du Sacrifice",
        "SANDSWEPT_SHRINE_SACRIFICE_USE_MESSAGE_2P": "<style=cShrine>Votre temps a \u00e9t\u00e9 sacrifi\u00e9.</color>",
        "SANDSWEPT_SHRINE_SACRIFICE_USE_MESSAGE": "<style=cShrine>Le temps de {0} a \u00e9t\u00e9 sacrifi\u00e9.</color>",
        "SANDSWEPT_SHRINE_SACRIFICE_DESCRIPTION": "Quand il est activ\u00e9, le Sanctuaire du Sacrifice consomme {curseCost}% de la sant\u00e9 maximale du survivant en \u00e9change de {itemCount} copies d'un objet commun al\u00e9atoire.",
        "SANDSWEPT_SHRINE_OF_SACRIFICE_DESCRIPTION": "Quand il est activ\u00e9, le Sanctuaire du Sacrifice consomme {curseCost}% de la sant\u00e9 maximale du survivant en \u00e9change de {itemCount} copies d'un objet commun al\u00e9atoire.",

        "SANDSWEPT_SHRINE_FUTURE_NAME": "Sanctuaire du Futur",
        "SANDSWEPT_SHRINE_FUTURE_CONTEXT": "Offrir au Sanctuaire du Futur",
        "SANDSWEPT_SHRINE_FUTURE_USE_MESSAGE_2P": "<style=cShrine>Le temps a chang\u00e9.</color>",
        "SANDSWEPT_SHRINE_FUTURE_USE_MESSAGE": "<style=cShrine>Le temps s'est d\u00e9form\u00e9.</color>",
        "SANDSWEPT_SHRINE_OF_THE_FUTURE_DESCRIPTION": "Quand il est activ\u00e9, le Sanctuaire du Futur invoque un mini-boss \u00e9lite puissant al\u00e9atoire pour chaque joueur qui, une fois vaincu, l\u00e2che {itemCount} potentiels d'objet par joueur.",

        "SANDSWEPT_SHRINE_DEATH_NAME": "Sanctuaire de la Mort",
        "SANDSWEPT_SHRINE_DEATH_CONTEXT": "Offrir au Sanctuaire de la Mort",
        "SANDSWEPT_SHRINE_DEATH_DESCRIPTION": "Quand il est activ\u00e9, le Sanctuaire de la Mort consomme {percentHealthCost}% de la sant\u00e9 du survivant et d\u00e9sactive tous les soins pendant {healingDisableDuration} secondes, mais a {onKillProcChance}% de chance de d\u00e9clencher les effets de kill et {onInteractProcChance}% de chance de d\u00e9clencher les effets d'interaction.",

        "SANDSWEPT_VOLTAIC_DRONE_BODY": "Drone Volta\u00efque",
        "SANDSWEPT_VOLTAIC_DRONE_BROKEN_NAME": "Drone Volta\u00efque Endommag\u00e9",
        "SANDSWEPT_VOLTAIC_DRONE_CONTEXT": "R\u00e9parer ?",
        "SANDSWEPT_VOLTAIC_DRONE_BROKEN_DESCRIPTION": "Un compagnon achet\u00e9 avec de l'or qui suivra le survivant \u00e0 courte distance. Tire un boulon \u00e9lectrique qui \u00e9lectrocute les cibles proches.",
        "SANDSWEPT_VOLTAIC_PRIM_NAME": "Jump Start",
        "SANDSWEPT_VOLTAIC_PRIME_DESC": "Tire une tige d'insertion qui \u00e9lectrocute r\u00e9p\u00e9titivement les cibles pour 200% de d\u00e9g\u00e2ts.",
        "SANDSWEPT_VOLTAIC_OPERATOR_DESC": "Tire une tige d'insertion qui \u00e9lectrocute r\u00e9p\u00e9titivement les cibles pour 600% de d\u00e9g\u00e2ts, les maintenant en place.",
        "SANDSWEPT_VOLTAIC_DESC": "Tire des tiges d'insertion qui font jaillir de l'\u00e9lectricit\u00e9 vers les cibles proches pour 200% de d\u00e9g\u00e2ts.",
        "SANDSWEPT_VOLTAIC_PICKUP": "Tire des tiges d'insertion qui \u00e9lectrocutent les cibles.",

        "SANDSWEPT_INFERNO_DRONE_BODY": "Drone Inferno",
        "SANDSWEPT_INFERNO_DRONE_BROKEN_NAME": "Drone Inferno Endommag\u00e9",
        "SANDSWEPT_INFERNO_DRONE_CONTEXT": "R\u00e9parer ?",
        "SANDSWEPT_INFERNO_DRONE_BROKEN_DESCRIPTION": "Un compagnon achet\u00e9 avec de l'or qui suivra le survivant \u00e0 courte distance. Tire des cocktails molotov.",
        "SANDSWEPT_INFERNO_PRIM_NAME": "Br\u00fblure",
        "SANDSWEPT_INFERNO_PRIM_DESC": "Tire une roquette qui laisse des flaques de napalm pour 3x300% de d\u00e9g\u00e2ts par seconde.",
        "SANDSWEPT_INFERNO_OPERATOR_DESC": "Avancez et couvrez le sol, laissant des flaques de napalm pour 7x300% de d\u00e9g\u00e2ts. S'\u00e9chelonne avec la vitesse d'attaque.",
        "SANDSWEPT_INFERNO_DESC": "Tire des roquettes sur les cibles qui cr\u00e9ent des flaques de napalm pour 300% de d\u00e9g\u00e2ts par seconde.",
        "SANDSWEPT_INFERNO_PICKUP": "Tire des roquettes sur les cibles qui laissent des flaques de napalm.",

        "SANDSWEPT_OBJECTIVE_CHARGE_TP_EARLY": "Trouvez et activez le <style=cDeath>T\u00e9l\u00e9porteur <sprite name=\"TP\" tint=1></style> dans <style=cDeath>{0}s !</style>",
        "SANDSWEPT_OBJECTIVE_GET_UP_TO_X_ITEMS": "Obtenez jusqu'\u00e0 <style=cIsUtility>{0} objets</style>.",

