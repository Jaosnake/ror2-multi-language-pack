		private void GrantRandomMagicite()
		{
			Random random = new Random();
			switch (random.Next(9))
			{
			default:
				Debug.LogError((object)"[SynthesisFailedOnSelectingMagiciteCategory]");
				break;
			case 0:
			case 1:
			case 2:
			case 3:
				MagiciteSelect(MagiciteDefs.SpellMagicites, random);
				break;
			case 4:
			case 5:
				MagiciteSelect(MagiciteDefs.LimitMagicites, random);
				break;
			case 6:
			case 7:
				MagiciteSelect(MagiciteDefs.FinisherMagicites, random);
				break;
			case 8:
				MagiciteSelect(MagiciteDefs.SupportMagicites, random);
				break;
