	public static class ArmorerTokens
	{
		public static void Init()
		{
			AddArmorerTokens();
		}

		public static void AddArmorerTokens()
		{
			string text = "Tatertotticus_Armorer_";
			string text2 = "Armorer is a skilled fighter who makes use of a wide arsenal of weaponry to take down their foes.<color=#CCD3E0>" + Environment.NewLine + Environment.NewLine + "< ! > Metal Blaster is a good source of consistent ranged damage and Heavy Metal stacks." + Environment.NewLine + Environment.NewLine + "< ! > Frag Cannon is a powerful offensive skill, with its piercing and high damage." + Environment.NewLine + Environment.NewLine + "< ! > Scrap Thruster gives significant horizontal movement paired with a large area of effect." + Environment.NewLine + Environment.NewLine + "< ! > Alloyed Bulwark can be used to quickly save yourself, or as a buffer." + Environment.NewLine + Environment.NewLine;
			string text3 = "..and so he left, searching for a new identity.";
			string text4 = "..and so he vanished, forever a blank slate.";
			Language.Add(text + "NAME", "Armorer");
			Language.Add(text + "DESCRIPTION", text2);
			Language.Add(text + "SUBTITLE", "Resourceful Tinkerer");
			Language.Add(text + "LORE", "Transcribed recording recovered from a recon squad: \r\n\r\n#1 “Keep up, we’ve almost lost it, I’m pretty sure I damaged it a bit” \r\n\r\n#2 “I’m trying, I’m just...really tired” \r\n\r\n#3 “What even was that thing...it almost looked like one of those crazy birds...” \r\n\r\n#1 “What? No way. That thing was a walking hunk of metal, must’ve been some kind of malfunctioning machine” \r\n\r\n#3 “I’m telling you, there was a bird under all the machinery!” \r\n\r\n#1 “Yeah, sure, let’s just keep going” \r\n\r\nLoud thud is heard \r\n\r\n#3 “Crap, Calem just fell over...” \r\n\r\n#1 “Well get him back up, we have to move!” \r\n\r\n#3 “He’s not getting up; there’s some weird metal crusted over half his suit!” \r\n\r\nLoud metal scraping is heard in the distance, followed by a growing hum \r\n\r\n#1 “Shit” \r\n\r\nEnd of recording ");
			Language.Add(text + "OUTRO_FLAVOR", text3);
			Language.Add(text + "OUTRO_FAILURE", text4);
			Language.Add(text + "Phoenix", "Phoenix");
			Language.Add(text + "Quetzalcoatl", "Quetzalcoatl");
			Language.Add(text + "PASSIVE_NAME", "Heavy Metal");
			Language.Add(text + "PASSIVE_DESCRIPTION", "Armorer's attacks apply stacks of Heavy Metal to enemies, reducing their damage and movement speed. When taking damage, gain stacks of Bulk Up, increasing your armor and attack speed.");
			Language.Add(text + "PRIMARY_BLASTER_NAME", "Metal Blaster");
			Language.Add(text + "PRIMARY_BLASTER_DESCRIPTION", "<style=cIsUtility>Agile.</style>" + $"Shoot projectile for <style=cIsDamage>{150f}% damage</style>, which explodes for <style=cIsDamage>{75f}% damage</style>.");
			Language.Add(text + "SECONDARY_GUN_NAME", "Frag Cannon");
			Language.Add(text + "SECONDARY_GUN_DESCRIPTION", $"Fire a piercing laser for <style=cIsDamage>{500f}% damage</style>. Consume stacks of Bulk Up to fire additional beams.");
			Language.Add(text + "UTILITY_ROLL_NAME", "Scrap Thruster");
			Language.Add(text + "UTILITY_ROLL_DESCRIPTION", $"Fly forward with unstable engines, shrapnel flies off around you for <style=cIsDamage>{600f}% damage</style>.");
			Language.Add(text + "SPECIAL_BOMB_NAME", "Alloyed Bulwark");
			Language.Add(text + "SPECIAL_BOMB_DESCRIPTION", $"Release a burst of energy dealing damage <style=cIsDamage>{300f}% damage</style>. If you are hit for significant damage shortly after releasing energy, gain max Bulk Up and heal all nearby allies.");
			Language.Add(text + "SPECIAL_VIRUS_NAME", "Machine Curse");
			Language.Add(text + "SPECIAL_VIRUS_DESCRIPTION", "Send out a wave of nanobots, which give barrier and a damage boost to nearby allies, and detonates Heavy Metal on nearby enemies, dealing damage for each one, and additionally applying Anti Healing to weakened targets");
			Language.Add(Tokens.GetAchievementNameToken("Tatertotticus_Armorer_masteryAchievement"), "Armorer: Mastery");
			Language.Add(Tokens.GetAchievementDescriptionToken("Tatertotticus_Armorer_masteryAchievement"), "As Armorer, beat the game or obliterate on Monsoon.");
			Language.Add(Tokens.GetAchievementNameToken("Tatertotticus_Armorer_grandMasteryAchievement"), "Armorer: Grand Mastery");
			Language.Add(Tokens.GetAchievementDescriptionToken("Tatertotticus_Armorer_grandMasteryAchievement"), "As Armorer, beat the game or obliterate on Typhoon");
			Language.Add(Tokens.GetAchievementNameToken("Tatertotticus_Armorer_healingAchievement"), "Armorer: Repair Expert");
			Language.Add(Tokens.GetAchievementDescriptionToken("Tatertotticus_Armorer_healingAchievement"), "As Armorer, use Alloyed Bulwark's damage absorption to heal at least 200% of your health.");
		}
	}
	public static class ArmorerUnlockables
	{
		public static UnlockableDef characterUnlockableDef;

		public static UnlockableDef masterySkinUnlockableDef;

		public static UnlockableDef grandMasterySkinUnlockableDef;

		public static UnlockableDef altSpecialUnlockableDef;

		public static void Init()
		{
			masterySkinUnlockableDef = Content.CreateAndAddUnlockbleDef("Tatertotticus_Armorer_masteryUnlockable", Tokens.GetAchievementNameToken("Tatertotticus_Armorer_masteryAchievement"), CharacterBase<ArmorerSurvivor>.instance.assetBundle.LoadAsset<Sprite>("texMasteryAchievement"));
			grandMasterySkinUnlockableDef = Content.CreateAndAddUnlockbleDef("Tatertotticus_Armorer_grandMasteryUnlockable", Tokens.GetAchievementNameToken("Tatertotticus_Armorer_grandMasteryAchievement"), CharacterBase<ArmorerSurvivor>.instance.assetBundle.LoadAsset<Sprite>("texGrandMasterySkin"));
			altSpecialUnlockableDef = Content.CreateAndAddUnlockbleDef("Tatertotticus_Armorer_altSpecialUnlockable", Tokens.GetAchievementNameToken("Tatertotticus_Armorer_healingAchievement"), CharacterBase<ArmorerSurvivor>.instance.assetBundle.LoadAsset<Sprite>("MachineVirusIcon"));
		}
	}
