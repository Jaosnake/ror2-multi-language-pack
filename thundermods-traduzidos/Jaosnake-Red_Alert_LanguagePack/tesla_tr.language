        "HABIBI_TESLA_BODY_SECONDARY_BIGZAP_NAME": "2000 Volt",
        "HABIBI_TESLA_BODY_SECONDARY_BIGZAP_DESCRIPTION": "<style=cIsUtility>Çekici.</style>Geniş bir alanda elektrik patlaması yaratın<style=cIsDamage>%690 hasar</style>. Yakınken<style=cIsUtility>Tesla Kulesi</style>, bir gerçekleştir<style=cIsUtility>güçlendirilmiş, şok edici</style>için sürüm<style=cIsDamage>%1500 hasar</style>.",
        "HABIBI_TESLA_BODY_SECONDARY_BIGZAPPUNCH_NAME": "Yüklü Yumruk",
        "HABIBI_TESLA_BODY_SECONDARY_BIGZAPPUNCH_DESCRIPTION": "Bir yumruk yüklemek için basılı tutun<style=cIsDamage>%80-%800 hasar</style>ve düşmanları bir koni içinde zaplayın<style=cIsDamage>%40-%400 hasar</style>. Yakınken<style=cIsUtility>Tesla Kulesi</style>, zap konisini uzun menzilli bir koni ile değiştirin<style=cIsUtility>şok edici</style>ışın için<style=cIsDamage>%120-%1200 hasar</style>",
        "HABIBI_TESLA_BODY_UTILITY_BARRIER_NAME": "Şarj Ediliyor",
