			private void Awake()
			{
				granter = ((Component)this).gameObject.AddComponent<AchievementGranter>();
			}

			public void Success()
			{
				UserProfile userProfile = LocalUserManager.GetFirstLocalUser().userProfile;
				string text = "ROB_HUNK_SUPPORTER_ACHIEVEMENT_ID";
				bool flag = !string.IsNullOrEmpty(text);
				bool flag2 = flag && userProfile.HasAchievement(text);
				bool flag3 = Object.op_Implicit((Object)(object)Hunk.earlySupporterUnlockableDef) && userProfile.HasUnlockable(Hunk.earlySupporterUnlockableDef);
				if (flag && !flag2)
				{
					foreach (AchievementNotificationPanel instances in AchievementNotificationPanel.instancesList)
					{
						Object.Destroy((Object)(object)((Component)instances).gameObject);
					}
					userProfile.AddAchievement(text, true);
				}
				if (!flag3)
				{
					userProfile.GrantUnlockable(Hunk.earlySupporterUnlockableDef);
				}
			}

			private void Update()
			{
				stopwatch -= Time.deltaTime;
				if (step > 0 && stopwatch <= 0f)
				{
					step = 0;
				}
				switch (step)
				{
				case 0:
					if (Input.GetKeyDown((KeyCode)273))
					{
						stopwatch = 3f;
						step++;
					}
					break;
				case 1:
					if (Input.GetKeyDown((KeyCode)273))
					{
						stopwatch = 3f;
						step++;
					}
					break;
				case 2:
					if (Input.GetKeyDown((KeyCode)274))
					{
						stopwatch = 3f;
						step++;
					}
					break;
				case 3:
					if (Input.GetKeyDown((KeyCode)274))
					{
						stopwatch = 3f;
						step++;
					}
					break;
				case 4:
					if (Input.GetKeyDown((KeyCode)276))
					{
						stopwatch = 3f;
						step++;
					}
					break;
				case 5:
					if (Input.GetKeyDown((KeyCode)275))
					{
						stopwatch = 3f;
						step++;
					}
					break;
				case 6:
					if (Input.GetKeyDown((KeyCode)276))
					{
						stopwatch = 3f;
						step++;
					}
					break;
				case 7:
					if (Input.GetKeyDown((KeyCode)275))
					{
						stopwatch = 3f;
						step++;
						Util.PlaySound("sfx_hunk_retheme_global", ((Component)this).gameObject);
						Success();
					}
					break;
				}
			}
		}
