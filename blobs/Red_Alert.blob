	public static class TeslaUnlockables
	{
		public static UnlockableDef characterUnlockableDef;

		public static UnlockableDef masterySkinUnlockableDef;

		public static UnlockableDef grandMasterySkinUnlockableDef;

		public static UnlockableDef recolorsUnlockableDef;

		public static UnlockableDef utilityUnlockableDef;

		public static UnlockableDef secondaryUnlockableDef;

		public static UnlockableDef cursedPrimaryUnlockableDef;

		public static void Init()
		{
			masterySkinUnlockableDef = Content.CreateAndAddUnlockbleDef("HABIBI_TESLA_BODY_MASTERYUNLOCKABLE_REWARD_ID", Tokens.GetAchievementNameToken("HABIBI_TESLA_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_ID"), CharacterBase<TeslaTrooperSurvivor>.instance.assetBundle.LoadAsset<Sprite>("texTeslaSkinMastery"));
			grandMasterySkinUnlockableDef = Content.CreateAndAddUnlockbleDef("HABIBI_TESLA_BODY_GRANDMASTERYUNLOCKABLE_REWARD_ID", Tokens.GetAchievementNameToken("HABIBI_TESLA_BODY_GRANDMASTERYUNLOCKABLE_ACHIEVEMENT_ID"), CharacterBase<TeslaTrooperSurvivor>.instance.assetBundle.LoadAsset<Sprite>("texTeslaSkinNod"));
			utilityUnlockableDef = Content.CreateAndAddUnlockbleDef("HABIBI_TESLA_BODY_BIGZAPUNLOCKABLE_REWARD_ID", Tokens.GetAchievementNameToken("HABIBI_TESLA_BODY_BIGZAPUNLOCKABLE_ACHIEVEMENT_ID"), CharacterBase<TeslaTrooperSurvivor>.instance.assetBundle.LoadAsset<Sprite>("texTeslaSkillUtilityAlt"));
			secondaryUnlockableDef = Content.CreateAndAddUnlockbleDef("HABIBI_TESLA_BODY_SHIELDZAPUNLOCKABLE_REWARD_ID", Tokens.GetAchievementNameToken("HABIBI_TESLA_BODY_SHIELDZAPUNLOCKABLE_ACHIEVEMENT_ID"), CharacterBase<TeslaTrooperSurvivor>.instance.assetBundle.LoadAsset<Sprite>("texTeslaSkillUtilityAlt"));
			cursedPrimaryUnlockableDef = Content.CreateAndAddUnlockbleDef("HABIBI_TESLA_BODY_ZAPALLYUNLOCKABLE_REWARD_ID", Tokens.GetAchievementNameToken("HABIBI_TESLA_BODY_ZAPALLYUNLOCKABLE_ACHIEVEMENT_ID"), CharacterBase<TeslaTrooperSurvivor>.instance.assetBundle.LoadAsset<Sprite>("texTeslaSkillSecondaryAlt"));
		}
	}
	public class TeslaSkinDef : SkinDef
	{
