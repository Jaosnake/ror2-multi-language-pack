        "SS2_DRONE_SHOCK_INTERACTABLE_NAME": "Drone shock rotto",
        "SS2_DRONE_SHOCK_INTERACTABLE_CONTEXT": "Ripara il drone shock",
        "SS2_DRONE_SHOCK_PICKUP": "<style=cIsUtility>Shock</style> i nemici vicini, interrompendoli e stordendoli.",
        "SS2_DRONE_SHOCK_DESCRIPTION": "Un compagno acquistato con l'oro che seguirà il sopravvissuto a distanza ravvicinata, <style=cIsUtility>scioccando</style> i nemici, interrompendoli e stordendoli.",
        "SS2_DRONE_SHOCK_SKILL_DESCRIPTION": "Spara un'esplosione elettrica, infliggendo <style=cIsDamage>100% di danni</style> in un'area e <style=cIsUtility>scioccante</style> nemici per <style=cIsUtility>5 secondi</style>.",
