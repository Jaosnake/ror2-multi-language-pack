			segment1.positionCount = ((array.Length >= 1) ? (array.Length - 1) : array.Length);
			segment1.SetPositions(array);
			segment2.positionCount = ((array2.Length >= 1) ? (array2.Length - 1) : array2.Length);
			segment2.SetPositions(array2);
			segment3.positionCount = ((array3.Length >= 1) ? (array3.Length - 1) : array3.Length);
			segment3.SetPositions(array3);
			originalRedLength = array3;
		}

