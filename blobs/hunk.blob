			private void GivePassiveItem()
			{
				if ((Object)(object)hunk.passive.toolSkillSlot.skillDef == (Object)(object)Hunk.scanGunDef)
				{
					inventory.GiveItemPermanent(BaseWeapon<ScanGun>.instance.itemDef, 1);
				}
				if ((Object)(object)hunk.passive.toolSkillSlot.skillDef == (Object)(object)Hunk.grappleGunDef)
				{
					inventory.GiveItemPermanent(BaseWeapon<GrappleGun>.instance.itemDef, 1);
				}
				if ((Object)(object)hunk.passive.toolSkillSlot.skillDef == (Object)(object)Hunk.jetpackDef)
				{
					inventory.GiveItemPermanent(Hunk.jetpack, 1);
				}
				if ((Object)(object)hunk.passive.toolSkillSlot.skillDef == (Object)(object)Hunk.survivalKitDef)
				{
					inventory.GiveItemPermanent(Hunk.survivalKit, 1);
				}
				if ((Object)(object)hunk.passive.toolSkillSlot.skillDef == (Object)(object)Hunk.transceiverDef)
				{
					inventory.GiveItemPermanent(Hunk.transceiver, 1);
				}
				if ((Object)(object)hunk.passive.toolSkillSlot.skillDef == (Object)(object)Hunk.infiniteRocketDef)
				{
					inventory.GiveItemPermanent(BaseWeapon<ATM>.instance.itemDef, 1);
				}
			}

			public void SwapToLastWeapon()
			{
				int num = equippedIndex;
				equippedIndex = lastEquippedIndex;
				lastEquippedIndex = num;
			}

			public void CycleWeapon()
			{
				lastEquippedIndex = equippedIndex;
				equippedIndex++;
				if (equippedIndex >= weaponData.Length)
				{
					equippedIndex = 0;
				}
			}

			public void SwapToWeapon(int index)
			{
				lastEquippedIndex = equippedIndex;
				equippedIndex = index;
			}

			public void AddWeapon(HunkWeaponDef weaponDef)
			{
				for (int i = 0; i < weaponData.Length; i++)
				{
					if ((Object)(object)weaponData[i].weaponDef == (Object)(object)weaponDef)
					{
						return;
					}
				}
				Array.Resize(ref weaponData, weaponData.Length + 1);
				bool flag = false;
				HunkWeaponData[] array = storedWeaponData;
				for (int j = 0; j < array.Length; j++)
				{
					HunkWeaponData hunkWeaponData = array[j];
					if ((Object)(object)weaponDef == (Object)(object)hunkWeaponData.weaponDef)
					{
						flag = true;
						RemoveStoredData(weaponDef);
						weaponData[weaponData.Length - 1] = new HunkWeaponData
						{
							weaponDef = weaponDef,
							totalAmmo = hunkWeaponData.totalAmmo,
							currentAmmo = hunkWeaponData.currentAmmo
						};
					}
				}
				if (!flag)
				{
					weaponData[weaponData.Length - 1] = new HunkWeaponData
					{
						weaponDef = weaponDef,
						totalAmmo = weaponDef.magSize * weaponDef.startingMags,
						currentAmmo = weaponDef.magSize
					};
				}
				if (hasInit)
				{
					Util.PlaySound("sfx_hunk_weapon_get", ((Component)hunk).gameObject);
				}
				AddWeaponItem(weaponDef);
			}

			public void RemoveWeapon(HunkWeaponDef weaponDef)
			{
				for (int i = 0; i < weaponData.Length; i++)
				{
					if ((Object)(object)weaponData[i].weaponDef == (Object)(object)weaponDef)
					{
						DropWeapon(i, createPickup: false);
						break;
					}
				}
			}

			public void DropWeapon(int index, bool createPickup = true)
			{
				//IL_0175: Unknown result type (might be due to invalid IL or missing references)
				//IL_017a: Unknown result type (might be due to invalid IL or missing references)
				//IL_018a: Unknown result type (might be due to invalid IL or missing references)
				//IL_019f: Unknown result type (might be due to invalid IL or missing references)
				//IL_01a9: Unknown result type (might be due to invalid IL or missing references)
				if (index >= weaponData.Length || (Object)(object)weaponData[index].weaponDef == (Object)null)
				{
					return;
				}
				HunkWeaponData[] array = storedWeaponData;
				for (int i = 0; i < array.Length; i++)
				{
					HunkWeaponData hunkWeaponData = array[i];
					if ((Object)(object)hunkWeaponData.weaponDef == (Object)(object)weaponData[index].weaponDef)
					{
						return;
					}
				}
				HunkWeaponDef weaponDef = weaponData[index].weaponDef;
				int currentAmmo = weaponData[index].currentAmmo;
				int num = weaponData[index].totalAmmo;
				Array.Resize(ref storedWeaponData, storedWeaponData.Length + 1);
				storedWeaponData[storedWeaponData.Length - 1] = new HunkWeaponData
				{
					weaponDef = weaponDef,
					totalAmmo = num,
					currentAmmo = currentAmmo
				};
				for (int j = index; j < weaponData.Length - 1; j++)
				{
					weaponData[j] = weaponData[j + 1];
				}
				Array.Resize(ref weaponData, weaponData.Length - 1);
				if (NetworkServer.active && createPickup)
				{
					PickupDropletController.CreatePickupDroplet(PickupCatalog.FindPickupIndex(weaponDef.itemDef.itemIndex), hunk.characterBody.corePosition, hunk.characterBody.inputBank.aimDirection * 15f);
					inventory.RemoveItem(weaponDef.itemDef, 100);
				}
				if (index < equippedIndex)
				{
					equippedIndex--;
				}
				if (lastEquippedIndex == index)
				{
					lastEquippedIndex = 0;
					for (int k = 0; k < weaponData.Length; k++)
					{
						if (k != equippedIndex)
						{
							lastEquippedIndex = k;
						}
					}
					hunk.HandleBackWeapon();
				}
				else if (index < lastEquippedIndex)
				{
					lastEquippedIndex--;
				}
			}

			public void RemoveStoredData(HunkWeaponDef weaponDef)
			{
				int num = 0;
				for (int i = 0; i < storedWeaponData.Length; i++)
				{
					if (Object.op_Implicit((Object)(object)storedWeaponData[i].weaponDef) && (Object)(object)storedWeaponData[i].weaponDef == (Object)(object)weaponDef)
					{
						num = i;
					}
				}
				for (int j = num; j < storedWeaponData.Length - 1; j++)
				{
					storedWeaponData[j] = storedWeaponData[j + 1];
				}
				Array.Resize(ref storedWeaponData, storedWeaponData.Length - 1);
			}

			private void Update()
			{
			}

			private void AddWeaponItem(HunkWeaponDef weaponDef)
			{
				if (NetworkServer.active && inventory.GetItemCount(weaponDef.itemDef) <= 0)
				{
					inventory.GiveItemPermanent(weaponDef.itemDef, 1);
				}
			}

			private void SpawnKeycard()
			{
				if (!Object.op_Implicit((Object)(object)hunk) || disableVirus)
				{
					return;
				}
				if (Object.op_Implicit((Object)(object)hunk.characterBody) && !hunk.characterBody.isPlayerControlled)
				{
					spawnedKeycardThisStage = true;
					((MonoBehaviour)this).CancelInvoke();
					return;
				}
				if (!Helpers.canVirusSpawn)
				{
					spawnedKeycardThisStage = true;
					((MonoBehaviour)this).CancelInvoke();
					return;
				}
				if (Object.op_Implicit((Object)(object)hunk))
				{
					if (!hunk.shouldSpawnVirusEvent)
					{
						((MonoBehaviour)this).CancelInvoke();
						return;
					}
