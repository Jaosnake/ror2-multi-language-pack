				}
				((TMP_Text)targetText).text = string.Empty;
				((Component)targetText).gameObject.SetActive(false);
				durationDisplay.SetActive(false);
			}

			private void OnDestroy()
			{
				if (Object.op_Implicit((Object)(object)iDrive))
				{
					DriverController driverController = iDrive;
					driverController.onConsumeAmmo = (Action)Delegate.Remove(driverController.onConsumeAmmo, new Action(SetDisplay));
				}
			}

			private void Update()
			{
