		private class Pool<T> where T : class, IRecycleable, new()
		{
			private const int MIN_SIZE = 4;

			private static readonly T[] EmptyArray = new T[0];

			private T[] array;

			private int Count;

			public void Recycle(T obj)
			{
				if (this.array == EmptyArray)
				{
					this.array = new T[4];
				}
				else if (Count == this.array.Length)
				{
					T[] array = new T[this.array.Length * 2];
					T[] destinationArray = array;
					Array.Copy(this.array, destinationArray, this.array.Length + 1);
					this.array = destinationArray;
				}
				if (this.array != null)
				{
					if (this.array.Length <= Count)
					{
						throw new IndexOutOfRangeException();
					}
					this.array[Count] = obj;
					Count++;
				}
			}

			public T Get()
			{
				if (Count == 0)
				{
					return null;
				}
				if (Count - 1 < array.Length)
				{
					T result = array[Count - 1];
					array[Count - 1] = null;
					Count--;
					return result;
				}
				throw new IndexOutOfRangeException();
			}

			public void Clear()
			{
				int num = 0;
				if (0 < Count)
				{
					do
					{
						if (array.Length <= num)
						{
							throw new IndexOutOfRangeException();
						}
						array[num] = null;
					}
					while (num + 1 < Count);
				}
				Count = 0;
			}

			public Pool()
			{
				array = new T[4];
			}
		}

