		{
			((EntityState)this).PlayAnimation("Gesture, Override", javReady + "BolasThrow", "Hand.playbackRate", loopDuration, 0f);
			bolas.SetActive(false);
			((AimThrowableBase)this).OnExit();
		}
	}
