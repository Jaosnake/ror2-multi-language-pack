				foreach (GenericSkill val in componentsInChildren)
				{
					Object.DestroyImmediate((Object)(object)val);
				}
			}
			if (passiveEnabled)
			{
				LeeHyperrealPassive component = targetPrefab.GetComponent<LeeHyperrealPassive>();
				if (Object.op_Implicit((Object)(object)component))
				{
					component.orbPassiveSkillSlot = CreateGenericSkillWithSkillFamily(targetPrefab, "Lee: Hyperreal - Orbs and Ammo");
					component.hypermatrixPassiveSkillSlot = CreateGenericSkillWithSkillFamily(targetPrefab, "Lee: Hyperreal - Hypermatrix");
					component.VFXColorPassiveSkillSlot = CreateGenericSkillWithSkillFamily(targetPrefab, "Lee:_Hyperreal_-_VFX_Color");
				}
			}
			SkillLocator component2 = targetPrefab.GetComponent<SkillLocator>();
			component2.primary = CreateGenericSkillWithSkillFamily(targetPrefab, "Primary");
			component2.secondary = CreateGenericSkillWithSkillFamily(targetPrefab, "Secondary");
			component2.utility = CreateGenericSkillWithSkillFamily(targetPrefab, "Utility");
			component2.special = CreateGenericSkillWithSkillFamily(targetPrefab, "Special");
		}

