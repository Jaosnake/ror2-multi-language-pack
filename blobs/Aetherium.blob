					{
						ParticleSystem = ((Component)ItemDisplay).GetComponentsInChildren<ParticleSystem>();
						CharacterModel componentInParent = ((Component)ItemDisplay).GetComponentInParent<CharacterModel>();
						if (Object.op_Implicit((Object)(object)componentInParent))
						{
							CharacterBody body = componentInParent.body;
