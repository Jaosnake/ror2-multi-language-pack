	internal class LeeHyperrealNotification : GenericNotification
	{
		public Animator animator;

		public bool triggeredHide;

		public Material portraitOutline;

		public Material descriptionOutline;

		public Material descriptionInner;

		public void Start()
		{
			animator = ((Component)this).gameObject.GetComponent<Animator>();
			triggeredHide = false;
		}

		public void CheckNotificationVisibility(float t)
		{
			if (!Object.op_Implicit((Object)(object)animator))
			{
				animator = ((Component)this).gameObject.GetComponent<Animator>();
			}
			if (t >= 1f && !triggeredHide && Object.op_Implicit((Object)(object)animator))
			{
				triggeredHide = true;
				animator.SetTrigger("Outro");
			}
			if (t > 1.5f && triggeredHide)
			{
				Object.Destroy((Object)(object)((Component)this).gameObject);
			}
		}

		public void SetText(string title, string desc, CharacterMaster master)
		{
			//IL_0098: Unknown result type (might be due to invalid IL or missing references)
			//IL_00bb: Unknown result type (might be due to invalid IL or missing references)
			//IL_00c0: Unknown result type (might be due to invalid IL or missing references)
			//IL_0161: Unknown result type (might be due to invalid IL or missing references)
			//IL_0174: Unknown result type (might be due to invalid IL or missing references)
			//IL_0187: Unknown result type (might be due to invalid IL or missing references)
			base.titleText.token = title;
			base.descriptionText.token = desc;
			bool flag = false;
			if (Object.op_Implicit((Object)(object)master) && Object.op_Implicit((Object)(object)master.GetBody()) && Object.op_Implicit((Object)(object)master.GetBody().portraitIcon))
			{
				flag = true;
				base.iconImage.texture = master.GetBody().portraitIcon;
			}
			if (!flag)
			{
				base.iconImage.texture = LeeHyperreal.staticBodyPrefab.GetComponent<CharacterBody>().portraitIcon;
			}
			((Graphic)base.titleTMP).color = StaticValues.bodyColor;
			CharacterBody body = master.GetBody();
			if (Object.op_Implicit((Object)(object)body))
			{
				Color val = ParticleAssets.RetrieveParticleColor(body);
				portraitOutline = ((Graphic)((Component)((Component)this).gameObject.transform.Find("LeeNotificationExtraParent/LeeNotificationExtraParent2/CharacterPortraitbackground/CharacterPortrait/CharacterPortraitOutline")).gameObject.GetComponent<Image>()).material;
				descriptionOutline = ((Graphic)((Component)((Component)this).gameObject.transform.GetChild(0).GetChild(0).GetChild(0)).gameObject.GetComponent<Image>()).material;
				descriptionInner = ((Graphic)((Component)((Component)this).gameObject.transform.GetChild(0).GetChild(0).GetChild(0)
					.GetChild(0)).gameObject.GetComponent<Image>()).material;
				portraitOutline.SetColor("_GlowColor", val);
				descriptionOutline.SetColor("_GlowColor", val);
				descriptionInner.SetColor("_glowcolor", val);
			}
		}
	}
	internal class LeeHyperrealNotificationQueue : MonoBehaviour
	{
		public const float firstNotificationLengthSeconds = 8f;

		public const float repeatNotificationLengthSeconds = 8f;

		private TimedNotificationInfo notification;

		public event Action<LeeHyperrealNotificationQueue> onCurrentNotificationChanged;

		public static LeeHyperrealNotificationQueue GetNotificationQueueForMaster(CharacterMaster master)
		{
			if ((Object)(object)master != (Object)null)
			{
				LeeHyperrealNotificationQueue leeHyperrealNotificationQueue = ((Component)master).GetComponent<LeeHyperrealNotificationQueue>();
				if (!Object.op_Implicit((Object)(object)leeHyperrealNotificationQueue))
				{
					leeHyperrealNotificationQueue = ((Component)master).gameObject.AddComponent<LeeHyperrealNotificationQueue>();
				}
				return leeHyperrealNotificationQueue;
			}
			return null;
		}

		public static void PushNotification(CharacterMaster characterMaster, StaticValues.CustomItemEffect tokenPair)
		{
			//IL_0028: Unknown result type (might be due to invalid IL or missing references)
			//IL_0037: Expected O, but got Unknown
			if (((NetworkBehaviour)characterMaster).hasAuthority)
			{
				LeeHyperrealNotificationQueue notificationQueueForMaster = GetNotificationQueueForMaster(characterMaster);
				if (Object.op_Implicit((Object)(object)notificationQueueForMaster))
				{
					notificationQueueForMaster.PushNotification(new NotificationInfo((object)tokenPair, (TransformationInfo)null, false, 0), 6f);
				}
			}
		}

		private void PushNotification(NotificationInfo info, float duration)
		{
			//IL_0002: Unknown result type (might be due to invalid IL or missing references)
			//IL_0007: Unknown result type (might be due to invalid IL or missing references)
			//IL_000e: Unknown result type (might be due to invalid IL or missing references)
			//IL_001e: Unknown result type (might be due to invalid IL or missing references)
			//IL_002a: Expected O, but got Unknown
			notification = new TimedNotificationInfo
			{
				notification = info,
				startTime = Run.instance.fixedTime,
				duration = duration
			};
			this.onCurrentNotificationChanged?.Invoke(this);
		}

		public float GetCurrentNotificationT()
		{
			if ((Object)(object)Run.instance != (Object)null && notification != null)
			{
				return (Run.instance.fixedTime - notification.startTime) / notification.duration;
			}
			return 1f;
		}

		public NotificationInfo GetCurrentNotification()
		{
			return notification?.notification;
		}
	}
