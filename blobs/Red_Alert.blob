		public override UnlockableDef characterUnlockableDef => TeslaUnlockables.characterUnlockableDef;

		public override ItemDisplaysBase itemDisplays { get; } = new TeslaItemDisplays();


		public override void Initialize()
		{
			if (GeneralConfig.TeslaEnabled.Value)
			{
				base.Initialize();
				TeslaDamageTypes.Init();
			}
		}

		public override List<IEnumerator> GetAssetBundleInitializedCoroutines()
		{
			return TeslaAssets.GetAssetBundleInitializedCoroutines(assetBundle);
		}

		public override void OnCharacterInitialized()
		{
			TeslaUnlockables.Init();
			Config.ConfigureBody(prefabCharacterBody, "1-1. Tesla Trooper Body 0.1");
			TeslaConfig.Init();
			TeslaAssets.OnCharacterInitialized(assetBundle);
			TeslaStates.Init();
			TeslaTokens.Init();
			Language.PrintOutput("tesla.txt");
			TeslaColors.Init();
			TeslaBuffs.Init(assetBundle);
			TeslaCompat.Init();
			TeslaDeployables.Init();
			InitializeEntityStateMachines();
			InitializeSkills();
			InitializeSkins();
			InitializeCharacterMaster();
			AdditionalBodySetup();
			new TeslaTowerNotSurvivor().Initialize();
			AddHooks();
			Log.CurrentTime(bodyName + " initializecharacter done");
		}

		protected override void InitializeSurvivor()
		{
			base.InitializeSurvivor();
			VoiceLineInLobby voiceLineInLobby = displayPrefab.AddComponent<VoiceLineInLobby>();
			voiceLineInLobby.voiceLineContext = new VoiceLineContext("Tesla", 5, 4, 6);
			displayPrefab.AddComponent<MenuSoundComponent>().sound = "Play_Tesla_lobby";
			ChildLocator component = displayPrefab.GetComponent<ChildLocator>();
			((Component)component.FindChild("LightningParticles")).GetComponent<ParticleSystemRenderer>().trailMaterial = TeslaAssets.ChainLightningMaterial;
			((Component)component.FindChild("LightningParticles2")).GetComponent<ParticleSystemRenderer>().trailMaterial = TeslaAssets.ChainLightningMaterial;
		}

		private void AdditionalBodySetup()
		{
			VoiceLineController voiceLineController = bodyPrefab.AddComponent<VoiceLineController>();
			voiceLineController.voiceLineContext = new VoiceLineContext("Tesla", 5, 4, 6);
			bodyPrefab.AddComponent<TeslaTrackerComponent>();
			bodyPrefab.AddComponent<TeslaTrackerComponentZap>();
			bodyPrefab.AddComponent<TeslaTrackerComponentDash>();
			bodyPrefab.AddComponent<TeslaTowerControllerController>();
			bodyPrefab.AddComponent<TeslaWeaponComponent>();
			bodyPrefab.AddComponent<TeslaZapBarrierController>();
			if (GeneralCompat.VREnabled)
			{
				bodyPrefab.AddComponent<TeslaVRComponent>();
			}
			prefabCharacterModel.baseRendererInfos[0].defaultMaterial.SetEmission(2f);
			prefabCharacterModel.baseRendererInfos[5].defaultMaterial.SetEmission(2f);
			bodyPrefab.GetComponent<CharacterBody>().spreadBloomCurve = AnimationCurve.EaseInOut(0f, 0f, 0.5f, 1f);
			bodyPrefab.GetComponent<Interactor>().maxInteractionDistance = 5f;
			ChildLocator component = characterModelObject.GetComponent<ChildLocator>();
			((Component)component.FindChild("LightningParticles")).GetComponent<ParticleSystemRenderer>().trailMaterial = TeslaAssets.ChainLightningMaterial;
			((Component)component.FindChild("LightningParticles2")).GetComponent<ParticleSystemRenderer>().trailMaterial = TeslaAssets.ChainLightningMaterial;
			InitializeHitboxes();
		}

		private void InitializeHitboxes()
		{
			Prefabs.SetupHitBoxGroup(characterModelObject, "PunchHitbox", "PunchHitbox");
		}

		public override void InitializeEntityStateMachines()
		{
			Prefabs.ClearEntityStateMachines(bodyPrefab);
			Prefabs.AddMainEntityStateMachine(bodyPrefab, "Body", typeof(TeslaCharacterMain), typeof(SpawnTeleporterState));
			Prefabs.AddEntityStateMachine(bodyPrefab, "Weapon");
			Prefabs.AddEntityStateMachine(bodyPrefab, "Weapon2");
		}

		public override void InitializeSkills()
		{
			Skills.CreateSkillFamilies(bodyPrefab);
			InitializePrimarySkills();
			InitializeSecondarySkills();
			InitializeUtilitySkills();
			InitializeSpecialSkills();
			if (GeneralCompat.ScepterInstalled)
			{
				InitializeScepterSkills();
			}
			InitializeRecolorSkills();
			FinalizeCSSPreviewDisplayController();
		}

		private void InitializePrimarySkills()
		{
			//IL_0029: Unknown result type (might be due to invalid IL or missing references)
			//IL_009d: Unknown result type (might be due to invalid IL or missing references)
			TeslaTrackingSkillDef teslaTrackingSkillDef = Skills.CreateSkillDef<TeslaTrackingSkillDef>(new SkillDefInfo("Tesla_Primary_Zap", "HABIBI_TESLA_BODY_PRIMARY_ZAP_NAME", "HABIBI_TESLA_BODY_PRIMARY_ZAP_DESCRIPTION", assetBundle.LoadAsset<Sprite>("texTeslaSkillPrimary"), new SerializableEntityStateType(typeof(Zap))));
			((SkillDef)teslaTrackingSkillDef).keywordTokens = new string[1] { "HABIBI_TESLA_BODY_KEYWORD_CHARGED" };
			Skills.AddPrimarySkills(bodyPrefab, teslaTrackingSkillDef);
			if (GeneralConfig.Cursed.Value)
			{
				SkillDef val = Skills.CreateSkillDef(new SkillDefInfo("Tesla_Primary_Punch", "HABIBI_TESLA_BODY_PRIMARY_PUNCH_NAME", "HABIBI_TESLA_BODY_PRIMARY_PUNCH_DESCRIPTION", assetBundle.LoadAsset<Sprite>("texTeslaSkillSecondaryAlt"), new SerializableEntityStateType(typeof(ZapPunchWithDeflect))));
				Skills.AddPrimarySkills(bodyPrefab, val);
				Skills.AddUnlockablesToFamily(bodyPrefab.GetComponent<SkillLocator>().primary.skillFamily, default(UnlockableDef), TeslaUnlockables.cursedPrimaryUnlockableDef);
			}
		}

