{
    "ru": {
        "KENKO_CADET_NAME": "\u041a\u0430\u0434\u0435\u0442",
        "KENKO_CADET_DESCRIPTION": "\u041a\u0430\u0434\u0435\u0442 - \u0443\u043d\u0438\u0432\u0435\u0440\u0441\u0430\u043b\u044c\u043d\u044b\u0439 \u0441\u0442\u0440\u0435\u043b\u043e\u043a, \u0441\u043f\u043e\u0441\u043e\u0431\u043d\u044b\u0439 \u043c\u0430\u043d\u0435\u0432\u0440\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0432 \u0431\u043e\u044e \u0441 \u043e\u0440\u0443\u0436\u0438\u0435\u043c \u0431\u043b\u0438\u0436\u043d\u0435\u0433\u043e \u0440\u0430\u0434\u0438\u0443\u0441\u0430 \u0438 \u0431\u044b\u0441\u0442\u0440\u043e\u0439 \u043c\u043e\u0431\u0438\u043b\u044c\u043d\u043e\u0441\u0442\u044c\u044e.<color=#CCD3E0>\n\n< ! > \u0421\u0442\u0440\u0435\u043b\u044f\u0439\u0442\u0435 \u0432\u043f\u043b\u043e\u0442\u043d\u0443\u044e, \u0447\u0442\u043e\u0431\u044b \u044d\u0444\u0444\u0435\u043a\u0442\u0438\u0432\u043d\u043e \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u044c \u043e\u0433\u0440\u0430\u043d\u0438\u0447\u0435\u043d\u043d\u044b\u0439 \u0431\u043e\u0435\u0437\u0430\u043f\u0430\u0441 \u0431\u0435\u0437 \u0441\u043d\u0438\u0436\u0435\u043d\u0438\u044f \u0443\u0440\u043e\u043d\u0430.\n\n< ! > \u041f\u043b\u0430\u043d C \u0443\u0432\u0435\u043b\u0438\u0447\u0438\u0432\u0430\u0435\u0442 \u0443\u0440\u043e\u043d \u0438 \u0440\u0430\u0434\u0438\u0443\u0441 \u0432 \u0437\u0430\u0432\u0438\u0441\u0438\u043c\u043e\u0441\u0442\u0438 \u043e\u0442 \u0442\u0435\u043a\u0443\u0449\u0435\u0433\u043e \u0431\u043e\u0435\u0437\u0430\u043f\u0430\u0441\u0430, \u043f\u043e\u044d\u0442\u043e\u043c\u0443 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0439\u0442\u0435 \u0435\u0433\u043e, \u043a\u043e\u0433\u0434\u0430 \u043c\u0430\u0433\u0430\u0437\u0438\u043d \u043f\u043e\u043b\u043e\u043d.\n\n< ! > \u0418\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0439\u0442\u0435 \u041f\u0435\u0440\u0435\u043a\u0430\u0442 \u0441 \u043f\u0435\u0440\u0435\u0437\u0430\u0440\u044f\u0434\u043a\u043e\u0439, \u0447\u0442\u043e\u0431\u044b \u0431\u044b\u0441\u0442\u0440\u043e \u0438\u0437\u0431\u0435\u0436\u0430\u0442\u044c \u0432\u0437\u0440\u044b\u0432\u043d\u043e\u0433\u043e \u0443\u0440\u043e\u043d\u0430 \u0438 \u043f\u043e\u043b\u043d\u043e\u0441\u0442\u044c\u044e \u0432\u043e\u0441\u043f\u043e\u043b\u043d\u0438\u0442\u044c \u043c\u0430\u0433\u0430\u0437\u0438\u043d.\n\n< ! > \u0421\u0442\u0430\u0440\u0430\u0439\u0442\u0435\u0441\u044c \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u044c \u0414\u0440\u043e\u043d\u043e\u0432 \u042d\u0445\u043e \u043a\u0430\u043a \u043c\u043e\u0436\u043d\u043e \u0447\u0430\u0449\u0435, \u0442\u0430\u043a \u043a\u0430\u043a \u043e\u043d\u0438 \u043f\u043e\u043c\u043e\u0433\u0430\u044e\u0442 \u0443\u043d\u0438\u0447\u0442\u043e\u0436\u0430\u0442\u044c \u0432\u0440\u0430\u0433\u043e\u0432, \u043a\u043e\u0442\u043e\u0440\u044b\u0445 \u0432\u044b \u043c\u043e\u0433\u043b\u0438 \u043f\u0440\u043e\u043f\u0443\u0441\u0442\u0438\u0442\u044c \u0432\u043e \u0432\u0440\u0435\u043c\u044f \u043f\u0435\u0440\u0435\u0434\u0432\u0438\u0436\u0435\u043d\u0438\u044f. <i>Translated by: Jaosnake</i>",
        "KENKO_CADET_SUBTITLE": "\u0423\u043d\u0438\u0432\u0435\u0440\u0441\u0430\u043b\u044c\u043d\u044b\u0439 \u0421\u0442\u0440\u0435\u043b\u043e\u043a",
        "KENKO_CADET_DEFAULT_SKIN_NAME": "\u041e\u0431\u044b\u0447\u043d\u044b\u0439",
        "KENKO_CADET_MASTERY_SKIN_NAME": "\u041a\u0430\u0434\u0435\u0442: \u0421\u043f\u0435\u0446\u0438\u0430\u043b\u0438\u0441\u0442",
        "KENKO_CADET_PRIMARY_SMG_NAME": "\u041f\u0443\u043b\u0435\u043c\u0435\u0442\u043d\u044b\u0439 \u0428\u0442\u043e\u0440\u043c",
        "KENKO_CADET_PRIMARY_SMG_DESCRIPTION": "<style=cIsUtility>\u041f\u0440\u043e\u0432\u043e\u0440\u043d\u044b\u0439</style>. \u0421\u0442\u0440\u0435\u043b\u044f\u0439\u0442\u0435 \u043b\u0430\u0437\u0435\u0440\u043e\u043c \u043d\u0430 <style=cIsDamage>60% \u0443\u0440\u043e\u043d\u0430</style>. \u0422\u0440\u0435\u0431\u0443\u0435\u0442 <style=cIsUtility>\u043f\u0435\u0440\u0435\u0437\u0430\u0440\u044f\u0434\u043a\u0438</style> \u043f\u043e\u0441\u043b\u0435 20 \u0432\u044b\u0441\u0442\u0440\u0435\u043b\u043e\u0432. <i>Translated by: Jaosnake</i>",
        "KENKO_CADET_PRIMARY_SHOTGUN_NAME": "\u0420\u0430\u0437\u0440\u0443\u0448\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0435 \u041f\u0440\u0438\u043b\u0438\u0432\u044b",
        "KENKO_CADET_PRIMARY_SHOTGUN_DESCRIPTION": "<style=cIsUtility>\u041f\u0440\u043e\u0432\u043e\u0440\u043d\u044b\u0439</style>. \u0421\u0442\u0440\u0435\u043b\u044f\u0439\u0442\u0435 \u043e\u0447\u0435\u0440\u0435\u0434\u044c\u044e \u043d\u0430 <style=cIsDamage>3x100% \u0443\u0440\u043e\u043d\u0430</style>. \u0422\u0440\u0435\u0431\u0443\u0435\u0442 <style=cIsUtility>\u043f\u0435\u0440\u0435\u0437\u0430\u0440\u044f\u0434\u043a\u0438</style> \u043f\u043e\u0441\u043b\u0435 10 \u0441\u043d\u0430\u0440\u044f\u0434\u043e\u0432. <i>Translated by: Jaosnake</i>",
        "KENKO_CADET_SECONDARY_GRENADE_NAME": "\u041f\u043b\u0430\u043d B",
        "KENKO_CADET_SECONDARY_GRENADE_DESCRIPTION": "\u0421\u0442\u0440\u0435\u043b\u044f\u0439\u0442\u0435 \u0438\u0437 \u043b\u0451\u0433\u043a\u043e\u0433\u043e \u0433\u0440\u0430\u043d\u0430\u0442\u043e\u043c\u0451\u0442\u0430 \u043d\u0430 <style=cIsDamage>400% \u0443\u0440\u043e\u043d\u0430</style>. <i>Translated by: Jaosnake</i>",
        "KENKO_CADET_SECONDARY_THROWGUN_NAME": "\u041f\u043b\u0430\u043d C",
        "KENKO_CADET_SECONDARY_THROWGUN_DESCRIPTION": "\u0411\u0440\u043e\u0441\u0430\u0439\u0442\u0435 \u043e\u0440\u0443\u0436\u0438\u0435, \u043d\u0430\u043d\u043e\u0441\u044f <style=cIsDamage>250% \u0434\u043e 750% \u0443\u0440\u043e\u043d\u0430</style> \u0432 \u0437\u0430\u0432\u0438\u0441\u0438\u043c\u043e\u0441\u0442\u0438 \u043e\u0442 \u0442\u0435\u043a\u0443\u0449\u0435\u0433\u043e \u0431\u043e\u0435\u0437\u0430\u043f\u0430\u0441\u0430. <i>Translated by: Jaosnake</i>",
        "KENKO_CADET_UTILITY_SLIDE_NAME": "\u0421\u043a\u043e\u043b\u044c\u0436\u0435\u043d\u0438\u0435 \u0441 \u041f\u0435\u0440\u0435\u0437\u0430\u0440\u044f\u0434\u043a\u043e\u0439",
        "KENKO_CADET_UTILITY_SLIDE_DESCRIPTION": "\u0421\u043a\u043e\u043b\u044c\u0437\u043d\u0438\u0442\u0435 \u0432 \u043d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0438, <style=cIsUtility>\u043c\u0433\u043d\u043e\u0432\u0435\u043d\u043d\u043e \u043f\u0435\u0440\u0435\u0437\u0430\u0440\u044f\u0436\u0430\u044f</style> \u043e\u0440\u0443\u0436\u0438\u0435. <i>Translated by: Jaosnake</i>",
        "KENKO_CADET_UTILITY_ROLLOAD_NAME": "\u041f\u0435\u0440\u0435\u043a\u0430\u0442 \u0441 \u041f\u0435\u0440\u0435\u0437\u0430\u0440\u044f\u0434\u043a\u043e\u0439",
        "KENKO_CADET_UTILITY_ROLLOAD_DESCRIPTION": "\u041f\u0435\u0440\u0435\u043a\u0430\u0442\u0438\u0442\u0435\u0441\u044c \u0432 \u043d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0438, <style=cIsUtility>\u043c\u0433\u043d\u043e\u0432\u0435\u043d\u043d\u043e \u043f\u0435\u0440\u0435\u0437\u0430\u0440\u044f\u0436\u0430\u044f</style> \u043e\u0440\u0443\u0436\u0438\u0435. <i>Translated by: Jaosnake</i>",
        "KENKO_CADET_SPECIAL_ULTRA_NAME": "\u041f\u043b\u0430\u043d A",
        "KENKO_CADET_SPECIAL_ULTRA_DESCRIPTION": "<style=cIsUtility>\u041f\u0440\u043e\u0432\u043e\u0440\u043d\u044b\u0439</style>. \u0421\u0442\u0440\u0435\u043b\u044f\u0439\u0442\u0435 \u0442\u044f\u0436\u0451\u043b\u043e\u0439 \u043e\u0447\u0435\u0440\u0435\u0434\u044c\u044e \u0434\u0440\u043e\u0431\u0438 \u043d\u0430 <style=cIsDamage>32x150% \u0443\u0440\u043e\u043d\u0430</style>. <i>Translated by: Jaosnake</i>",
        "KENKO_CADET_SPECIAL_ECHO_NAME": "\u0414\u0440\u043e\u043d\u044b \u042d\u0445\u043e",
        "KENKO_CADET_SPECIAL_ECHO_DESCRIPTION": "\u0421\u043e\u0437\u0434\u0430\u0439\u0442\u0435 <style=cIsDamage>\u0434\u0432\u0443\u0445 \u0434\u0440\u043e\u043d\u043e\u0432</style>, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0438\u0449\u0443\u0442 \u0431\u043b\u0438\u0436\u0430\u0439\u0448\u0438\u0445 \u0432\u0440\u0430\u0433\u043e\u0432, \u043d\u0430\u043d\u043e\u0441\u044f <style=cIsDamage>2x370% \u0443\u0440\u043e\u043d\u0430</style>. <i>Translated by: Jaosnake</i>"
    }
}
