				LanguageAPI.Add(text + "KNIFE_RE4_DESCRIPTION", "A knife forged with infinite possibilities.");
				LanguageAPI.Add(text + "KNIFE_BLOODY_NAME", "Soiled Blade");
				LanguageAPI.Add(text + "KNIFE_BLOODY_DESCRIPTION", "A bloodied blade with a serrated edge that has torn up many opponents.");
				LanguageAPI.Add(text + "KNIFE_HOTDOGGER_NAME", "HOT DOGGER");
