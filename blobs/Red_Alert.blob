	internal class TeslaSkillsPlusCompat
	{
		[SkillLevelModifier("Tesla_Primary_Zap", new Type[] { typeof(Zap) })]
		internal class TeslaPrimaryModifier : BaseSkillModifier
		{
			public override void OnSkillEnter(BaseState skillState, int level)
			{
				((BaseSkillModifier)this).OnSkillEnter(skillState, level);
				if (skillState is Zap zap)
				{
					zap.skillsPlusCasts = Mathf.FloorToInt(BaseSkillModifier.AdditiveScaling(0f, 0.5f, level));
				}
			}
		}

		[SkillLevelModifier("Tesla_Secondary_BigZap", new Type[]
		{
			typeof(AimBigZap),
			typeof(BigZap),
			typeof(TowerBigZap)
		})]
		internal class TeslaSecondaryModifier : BaseSkillModifier
		{
			public override void OnSkillEnter(BaseState skillState, int level)
			{
				((BaseSkillModifier)this).OnSkillEnter(skillState, level);
				if (skillState is AimBigZap aimBigZap)
				{
					aimBigZap.skillsPlusMulti = BaseSkillModifier.MultScaling(1f, 0.1f, level);
				}
				else if (skillState is BigZap bigZap)
				{
					bigZap.skillsPlusAreaMulti = BaseSkillModifier.MultScaling(1f, 0.1f, level);
					bigZap.skillsPlusDamageMulti = BaseSkillModifier.MultScaling(1f, 0.1f, level);
				}
				else if (skillState is TowerBigZap towerBigZap)
				{
					towerBigZap.secondarySkillsPlusAreaMulti = BaseSkillModifier.MultScaling(1f, 0.1f, level);
					towerBigZap.secondarySkillsPlusDamageMulti = BaseSkillModifier.MultScaling(1f, 0.05f, level);
				}
			}
		}

		[SkillLevelModifier("Tesla_Utility_ShieldZap", new Type[] { typeof(ShieldZapCollectDamage) })]
		internal class TeslaUtilityModifier : BaseSkillModifier
		{
			public override void OnSkillEnter(BaseState skillState, int level)
			{
				((BaseSkillModifier)this).OnSkillEnter(skillState, level);
				if (skillState is ShieldZapCollectDamage shieldZapCollectDamage)
				{
					shieldZapCollectDamage.skillsPlusSeconds = BaseSkillModifier.AdditiveScaling(0f, 0.5f, level);
				}
			}
		}

		[SkillLevelModifier("Tesla_Special_Tower", new Type[] { })]
		internal class TeslaSpecialModifier : BaseSkillModifier
		{
			public override void OnSkillLeveledUp(int level, CharacterBody characterBody, SkillDef skillDef)
			{
				((BaseSkillModifier)this).OnSkillLeveledUp(level, characterBody, skillDef);
				skillDef.baseMaxStock = (int)BaseSkillModifier.AdditiveScaling(1f, 0.334f, level);
				SkillsPlusAdditionalTowers = (int)BaseSkillModifier.AdditiveScaling(0f, 0.334f, level);
				TowerLifetime.skillsPlusSeconds = BaseSkillModifier.AdditiveScaling(0, 1, level);
			}
		}

		[SkillLevelModifier("Tesla_Special_Scepter_Tower", new Type[] { })]
		internal class TeslaSpecialScepterModifier : BaseSkillModifier
		{
			public override void OnSkillLeveledUp(int level, CharacterBody characterBody, SkillDef skillDef)
			{
				((BaseSkillModifier)this).OnSkillLeveledUp(level, characterBody, skillDef);
				skillDef.baseMaxStock = (int)BaseSkillModifier.AdditiveScaling(2f, 0.334f, level);
				SkillsPlusAdditionalTowers = (int)BaseSkillModifier.AdditiveScaling(0f, 0.334f, level);
				TowerLifetime.skillsPlusSeconds = BaseSkillModifier.AdditiveScaling(0, 1, level);
			}
		}

		public static int SkillsPlusAdditionalTowers;

		[MethodImpl(MethodImplOptions.NoInlining | MethodImplOptions.NoOptimization)]
		public static void init()
		{
			SkillModifierManager.LoadSkillModifiers();
		}
	}
	public static class TeslaVRCompat
	{
		public static void init()
		{
			if (VR.enabled && MotionControls.enabled)
			{
				GeneralCompat.VREnabled = true;
				RoR2Application.onLoad = (Action)Delegate.Combine(RoR2Application.onLoad, new Action(LoadCustomHands));
			}
		}

		private static void LoadCustomHands()
		{
			GameObject val = CharacterBase<TeslaTrooperSurvivor>.instance.assetBundle.LoadAsset<GameObject>("VRRightHandPrefab");
			GameObject val2 = CharacterBase<TeslaTrooperSurvivor>.instance.assetBundle.LoadAsset<GameObject>("VRLeftHandPrefab");
			MotionControls.AddHandPrefab(val);
			MotionControls.AddHandPrefab(val2);
			MotionControls.AddSkillBindingOverride("TeslaTrooperBody", (SkillSlot)0, (SkillSlot)2, (SkillSlot)3, (SkillSlot)1);
		}
	}
