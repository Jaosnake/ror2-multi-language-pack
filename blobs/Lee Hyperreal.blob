		public static float ScaleAttackSpeed(float inputAttackSpeed)
		{
			float num = Mathf.InverseLerp(1f, 2.5f, inputAttackSpeed);
			return Mathf.Lerp(1f, 1.35f, num);
		}

		public static float ScaleMoveSpeed(float inputMoveSpeed)
		{
			float num = Mathf.InverseLerp(1f, 25f, inputMoveSpeed);
			return Mathf.Lerp(1f, 2.5f, num);
		}
	}
	internal static class Tokens
	{
		internal static string GenerateName()
		{
			Random random = new Random();
			int index = random.Next(StaticValues.prefix.Count);
			string text = StaticValues.prefix[index];
			int index2 = random.Next(StaticValues.suffix.Count);
			string text2 = StaticValues.suffix[index2];
			return text + " " + text2;
		}

		internal static void AddTokens()
		{
			//IL_0d34: Unknown result type (might be due to invalid IL or missing references)
			//IL_0d43: Unknown result type (might be due to invalid IL or missing references)
			//IL_0d52: Unknown result type (might be due to invalid IL or missing references)
			string text = GenerateName();
			string text2 = "POPCORN_LEE_HYPERREAL_BODY_";
			string text3 = Helpers.Lee("Lee: Hyperreal", text) + " is a highly technical grounded character with hard to master gameplay. He entirely focuses on damage to the detriment of his survivability." + Environment.NewLine + Environment.NewLine + "<!> " + Helpers.UtilDesc("[3-ping]s") + " do " + Helpers.DmgDesc("4 times") + " the damage compared to 1 or 2-pings of the same color so always try to manipulate the orb list to do " + Helpers.UtilDesc("[3-ping]s") + "." + Environment.NewLine + Environment.NewLine + "<!> On a successful parry with " + Helpers.UtilDesc("[Armament Barrage]") + ", you can instantly parry again. With decent timing, you can reduce/entirely negate damage. Projectiles parried will be reflected with their damage multiplied. Hitting enemies with this ability will regen orbs faster." + Environment.NewLine + Environment.NewLine + "<!> Entering the " + Helpers.UtilDesc("[Hypermatrix]") + " is your time to shine. Delete those bosses but watch out for the end-lag on orb skills in Hypermatrix." + Environment.NewLine + Environment.NewLine + "<!> Try to keep your ammo counters filled. Get " + Helpers.UtilDesc("[Enhanced Bullets]") + " from parrying, and " + Helpers.UtilDesc("[Coloured Bullets]") + " from " + Helpers.UtilDesc("[3-ping]s") + " " + Environment.NewLine + Environment.NewLine + "<!> " + Helpers.UtilDesc("[Snipe Stance]") + " is your highest damaging tool, even more so with " + Helpers.UtilDesc("[Enhanced Bullets]") + ". However, you’re vulnerable in this stance, so use this skill wisely." + Environment.NewLine + Environment.NewLine + "<!> " + Helpers.UtilDesc("[End of Time]") + " can decimate a huge radius of enemies with its unlimited range and huge radius. But be mindful of its long cooldown.";
			string text4 = "\"The tests are going well?\"" + Environment.NewLine + Environment.NewLine + "Crisp footsteps from expensive shoes sounded too loud in the medically sterile chambers." + Environment.NewLine + Environment.NewLine + "\"Yes, sir. Did you feel that just now?\"" + Environment.NewLine + Environment.NewLine + "The deep hum of energy that swept through the disinfected floors vibrated against the shoes, the expensive pair and the worn-down pair." + Environment.NewLine + Environment.NewLine + "\"That was a weapons test, sir. Handheld weapon.\"" + Environment.NewLine + Environment.NewLine + "That put a falter in the footsteps. \"Handheld?\"" + Environment.NewLine + Environment.NewLine + "\"Yes sir. It’s come a long way since you were here last.\"" + Environment.NewLine + Environment.NewLine + "\"Hrm. Well, the weapons won’t mean much if the subject is another defect. Are we close?\"" + Environment.NewLine + Environment.NewLine + "\"Yes sir, right this way.\"" + Environment.NewLine + Environment.NewLine + "The shabby, chemical-stained and malfunction-burnt shoes pulled ahead, and fumbling hands reached for a card he’d been gifted for the day. They knew he’d be a nervous wreck, but it fed their guest’s ego, which meant he had a happier visit." + Environment.NewLine + Environment.NewLine + "A single swipe, a retinal scan he’d just been given access to, and they were in a room neither of them had seen before." + Environment.NewLine + Environment.NewLine + "\"It’s… is it an it? Or a he?\"" + Environment.NewLine + Environment.NewLine + "Words from a memorized infographic filled his head. \"It’s both, sir. The biosynthesis worked perfectly, unlike previous tests. It’s a perfect combination.\"" + Environment.NewLine + Environment.NewLine + "\"I see. So it is organic?\"" + Environment.NewLine + Environment.NewLine + "\"It’s cybernetic, but you are correct. And it wasn’t easy, sir. Like growing a square watermelon with natural selection.\"" + Environment.NewLine + Environment.NewLine + "\"Yes yes, I get your point. The funds will be transferred on my return.\"" + Environment.NewLine + Environment.NewLine + "\"Thank you, sir.\"" + Environment.NewLine + Environment.NewLine + "The expensive shoes turned to leave, but were stopped by a sudden thought. \"Say… you’ve tested it, right?\"" + Environment.NewLine + Environment.NewLine + "A nervous swallow, an unexpected question. \"Hm? Oh, uh— no, I guess we haven’t.\"" + Environment.NewLine + Environment.NewLine + "\"Hm. Well fix that, or else I’ll have to view it as a liability. You don’t want to repeat the last mistake, do you?\"" + Environment.NewLine + Environment.NewLine + "The bitter words made the shabby shoes falter, and an access card trembled inside an acid-burned hand. \"No, Mr. Wade. No we don’t. We’ll send you footage of the live testing, for your decision.\"" + Environment.NewLine + Environment.NewLine + "An hour later, a large case was stowed in the loading bay, and a UES high priority boarding card let a pair of shabby shoes and acrid burns onto the Safe Travels.";
			string text5 = "..and so he left, still no closer to his true reality.";
			string text6 = "..and so he vanished, with a mission unfulfilled.";
			LanguageAPI.Add(text2 + "NAME", Helpers.Lee("Lee: Hyperreal", text, Config.isBlueName.Value) ?? "");
			LanguageAPI.Add(text2 + "DESCRIPTION", text3);
			LanguageAPI.Add(text2 + "SUBTITLE", "Hypermatrix Traverser");
			LanguageAPI.Add(text2 + "LORE", text4);
			LanguageAPI.Add(text2 + "OUTRO_FLAVOR", text5);
			LanguageAPI.Add(text2 + "OUTRO_FAILURE", text6);
			LanguageAPI.Add(text2 + "SURVIVOR_POD_EXIT", "Traverse Dimension");
			LanguageAPI.Add(text2 + "DEFAULT_SKIN_NAME", "Lee: Hyperreal");
			LanguageAPI.Add(text2 + "ALT_SKIN_NAME", "Lee: Real");
			LanguageAPI.Add(text2 + "SCARLET_SKIN_NAME", "Lee: Scarlet Redeemer");
			LanguageAPI.Add(text2 + "PROSPECTOR_SKIN_NAME", text + ": Prospector");
			LanguageAPI.Add(text2 + "PROSPECTOR_ALT_SKIN_NAME", text + ": Comrade");
			LanguageAPI.Add(text2 + "YI_SKIN_NAME", "Yi");
			LanguageAPI.Add(text2 + "BK_SKIN_NAME", "Boykisser");
			LanguageAPI.Add(text2 + "PASSIVE_ORB_AND_AMMO_NAME", "Orb and Ammo System");
			LanguageAPI.Add(text2 + "PASSIVE_ORB_AND_AMMO_DESCRIPTION", Helpers.Lee("Lee: Hyperreal", text) + " uses " + Helpers.UtilDesc("[Orbs]") + " that allow the execution of unique skills. His " + Helpers.UtilDesc("[Ammo Counter]") + " grants unique effects for " + Helpers.UtilDesc("[Snipe Stance]") + ".");
			LanguageAPI.Add(text2 + "PASSIVE_DOMAIN_NAME", "Hypermatrix System");
			LanguageAPI.Add(text2 + "PASSIVE_DOMAIN_DESCRIPTION", Helpers.Lee("Lee: Hyperreal", text) + " has access to the " + Helpers.UtilDesc("[Hypermatrix]") + ", by holding the Primary button down with a full " + Helpers.UtilDesc("[Power Gauge]") + ". " + Helpers.Lee("Lee: Hyperreal", text) + " gains more hits in place of attack speed, however Snipe Stance scales normally.");
			LanguageAPI.Add(text2 + "PASSIVE_VFX_COLOR_NAME", "VFX Color");
			LanguageAPI.Add(text2 + "PASSIVE_DEFAULT_VFX_NAME", "Default VFX");
			LanguageAPI.Add(text2 + "PASSIVE_DEFAULT_VFX_DESCRIPTION", "Sets the VFX colour to the default based on the skin choice");
			LanguageAPI.Add(text2 + "PASSIVE_RED_VFX_NAME", "Red VFX");
			LanguageAPI.Add(text2 + "PASSIVE_RED_VFX_DESCRIPTION", "Sets the VFX colour to Red");
			LanguageAPI.Add(text2 + "PASSIVE_ORANGE_VFX_NAME", "Orange VFX");
			LanguageAPI.Add(text2 + "PASSIVE_ORANGE_VFX_DESCRIPTION", "Sets the VFX colour to Orange");
			LanguageAPI.Add(text2 + "PASSIVE_YELLOW_VFX_NAME", "Yellow VFX");
			LanguageAPI.Add(text2 + "PASSIVE_YELLOW_VFX_DESCRIPTION", "Sets the VFX colour to Yellow");
			LanguageAPI.Add(text2 + "PASSIVE_GREEN_VFX_NAME", "Green VFX");
			LanguageAPI.Add(text2 + "PASSIVE_GREEN_VFX_DESCRIPTION", "Sets the VFX colour to Green");
			LanguageAPI.Add(text2 + "PASSIVE_BLUE_VFX_NAME", "Blue VFX");
			LanguageAPI.Add(text2 + "PASSIVE_BLUE_VFX_DESCRIPTION", "Sets the VFX colour to Blue");
			LanguageAPI.Add(text2 + "PASSIVE_LIGHTBLUE_VFX_NAME", "Light Blue VFX");
			LanguageAPI.Add(text2 + "PASSIVE_LIGHTBLUE_VFX_DESCRIPTION", "Sets the VFX colour to Light Blue");
			LanguageAPI.Add(text2 + "PASSIVE_VIOLET_VFX_NAME", "Violet VFX");
			LanguageAPI.Add(text2 + "PASSIVE_VIOLET_VFX_DESCRIPTION", "Sets the VFX colour to Violet");
			LanguageAPI.Add(text2 + "PASSIVE_PINK_VFX_NAME", "Pink VFX");
			LanguageAPI.Add(text2 + "PASSIVE_PINK_VFX_DESCRIPTION", "Sets the VFX colour to Pink");
			LanguageAPI.Add(text2 + "PASSIVE_RAINBOW_VFX_NAME", "Rainbow VFX");
			LanguageAPI.Add(text2 + "PASSIVE_RAINBOW_VFX_DESCRIPTION", "Randomly selects a VFX from any color");
			LanguageAPI.Add(text2 + "PRIMARY_NAME", "Armament Barrage");
			LanguageAPI.Add(text2 + "PRIMARY_DESCRIPTION", "Launch a 5-string-combo attack. On hit 1 and 3, perform a " + Helpers.UtilDesc("[Parry]") + " active for a short time. In the air, slam down, dealing " + Helpers.DmgDesc($"{400f}% damage") + ", increasing up to " + Helpers.DmgDesc($"{3f}x times,") + " based on distance travelled. Hold down at anytime with a full " + Helpers.UtilDesc("[Power Gauge]") + " to enter the " + Helpers.UtilDesc("[Hypermatrix]"));
			LanguageAPI.Add(text2 + "SECONDARY_SNIPE_NAME", "Snipe");
			LanguageAPI.Add(text2 + "SECONDARY_SNIPE_DESCRIPTION", "Shoot a bullet for " + Helpers.DmgDesc($"{400f}% damage") + ".");
			LanguageAPI.Add(text2 + "EXIT_SNIPE_NAME", "Exit Snipe Stance");
			LanguageAPI.Add(text2 + "EXIT_SNIPE_DESCRIPTION", "Exit " + Helpers.UtilDesc("[Snipe Stance]") + ", allowing you to move again.");
			LanguageAPI.Add(text2 + "ENTER_SNIPE_NAME", "Snipe Stance");
			LanguageAPI.Add(text2 + "ENTER_SNIPE_DESCRIPTION", "Enter " + Helpers.UtilDesc("[Snipe Stance]") + ", locking you in place, allowing you to Snipe using Primary for " + Helpers.DmgDesc($"{400f}% damage") + ".");
			LanguageAPI.Add(text2 + "DASH_NAME", "Reality Travel");
			LanguageAPI.Add(text2 + "DASH_DESCRIPTION", Helpers.UtilDesc("Dodge") + ", turning invincible for a short time.");
			LanguageAPI.Add(text2 + "ULTIMATE_NAME", "End of Time");
			LanguageAPI.Add(text2 + "ULTIMATE_DESCRIPTION", "Turn invincible, pulling out a cannon that blasts enemies in a wide radius for " + Helpers.DmgDesc($"{6500f}% damage") + " after a short windup. Move changes while in the " + Helpers.UtilDesc("[Hypermatrix]") + ".");
			LanguageAPI.Add(text2 + "ULTIMATE_DOMAIN_NAME", "Collapsing Realm");
			LanguageAPI.Add(text2 + "ULTIMATE_DOMAIN_DESCRIPTION", "Collapse the " + Helpers.UtilDesc("[Hypermatrix]") + ", turning invincible for a short time and dealing " + Helpers.DmgDesc($"{1500f}% damage") + " in your wake.Each 3-Ping during hypermatrix adds 3 hits of 200% damage to " + Helpers.UtilDesc("[Collapsing Realm]"));
			LanguageAPI.Add(text2 + "ITEM_EFFECT_TITLE", "Hyper effect");
			LanguageAPI.Add(text2 + "ITEM_EFFECT_BACKUPMAG_DESC", Helpers.Lee("Lee: Hyperreal", text) + " gains " + Helpers.UtilDesc("+1") + " " + Helpers.Stack("(+1 per stack)") + " Enhanced bullet(s) on each successful " + Helpers.UtilDesc("[Parry]"));
			LanguageAPI.Add(text2 + "ITEM_EFFECT_ALIEN_HEAD_DESC", Helpers.Lee("Lee: Hyperreal", text) + "'s orbs charge " + Helpers.UtilDesc("25% faster") + ".");
			LanguageAPI.Add(text2 + "ITEM_EFFECT_PURITY_DESC", Helpers.Lee("Lee: Hyperreal", text) + "'s orb recharge rate is reduced by " + Helpers.UtilDesc("2") + " " + Helpers.Stack("(+1 per stack)") + " seconds");
			LanguageAPI.Add(text2 + "ITEM_EFFECT_ATTACK_SPEED_DESC", Helpers.Lee("Lee: Hyperreal", text) + "'s primary gains more " + Helpers.UtilDesc("hits") + " instead of attack speed. E.g. 250% attack speed = 2 hits and a half damage hit.");
			LanguageAPI.Add(text2 + "ITEM_EFFECT_LUMINOUS_SHOT_DESC", Helpers.Lee("Lee: Hyperreal", text) + "'s Snipe Stance shots give " + Helpers.UtilDesc("1 Stack") + " per shot instead of using Secondary");
			LanguageAPI.Add(text2 + "KEYWORD_ORBS", Helpers.Keyword("Orb System") + Environment.NewLine + Helpers.Lee("Lee: Hyperreal", text) + " uses 3 different coloured Orbs to use extra skills." + Environment.NewLine + "In Simple Mode, activate " + Helpers.BlueOrb() + ", " + Helpers.RedOrb() + " and " + Helpers.YellowOrb() + " orbs using the keys " + Helpers.UserSetting($"{Config.blueOrbTrigger.Value}, {Config.redOrbTrigger.Value}, {Config.yellowOrbTrigger.Value}") + " respectively, to use the first group of coloured orbs going from left to right. " + Environment.NewLine + "Using 3 adjacent orbs of the same color, known as a " + Helpers.UtilDesc("[3-ping]") + ", will increase the orb's skill damage by " + Helpers.DmgDesc($"{4f}x times") + ", while also granting extra attacks for " + Helpers.RedOrb() + " and " + Helpers.YellowOrb() + " Orbs.");
			LanguageAPI.Add(text2 + "KEYWORD_AMMO", Helpers.Keyword("Ammo System") + Environment.NewLine + Helpers.Lee("Lee: Hyperreal", text) + " can store and use a variety of " + Helpers.UtilDesc("Ammo") + ", indicated above the " + Helpers.UtilDesc("[Power Gauge]") + "." + Environment.NewLine + "Using a " + Helpers.UtilDesc("[3-ping]") + " will store a " + Helpers.UtilDesc("[Coloured Bullet]") + ", which can be used in the " + Helpers.UtilDesc("[Hypermatrix]") + " to add 3 Orbs of that shots colour back into your " + Helpers.UtilDesc("[Orb System]") + " by Sniping during it." + Environment.NewLine + "Upon a successful " + Helpers.UtilDesc("[Parry]") + ", " + Helpers.UtilDesc("[Enhancedd Bullet]'s") + " are granted, increasing the damage of your next shot in " + Helpers.UtilDesc("[Snipe Stance]") + " by " + Helpers.DmgDesc($"{2f}x times.  "));
			LanguageAPI.Add(text2 + "KEYWORD_SNIPE_STANCE", Helpers.Keyword("Snipe Stance") + Environment.NewLine + "Enter a stance which immobilises you, changing your " + Helpers.UserSetting("Primary Skill") + " to a Sniping shot that deals " + Helpers.DmgDesc($"{400f}% Damage") + " per shot." + Environment.NewLine + "Using " + Helpers.UserSetting("Utility Skill") + " without any directional input allows you to dodge backwards while firing a bullet that deals " + Helpers.DmgDesc($"{400f}% Damage") + ". Using this skill otherwise cancels the stance.");
			LanguageAPI.Add(text2 + "KEYWORD_POWER_GAUGE", Helpers.Keyword("Power Gauge") + Environment.NewLine + "The Power Gauge situated above the Health gauge determines when you can enter the " + Helpers.UtilDesc("[Hypermatrix]") + ", and how long left before exiting. Hold the " + Helpers.UserSetting("Primary Skill") + " to enter the " + Helpers.UtilDesc("[Hypermatrix]") + ".");
			LanguageAPI.Add(text2 + "KEYWORD_PARRY", Helpers.Keyword("Parry") + Environment.NewLine + "Upon a successful parry, stun the enemy that dealt the damage if they can be stunned. Any projectile parried will be shot back in the direction you aim at. A successful parry resets " + Helpers.UtilDesc("[Armament Barrage]") + ", starting from the move used to parry again.");
			LanguageAPI.Add(text2 + "KEYWORD_DOMAIN", Helpers.Keyword("Hypermatrix System") + Environment.NewLine + "Above your Health is the " + Helpers.UtilDesc("[Hypermatrix System Gauge]") + ". When the gauge is full, holding " + Helpers.UserSetting("Primary Skill") + " at any time in " + Helpers.UtilDesc("[Armament Barrage]") + " will transition him into the " + Helpers.UtilDesc("[Hypermatrix]") + ". " + Environment.NewLine + "While in this state, " + Helpers.RedOrb() + " and " + Helpers.YellowOrb() + " orbs change entirely, and your Special becomes " + Helpers.UtilDesc("[Collapsing Realm]") + "." + Environment.NewLine + "If the gauge runs out while in this state, " + Helpers.UtilDesc("[Collapsing Realm]") + " will trigger automatically, exiting you out of the " + Helpers.UtilDesc("[Hypermatrix]") + ".");
			LanguageAPI.Add(text2 + "KEYWORD_DOMAIN_ULT", Helpers.Keyword("Collapsing Realm") + Environment.NewLine + "Collapse the " + Helpers.UtilDesc("[Hypermatrix]") + ", turning invincible for a short time and dealing " + Helpers.DmgDesc($"{1500f}% damage") + " in your wake. add 3 hits of " + Helpers.DmgDesc(string.Format("{0}% damage every time you use a {1} in hypermatrix. max of 4 times for 12 hits extra.", 200f, Helpers.UtilDesc("[3-ping]"))));
			LanguageAPI.Add("LEE_HYPERREAL_BODY_BROTHER_RESPONSE_ENTRY", "How did you get here?");
			LanguageAPI.Add("LEE_HYPERREAL_BODY_BROTHER_RESPONSE_ON_DEATH_1", "Pray in your own dimension.");
			LanguageAPI.Add("LEE_HYPERREAL_BODY_BROTHER_RESPONSE_ON_DEATH_2", "Another reality won't save you from me.");
			LanguageAPI.Add("LEE_HYPERREAL_BODY_BROTHER_RESPONSE_ON_DEATH_3", "I'll crush every copy of you.");
			LanguageAPI.Add("ACHIEVEMENT_" + text2 + "MASTERYUNLOCKABLE_ACHIEVEMENT_NAME", Helpers.Lee("Lee: Hyperreal", text) + ": Mastery");
			LanguageAPI.Add("ACHIEVEMENT_" + text2 + "MASTERYUNLOCKABLE_ACHIEVEMENT_DESCRIPTION", "As " + Helpers.Lee("Lee: Hyperreal", text) + ", beat the game or obliterate on Monsoon.");
			LanguageAPI.Add(text2 + "MASTERYUNLOCKABLE_UNLOCKABLE_NAME", Helpers.Lee("Lee: Hyperreal", text) + ": Mastery");
			LanguageAPI.Add("ACHIEVEMENT_" + text2 + "BLUESKIN_ACHIEVEMENT_NAME", Helpers.Lee("Lee: Hyperreal", text) + ": Real");
			LanguageAPI.Add("ACHIEVEMENT_" + text2 + "BLUESKIN_ACHIEVEMENT_DESCRIPTION", "As " + Helpers.Lee("Lee: Hyperreal", text) + ", beat the game on Monsoon with Transcendence, or Roll for a 5% chance from a Medium chest or higher tier.");
			LanguageAPI.Add(text2 + "BLUESKIN_UNLOCKABLE_NAME", Helpers.Lee("Lee: Hyperreal", text) + ": Real");
			LanguageAPI.Add("ACHIEVEMENT_" + text2 + "SCARLET_ACHIEVEMENT_NAME", Helpers.Lee("Lee: Hyperreal", text) + ": Scarlet");
			LanguageAPI.Add("ACHIEVEMENT_" + text2 + "SCARLET_ACHIEVEMENT_DESCRIPTION", "As " + Helpers.Lee("Lee: Hyperreal", text) + ", beat the game on Monsoon with no watches and bleed items, or Roll for a 5% chance from a Legendary chest.");
			LanguageAPI.Add(text2 + "SCARLET_UNLOCKABLE_NAME", Helpers.Lee("Lee: Hyperreal", text) + ": Scarlet");
			LanguageAPI.Add("ACHIEVEMENT_" + text2 + "YELLOW_VFX_ACHIEVEMENT_NAME", Helpers.Lee("Lee: Hyperreal", text) + ": Yellow VFX");
			LanguageAPI.Add("ACHIEVEMENT_" + text2 + "YELLOW_VFX_ACHIEVEMENT_DESCRIPTION", "As " + Helpers.Lee("Lee: Hyperreal", text) + ", beat the game on Monsoon while holding 5 or more Boss Tier Items, or Roll any chest for a 2% chance.");
			LanguageAPI.Add(text2 + "YELLOW_VFX_UNLOCKABLE_NAME", Helpers.Lee("Lee: Hyperreal", text) + ": Yellow VFX");
			LanguageAPI.Add("ACHIEVEMENT_" + text2 + "GREEN_VFX_ACHIEVEMENT_NAME", Helpers.Lee("Lee: Hyperreal", text) + ": Green VFX");
			LanguageAPI.Add("ACHIEVEMENT_" + text2 + "GREEN_VFX_ACHIEVEMENT_DESCRIPTION", "As " + Helpers.Lee("Lee: Hyperreal", text) + ", beat the game on Monsoon while holding 15 or more Healing items (RoR2 items only), or Roll any chest for a 2% chance.");
			LanguageAPI.Add(text2 + "GREEN_VFX_UNLOCKABLE_NAME", Helpers.Lee("Lee: Hyperreal", text) + ": Green VFX");
			LanguageAPI.Add("ACHIEVEMENT_" + text2 + "PINK_VFX_ACHIEVEMENT_NAME", Helpers.Lee("Lee: Hyperreal", text) + ": Pink VFX");
			LanguageAPI.Add("ACHIEVEMENT_" + text2 + "PINK_VFX_ACHIEVEMENT_DESCRIPTION", "As " + Helpers.Lee("Lee: Hyperreal", text) + ", kill the Teleporter boss with End of Time at max strength, or Roll any chest for a 2% chance.");
			LanguageAPI.Add(text2 + "PINK_VFX_UNLOCKABLE_NAME", Helpers.Lee("Lee: Hyperreal", text) + ": Pink VFX");
			LanguageAPI.Add("ACHIEVEMENT_" + text2 + "VIOLET_VFX_ACHIEVEMENT_NAME", Helpers.Lee("Lee: Hyperreal", text) + ": Violet VFX");
			LanguageAPI.Add("ACHIEVEMENT_" + text2 + "VIOLET_VFX_ACHIEVEMENT_DESCRIPTION", "As " + Helpers.Lee("Lee: Hyperreal", text) + ", beat the game on Eclipse 8, or Roll for a 1% chance from a Legendary chest.");
			LanguageAPI.Add(text2 + "VIOLET_VFX_UNLOCKABLE_NAME", Helpers.Lee("Lee: Hyperreal", text) + ": Violet VFX");
		}
	}
	internal class Unlockables
	{
		public static UnlockableDef masteryUnlockableDef;

		public static UnlockableDef blueSkinUnlockableDef;

		public static UnlockableDef scarletUnlockableDef;

		public static UnlockableDef yellowVFXUnlockableDef;

		public static UnlockableDef greenVFXUnlockableDef;

		public static UnlockableDef pinkVFXUnlockableDef;

		public static UnlockableDef violetVFXUnlockableDef;

		public static void Initialize()
		{
			masteryUnlockableDef = ContentPacks.CreateAndAddUnlockbleDef("POPCORN_LEE_HYPERREAL_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_ID", Helpers.GetAchievementNameToken("POPCORN_LEE_HYPERREAL_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT"), LeeHyperrealAssets.mainAssetBundle.LoadAsset<Sprite>("ProspectorSkinRedIcon"));
			blueSkinUnlockableDef = ContentPacks.CreateAndAddUnlockbleDef("POPCORN_LEE_HYPERREAL_BODY_BLUESKIN_ACHIEVEMENT_ID", Helpers.GetAchievementNameToken("POPCORN_LEE_HYPERREAL_BODY_BLUESKIN_ACHIEVEMENT"), LeeHyperrealAssets.mainAssetBundle.LoadAsset<Sprite>("texCloneSkin"));
			scarletUnlockableDef = ContentPacks.CreateAndAddUnlockbleDef("POPCORN_LEE_HYPERREAL_BODY_SCARLET_ACHIEVEMENT_ID", Helpers.GetAchievementNameToken("POPCORN_LEE_HYPERREAL_BODY_SCARLET_ACHIEVEMENT"), LeeHyperrealAssets.mainAssetBundle.LoadAsset<Sprite>("texScarletSkin"));
			yellowVFXUnlockableDef = ContentPacks.CreateAndAddUnlockbleDef("POPCORN_LEE_HYPERREAL_BODY_YELLOW_VFX_ACHIEVEMENT_ID", Helpers.GetAchievementNameToken("POPCORN_LEE_HYPERREAL_BODY_YELLOW_VFX_ACHIEVEMENT"), LeeHyperrealAssets.mainAssetBundle.LoadAsset<Sprite>("VFXIconYellow"));
			greenVFXUnlockableDef = ContentPacks.CreateAndAddUnlockbleDef("POPCORN_LEE_HYPERREAL_BODY_GREEN_VFX_ACHIEVEMENT_ID", Helpers.GetAchievementNameToken("POPCORN_LEE_HYPERREAL_BODY_GREEN_VFX_ACHIEVEMENT"), LeeHyperrealAssets.mainAssetBundle.LoadAsset<Sprite>("VFXIconGreen"));
			pinkVFXUnlockableDef = ContentPacks.CreateAndAddUnlockbleDef("POPCORN_LEE_HYPERREAL_BODY_PINK_VFX_ACHIEVEMENT_ID", Helpers.GetAchievementNameToken("POPCORN_LEE_HYPERREAL_BODY_PINK_VFX_ACHIEVEMENT"), LeeHyperrealAssets.mainAssetBundle.LoadAsset<Sprite>("VFXIconPink"));
			violetVFXUnlockableDef = ContentPacks.CreateAndAddUnlockbleDef("POPCORN_LEE_HYPERREAL_BODY_VIOLET_VFX_ACHIEVEMENT_ID", Helpers.GetAchievementNameToken("POPCORN_LEE_HYPERREAL_BODY_VIOLET_VFX_ACHIEVEMENT"), LeeHyperrealAssets.mainAssetBundle.LoadAsset<Sprite>("VFXIconViolet"));
		}
	}
	public abstract class BaseMasteryUnlockable : BaseAchievement
	{
		public abstract string RequiredCharacterBody { get; }

		public abstract float RequiredDifficultyCoefficient { get; }

		public override void OnBodyRequirementMet()
		{
			((BaseAchievement)this).OnBodyRequirementMet();
			Run.onClientGameOverGlobal += OnClientGameOverGlobal;
		}

		public override void OnBodyRequirementBroken()
		{
			Run.onClientGameOverGlobal -= OnClientGameOverGlobal;
			((BaseAchievement)this).OnBodyRequirementBroken();
		}

		public override BodyIndex LookUpRequiredBodyIndex()
		{
			//IL_0007: Unknown result type (might be due to invalid IL or missing references)
			//IL_000c: Unknown result type (might be due to invalid IL or missing references)
			//IL_000f: Unknown result type (might be due to invalid IL or missing references)
			return BodyCatalog.FindBodyIndex(RequiredCharacterBody);
		}

		private void OnClientGameOverGlobal(Run run, RunReport runReport)
		{
			//IL_002f: Unknown result type (might be due to invalid IL or missing references)
			//IL_0034: Unknown result type (might be due to invalid IL or missing references)
			//IL_0035: Unknown result type (might be due to invalid IL or missing references)
			//IL_0077: Unknown result type (might be due to invalid IL or missing references)
			//IL_0079: Invalid comparison between Unknown and I4
			//IL_007b: Unknown result type (might be due to invalid IL or missing references)
			//IL_007e: Invalid comparison between Unknown and I4
			if (!Object.op_Implicit((Object)(object)runReport.gameEnding) || !runReport.gameEnding.isWin)
			{
				return;
			}
			DifficultyIndex val = runReport.ruleBook.FindDifficulty();
			DifficultyDef difficultyDef = DifficultyCatalog.GetDifficultyDef(val);
			if (difficultyDef != null)
			{
				bool flag = difficultyDef.countsAsHardMode && difficultyDef.scalingValue >= RequiredDifficultyCoefficient;
				bool flag2 = difficultyDef.nameToken == "INFERNO_NAME";
				bool flag3 = (int)val >= 3 && (int)val <= 10;
				if (flag || flag2 || flag3)
				{
					((BaseAchievement)this).Grant();
				}
			}
		}
	}
}
namespace LeeHyperrealMod.Modules.Networking
{
	internal class AchievementGranterNetworkRequest : INetMessage, ISerializableObject
	{
