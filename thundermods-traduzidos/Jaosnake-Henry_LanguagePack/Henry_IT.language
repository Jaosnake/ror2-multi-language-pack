{
    "IT": {
        "ROB_HENRY_BODY_NAME": "Enrico",
        "ROB_HENRY_BODY_DESCRIPTION": "Henry è un abile combattente che usa un vasto arsenale di armi per abbattere i suoi nemici.<color=#CCD3E0>",
        "ROB_HENRY_BODY_SUBTITLE": "Il Prescelto",
        "ROB_HENRY_BODY_LORE": "tradizione del campione",
        "ROB_HENRY_BODY_OUTRO_FLAVOR": "..e così se ne andò, in cerca di una nuova identità.",
        "ROB_HENRY_BODY_OUTRO_FAILURE": "..e così svanì, per sempre una tabula rasa.",
        "ROB_HENRY_BODY_DEFAULT_SKIN_NAME": "Predefinito",
        "ROB_HENRY_BODY_MASTERY_SKIN_NAME": "Alternativo",
        "ROB_HENRY_BODY_TYPHOON_SKIN_NAME": "V1",
        "ROB_HENRY_BODY_DANTE_SKIN_NAME": "Dante",
        "ROB_HENRY_BODY_VERGIL_SKIN_NAME": "Vergil",
        "ROB_HENRY_BODY_SAMURAI_SKIN_NAME": "Samurai",
        "ROB_HENRY_BODY_SOLDIER_SKIN_NAME": "Campione",
        "ROB_HENRY_BODY_ZOMBIE_SKIN_NAME": "Zombie",
        "ROB_HENRY_BODY_SKELETON_SKIN_NAME": "Scheletro",
        "ROB_HENRY_BODY_PASSIVE_NAME": "Passiva di Henry",
        "ROB_HENRY_BODY_PASSIVE_DESCRIPTION": "Testo di esempio.",
        "ROB_HENRY_BODY_PRIMARY_SLASH_NAME": "Spada",
        "ROB_HENRY_BODY_PRIMARY_SLASH_DESCRIPTION": "<style=cIsUtility>Agile.</style> Oscilla in avanti per <style=cIsDamage>280% di danno</style>.",
        "ROB_HENRY_BODY_PRIMARY_PUNCH_NAME": "Guantoni da Boxe",
        "ROB_HENRY_BODY_PRIMARY_PUNCH_DESCRIPTION": "<style=cIsUtility>Agile.</style> Colpisci rapidamente per <style=cIsDamage>240% di danno</style>. <style=cIsUtility>Ignora l’armatura.</style>",
        "ROB_HENRY_BODY_PRIMARY_GUN_NAME": "Pistola",
        "ROB_HENRY_BODY_PRIMARY_GUN_DESCRIPTION": "<style=cIsUtility>Agile.</style> Spara con una piccola pistola per <style=cIsDamage>90% di danno</style>.",
        "ROB_HENRY_BODY_SECONDARY_GUN_NAME": "Pistola",
        "ROB_HENRY_BODY_SECONDARY_GUN_DESCRIPTION": "<style=cIsUtility>Agile.</style> Spara con una pistola per <style=cIsDamage>420% di danno</style>.",
        "ROB_HENRY_BODY_SECONDARY_STINGER_NAME": "Stinger",
        "ROB_HENRY_BODY_SECONDARY_STINGER_DESCRIPTION": "<style=cIsUtility>Agile.</style> Scatta contro un nemico per <style=cIsDamage>450% di danno</style>.",
        "ROB_HENRY_BODY_SECONDARY_UZI_NAME": "Uzi",
        "ROB_HENRY_BODY_SECONDARY_UZI_DESCRIPTION": "Spara con una uzi per <style=cIsDamage>75% di danno</style>.",
        "ROB_HENRY_BODY_UTILITY_ROLL_NAME": "Rotolata",
        "ROB_HENRY_BODY_UTILITY_ROLL_DESCRIPTION": "Rotola per una breve distanza, ottenendo <style=cIsUtility>300 armatura</style>. <style=cIsUtility>Non puoi essere colpito durante la rotolata.</style>",
        "ROB_HENRY_BODY_UTILITY_SHOTGUN_NAME": "Shotgun",
        "ROB_HENRY_BODY_UTILITY_SHOTGUN_DESCRIPTION": "Spara con uno <style=cIsUtility>shotgun</style> per <style=cIsDamage>14x140% di danno</style>, spingendoti con il rinculo.",
        "ROB_HENRY_BODY_SPECIAL_BOMB_NAME": "Bomba",
        "ROB_HENRY_BODY_SPECIAL_BOMB_DESCRIPTION": "Lancia una bomba per <style=cIsDamage>1600% di danno</style>.",
        "ROB_HENRY_BODY_SPECIAL_SCEPBOMB_NAME": "Più Bombe!",
        "ROB_HENRY_BODY_SPECIAL_SCEPBOMB_DESCRIPTION": "Lancia una bomba per <style=cIsDamage>1600% di danno</style>.\n<color=#d299ff>SCEPTER: tieni fino a 4 bombe. Tempo di ricarica dimezzato.</color>",
        "ROB_HENRY_BODY_SPECIAL_BAZOOKA_NAME": "Bazooka",
        "ROB_HENRY_BODY_SPECIAL_BAZOOKA_DESCRIPTION": "Carica e spara razzi per <style=cIsDamage>600%-1600% di danno</style>.",
        "ROB_HENRY_BODY_PRIMARY_BAZOOKA_NAME": "Spara",
        "ROB_HENRY_BODY_PRIMARY_BAZOOKA_DESCRIPTION": "Carica e spara un razzo per <style=cIsDamage>600%-1600% di danno</style>.",
        "ROB_HENRY_BODY_PRIMARY_BAZOOKAOUT_NAME": "Annulla",
        "ROB_HENRY_BODY_PRIMARY_BAZOOKAOUT_DESCRIPTION": "Riponi il tuo <style=cIsDamage>bazooka</style>.",
        "ROB_HENRY_BODY_SPECIAL_SCEPBAZOOKA_NAME": "Armageddon",
        "ROB_HENRY_BODY_SPECIAL_SCEPBAZOOKA_DESCRIPTION": "Carica e spara razzi per <style=cIsDamage>600%-1600% di danno</style>.\n<color=#d299ff>SCEPTER: tieni due Bazooka contemporaneamente.</color>",
        "ROB_HENRY_BODY_PRIMARY_SCEPBAZOOKA_NAME": "Spara",
        "ROB_HENRY_BODY_PRIMARY_SCEPBAZOOKA_DESCRIPTION": "Carica e spara un razzo per <style=cIsDamage>600%-1600% di danno</style>.\n<color=#d299ff>SCEPTER: tieni due Bazooka contemporaneamente.</color>",
        "ROB_HENRY_BODY_SPECIAL_FRENZY_NAME": "Rampage",
        "ROB_HENRY_BODY_SPECIAL_FRENZY_DESCRIPTION": "Accumula <style=cIsHealth>Fury</style> colpendo. Usala quando è carica per entrare in <style=cIsDamage>frenesia</style> per <style=cIsUtility>10 secondi</style>. <style=cIsHealth>Si carica più velocemente con poca salute.</style>",
        "ROB_HENRY_BODY_SPECIAL_SCEPFRENZY_NAME": "Super Saiyan",
        "ROB_HENRY_BODY_SPECIAL_SCEPFRENZY_DESCRIPTION": "Accumula <style=cIsHealth>Fury</style> colpendo. Usala quando è carica per entrare in <style=cIsDamage>frenesia</style> per <style=cIsUtility>10 secondi</style>. <style=cIsHealth>Si carica più velocemente con poca salute.</style>\n<color=#d299ff>SCEPTER: bonus alle statistiche molto aumentati. Durata aumentata.</color>",
        "ACHIEVEMENT_ROB_HENRY_BODY_UNLOCKABLE_ACHIEVEMENT_ID_NAME": "Prelude",
        "ACHIEVEMENT_ROB_HENRY_BODY_UNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "Entra nelle Pianure Titaniche.",
        "ACHIEVEMENT_ROB_HENRY_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_ID_NAME": "Henry: Mastery",
        "ACHIEVEMENT_ROB_HENRY_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "Come Henry, completa il gioco o obliterati a Monsone.",
        "ACHIEVEMENT_ROB_HENRY_BODY_TYPHOONUNLOCKABLE_ACHIEVEMENT_ID_NAME": "Henry: Grand Mastery",
        "ACHIEVEMENT_ROB_HENRY_BODY_TYPHOONUNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "Come Henry, completa il gioco o obliterati a Tifone o Eclipse.\n<color=#8888>(Conta qualsiasi difficoltà Tifone o superiore)</color>",
        "ROB_HENRY_BODY_DANTEUNLOCKABLE_ACHIEVEMENT_NAME": "Henry: Jackpot",
        "ROB_HENRY_BODY_DANTEUNLOCKABLE_ACHIEVEMENT_DESC": "As Henry, defeat a Twisted Scavenger on Monsoon.",
        "ROB_HENRY_BODY_DANTEUNLOCKABLE_UNLOCKABLE_NAME": "Henry: Jackpot",
        "ROB_HENRY_BODY_VERGILUNLOCKABLE_ACHIEVEMENT_NAME": "Henry: 200% Motivated",
        "ROB_HENRY_BODY_VERGILUNLOCKABLE_ACHIEVEMENT_DESC": "As Henry, defeat the King of Nothing with no items.",
        "ROB_HENRY_BODY_VERGILUNLOCKABLE_UNLOCKABLE_NAME": "Henry: 200% Motivated",
        "ACHIEVEMENT_ROB_HENRY_MASTERYACHIEVEMENT_NAME": "Henry: Mastery",
        "ACHIEVEMENT_ROB_HENRY_MASTERYACHIEVEMENT_DESCRIPTION": "Nei panni di Henry, finisci il gioco o distruggi durante Monsoon.",
        "ROB_MRGREEN_BODY_NAME": "Mr. Green",
        "ROB_MRGREEN_BODY_DESCRIPTION": "Mr. Green<color=#CCD3E0>\n\n< ! > Sword is a good all-rounder while Boxing Gloves are better for laying a beatdown on more powerful foes.\n\n< ! > Pistol is a powerful anti air, with its low cooldown and high damage.\n\n< ! > Roll has a lingering armor buff that helps to use it aggressively.\n\n< ! > Bomb can be used to wipe crowds with ease.</color>",
        "ROB_MRGREEN_BODY_SUBTITLE": "Il",
        "ROB_MRGREEN_BODY_LORE": "lore di esempio parte 2",
        "ROB_MRGREEN_BODY_OUTRO_FLAVOR": "..and so he left, bottom text.",
        "ROB_MRGREEN_BODY_DEFAULT_SKIN_NAME": "Predefinito",
        "ROB_MRGREEN_BODY_PASSIVE_NAME": "Passiva di Mr. Green",
        "ROB_MRGREEN_BODY_PASSIVE_DESCRIPTION": "Testo di esempio.",
        "ROB_MRGREEN_BODY_PRIMARY_PUNCH_NAME": "Martial Arts",
        "ROB_MRGREEN_BODY_PRIMARY_PUNCH_DESCRIPTION": "Esegui una rapida combo di pugni e calci per <style=cIsDamage>90% di danno</style>.",
        "ROB_MRGREEN_BODY_SECONDARY_CLONETHROW_NAME": "Lancio Clone",
        "ROB_MRGREEN_BODY_SECONDARY_CLONETHROW_DESCRIPTION": "Evoca un clone e lancialo in avanti, afferrando i nemici vicini e schiantandoli a terra per <style=cIsDamage>420% di danno</style>.",
        "ROB_MRGREEN_BODY_UTILITY_DASH_NAME": "People's Elbow",
        "ROB_MRGREEN_BODY_UTILITY_DASH_DESCRIPTION": "Scatta per una breve distanza. A contatto con un <style=cIsUtility>clone</style>, balzi in aria e ricadi con una potente <style=cIsUtility>gomitata</style> per <style=cIsDamage>800% di danno</style>.",
        "ROB_MRGREEN_BODY_SPECIAL_RES_NAME": "Resurrection",
        "ROB_MRGREEN_BODY_SPECIAL_RES_DESCRIPTION": "Resuscita tutti i cloni caduti.",
        "ROB_NEMRY_BODY_NAME": "Nemesis Henry",
        "ROB_NEMRY_BODY_DESCRIPTION": "Nemesis Henry is a volatile swordsman who wields a special blade that stores energy to boost its attacks. He has no cooldowns, but must manage his energy well.<color=#CCD3E0>\n\n< ! > Sword Mode is used to build up energy while Gun Mode is used to spend energy for powerful attacks.\n\n< ! > Swordmaster can be charged up for more damage.\n\n< ! > Flash Step is a powerful aggressive tool that helps to build up energy.\n\n< ! > Use Hydra Bite to stay healthy and Hyper Beam to unleash a ton of damage.</color>",
        "ROB_NEMRY_BODY_SUBTITLE": "Il Caduto",
        "ROB_NEMRY_BODY_LORE": "lore di esempio",
        "ROB_NEMRY_BODY_OUTRO_FLAVOR": "..and so he left, having blown up the moon for no discernible reason.",
        "ROB_NEMRY_BODY_OUTRO_FAILURE": "..he tried so hard, and got so far. But in the end it doesn't even matter.",
        "ROB_NEMRY_BODY_DEFAULT_SKIN_NAME": "Nemesis",
        "ROB_NEMRY_BODY_MASTERY_SKIN_NAME": "Captive #001",
        "ROB_NEMRY_BODY_TYPHOON_SKIN_NAME": "FLLFFL",
        "ROB_NEMRY_BODY_PASSIVE_NAME": "Gunblade acida",
        "ROB_NEMRY_BODY_PASSIVE_DESCRIPTION": "Nemesis Henry brandisce un’arma speciale che può alternare Sword Mode e Gun Mode. Le sue abilità non hanno ricariche normali, ma usano il sistema di <style=cIsHealing>Energia</style> della spada.",
        "ROB_NEMRY_BODY_PRIMARY_SPEAR_NAME": "Trafiggi",
        "ROB_NEMRY_BODY_PRIMARY_SPEAR_DESCRIPTION": "<style=cIsUtility>Agile.</style> Trafiggi in avanti per <style=cIsDamage>160% danno</style>. <style=cIsDamage>molto <style=cIsHealing>50%</style> Cura il 50% del danno inflitto.</style>.",
        "ROB_WEAPON_SWAP_SKILL": "Weapon Swap",
        "ROB_NEMRY_BODY_PRIMARY_SWORD_NAME": "Sword Mode",
        "ROB_NEMRY_BODY_PRIMARY_SWORD_DESCRIPTION": "Swing your blade forward for <style=cIsDamage>280% damage</style>. Generate <style=cIsHealing>20% Energy</style> on hit.",
        "ROB_NEMRY_BODY_PRIMARY_GUN_NAME": "Gun Mode",
        "ROB_NEMRY_BODY_PRIMARY_GUN_DESCRIPTION": "<style=cIsHealing>2.5% Energy.</style> Fire a piercing <style=cIsHealing>Energy</style> shot for <style=cIsDamage>240% damage</style>.",
        "ROB_NEMRY_BODY_PRIMARY_SWORDCSS_NAME": "Sword Mode / Gun Mode",
        "ROB_NEMRY_BODY_PRIMARY_SWORDCSS_DESCRIPTION": "Swing your blade forward for <style=cIsDamage>280% damage</style>. Generate <style=cIsHealing>20% Energy</style> on hit.\n<style=cIsHealing>2.5% Energy.</style> Fire a piercing <style=cIsHealing>Energy</style> shot for <style=cIsDamage>240% damage</style>.",
        "ROB_NEMRY_BODY_SECONDARY_BLAST_NAME": "Null Blast",
        "ROB_NEMRY_BODY_SECONDARY_BLAST_DESCRIPTION": "<style=cIsUtility>Agile.</style> Lancia una massa di energia misteriosa per <style=cIsDamage>200% danno</style>.",
        "ROB_NEMRY_BODY_SECONDARY_CHARGE_NAME": "Swordmaster",
        "ROB_NEMRY_BODY_SECONDARY_CHARGE_DESCRIPTION": "<style=cIsHealing>10% Energia.</style> Scatta verso un nemico vicino per <style=cIsDamage>700% danno</style>.",
        "ROB_NEMRY_BODY_SECONDARY_TORRENT_NAME": "Gunslinger",
        "ROB_NEMRY_BODY_SECONDARY_TORRENT_DESCRIPTION": "<style=cIsHealing>5% Energia.</style> Spara una raffica di Energia.",
        "ROB_NEMRY_BODY_SECONDARY_CHARGECSS_NAME": "Swordmaster / Gunslinger",
        "ROB_NEMRY_BODY_SECONDARY_CHARGECSS_DESCRIPTION": "<style=cIsHealing>10% Energia.</style> Scatta verso un nemico vicino per <style=cIsDamage>700% danno</style>.\n<style=cIsHealing>5% Energia.</style> Spara una raffica di Energia.",
        "ROB_NEMRY_BODY_UTILITY_DODGESLASH_NAME": "Taglio rapido",
        "ROB_NEMRY_BODY_UTILITY_DODGESLASH_DESCRIPTION": "Esegui un salto all’indietro e taglia i nemici vicini per <style=cIsDamage>300% danno</style>.",
        "ROB_NEMRY_BODY_UTILITY_BLINK_NAME": "Flash Step",
        "ROB_NEMRY_BODY_UTILITY_BLINK_DESCRIPTION": "<style=cIsHealing>5% Energia.</style> Scatta verso un nemico vicino per",
        "ROB_NEMRY_BODY_UTILITY_BURST_NAME": "Esplosione di energia",
        "ROB_NEMRY_BODY_UTILITY_BURST_DESCRIPTION": "<style=cIsHealing>10% Energia.</style> Scarica energia e spingiti con il rinculo per <style=cIsDamage>400% danno</style>.",
        "ROB_NEMRY_BODY_UTILITY_BLINKCSS_NAME": "Flash Step / Esplosione di energia",
        "ROB_NEMRY_BODY_UTILITY_BLINKCSS_DESCRIPTION": "<style=cIsHealing>5% Energia.</style> Scatta verso un nemico vicino per\n<style=cIsHealing>10% Energia.</style> Scarica energia e spingiti con il rinculo per <style=cIsDamage>400% danno</style>.",
        "ROB_NEMRY_BODY_SPECIAL_STAB_NAME": "Hydra Bite",
        "ROB_NEMRY_BODY_SPECIAL_STAB_DESCRIPTION": "<style=cIsHealing>100% Energia.</style> Affonda la lama in un nemico per <style=cIsDamage>2800% danno</style>. <style=cIsHealing>Cura il 50% del danno inflitto.</style>",
        "ROB_NEMRY_BODY_SPECIAL_BEAM_NAME": "Hyper Beam",
        "ROB_NEMRY_BODY_SPECIAL_BEAM_DESCRIPTION": "<style=cIsHealing>100% Energia.</style> Carica una potente raffica di laser per <style=cIsDamage>10x540% danno</style>.",
        "ROB_NEMRY_BODY_SPECIAL_STABCSS_NAME": "Hydra Bite / Hyper Beam",
        "ROB_NEMRY_BODY_SPECIAL_STABCSS_DESCRIPTION": "<style=cIsHealing>100% Energia.</style> Affonda la lama in un nemico per <style=cIsDamage>2800% danno</style>. <style=cIsHealing>Cura il 50% del danno inflitto.</style>\n<style=cIsHealing>100% Energia.</style> Carica una potente raffica di laser per <style=cIsDamage>molto danno</style>.",
