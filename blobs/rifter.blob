	public static class RifterStates
	{
		public static void Init()
		{
			Content.AddEntityState(typeof(RiftBase));
			Content.AddEntityState(typeof(RiftFocus));
			Content.AddEntityState(typeof(RiftGauntletShort));
			Content.AddEntityState(typeof(RiftBuckshot));
			Content.AddEntityState(typeof(SlipstreamIn));
			Content.AddEntityState(typeof(Slipstream));
			Content.AddEntityState(typeof(PortalBaseState));
			Content.AddEntityState(typeof(PortalLocate));
			Content.AddEntityState(typeof(PortalDrop));
			Content.AddEntityState(typeof(ModifiedTeleport));
			Content.AddEntityState(typeof(FractureShot));
			Content.AddEntityState(typeof(FaultLine));
			Content.AddEntityState(typeof(FireRiftProjectile));
			Content.AddEntityState(typeof(ChainedWorlds));
			Content.AddEntityState(typeof(ChainedWorldsStartup));
			Content.AddEntityState(typeof(TimelockDrop));
			Content.AddEntityState(typeof(TimelockLocate));
			Content.AddEntityState(typeof(RifterMain));
		}
	}
	public static class RifterStaticValues
	{
		public const float blastRadius = 6.75f;

		public const float fractureCoefficient = 0.75f;

		public const float fractureCoefficientMax = 1.5f;

		public const float primaryRiftCoefficient = 5f;

		public const float buckshotRiftCoefficient = 2.8f;

		public const float buckshotWeakRiftCoefficient = 1.2f;

		public const float secondaryRiftCoefficient = 4.6f;

		public const float wanderingRiftCoefficient = 7f;

		public const float wRiftOnPrimaryBlastCoefficient = 3f;

		public const float riftPrimaryDistance = 45f;

		public const float riftSecondaryDistance = 25f;

		public const float riftSpecialDistance = 65f;

		public const float overchargedCoefficient = 1.2f;

		public const float timelockBlast = 5f;

		public const float portalBlast = 1.5f;

		public const float timelockEnemyMultiplier = 1.2f;

		public const float timelockRadius = 15f;
	}
	public static class RifterTokens
	{
		public static void Init()
		{
			AddRifterTokens();
			Language.PrintOutput("Rifter.txt");
		}

		public static void AddRifterTokens()
		{
			string text = "BLAKE_RIFTER_";
			string text2 = "The Rifter utilizes strategic positioning to create devestating rifts in reality.<color=#CCD3E0>" + Environment.NewLine + Environment.NewLine + "<!> Rifts are significantly stronger than fracture lines - positioning is key!" + Environment.NewLine + Environment.NewLine + "<!> Utilizing your primary's long-range and mid-range capabilities allow you to mix up your positions." + Environment.NewLine + Environment.NewLine + "<!> Certain skills can teleport enemies, while some are conditional. Using this power can keep enemies at bay." + Environment.NewLine + Environment.NewLine + "<!> Timelock can be a powerful tool for gathering enemies and blasting them all at once!" + Environment.NewLine + Environment.NewLine;
			string text3 = "..and so he left a fractured world behind.";
			string text4 = "..and so he vanished from all realms.";
			string text5 = "\"...Funny...\"\r\n\r\n\"Yeah. Real funny.\"\r\n\r\n\"It just... appeared?\"\r\n\r\n\"Well that's what they're sticking to, at least.\"\r\n\r\n\"Huh. Never imagined <i>we'd</i> be the ones they'd keep secrets from.\"\r\n\r\n\"I guess they can't have their Science Division knowing everything that comes their way.\"\r\n\r\nHannegan peered through the strange, glassy substance. He wanted to describe it as glass, but his need for concrete evidence got the better of him. He also wanted to tap it.\r\n\r\nHe tapped it.\r\n\r\nIt resonated in a very peculiar frequency, almost... like it was clipping in and out of time? He kept the thought in mind, but hesitated to draw conclusions from it.\r\n\r\n\"Hannegan, you know how much I hate it when you touch samples without permission.\"\r\n\r\n\"Permission to touch it?\"\r\n\r\n\"...Yes... It's not reactive to touch.\"\r\n\r\n\"Did they specify the material of this... glassy stuff?\"\r\n\r\n\"No. And it's not our point of interest.\"\r\n\r\nThe lead scientist, D.O. Harold Schmeuller, gestured toward the glassy substance, but not the substance itself. He pointed at what was <i>inside</i>.\r\n\r\n\"They say they've got readings of a crude, yet incomprehensibly advanced object which has the ability to teleport objects.\"\r\n\r\n\"You make that sound special. We've already worked out a way to teleport things. What's the difference?\"\r\n\r\n\"The intel I have been given suggests it appeared -- not just through space -- but through <i>time</i>.\"\r\n\r\n\"Time? That's impossi-\"\r\n\r\n\"Impossible, yes. Unless it isn't. Our task here is to find out how this thing teleports through time and space, and to replicate it. Project Rifter, is what they're calling it. Also, remember, Hannegan, we test weapons, <i>not</i> convenience items.";
			Language.Add(text + "NAME", "Rifter");
			Language.Add(text + "DESCRIPTION", text2);
			Language.Add(text + "SUBTITLE", "The Fractured One");
			Language.Add(text + "LORE", text5);
			Language.Add(text + "OUTRO_FLAVOR", text3);
			Language.Add(text + "OUTRO_FAILURE", text4);
			Language.Add(text + "MASTERY_SKIN_NAME", "Survivalist");
			Language.Add(text + "PASSIVE_RIFT_BOOST", "Shatter");
			Language.Add(text + "PASSIVE_RIFT_BOOST_DESCRIPTION", "Slows by 10% and reduces armor by 5. Stacks linearly.");
			Language.Add(text + "PASSIVE_RIFT_FRACTURE", "Rift/Fracture");
			Language.Add(text + "PASSIVE_RIFT_FRACTURE_DESCRIPTION", "Rifts and fracture lines weaken the closer they are to rifter.");
			Language.Add(text + "PRIMARY_GAUNTLET_RANGED", "Focused Rift");
			Language.Add(text + "PRIMARY_GAUNTLET_RANGED_DESCRIPTION", $"<style=cIsUtility>Fracture</style>. Shoot a far-ranged rift for <style=cIsDamage>{500f}% damage</style>, dealing up to 5 shatter. If secondary skill is held, shoot a mid-range rift for <style=cIsDamage>{400.0}%</style>.");
			Language.Add(text + "PRIMARY_BUCKSHOT", "Scattered Rifts");
			Language.Add(text + "PRIMARY_BUCKSHOT_DESCRIPTION", $"<style=cIsUtility>Fracture</style>. Shoot a rift for <style=cIsDamage>{280f} damage</style> that ripples for <style=cIsDamage>5 x {120.00001f}% damage</style>. Deals 5 shatter. If secondary skill is held, shoot at mid-range.");
			Language.Add(text + "SECONDARY_FRACTURE", "Fracture Shot");
			Language.Add(text + "SECONDARY_FRACTURE_DESCRIPTION", $"Shoot <style=cIsDamage>3 x {75f}% damage</style> piercing fracture shots.");
			Language.Add(text + "SECONDARY_FAULT_LINE", "Wandering Rift");
			Language.Add(text + "SECONDARY_FAULT_LINE_DESCRIPTION", $"Throw out a slow, dormant rift. Rift will activate for <style=cIsDamage>{300f}% damage</style> when another rift activates. On impact it will explode for <style=cIsDamage>{700f}% damage</style> and apply 10 stacks of shatter. Cannot teleport.");
			Language.Add(text + "UTILITY_SLIPSTREAM", "Slipstream");
			Language.Add(text + "UTILITY_PRESTIGE_SLIPSTREAM", "Prestige Slipstream");
			Language.Add(text + "UTILITY_SLIPSTREAM_DESCRIPTION", "<style=cIsUtility>Teleport</style> a short distance. Replenishes secondary skill stock.");
			Language.Add(text + "UTILITY_QUANTUM_RIFT", "Quantum Portals");
			Language.Add(text + "UTILITY_QUANTUM_RIFT_DESCRIPTION", "<style=cIsUtility>Fracture</style>. Dash back and create two portals, each blasting for <style=cIsDamage>150% damage</style> per second. Portals <style=cIsUtility>teleport</style> to each other.");
			Language.Add(text + "UTILITY_CHAINED_WORLDS", "Chained Worlds");
			Language.Add(text + "UTILITY_CHAINED_WORLDS_DESCRIPTION", $"Shoot 5 rifts in a line, dealing <style=cIsDamage>{460f}% damage</style> and 5 shatter per rift. Rifts <style=cIsUtility>teleport enemies to the next</style>. Last Rift applies 10 shatter.");
			Language.Add(text + "SPECIAL_TIMELOCK", "Timelock");
			Language.Add(text + "SPECIAL_TIMELOCK_DESCRIPTION", "<style=cIsHealth>Crushing</style>. Create a field that deals 10 shatter and causes rifts to teleport to itself. <style=cIsUtility>Hitting it with a rift</style> collapses the timelock for <style=cIsDamage>500% damage</style>.");
			Language.Add(text + "SPECIAL_RECURSION_SCEPTER", "To Singularity");
			Language.Add(text + "SPECIAL_RECURSION_DESCRIPTION_SCEPTER", $"Position 10 stacked rifts, dealing <style=cIsDamage>{350f}%  damage</style> <style=cStack>(* 120% per rift)</style>. Each rift is <style=cIsDamage>5% smaller</style> than the last.");
			Language.Add(text + "SPECIAL_CHAINED_WORLDS_SCEPTER", "Colliding Worlds");
			Language.Add(text + "SPECIAL_CHAINED_WORLDS_DESCRIPTION_SCEPTER", $"Charge and shoot 7 rifts in a line, dealing <style=cIsDamage>{460f}% damage</style> <cStack/style> (* 120% per rift) <style=cStack> per rift. Rifts <style=cIsUtility>teleport enemies to the next</style>.");
			Language.Add(Tokens.GetAchievementNameToken("BLAKE_RIFTER_masteryAchievement"), "Rifter: Mastery");
			Language.Add(Tokens.GetAchievementDescriptionToken("BLAKE_RIFTER_masteryAchievement"), "As rifter, beat the game or obliterate on monsoon.");
			Language.Add(Tokens.GetAchievementNameToken("BLAKE_RIFTER_BUCKSHOT_ACHIEVEMENT"), "Rifter: tangling reality");
			Language.Add(Tokens.GetAchievementDescriptionToken("BLAKE_RIFTER_BUCKSHOT_ACHIEVEMENT"), "Teleport 10 or more enemies in at once!");
		}
	}
