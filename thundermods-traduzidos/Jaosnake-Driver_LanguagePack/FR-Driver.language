        "ROB_DRIVER_BODY_SECONDARY_SNIPER_NAME": "Se concentrer",
        "ROB_DRIVER_BODY_SECONDARY_SNIPER_DESCRIPTION": "Visez à travers votre lunette, <style=cIsDamage>exposant les points faibles</style> et tirez un tir dévastateur infligeant 600 % de dégâts.</i>",
        "ROB_DRIVER_BODY_SECONDARY_BANDITREVOLVER_NAME": "Extinction des feux",
        "ROB_DRIVER_BODY_SECONDARY_BANDITREVOLVER_DESCRIPTION": "Visez et tirez un tir dévastateur infligeant 1 500 % de dégâts. <style=cIsHealth>Actualise les temps de recharge et les munitions en cas d'assassinat, mais consomme l'arme.</style></i>",
        "ROB_DRIVER_BODY_SECONDARY_GOLDENGUN_NAME": "Desperado",
        "ROB_DRIVER_BODY_SECONDARY_GOLDENGUN_DESCRIPTION": "Visez et tirez un tir dévastateur infligeant 1 500 % de dégâts. <style=cIsHealth>Consomme l'arme lors de son utilisation.</style></i>",
        "ROB_DRIVER_BODY_SECONDARY_LUNARHAMMER_NAME": "Fragments",
