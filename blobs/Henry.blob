			GameObject val = CreateGhostPrefab("HenryBazookaRocketGhost");
			((Component)val.GetComponentInChildren<ParticleSystem>()).gameObject.AddComponent<DetachOnDestroy>();
			component2.ghostPrefab = val;
			component2.startSound = "";
		}

