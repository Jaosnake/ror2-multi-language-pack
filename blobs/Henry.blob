		[MethodImpl(MethodImplOptions.NoInlining | MethodImplOptions.NoOptimization)]
		private static void AddScepterSKills(SkillDef bombSkillDef, SkillDef bazookaSkillDef, SkillDef frenzySkillDef)
		{
			ItemBase<AncientScepterItem>.instance.RegisterScepterSkill(bombSkillDef, SurvivorBase.instance.fullBodyName, (SkillSlot)3, 0);
			ItemBase<AncientScepterItem>.instance.RegisterScepterSkill(bazookaSkillDef, SurvivorBase.instance.fullBodyName, (SkillSlot)3, 1);
			ItemBase<AncientScepterItem>.instance.RegisterScepterSkill(frenzySkillDef, SurvivorBase.instance.fullBodyName, (SkillSlot)3, 2);
		}

