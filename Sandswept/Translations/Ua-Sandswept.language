        "SANDSWEPT_VOID_SHRINE_RUIN_NAME": "Святиня Руїни",
        "SANDSWEPT_VOID_SHRINE_RUIN_CONTEXT": "Пропозиція до Shrine of Ruin",
        "SANDSWEPT_VOID_SHRINE_RUIN_USE_MESSAGE_2P": "<style=cShrine>Корупція поширюється.</color>",
        "SANDSWEPT_VOID_SHRINE_RUIN_USE_MESSAGE": "<style=cShrine>Корупція поширюється.</color>",
        "SANDSWEPT_SHRINE_OF_RUIN_DESCRIPTION": "Коли активується тим, хто вижив, Святилище руїн споживає 10 випадкових білих предметів з інвентарю та псує наступний рівень.",
        "SANDSWEPT_SHRINE_SACRIFICE_NAME": "Храм Жертви",
        "SANDSWEPT_SHRINE_SACRIFICE_CONTEXT": "Пропозиція до Храму Жертви",
        "SANDSWEPT_SHRINE_SACRIFICE_USE_MESSAGE_2P": "<style=cShrine>Ваш час був принесений в жертву.</color>",
        "SANDSWEPT_SHRINE_SACRIFICE_USE_MESSAGE": "Час <style=cShrine>{0} було принесено в жертву. </color>",
        "SANDSWEPT_SHRINE_SACRIFICE_DESCRIPTION": "При активації Shrine of Sacrifice споживає {curseCost}% від максимального здоров'я вижилого в обмін на {itemCount} копій випадкового звичайного предмета.",
        "SANDSWEPT_SHRINE_OF_SACRIFICE_DESCRIPTION": "При активації Shrine of Sacrifice споживає {curseCost}% від максимального здоров'я вижилого в обмін на {itemCount} копій випадкового звичайного предмета.",
        "SANDSWEPT_SHRINE_FUTURE_NAME": "Святиня майбутнього",
        "SANDSWEPT_SHRINE_FUTURE_CONTEXT": "Пропозиція святині майбутнього",
        "SANDSWEPT_SHRINE_FUTURE_USE_MESSAGE_2P": "<style=cShrine>Час змінився.</color>",
        "SANDSWEPT_SHRINE_FUTURE_USE_MESSAGE": "<style=cShrine>Час спотворено.</color>",
        "SANDSWEPT_SHRINE_OF_THE_FUTURE_DESCRIPTION": "Коли активовано, Храм майбутнього викликає випадкового сильного елітного міні-боса для кожного гравця, який у разі поразки втрачає {itemCount} потенціалів предметів для кожного гравця.",
        "SANDSWEPT_SHRINE_DEATH_NAME": "Храм смерті",
        "SANDSWEPT_SHRINE_DEATH_CONTEXT": "Пропозиція Храму Смерті",
        "SANDSWEPT_SHRINE_DEATH_DESCRIPTION": "Коли його активовано, Храм смерті споживає {percentHealthCost}% здоров'я вижилого та вимикає всі зцілення на {healingDisableDuration} секунд, але має {onKillProcChance}% шансу викликати ефекти при вбивстві та {onInteractProcChance}% шансу викликати ефекти взаємодії.",
        "SANDSWEPT_VOLTAIC_DRONE_BODY": "Voltaic Drone",
