{
    "ja": {
        "JAVANGLE_MYST_BODY_NAME": "ミスト",
        "JAVANGLE_MYST_BODY_DESCRIPTION": "ミストは多用途な生存者であり、<style=cIsUtility>魔力</style>を使って様々な超自然的なスキルを駆使し、<style=cIsUtility>リミット</style>を使って強力なスーパームーブを解放する。",
        "JAVANGLE_MYST_BODY_SUBTITLE": "神秘の魔術師",
