	public class CadetController : MonoBehaviour
	{
		private CharacterBody characterBody;

		private ModelSkinController skinController;

		private ChildLocator childLocator;

		private CharacterModel characterModel;

		private Animator animator;

		private SkillLocator skillLocator;

		private readonly int maxCasingCount = 10;

		private readonly int maxBulletCount = 20;

		private GameObject[] casingObjects;

		private GameObject[] bulletObjects;

		private int currentCasing;

		private int currentBullet;

		public GameObject gunProjectile;

		public Material matGunSkin;

		public ModdedDamageType ModdedDamageType = DamageTypes.Default;

		public int ammo = 20;

		public int maxAmmo;

		public Action onAmmoChange;

		public float jamTimer;

		public bool gunThrown = false;

		public bool grenadeLaunched = false;

		public bool mustReload = false;

		public bool speedUpReload = true;

		public bool atMaxAmmo => ammo >= maxAmmo;

		public bool isLauncher => skillLocator.secondary.skillDef.skillNameToken == "KENKO_CADET_SECONDARY_GRENADE_NAME";

		private void Awake()
		{
			characterBody = ((Component)this).GetComponent<CharacterBody>();
			ModelLocator component = ((Component)this).GetComponent<ModelLocator>();
			childLocator = ((Component)component.modelBaseTransform).GetComponentInChildren<ChildLocator>();
			animator = ((Component)component.modelBaseTransform).GetComponentInChildren<Animator>();
			characterModel = ((Component)component.modelBaseTransform).GetComponentInChildren<CharacterModel>();
			skillLocator = ((Component)this).GetComponent<SkillLocator>();
			skinController = ((Component)component.modelTransform).gameObject.GetComponent<ModelSkinController>();
			((MonoBehaviour)this).Invoke("InitModelsAndSkillDefs", 0.5f);
		}

		private void Start()
		{
			maxAmmo = skillLocator.primary.skillDef.GetMaxStock(skillLocator.primary);
			ammo = maxAmmo;
			if (isLauncher)
			{
				((Component)childLocator.FindChild("LauncherModel")).gameObject.SetActive(true);
				((Component)childLocator.FindChild("GrenadeModel")).gameObject.SetActive(true);
			}
			else
			{
				((Component)childLocator.FindChild("LauncherModel")).gameObject.SetActive(false);
				((Component)childLocator.FindChild("GrenadeModel")).gameObject.SetActive(false);
			}
			onAmmoChange?.Invoke();
		}

		public void Reload()
		{
			//IL_002a: Unknown result type (might be due to invalid IL or missing references)
			ammo = maxAmmo;
			NetworkIdentity component = ((Component)this).gameObject.GetComponent<NetworkIdentity>();
			if (Object.op_Implicit((Object)(object)component))
			{
				NetMessageExtensions.Send((INetMessage)(object)new SyncAmmo(component.netId, (uint)ammo), (NetworkDestination)1);
				onAmmoChange?.Invoke();
			}
		}

		private void InitModelsAndSkillDefs()
		{
			//IL_00f1: Unknown result type (might be due to invalid IL or missing references)
			//IL_00fb: Unknown result type (might be due to invalid IL or missing references)
			//IL_01d1: Unknown result type (might be due to invalid IL or missing references)
			//IL_01db: Unknown result type (might be due to invalid IL or missing references)
			GameObject val;
			GameObject val2;
			if (skinController.currentSkinIndex == 1)
			{
				val = CadetAssets.bulletMastery;
				val2 = CadetAssets.casingMastery;
				gunProjectile = CadetAssets.gunPrefabMastery;
				matGunSkin = ((Renderer)((Component)CadetAssets.gunPrefabMastery.GetComponent<ProjectileController>().ghostPrefab.transform.Find("Model")).GetComponent<MeshRenderer>()).material;
			}
			else
			{
				val = CadetAssets.bullet;
				val2 = CadetAssets.casing;
				gunProjectile = CadetAssets.gunPrefab;
				matGunSkin = ((Renderer)((Component)CadetAssets.gunPrefab.GetComponent<ProjectileController>().ghostPrefab.transform.Find("Model")).GetComponent<MeshRenderer>()).material;
			}
			currentCasing = 0;
			casingObjects = (GameObject[])(object)new GameObject[maxCasingCount + 1];
			for (int i = 0; i < maxCasingCount; i++)
			{
				casingObjects[i] = Object.Instantiate<GameObject>(val2, childLocator.FindChild("Weapon"), false);
				casingObjects[i].transform.localScale = Vector3.one * 1.1f;
				casingObjects[i].SetActive(false);
				casingObjects[i].GetComponent<Rigidbody>().collisionDetectionMode = (CollisionDetectionMode)1;
				casingObjects[i].layer = LayerIndex.ragdoll.intVal;
				((Component)casingObjects[i].transform.GetChild(0)).gameObject.layer = LayerIndex.ragdoll.intVal;
			}
			currentBullet = 0;
			bulletObjects = (GameObject[])(object)new GameObject[maxBulletCount + 1];
			for (int j = 0; j < maxBulletCount; j++)
			{
				bulletObjects[j] = Object.Instantiate<GameObject>(val, childLocator.FindChild("Weapon"), false);
				bulletObjects[j].transform.localScale = Vector3.one * 1.1f;
				bulletObjects[j].SetActive(false);
				bulletObjects[j].GetComponent<Rigidbody>().collisionDetectionMode = (CollisionDetectionMode)1;
				bulletObjects[j].layer = LayerIndex.ragdoll.intVal;
				((Component)bulletObjects[j].transform.GetChild(0)).gameObject.layer = LayerIndex.ragdoll.intVal;
			}
		}

		public void Mag()
		{
			((Component)childLocator.FindChild("MagModel")).gameObject.SetActive(true);
		}

		public void DropMag(Vector3 force)
		{
			//IL_0083: Unknown result type (might be due to invalid IL or missing references)
			//IL_00f8: Unknown result type (might be due to invalid IL or missing references)
			((Component)childLocator.FindChild("MagModel")).gameObject.SetActive(false);
			if (casingObjects != null && !((Object)(object)casingObjects[currentCasing] == (Object)null))
			{
				Transform val = childLocator.FindChild("Weapon");
				casingObjects[currentCasing].SetActive(false);
				casingObjects[currentCasing].transform.position = val.position;
				casingObjects[currentCasing].transform.SetParent((Transform)null);
				casingObjects[currentCasing].SetActive(true);
				Util.PlaySound("sfx_driver_gun_drop", casingObjects[currentCasing]);
				Rigidbody component = casingObjects[currentCasing].gameObject.GetComponent<Rigidbody>();
				if (Object.op_Implicit((Object)(object)component))
				{
					component.velocity = force;
				}
				currentCasing++;
				if (currentCasing >= maxCasingCount)
				{
					currentCasing = 0;
				}
			}
		}

		public void DropBullet(Vector3 force)
		{
			//IL_0067: Unknown result type (might be due to invalid IL or missing references)
			//IL_00c4: Unknown result type (might be due to invalid IL or missing references)
			if (bulletObjects != null && !((Object)(object)bulletObjects[currentBullet] == (Object)null))
			{
				Transform val = childLocator.FindChild("Weapon");
				bulletObjects[currentBullet].SetActive(false);
				bulletObjects[currentBullet].transform.position = val.position;
				bulletObjects[currentBullet].transform.SetParent((Transform)null);
				bulletObjects[currentBullet].SetActive(true);
				Rigidbody component = bulletObjects[currentBullet].gameObject.GetComponent<Rigidbody>();
				if (Object.op_Implicit((Object)(object)component))
				{
					component.velocity = force;
				}
				currentBullet++;
				if (currentBullet >= maxBulletCount)
				{
					currentBullet = 0;
				}
			}
		}

		public void DropShotgun()
		{
			//IL_0023: Unknown result type (might be due to invalid IL or missing references)
			//IL_002d: Unknown result type (might be due to invalid IL or missing references)
			//IL_0032: Unknown result type (might be due to invalid IL or missing references)
			//IL_003c: Unknown result type (might be due to invalid IL or missing references)
			//IL_0041: Unknown result type (might be due to invalid IL or missing references)
			//IL_0051: Unknown result type (might be due to invalid IL or missing references)
			//IL_0056: Unknown result type (might be due to invalid IL or missing references)
			//IL_0077: Unknown result type (might be due to invalid IL or missing references)
			//IL_0098: Unknown result type (might be due to invalid IL or missing references)
			//IL_009d: Unknown result type (might be due to invalid IL or missing references)
			//IL_00a7: Unknown result type (might be due to invalid IL or missing references)
			//IL_00ac: Unknown result type (might be due to invalid IL or missing references)
			GameObject val = Object.Instantiate<GameObject>(CadetAssets.discardedShotgunEffect);
			val.GetComponent<DiscardShotgunComponent>().Init(matGunSkin, characterBody.characterDirection.forward * -2.5f + Vector3.up * 9f + characterBody.characterMotor.velocity);
			val.transform.rotation = characterBody.modelLocator.modelTransform.rotation;
			val.transform.position = childLocator.FindChild("Weapon2").position + Vector3.up * 0.5f;
		}

		private void FixedUpdate()
		{
			if (maxAmmo != skillLocator.primary.skillDef.GetMaxStock(skillLocator.primary) + characterBody.inventory.GetItemCount(Items.SecondarySkillMagazine))
			{
				maxAmmo = skillLocator.primary.skillDef.GetMaxStock(skillLocator.primary) + characterBody.inventory.GetItemCount(Items.SecondarySkillMagazine);
			}
			if (skillLocator.primary.skillDef.GetMaxStock(skillLocator.primary) != maxAmmo)
			{
				skillLocator.primaryBonusStockSkill.SetBonusStockFromBody(characterBody.inventory.GetItemCount(Items.SecondarySkillMagazine));
			}
			if (skillLocator.primary.skillDef.skillNameToken != "KENKO_CADET_PRIMARY_SMG_NAME" || skillLocator.primary.skillDef.skillNameToken != "KENKO_CADET_PRIMARY_SHOTGUN_NAME")
			{
				if (skillLocator.primary.stock < ammo)
				{
					ammo--;
				}
				if (skillLocator.primary.stock <= 0 && !mustReload)
				{
					mustReload = true;
				}
				else if (skillLocator.primary.stock == maxAmmo && mustReload)
				{
					mustReload = false;
					Reload();
				}
			}
			if (isLauncher)
			{
				if (skillLocator.secondary.stock <= 0 && ((Component)childLocator.FindChild("GrenadeModel")).gameObject.activeSelf)
				{
					((Component)childLocator.FindChild("GrenadeModel")).gameObject.SetActive(false);
				}
				else if (skillLocator.secondary.stock > 0 && !((Component)childLocator.FindChild("GrenadeModel")).gameObject.activeSelf)
				{
					((Component)childLocator.FindChild("GrenadeModel")).gameObject.SetActive(true);
				}
			}
		}
	}
	public class CadetCSS : MonoBehaviour
	{
		private bool hasPlayed = false;

		private float timer = 0f;

		private void Awake()
		{
		}

		private void FixedUpdate()
		{
			timer += Time.fixedDeltaTime;
			if (!hasPlayed && timer >= 3.5f)
			{
				hasPlayed = true;
				Util.PlaySound("sfx_driver_foley", ((Component)this).gameObject);
			}
		}
	}
