		public BulletType ConsumeColouredBullet()
		{
			if (ColouredBulletList.Count == 0)
			{
				return BulletType.NONE;
			}
			BulletType result = ColouredBulletList[0];
			ColouredBulletList.RemoveAt(0);
			uiController.AdvanceBulletState(new LeeHyperrealUIController.BulletState(enhancedBulletAmount, ColouredBulletList.ToList(), body.attackSpeed * 1.5f, isColouredBulletMoving: true, isEnhancedBulletMoving: false));
			return result;
		}

		public void GrantColouredBullet(BulletType bulletType)
		{
			if (ColouredBulletList.Count < 5)
			{
				ColouredBulletList.Add(bulletType);
			}
			uiController.SetBulletStates(ColouredBulletList);
		}

		public void GrantEnhancedBullet(int amount)
		{
			int num = body.skillLocator.secondary.maxStock - 1;
			enhancedBulletAmount += amount + num;
			uiController.SetEnhancedBulletState(enhancedBulletAmount);
		}

		public bool ConsumeEnhancedBullet(int amount)
		{
			if (enhancedBulletAmount == 0)
			{
				return false;
			}
			enhancedBulletAmount -= amount;
			uiController.AdvanceBulletState(new LeeHyperrealUIController.BulletState(enhancedBulletAmount, ColouredBulletList.ToList(), body.attackSpeed * 1.5f, isColouredBulletMoving: false, isEnhancedBulletMoving: true));
			return true;
		}

		public void OnDestroy()
		{
			if (Object.op_Implicit((Object)(object)snipeAerialPlatform))
			{
				snipeAerialPlatform.GetComponent<DestroyPlatformOnDelay>().StartDestroying();
			}
			Unhook();
		}
	}
