		public void ConsumeOrbsFromSlot(int slotToConsumeFrom)
		{
			isCheckingInput = true;
			List<Tuple<OrbType, int?>> list = new List<Tuple<OrbType, int?>>();
			for (int i = 0; i < orbList.Count; i++)
			{
				if (i == 0)
				{
					list.Add(new Tuple<OrbType, int?>(orbList[i], 1));
				}
				else if (list[list.Count - 1].Item1 == orbList[i])
				{
					list[list.Count - 1] = new Tuple<OrbType, int?>(list[list.Count - 1].Item1, list[list.Count - 1].Item2 + 1);
				}
				else
				{
					list.Add(new Tuple<OrbType, int?>(orbList[i], 1));
				}
			}
			int? num = 0;
			bool flag = false;
			for (int j = 0; j < list.Count; j++)
			{
				num += list[j].Item2;
				if (!(num >= slotToConsumeFrom) || flag)
				{
					continue;
				}
				flag = true;
				int num2 = 0;
				int[] array = new int[3];
				for (int k = 0; k < list.Count; k++)
				{
					if (k == j)
					{
						array[0] = num2;
						array[1] = ((list[j].Item2 >= 2) ? (num2 + 1) : (-1));
						array[2] = ((list[j].Item2 >= 3) ? (num2 + 2) : (-1));
						k = list.Count - 1;
					}
					num2 += list[k].Item2.Value;
				}
				ClearSuggestedOrbs(array);
				TriggerOrbState(list[j].Item2.Value, list[j].Item1);
			}
			isCheckingInput = false;
		}

		private void ClearSuggestedOrbs(int[] indexes)
		{
			for (int num = indexes.Length - 1; num > -1; num--)
			{
				if (indexes[num] != -1)
				{
					orbList.RemoveAt(indexes[num]);
					if (Object.op_Implicit((Object)(object)uiController))
					{
						uiController.PingSpecificOrb(indexes[num]);
					}
				}
			}
		}

		public void TriggerOrbState(int strength, OrbType orbType)
		{
			isExecutingSkill = true;
			EntityStateMachine val = null;
			EntityStateMachine[] array = stateMachines;
			foreach (EntityStateMachine val2 in array)
			{
				if (val2.customName == "Body")
				{
					val = val2;
				}
