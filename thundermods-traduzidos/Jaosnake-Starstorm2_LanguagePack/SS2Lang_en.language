                    "SS2_ACHIEVEMENT_COMMANDO_NEMESISSKIN_NAME":  "Commando: Lone Echo",
                    "SS2_DIFFICULTY_TEMPEST3_NAME":  "Tempest +3",
                    "SS2_NEMCOMMANDO_SPECIAL_SCEPSUBMISSION_DESCRIPTION":  "\u003cstyle=cIsUtility\u003eAgile.\u003c/style\u003e \u003cstyle=cDeath\u003eRending.\u003c/style\u003e \u003cstyle=cIsUtility\u003eCharge up\u003c/style\u003e, then fire a barrage of up to \u003cstyle=cIsDamage\u003e6 blasts of 4x70%.\u003c/style\u003e. \u003cstyle=cIsUtility\u003eThe number of shots increases with attack speed\u003c/style\u003e. \n\u003ccolor=#d299ff\u003eSCEPTER: Additionally fires up to {0} lasers which deal {2}% damage.\u003c/color\u003e",
                    "SS2_RAILGUNNER_ROLL_NAME":  "Tactical Roll",
