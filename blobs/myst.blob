					((BasePool<PayCostContext>)(object)PayCostContext.pool).Request(ref val);
					val.activator = ((Component)characterBody).GetComponent<Interactor>();
					val.activatorBody = characterBody;
					val.activatorMaster = characterBody.master;
					val.activatorInventory = characterBody.inventory;
