			skillstate.MagMulti = random.Next(11);
			skillstate.MagKill = random.Next(11);
			skillstate.MagUse = random.Next(11);
			skillstate.MagTurbo = random.Next(11);
			skillstate.MagThrift = 150;
			skillstate.WildMagicCast = true;
			skillStateMachine.SetNextState((EntityState)(object)skillstate);
		}

