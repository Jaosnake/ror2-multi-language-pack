		internal static void AdjustMats()
		{
			Material[] array = mainAssetBundle.LoadAllAssets<Material>();
			Material[] array2 = array;
			foreach (Material val in array2)
			{
				if (((Object)val.shader).name == "Hopoo Games/FX/Cloud Remap")
				{
					val.shader = LegacyResourcesAPI.Load<Shader>("shaders/fx/hgcloudremap");
				}
				if (((Object)val.shader).name == "Stubbed Hopoo Games/FX/Cloud Remap")
				{
					val.shader = LegacyResourcesAPI.Load<Shader>("shaders/fx/hgcloudremap");
				}
