					foreach (Hunk.HunkGunSkin gunSkin in Hunk.gunSkins)
					{
						if (Object.op_Implicit((Object)(object)gunSkin.skinDef) && (Object)(object)gunSkin.skinDef == (Object)(object)modelSkinController.skins[modelSkinController.currentSkinIndex])
						{
