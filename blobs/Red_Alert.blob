		private void InitializeRecolorSkills()
		{
			if (characterModelObject.GetComponent<SkinRecolorController>().Recolors == null)
			{
				Log.Warning("Could not load recolors. types not serialized?");
				return;
			}
			SkillFamily skillFamily = Skills.CreateGenericSkillWithSkillFamily(bodyPrefab, "LOADOUT_SKILL_COLOR", "Recolor", hidden: true).skillFamily;
			SkinRecolorController component = characterModelObject.GetComponent<SkinRecolorController>();
			List<SkillDef> list = new List<SkillDef>
			{
				component.createRecolorSkillDef("Red"),
				component.createRecolorSkillDef("Blue"),
				component.createRecolorSkillDef("Green"),
				component.createRecolorSkillDef("Yellow"),
				component.createRecolorSkillDef("Orange"),
				component.createRecolorSkillDef("Cyan"),
				component.createRecolorSkillDef("Purple"),
				component.createRecolorSkillDef("Pink")
			};
			if (GeneralConfig.NewColor.Value)
			{
				list.Add(component.createRecolorSkillDef("Black"));
				list.Add(component.createRecolorSkillDef("White"));
			}
			for (int i = 0; i < list.Count; i++)
			{
				Skills.AddSkillToFamily(skillFamily, list[i], (i == 0) ? null : DesolatorUnlockables.recolorsUnlockableDef);
				AddCssPreviewSkill(i, skillFamily, list[i]);
			}
		}

		public override void InitializeSkins()
		{
			ModelSkinController component = ((Component)prefabCharacterModel).gameObject.GetComponent<ModelSkinController>();
			ChildLocator component2 = ((Component)prefabCharacterModel).GetComponent<ChildLocator>();
			RendererInfo[] baseRendererInfos = prefabCharacterModel.baseRendererInfos;
			List<SkinDef> list = new List<SkinDef>();
			SkinDef val = Skins.CreateSkinDef("DEFAULT_SKIN", assetBundle.LoadAsset<Sprite>("texIconSkinDesolatorDefault"), baseRendererInfos, characterModelObject);
			val.meshReplacements = assetBundle.GetMeshReplacements(baseRendererInfos, "DesoArmor", "DesoBody", "DesoCannon", "DesoArmorColor");
			val.rendererInfos[0].defaultMaterial = assetBundle.CreateHopooMaterialFromBundle("matDesolatorArmor");
			val.rendererInfos[1].defaultMaterial = assetBundle.CreateHopooMaterialFromBundle("matDesolatorBody");
			val.rendererInfos[2].defaultMaterial = assetBundle.CreateHopooMaterialFromBundle("matDesolatorCannon");
			val.rendererInfos[3].defaultMaterial = assetBundle.CreateHopooMaterialFromBundle("matDesolatorArmorColor");
			list.Add(val);
			SkinDef val2 = Skins.CreateSkinDef("HABIBI_DESOLATOR_BODY_MASTERY_SKIN_NAME", assetBundle.LoadAsset<Sprite>("texIconSkinDesolatorMastery"), baseRendererInfos, characterModelObject, DesolatorUnlockables.masterySkinUnlockableDef);
			val2.meshReplacements = assetBundle.GetMeshReplacements(baseRendererInfos, "DesoMasteryArmor", "DesoMasteryBody", "DesoMasteryCannon", "DesoMasteryArmorColor");
			val2.rendererInfos[0].defaultMaterial = assetBundle.CreateHopooMaterialFromBundle("matDesoMasteryArmor");
			val2.rendererInfos[1].defaultMaterial = assetBundle.CreateHopooMaterialFromBundle("matDesoMasteryBody");
			val2.rendererInfos[2].defaultMaterial = assetBundle.CreateHopooMaterialFromBundle("matDesoMasteryArmor");
			val2.rendererInfos[3].defaultMaterial = assetBundle.CreateHopooMaterialFromBundle("matDesoMasteryCrystal");
			list.Add(val2);
			component.skins = list.ToArray();
			displayPrefab.AddComponent<ModelSkinController>().skins = component.skins;
		}

		public override void InitializeCharacterMaster()
		{
			Prefabs.CloneDopplegangerMasterAsync(bodyPrefab, masterName, "RoR2/Base/Engi/EngiMonsterMaster.prefab");
		}

		protected void AddHooks()
		{
			//IL_0029: Unknown result type (might be due to invalid IL or missing references)
			//IL_0033: Expected O, but got Unknown
			//IL_003a: Unknown result type (might be due to invalid IL or missing references)
			//IL_0044: Expected O, but got Unknown
			GlobalEventManager.onServerDamageDealt += GlobalEventManager_onServerDamageDealt;
			HealthComponent.TakeDamage_Pre += HealthComponent_TakeDamage;
			BuffCatalog.Init += new hook_Init(BuffCatalog_Init);
			RecalculateStatsAPI.GetStatCoefficients += new StatHookEventHandler(RecalculateStatsAPI_GetStatCoefficients);
		}

		private void RecalculateStatsAPI_GetStatCoefficients(CharacterBody sender, StatHookEventArgs args)
		{
			if (sender.HasBuff(DesolatorBuffs.desolatorArmorBuff))
