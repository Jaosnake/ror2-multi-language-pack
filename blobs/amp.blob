			stopLoop.SoundEventToPlay = "PlayFieldLoop";
			stopLoop.SoundId = 2520482775u;
			PrefabAPI.RegisterNetworkPrefab(fieldProjectilePrefab);
			fieldProjectilePrefabBlue = Asset.mainAssetBundle.LoadAsset<GameObject>("StaticFieldDOTBlue");
			StaticFieldDamage staticFieldDamage2 = fieldProjectilePrefabBlue.AddComponent<StaticFieldDamage>();
			staticFieldDamage2.procCoefficient = 0.1f;
			BuffWard component2 = fieldProjectilePrefabBlue.GetComponent<BuffWard>();
			component2.buffDef = Buffs.nemAmpAtkSpeed;
			StopLoop stopLoop2 = fieldProjectilePrefabBlue.AddComponent<StopLoop>();
			stopLoop2.SoundEventToPlay = "PlayFieldLoop";
			stopLoop2.SoundId = 2520482775u;
			PrefabAPI.RegisterNetworkPrefab(fieldProjectilePrefabBlue);
		}

		private static void CreateFerroshot()
		{
			ferroshotPrefab = Asset.mainAssetBundle.LoadAsset<GameObject>("SpikeProjectile");
			ferroshotPrefab.GetComponent<ProjectileSimple>().lifetime = 1f;
			ferroshotPrefab.AddComponent<DestroyOnTimer>().duration = 0.5f;
			ferroshotPrefab.AddComponent<ChargedTargeting>();
			ferroshotPrefab.AddComponent<ChargedHoming>();
			ferroshotPrefab.AddComponent<ChargedDirectionFinder>();
			ProjectileController component = ferroshotPrefab.GetComponent<ProjectileController>();
			if ((Object)(object)Asset.mainAssetBundle.LoadAsset<GameObject>("SpikeGhost") != (Object)null)
			{
				component.ghostPrefab = CreateGhostPrefab("SpikeGhost");
			}
			component.procCoefficient = 0.7f;
			ProjectileSingleTargetImpact val = ferroshotPrefab.AddComponent<ProjectileSingleTargetImpact>();
			InitializeFerroshotContact(val);
			val.destroyOnWorld = true;
			val.impactEffect = Asset.bulletImpactEffect;
			PrefabAPI.RegisterNetworkPrefab(ferroshotPrefab);
		}

		private static void CreateVortex()
		{
			vortexPrefab = Asset.mainAssetBundle.LoadAsset<GameObject>("VortexProjectile");
			ProjectileController component = vortexPrefab.GetComponent<ProjectileController>();
			if ((Object)(object)Asset.mainAssetBundle.LoadAsset<GameObject>("VortexEffect") != (Object)null)
			{
				component.ghostPrefab = CreateGhostPrefab("VortexEffect");
			}
			component.allowPrediction = true;
			StopLoop stopLoop = vortexPrefab.AddComponent<StopLoop>();
			stopLoop.SoundEventToPlay = "PlayVortexFlightLoopAlter2";
			stopLoop.SoundId = 2447326215u;
			PrefabAPI.RegisterNetworkPrefab(vortexPrefab);
		}

		private static void CreateFireBeam()
		{
			//IL_0021: Unknown result type (might be due to invalid IL or missing references)
			fireBeamPrefab = Asset.mainAssetBundle.LoadAsset<GameObject>("HeatProjectile");
			ModdedDamageTypeHolderComponent val = fireBeamPrefab.AddComponent<ModdedDamageTypeHolderComponent>();
			val.Add(DamageTypes.strongBurnIfCharged);
			ProjectileController component = fireBeamPrefab.GetComponent<ProjectileController>();
			if ((Object)(object)Asset.mainAssetBundle.LoadAsset<GameObject>("HeatProjectileGhost") != (Object)null)
			{
				component.ghostPrefab = CreateGhostPrefab("HeatProjectileGhost");
			}
			component.allowPrediction = true;
			PrefabAPI.RegisterNetworkPrefab(fireBeamPrefab);
		}

		private static void CreateLightning()
		{
			lightningPrefab = CloneProjectilePrefab("MageLightningBombProjectile", "Lightning");
			lightningPrefab.GetComponent<Rigidbody>().useGravity = false;
			Object.Destroy((Object)(object)lightningPrefab.GetComponent<AntiGravityForce>());
			Object.Destroy((Object)(object)lightningPrefab.GetComponent<ProjectileProximityBeamController>());
			Object.Destroy((Object)(object)lightningPrefab.GetComponent<ProjectileImpactExplosion>());
			lightningPrefab.AddComponent<ProjectileImpactExplosion>();
			ProjectileImpactExplosion component = lightningPrefab.GetComponent<ProjectileImpactExplosion>();
			((ProjectileExplosion)component).blastRadius = 10f;
			component.destroyOnEnemy = false;
			component.lifetimeAfterImpact = 0f;
			component.impactEffect = LegacyResourcesAPI.Load<GameObject>("Prefabs/Effects/ImpactEffects/LightningStrikeImpact");
		}

