		public void UpdateMasterComponent()
		{
			masterComponent.equippedMagicites = equippedMagicites;
			masterComponent.inventoryMagicites = inventoryMagicites;
			masterComponent.limitNo = limitNo;
			masterComponent.limitRN = limitRN;
			masterComponent.limitTotal = limitTotal;
