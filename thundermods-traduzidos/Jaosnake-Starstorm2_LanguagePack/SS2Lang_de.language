    "SS2_PLAYER_ARMOR_25_DECREASE_NAME_TOKEN": "-25 % erlittener Schaden",
    "SS2_PLAYER_ARMOR_25_DECREASE_BODY_TOKEN": "Spieler erleiden 75 % Schaden.",
    "SS2_PLAYER_ARMOR_50_DECREASE_NAME_TOKEN": "-50 % erlittener Schaden",
