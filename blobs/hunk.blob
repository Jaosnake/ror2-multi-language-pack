				if (!NetworkServer.active)
				{
					return;
				}
				if (!isStageValid)
				{
					checkStopwatch = Random.Range(20f, 40f);
					return;
				}
				checkStopwatch = Random.Range(20f, 40f);
				if (Object.op_Implicit((Object)(object)nemesis) && nemesis.hasValidMutation)
				{
					strikeTeamChance = 1f;
