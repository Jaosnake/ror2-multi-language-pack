        "SS2_FAMILY_LAMP": "<style=cWorldEvent>[警告]你感到到一种深邃的寂静...</style>",
        "SS2_EXECUTIONER2_FIRINGSQUAD_NAME": "齐射",
        "SS2_SKIN_NEMCOMMANDO_COMMANDO": "士兵",
        "SS2_ACHIEVEMENT_NEMCOMMANDO_SWORDBEAM_DESC": "As Nemesis Commando, reach 100% bleed chance.",
        "SS2_ITEM_PORTABLEREACTOR_DESC": "进入关卡时获得<style=cIsUtility>无敌</style>状态和<style=cIsUtility>100%移动速度</style>,持续<style=cIsUtility>{0}</style> <style=cStack>(每层+{1})</style>秒。",
