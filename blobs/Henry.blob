	public class MrGreenCloneTracker : MonoBehaviour
	{
		public MrGreenCloneTracker rootTracker;

		public int cloneCap = 10;

		public int currentCloneCount;

		public List<GameObject> clones;

		public float timeLastSpawnedClone;

		public bool isRoot;

		private float timeBetweenCloneSpawns = 0.5f;

		private CharacterBody characterBody;

		private CharacterModel model;

		private ChildLocator childLocator;

		public bool canSpawnClone => currentCloneCount < cloneCap && Time.time > timeBetweenCloneSpawns + timeLastSpawnedClone;

		private void Awake()
		{
			characterBody = ((Component)this).gameObject.GetComponent<CharacterBody>();
			childLocator = ((Component)this).gameObject.GetComponentInChildren<ChildLocator>();
			model = ((Component)this).GetComponentInChildren<CharacterModel>();
			currentCloneCount = 0;
			clones = new List<GameObject>();
		}

		private void OnDestroy()
		{
			//IL_0061: Unknown result type (might be due to invalid IL or missing references)
			//IL_0066: Unknown result type (might be due to invalid IL or missing references)
			//IL_00a8: Unknown result type (might be due to invalid IL or missing references)
			//IL_00ae: Unknown result type (might be due to invalid IL or missing references)
			if (clones == null || !isRoot)
			{
				return;
			}
			foreach (GameObject clone in clones)
			{
				if (!Object.op_Implicit((Object)(object)clone))
				{
					continue;
				}
				CharacterDeathBehavior component = clone.GetComponent<CharacterDeathBehavior>();
				if (Object.op_Implicit((Object)(object)component))
				{
					component.deathState = new SerializableEntityStateType(typeof(DeathState));
				}
				HealthComponent component2 = clone.GetComponent<HealthComponent>();
				if (Object.op_Implicit((Object)(object)component2))
				{
					if (!component2.alive)
					{
						Object.Destroy((Object)(object)((Component)component2).gameObject);
					}
					else
					{
						component2.Suicide((GameObject)null, (GameObject)null, default(DamageTypeCombo));
					}
				}
			}
		}

		public void AddClone(GameObject newClone)
		{
			currentCloneCount++;
			clones.Add(newClone);
			timeLastSpawnedClone = Time.time;
		}
	}
	public class NemryEnergyComponent : MonoBehaviour
	{
		public enum WeaponMode
		{
			Sword,
			Gun
		}

		public float maxEnergy = 100f;

		public float currentEnergy;

		private float lastEnergy;

		private CharacterBody characterBody;

		private CharacterMaster characterMaster;

		private CharacterModel model;

		private ChildLocator childLocator;

		private HenryTracker tracker;

		private Animator modelAnimator;

		public WeaponMode weaponMode;

		private void Awake()
		{
			characterBody = ((Component)this).gameObject.GetComponent<CharacterBody>();
			childLocator = ((Component)this).gameObject.GetComponentInChildren<ChildLocator>();
			model = ((Component)this).gameObject.GetComponentInChildren<CharacterModel>();
			tracker = ((Component)this).gameObject.GetComponent<HenryTracker>();
			modelAnimator = ((Component)this).gameObject.GetComponentInChildren<Animator>();
			weaponMode = WeaponMode.Sword;
			currentEnergy = maxEnergy;
		}

		private void Start()
		{
			characterMaster = characterBody.master;
			ReplaceSkillDefs();
		}

		private void ReplaceSkillDefs()
		{
			SkillLocator component = ((Component)this).gameObject.GetComponent<SkillLocator>();
			component.primary.SetBaseSkill(Nemry.swordPrimaryDef);
			component.secondary.SetBaseSkill(Nemry.swordSecondaryDef);
			component.utility.SetBaseSkill(Nemry.swordUtilityDef);
			component.special.SetBaseSkill(Nemry.swordSpecialDef);
		}

		public bool AddEnergy(float amount)
		{
			if (currentEnergy >= maxEnergy)
			{
				return false;
			}
			currentEnergy = Mathf.Clamp(currentEnergy + amount, 0f, maxEnergy);
			if (currentEnergy >= maxEnergy && lastEnergy < maxEnergy)
			{
				Util.PlaySound("NemryMaxEnergy", ((Component)this).gameObject);
			}
			lastEnergy = currentEnergy;
			return true;
		}

		public bool SpendEnergy(float amount)
		{
			return SpendEnergy(amount, (SkillSlot)(-1));
		}

		public bool SpendEnergy(float amount, SkillSlot skillSlot)
		{
			//IL_0098: Unknown result type (might be due to invalid IL or missing references)
			//IL_009a: Invalid comparison between Unknown and I4
			//IL_00c5: Unknown result type (might be due to invalid IL or missing references)
			//IL_00c7: Invalid comparison between Unknown and I4
			if (characterBody.HasBuff(Buffs.NoCooldowns))
			{
				return true;
			}
			int itemCount = characterMaster.inventory.GetItemCount(Items.AlienHead);
			int itemCount2 = characterMaster.inventory.GetItemCount(Items.LunarBadLuck);
			int itemCount3 = characterMaster.inventory.GetItemCount(Items.SecondarySkillMagazine);
			int itemCount4 = characterMaster.inventory.GetItemCount(Items.UtilitySkillMagazine);
			for (int i = 0; i < itemCount; i++)
			{
				amount *= 0.75f;
			}
			if ((int)skillSlot == 1)
			{
				for (int j = 0; j < itemCount3; j++)
				{
					amount *= 0.95f;
				}
			}
			if ((int)skillSlot == 2)
			{
				for (int k = 0; k < itemCount4; k++)
				{
					amount *= 0.5f;
				}
			}
			amount = Mathf.Clamp(amount - (float)itemCount2 * 20f, 0f, float.PositiveInfinity);
			if (currentEnergy < amount)
			{
				return false;
			}
			currentEnergy = Mathf.Clamp(currentEnergy - amount, 0f, maxEnergy);
			lastEnergy = currentEnergy;
			return true;
		}
	}
