				SetNewSkin(((Component)val).gameObject, skinIndex);
			}
		}

		private void SetNewSkin(GameObject obj, uint skinIndex)
		{
			if (Config.loreMode.Value)
			{
				switch (skinIndex)
				{
				case 0u:
					SetProspectorSkin(obj);
					break;
				case 1u:
					SetComradeSkin(obj);
					break;
				case 4u:
					SetScarletSkin(obj);
					break;
				case 5u:
					SetYiSkin(obj);
					break;
				case 6u:
					SetBKSkin(obj);
					break;
				default:
					SetDefaultLeeSkin(obj);
					break;
				}
			}
			else
			{
				switch (skinIndex)
				{
				case 2u:
					SetScarletSkin(obj);
					break;
				case 3u:
					SetProspectorSkin(obj);
					break;
				case 4u:
					SetComradeSkin(obj);
					break;
				default:
					SetDefaultLeeSkin(obj);
					break;
				}
			}
		}

