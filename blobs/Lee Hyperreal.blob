		private void UpdateHoldTag()
		{
			uiController.SetHoldTagState(energy >= 100f);
		}

		public void EnableLoopEffect()
		{
			domainAerialEffectLoopParticleSystem.Play();
		}

		public void DisableLoopEffect()
		{
			domainAerialEffectLoopParticleSystem.Stop();
		}

		private void ChangeIconState()
		{
			if (skillLocator.special.stock >= 1 && GetDomainState())
			{
				SetIconState(UltimateIconState.DOMAIN);
			}
			else if (skillLocator.special.stock >= 10 && !GetDomainState())
			{
				SetIconState(UltimateIconState.ULTIMATE);
			}
			else
			{
				SetIconState(UltimateIconState.NONE);
			}
		}

		private void SetIconState(UltimateIconState incomingIconState)
		{
			iconState = incomingIconState;
			switch (iconState)
			{
			case UltimateIconState.NONE:
				uiController.TriggerNone();
				break;
			case UltimateIconState.DOMAIN:
				uiController.TriggerUltDomain();
				break;
			case UltimateIconState.ULTIMATE:
				uiController.TriggerUlt();
				break;
			}
		}

		public void SetTapped()
		{
			uiController.TriggerTappedUltIcon();
		}

		private void DestroyAllClonesAndBullets()
		{
			foreach (GameObject yellowOrbDomainEffect in yellowOrbDomainEffects)
			{
				Object.Destroy((Object)(object)yellowOrbDomainEffect);
			}
			yellowOrbDomainEffects.Clear();
			foreach (GameObject yellowCloneObject in yellowCloneObjects)
			{
				Object.Destroy((Object)(object)yellowCloneObject);
			}
			yellowCloneObjects.Clear();
			foreach (GameObject redCloneObject in redCloneObjects)
			{
				Object.Destroy((Object)(object)redCloneObject);
			}
			redCloneObjects.Clear();
		}

		private void ApplyIntutionBuffsToBody()
		{
			//IL_000c: Unknown result type (might be due to invalid IL or missing references)
			NetworkingHelpers.ApplyBuff(charBody, Buffs.intuitionBuff.buffIndex, intuitionStacks, -1f);
			uiController.SetIntuitionStacks(intuitionStacks);
		}

		private void ResetIntutionStacksOnBody()
		{
			//IL_000c: Unknown result type (might be due to invalid IL or missing references)
			NetworkingHelpers.ApplyBuff(charBody, Buffs.intuitionBuff.buffIndex, 0, -1f);
			intuitionStacks = 0;
			uiController.SetIntuitionStacks(intuitionStacks);
		}

		public void EnergyRegen()
		{
			energy += Time.deltaTime * powerRechargeSpeed;
			if (energy >= 100f)
			{
				energy = 100f;
			}
		}

		public void AddEnergy(float incomingEnergy)
		{
			energy += incomingEnergy;
			if (energy >= 100f)
			{
				energy = 100f;
			}
		}

		public void SpendEnergy(float energy)
		{
			this.energy -= energy;
			if (this.energy < 0f)
			{
				this.energy = 0f;
				DisableDomain(shouldSetState: true);
			}
		}

		public void UpdateUIController()
		{
			if (Object.op_Implicit((Object)(object)uiController) && charBody.hasEffectiveAuthority)
			{
				uiController.SetMeterLevel(energy / 100f);
			}
			else if (!Object.op_Implicit((Object)(object)uiController))
			{
				uiController = ((Component)this).GetComponent<LeeHyperrealUIController>();
			}
		}

		public void DisableDomain(bool shouldSetState)
		{
			//IL_001d: Unknown result type (might be due to invalid IL or missing references)
			if (shouldSetState && charBody.hasEffectiveAuthority)
			{
				NetMessageExtensions.Send((INetMessage)(object)new SetDomainUltimateNetworkRequest(((NetworkBehaviour)charBody).netId), (NetworkDestination)1);
			}
			isInDomain = false;
			energy = 0f;
			DisableDomainEffect();
			DestroyAllClonesAndBullets();
		}

		public void EnableDomain()
		{
			isInDomain = true;
			EnableDomainEffect();
		}

		public void EnableDomainEffect()
		{
			//IL_002e: Unknown result type (might be due to invalid IL or missing references)
			loopDomainEffect.SetActive(true);
			despawnDomainEffect.SetActive(false);
			uiController.DomainOverlayEnable(state: true);
			NetMessageExtensions.Send((INetMessage)(object)new PlaySoundNetworkRequest(((NetworkBehaviour)charBody).netId, "Play_c_liRk4_skill_ex_timestop_loop"), (NetworkDestination)1);
		}

		public void DisableDomainEffect()
		{
			//IL_002e: Unknown result type (might be due to invalid IL or missing references)
			loopDomainEffect.SetActive(false);
			despawnDomainEffect.SetActive(true);
			uiController.DomainOverlayEnable(state: false);
			NetMessageExtensions.Send((INetMessage)(object)new PlaySoundNetworkRequest(((NetworkBehaviour)charBody).netId, "Play_c_liRk4_skill_ex_timestop_end"), (NetworkDestination)1);
		}

		public bool DomainEntryAllowed()
		{
			if (isInDomain)
			{
				return false;
			}
			return energy >= 100f;
		}

		public bool GetDomainState()
		{
			return isInDomain;
		}

		public bool ConsumeIntuitionStacks(int amount)
		{
			if (amount > intuitionStacks)
			{
				return false;
			}
			intuitionStacks -= amount;
			uiController.SetIntuitionStacks(intuitionStacks);
			return true;
		}

		public void GrantIntuitionStack(int amount)
		{
			intuitionStacks += amount;
			if (intuitionStacks > maxIntuitionStack)
			{
				intuitionStacks = maxIntuitionStack;
			}
			uiController.SetIntuitionStacks(intuitionStacks);
		}

		public void SetFlagForAchievement()
		{
			if (intuitionStacks >= maxIntuitionStack)
			{
				HasBuiltUpMaxStack = true;
			}
			else
			{
				HasBuiltUpMaxStack = false;
			}
		}

		public int GetIntuitionStacks()
		{
			uiController.SetIntuitionStacks(intuitionStacks);
			return intuitionStacks;
		}

		public void OnDestroy()
		{
			Object.Destroy((Object)(object)loopDomainEffect);
			Object.Destroy((Object)(object)despawnDomainEffect);
			Object.Destroy((Object)(object)domainAerialEffectLoop);
			DestroyAllClonesAndBullets();
		}
	}
