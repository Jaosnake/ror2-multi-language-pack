	internal class HousePassiveManager : MonoBehaviour
	{
		public CharacterBody characterBody;

		public bool Initialised = false;

		public float InitTime = 0.5f;

		public bool isAuthority;

		public int roulletePriorityShot = 0;

		public int[] roulleteAmmo = new int[6] { 1, 1, 1, 1, 1, 1 };

		public int[] roulleteOrder = new int[6] { 0, 1, 2, 3, 4, 5 };

		public int roulleteOrderPosition = 0;

		public List<int> gameDeck;

		public List<int> gameDeckDiscardPile;

		public int[] handCards = new int[3];

		public int lastCardUsed = -1;

		public int LoadArt = 0;

		public int CardArt = 0;

		public Random random = new Random();

		public CombatDirector combatDirector;

		public float costScaler = 1f;

		public bool RussianRouletteDeath = false;

		public static bool isKKAInstalled;

		private int startDifficultyScaledCost = 1;

		public float MissileInterval = 0f;

		public int MissileCount = 0;

		private int storedScepterStacks = 0;

		private void Awake()
		{
			Auspicious.Init();
			characterBody = ((Component)this).GetComponent<CharacterBody>();
			((Component)this).gameObject.SetActive(false);
			combatDirector = ((Component)this).gameObject.AddComponent<CombatDirector>();
			combatDirector.moneyWaveIntervals = (RangeFloat[])(object)new RangeFloat[1];
			((Component)this).gameObject.SetActive(true);
			startDifficultyScaledCost = Run.instance.GetDifficultyScaledCost(1);
		}

		public int GetDifficultyScaledCost(int input)
		{
			return Mathf.FloorToInt((float)(input * startDifficultyScaledCost));
		}

		private void Start()
		{
			costScaler = Mathf.Pow(Run.instance.difficultyCoefficient, 1.25f);
			RussianRouletteDeath = false;
		}

		private void OnDestroy()
		{
			if (isAuthority)
			{
				HouseHUDManager.instance.DisableHUD();
			}
		}

		private void FixedUpdate()
		{
			Initialise();
			CardMissiles();
			if (isKKAInstalled)
			{
				KKAupdate();
			}
		}

		private void CardMissiles()
		{
			//IL_006f: Unknown result type (might be due to invalid IL or missing references)
			//IL_007d: Unknown result type (might be due to invalid IL or missing references)
			//IL_0082: Unknown result type (might be due to invalid IL or missing references)
			//IL_0089: Unknown result type (might be due to invalid IL or missing references)
			//IL_008e: Unknown result type (might be due to invalid IL or missing references)
			//IL_0098: Unknown result type (might be due to invalid IL or missing references)
			//IL_009d: Unknown result type (might be due to invalid IL or missing references)
			//IL_00a2: Unknown result type (might be due to invalid IL or missing references)
			//IL_00a7: Unknown result type (might be due to invalid IL or missing references)
			//IL_00c1: Unknown result type (might be due to invalid IL or missing references)
			//IL_00da: Unknown result type (might be due to invalid IL or missing references)
			//IL_016c: Unknown result type (might be due to invalid IL or missing references)
			if (MissileCount <= 0)
			{
				return;
			}
			MissileInterval -= Time.fixedDeltaTime;
			if (!(MissileInterval <= 0f))
			{
				return;
			}
			MissileInterval = 0.12f;
			MissileCount--;
			if (Util.HasEffectiveAuthority(characterBody.networkIdentity))
			{
				FireProjectileInfo val = default(FireProjectileInfo);
				val.position = characterBody.corePosition;
				val.rotation = Quaternion.LookRotation(Vector3.up + Random.insideUnitSphere * 0.3f);
				val.crit = characterBody.RollCrit();
				val.damageColorIndex = (DamageColorIndex)0;
				val.owner = ((Component)this).gameObject;
				val.procChainMask = default(ProcChainMask);
				val.force = 0f;
				val.useFuseOverride = false;
				val.useSpeedOverride = false;
				switch (random.Next(2))
				{
				case 0:
					val.projectilePrefab = Projectiles.PositiveCardMissilePrefab;
					val.damage = characterBody.damage * 0.7f;
					break;
				case 1:
					val.projectilePrefab = Projectiles.NeutralCardMissilePrefab;
					val.damage = characterBody.damage * 2.5f;
					break;
				}
				ProjectileManager.instance.FireProjectile(val);
			}
		}

		public BaseShotSkill GetShotFromCylinder()
		{
			if (roulletePriorityShot != 0)
			{
				int num = roulletePriorityShot;
				roulletePriorityShot = 0;
				if (isAuthority)
				{
					HouseHUDManager.instance.UpdateAmmo(roulletePriorityShot, roulleteAmmo);
				}
				return (BaseShotSkill)Activator.CreateInstance(((object)HouseShotDefs.shots[num].skillstate).GetType());
			}
			if (roulleteOrderPosition > 5)
			{
				return (BaseShotSkill)Activator.CreateInstance(((object)HouseShotDefs.shots[0].skillstate).GetType());
			}
			int num2 = roulleteAmmo[roulleteOrder[roulleteOrderPosition]];
			if (characterBody.HasBuff(Buffs.CupsBuff))
			{
				num2 = roulleteAmmo[roulleteOrder[random.Next(roulleteOrderPosition, 6)]];
			}
			else
			{
				num2 = roulleteAmmo[roulleteOrder[roulleteOrderPosition]];
				roulleteAmmo[roulleteOrder[roulleteOrderPosition]] = 0;
				roulleteOrderPosition++;
			}
			if (isAuthority)
			{
				HouseHUDManager.instance.UpdateAmmo(roulletePriorityShot, roulleteAmmo);
			}
			return (BaseShotSkill)Activator.CreateInstance(((object)HouseShotDefs.shots[num2].skillstate).GetType());
		}

		public BaseCardSkill GetCardFromSlot(int slotNo)
		{
			lastCardUsed = slotNo;
			Reload(HouseCardDefs.cards[handCards[slotNo]].type);
			return (BaseCardSkill)Activator.CreateInstance(((object)HouseCardDefs.cards[handCards[slotNo]].skillstate).GetType());
		}

		public void NextHand(string slotNo = "Default")
		{
			DiscardHand();
			for (int i = 0; i < 3; i++)
			{
				if (gameDeckDiscardPile.Count != 0 || gameDeck.Count != 0)
				{
					if (gameDeck.Count <= 0)
					{
						reshuffle();
					}
					handCards[i] = gameDeck[gameDeck.Count - 1];
					gameDeck.RemoveAt(gameDeck.Count - 1);
				}
				else
				{
					handCards[i] = 0;
				}
			}
			if (slotNo == "3")
			{
				slotNo = "Default";
			}
			if (isAuthority)
			{
				HouseHUDManager.instance.NewHand(handCards, slotNo);
			}
			lastCardUsed = -1;
		}

		public void DiscardHand()
		{
			for (int i = 0; i < 3; i++)
			{
				HouseCard houseCard = HouseCardDefs.cards[handCards[i]];
				if (((!houseCard.etherial && !characterBody.HasBuff(Buffs.StarBuff)) || i == lastCardUsed) && (!houseCard.exhaust || i != lastCardUsed))
				{
					gameDeckDiscardPile.Add(handCards[i]);
				}
				handCards[i] = 0;
			}
		}

		private void Reload(HouseCard.CardType type)
		{
			switch (LoadArt)
			{
			default:
				Debug.LogError((object)"[HouseError] HousePassiveManager was unable to find LoadArt");
				gameDeck = HouseCardDefs.DeckStandardSpread.ToList();
				break;
			case 0:
				ReloadStandard(type);
				break;
			case 1:
				ReloadAllIn();
				break;
			}
			if (isAuthority)
			{
				HouseHUDManager.instance.Reload(roulletePriorityShot, roulleteAmmo);
			}
		}

		private void ReloadStandard(HouseCard.CardType type)
		{
			roulleteOrderPosition = 0;
			Shuffle(roulleteOrder);
			roulleteAmmo = new int[6] { 1, 1, 1, 1, 1, 1 };
			if (random.Next(2) != 0)
			{
				return;
			}
			for (int num = random.Next(2) + 1; num > 0; num--)
			{
				int[] array = new int[1] { 1 };
				switch (type)
				{
				default:
					Debug.LogWarning((object)"[HouseError] PassiveManager was told that the card had no type.");
					break;
				case HouseCard.CardType.Positive:
					array = HouseShotDefs.positiveShots;
					break;
				case HouseCard.CardType.Negative:
					array = HouseShotDefs.negativeShots;
					break;
				case HouseCard.CardType.Neutral:
					array = HouseShotDefs.neutralShots;
					break;
				case HouseCard.CardType.Random:
					array = HouseShotDefs.randomShots;
					break;
				}
				roulleteAmmo[random.Next(6)] = array[random.Next(array.Length)];
			}
		}

		private void ReloadAllIn()
		{
			roulleteOrderPosition = 0;
			Shuffle(roulleteOrder);
			roulleteAmmo = new int[6] { 5, 5, 5, 5, 5, 5 };
			for (int num = random.Next(6); num > 0; num--)
			{
				roulleteAmmo[roulleteOrder[num]] = HouseShotDefs.positiveShots[random.Next(HouseShotDefs.positiveShots.Length)];
			}
			Shuffle(roulleteOrder);
		}

		public void Shuffle(List<int> array)
		{
			for (int num = array.Count - 1; num > 0; num--)
			{
				int index = random.Next(0, num + 1);
				int value = array[num];
				array[num] = array[index];
				array[index] = value;
			}
		}

		public void Shuffle(int[] array)
		{
			for (int num = array.Length - 1; num > 0; num--)
			{
				int num2 = random.Next(0, num + 1);
				int num3 = array[num];
				array[num] = array[num2];
				array[num2] = num3;
			}
		}

		public void reshuffle()
		{
			foreach (int item in gameDeckDiscardPile)
			{
				gameDeck.Add(item);
			}
			gameDeckDiscardPile.Clear();
			Shuffle(gameDeck);
		}

		private void Initialise()
		{
			if (Initialised)
			{
				return;
			}
			InitTime -= Time.fixedDeltaTime;
			if (!(InitTime <= 0f))
			{
				return;
			}
			SkillLocator skillLocator = characterBody.skillLocator;
			if (!Object.op_Implicit((Object)(object)skillLocator))
			{
				Debug.LogError((object)"[HouseError] HousePassiveManager was unable to find SkillLocator");
				gameDeck = HouseCardDefs.DeckStandardSpread.ToList();
			}
			else
			{
				InitialiseDeck();
				GenericSkill val = characterBody.skillLocator.allSkills[2];
				string skillNameToken = val.skillNameToken;
				string text = skillNameToken;
				if (!(text == "JAVANGLE_HOUSE_RELOADSTANDARD_NAME"))
				{
					if (!(text == "JAVANGLE_HOUSE_RELOADALLIN_NAME"))
					{
						Debug.LogError((object)"[HouseError] HousePassiveManager was unable to find ReloadArt");
					}
					else
					{
						LoadArt = 1;
					}
				}
				else
				{
					LoadArt = 0;
				}
				GenericSkill val2 = characterBody.skillLocator.allSkills[3];
				string skillNameToken2 = val2.skillNameToken;
				string text2 = skillNameToken2;
				if (!(text2 == "JAVANGLE_HOUSE_CARDARTSHOP_NAME"))
				{
					if (!(text2 == "JAVANGLE_HOUSE_CARDARTSSWEEP_NAME"))
					{
						Debug.LogError((object)"[HouseError] HousePassiveManager was unable to find CardArt");
					}
					else
					{
						CardArt = 1;
					}
				}
				else
				{
					CardArt = 0;
				}
			}
			Initialised = true;
			Shuffle(gameDeck);
			NextHand();
			Reload(HouseCard.CardType.Positive);
			bool flag = Util.HasEffectiveAuthority(characterBody.networkIdentity);
			isAuthority = flag && characterBody.isPlayerControlled;
			if (isAuthority)
			{
				HouseHUDManager.passiveManager = this;
				HouseHUDManager.instance.EnableHUD();
				HouseHUDManager.instance.UpdatePrimaryIconAndHotkeys();
				HouseHUDManager.instance.Reload(roulletePriorityShot, roulleteAmmo);
				HouseHUDManager.instance.NewHand(handCards);
			}
		}

		public void InitialiseDeck()
		{
			SkillLocator skillLocator = characterBody.skillLocator;
			if (!Object.op_Implicit((Object)(object)skillLocator))
			{
				Debug.LogError((object)"[HouseError] HousePassiveManager was unable to find SkillLocator");
				gameDeck = HouseCardDefs.DeckStandardSpread.ToList();
				return;
			}
			GenericSkill val = characterBody.skillLocator.allSkills[0];
			foreach (HouseDeckDef houseDeck in HouseCardDefs.houseDecks)
			{
				if ((Object)(object)val.skillDef == (Object)(object)houseDeck.deckSkillDef)
				{
					gameDeck = houseDeck.deckCards.ToList();
					break;
				}
			}
			if (HousePlugin.scepterInstalled)
			{
				storedScepterStacks = 0;
				HandleScepterCard();
			}
		}

		private void KKAupdate()
		{
			if (isAuthority && Object.op_Implicit((Object)(object)HouseHUDManager.HouseHotbar))
			{
				if (KingKombatArenaMainPlugin.s_GAME_MODE_ACTIVE && KingKombatArenaMainPlugin.IsInWaitingArea(((Component)characterBody).gameObject))
				{
					HouseHUDManager.instance.DisableHUD();
				}
				else
				{
					HouseHUDManager.instance.EnableHUD();
				}
			}
		}

		public void HandleScepterCard()
		{
			if (gameDeck == null)
			{
				return;
			}
			int itemCountPermanent = characterBody.inventory.GetItemCountPermanent(((ItemBase)ItemBase<AncientScepterItem>.instance).ItemDef);
			if (itemCountPermanent > storedScepterStacks)
			{
				int num = itemCountPermanent - storedScepterStacks;
				storedScepterStacks = itemCountPermanent;
				for (int i = 0; i < num; i++)
				{
					gameDeck.Add(35);
				}
				Shuffle(gameDeck);
			}
		}
	}
