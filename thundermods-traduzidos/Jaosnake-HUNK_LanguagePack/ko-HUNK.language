        "ROB_NEMESIS_BODY_OUTRO_FAILURE": "..그래서 그는 사라졌고, 인간 유닛은 이제 무력화되었습니다.",
        "ROB_NEMESIS_BODY_DEFAULT_SKIN_NAME": "기본",
        "ROB_NEMESIS_BODY_CLASSIC_SKIN_NAME": "권위 있는",
        "ROB_NEMESIS_BODY_VENOM_SKIN_NAME": "공생체",
        "ROB_NEMESIS_BODY_SUPER_SKIN_NAME": "<color=#FFFF00>얼리 서포터</color>",
        "ROB_NEMESIS_BODY_MAHORAGA_SKIN_NAME": "빅 라가 더 오프 스토파",
        "ROB_NEMESIS_BODY_MINOS_SKIN_NAME": "남자의 왕",
        "ROB_NEMESIS_BODY_PASSIVE_NAME": "최상 생명체",
        "ROB_NEMESIS_BODY_PASSIVE_DESCRIPTION": "<style=cIsDamage>피해 처리</style>은 <style=cIsHealth>바이오매스</style>을 저장하여 가득 차면 <style=cIsDamage>damage</style>를 증가시킵니다. 점프는 <style=cIsUtility>강력한 도약</style>을 위해 <style=cIsDamage>충전</style>이 될 수 있습니다.",
        "ROB_NEMESIS_BODY_PASSIVE2_NAME": "생물학적 무장",
        "ROB_NEMESIS_BODY_PASSIVE2_DESCRIPTION": "Nemesis T-Type은 <style=cIsDamage>관심 있는 사람</style>을 소비하여 <style=cIsHealth>변형</style>을 수행하고 <style=cIsDamage>새롭고 향상된 능력</style>을 얻을 수 있습니다.",
        "ROB_NEMESIS_BODY_PASSIVE22_NAME": "근육량 증가",
        "ROB_NEMESIS_BODY_PASSIVE22_DESCRIPTION": "<style=cIsUtility>근접 공격</style> 처리 <style=cIsDamage>20%</style> 더 많은 피해, <style=isHealth>BUT 아군이 피해를 입을 수 있음</style>.",
        "ROB_NEMESIS_BODY_MELEE_NAME": "잔인한 공격성",
        "ROB_NEMESIS_BODY_MELEE_DESCRIPTION": "<style=cIsDamage>350% 피해를 주는 펀치</style>. <style=cIsUtility>정지된</style> 동안 사용하면 <style=cIsDamage>800% 피해</style>를 위해 밟을 수 있습니다. <style=cIsUtility>running</style>을 어깨 강타로 사용하여 <style=cIsDamage>600% 피해</style>를 얻으세요.",
        "ROB_NEMESIS_BODY_GRAB_NAME": "치명적인 도달",
        "ROB_NEMESIS_BODY_GRAB_DESCRIPTION": "적을 잡아라. 1차를 사용하면 최대 체력의 10%를 소모하고 치유할 수 있으며, 2차를 사용하면 최대 2,400%의 데미지를 충전할 수 있습니다.",
        "ROB_NEMESIS_BODY_DASH_NAME": "바이오해저드 러시",
        "ROB_NEMESIS_BODY_DASH_DESCRIPTION": "<style=cIsUtility>이 공중에 있는 동안</style>을 사용하여 <style=cIsDamage>한 번</style>을 공중 대시하세요.",
        "ROB_NEMESIS_BODY_ULTIMATE_NAME": "임계질량",
