{
    "de": {
        "ROB_DANTE_BODY_NAME": "<color=#B70027>Dante</color>",
        "ROB_NERO_BODY_NAME": "<color=#2150AF>Nero</color>",
        "ROB_VERGIL_BODY_NAME": "<color=#32D2FF>Vergil</color>",
        "ROB_DANTE_BODY_DESCRIPTION": "<color=#B70027>Dante</color>ist ein legendärer Teufelsjäger, der mit zwei Pistolen und einem Schwert kämpft.<color=#CCD3E0>\n\n< ! >Ebony & Ivory ist eine zuverlässige und beständige Schadensquelle.\n\n< ! >Jeder Teufelsarm verfügt über ein einzigartiges Bewegungsset. Experimentieren Sie mit Richtungseingaben, um das Beste daraus zu machen.\n\n< ! >Verwenden Sie Trick, um Aktionen abzubrechen und eingehenden Schlägen auszuweichen.\n\n< ! >Devil Trigger macht so was und so.",
        "ROB_DANTE_BODY_SUBTITLE": "Legendärer Teufelsjäger",
        "ROB_DANTE_BODY_LORE": "Weißt du, ich sollte meine Jobs wirklich besser erkunden, bevor ich sie annehme.\n\nEin Typ kommt in meinen Laden und redet über Monster, die getötet werden müssen. Wirklich steif und ordentlich, wahrscheinlich militärisch. Die Schrotflinte dort, wo sein linker Arm sein sollte. Muss es ernst meinen.\n\nEr wirft eine Tüte Geld und ein Schiffsticket auf den Tisch. Damit werde ich monatelang schön sitzen!\n\nAber ich muss cool bleiben und hart spielen.\n\n„Langfristiger Job bedeutet langfristiges Gehalt.“\n\n„Ich glaube, das wird Ihre Meinung ändern.“\n\nFoto landet auf dem Tisch. Zeigt einen Mann, der in ... Glas gefangen ist? Ich kann sein Gesicht nicht erkennen, aber diesen Anhänger würde ich von überall her kennen.\n\nDieser Typ hat seine Hausaufgaben gemacht. Ich schätze, ich muss auf dieses Schiff.\n\n'Handeln.'\n\nJetzt darf ich um den Planeten wandern und den Müll aufräumen.\n\nWochenlanges Suchen, Töten, Überleben.\n\nAber ich muss es finden<color=#32D2FF>ihn</color>.\n\nJob ist ein Job, oder?\n\n<color=#B70027>Lasst uns rocken.</color>",
        "ROB_DANTE_BODY_OUTRO_FLAVOR": "..und so ging er.",
        "ROB_DANTE_BODY_OUTRO_FAILURE": "..und so verschwand er.",
        "ROB_DANTE_BODY_DEFAULT_SKIN_NAME": "<color=#B70027>Standard</color>",
        "ROB_DANTE_BODY_MASTERY_SKIN_NAME": "<color=#B70027>Klassiker</color>",
        "ROB_DANTE_BODY_TYPHOON_SKIN_NAME": "<color=#B70027>Keine Ahnung</color>",
        "ROB_DANTE_BODY_PRESTIGE_SKIN_NAME": "<color=#B70027>Prestige</color>",
        "ROB_DANTE_BODY_DMC2_SKIN_NAME": "<color=#B70027>Veteran</color>",
        "ROB_DANTE_BODY_DMC_SKIN_NAME": "<color=#B70027>El Donte</color>",
        "ROB_DANTE_BODY_SUPER_SKIN_NAME": "<color=#B70027>Super</color>",
        "ROB_DANTE_BODY_VERGIL_SKIN_NAME": "<color=#32D2FF>Vergil</color>",
        "ROB_DANTE_BODY_VERGILEX_SKIN_NAME": "<color=#32D2FF>Vergil EX</color>",
        "ROB_DANTE_BODY_MINECRAFT_SKIN_NAME": "<color=#B70027>Minecraft</color>",
        "ROB_DANTE_BODY_PASSIVE_NAME": "<color=#B70027>Sohn von Sparda</color>",
        "ROB_DANTE_BODY_PASSIVE_DESCRIPTION": "<color=#B70027>Dante</color>hat Zugriff auf mehrere<style=cIsDamage>einzigartige Fähigkeiten</style>. <style=cIsUtility>Bewegen Sie den Mauszeiger für weitere Informationen.</style>",
        "ROB_DANTE_BODY_CONFIRM_NAME": "Bestätigen",
        "ROB_DANTE_BODY_CONFIRM_DESCRIPTION": "Fahren Sie mit dem aktuellen Skill fort.",
        "ROB_DANTE_BODY_CANCEL_NAME": "Stornieren",
        "ROB_DANTE_BODY_CANCEL_DESCRIPTION": "Brechen Sie den aktuellen Skill ab.",
        "ROB_DANTE_BODY_PRIMARY_NAME": "<color=#B70027>Ebenholz und Elfenbein</color>",
        "ROB_DANTE_BODY_PRIMARY_DESCRIPTION": "Schnell schießen<style=cIsDamage>120 % Schaden</style>. Hör auf zu schießen<style=cIsUtility>1 Sekunde</style>eine vorbereiten<style=cIsDamage>Ladungsschuss</style>das handelt<style=cIsDamage>350 % Schaden</style>.",
        "ROB_NERO_BODY_PRIMARY_NAME": "<color=#2150AF>Blaue Rose</color>",
        "ROB_NERO_BODY_PRIMARY_DESCRIPTION": "Schießen Sie zweimal, z<style=cIsDamage>200 % Schaden</style>Und<style=cIsDamage>350 % Schaden</style>. Halten Sie<style=cIsUtility>1 Sekunde</style>eine vorbereiten<style=cIsDamage>Ladungsschuss</style>.",
        "ROB_VERGIL_BODY_PRIMARY_NAME": "<color=#32D2FF>Schwerter beschwören</color>",
        "ROB_VERGIL_BODY_PRIMARY_DESCRIPTION": "Feuerspektralschwerter für<style=cIsDamage>200 % Schaden</style>.",
        "ROB_DANTE_BODY_MELEE_NAME": "<color=#B70027>Sperren und Laden</color>",
        "ROB_DANTE_BODY_MELEE_DESCRIPTION": "Bereiten Sie Ihr vor<style=cIsUtility>gehaltene Waffe</style>. <style=cIsDamage>Primär</style>wird<style=cIsDamage>Nahkampfangriffe</style>, und feindliche Angriffe sind<style=cIsUtility>abgelenkt</style>während gehalten.",
        "ROB_DANTE_BODY_UTILITY_NAME": "<color=#B70027>Trick</color>",
        "ROB_DANTE_BODY_UTILITY_DESCRIPTION": "<style=cIsUtility>Bindestrich</style>in eine Richtung, kurz werdend<style=cIsUtility>unverwundbar</style>. <style=cIsUtility>Nahkampftreffer erneuern diese Fertigkeit sofort.</style>",
        "ROB_DANTE_BODY_SPECIAL_DEVILTRIGGER_NAME": "<color=#A556FF>Teufelsauslöser</color>",
        "ROB_DANTE_BODY_SPECIAL_DEVILTRIGGER_DESCRIPTION": "<color=#B70027>Hellbent.</color>Aktivieren<color=#A556FF>Teufelsauslöser</color>, entleeren Sie Ihre Anzeige, um vorübergehend zu gewinnen<style=cIsUtility>Rüstung</style>, <style=cIsHealing>Regeneration</style>Und<style=cIsDamage>Schaden</style>. <style=cIsUtility>Nahkampftreffer füllen die Anzeige.</style>",
        "ROB_DANTE_BODY_SPECIAL_DEVILTRIGGER_SCEPTER_NAME": "Perfekter Teufelsauslöser",
        "ROB_DANTE_BODY_SPECIAL_DEVILTRIGGER_SCEPTER_DESCRIPTION": "<color=#B70027>Hellbent.</color>Aktivieren<color=#A556FF>Teufelsauslöser</color>, entleeren Sie Ihre Anzeige, um vorübergehend zu gewinnen<style=cIsUtility>Rüstung</style>, <style=cIsHealing>Regeneration</style>Und<style=cIsDamage>Schaden</style>. <style=cIsUtility>Nahkampftreffer füllen die Anzeige.</style>\n<color=#d299ff>ZEPTER: Verwüste deine Feinde mit beschworenen Schwertern, während es aktiv ist.</color>",
        "ROB_DANTE_BODY_SPECIAL_SDT_NAME": "<color=#B70027>Sin Devil Trigger</color>",
        "ROB_DANTE_BODY_SPECIAL_SDT_DESCRIPTION": "<style=cIsUtility>Halten</style>um das Messgerät in den Trichter zu leiten<color=#B70027>Sin Devil Trigger</color>Messgerät.<style=cIsUtility>Halten</style>Wenn es voll ist, um es zu entfesseln<style=cIsDamage>wahre dämonische Form</style>für kurze Zeit.",
        "ROB_DANTE_BODY_SPECIAL_SDT_SCEPTER_NAME": "<color=#B70027>Perfekter Sin Devil-Auslöser</color>",
        "ROB_DANTE_BODY_SPECIAL_SDT_SCEPTER_DESCRIPTION": "<style=cIsUtility>Halten</style>um das Messgerät in den Trichter zu leiten<color=#B70027>Sin Devil Trigger</color>Messgerät.<style=cIsUtility>Halten</style>Wenn es voll ist, um es zu entfesseln<style=cIsDamage>wahre dämonische Form</style>für kurze Zeit.\n<color=#d299ff>ZEPTER: Verwüste deine Feinde mit beschworenen Schwertern, während es aktiv ist.</color>",
        "ROB_DANTE_BODY_SPECIAL_PISTOL_NAME": "Silberkugel",
        "ROB_DANTE_BODY_SPECIAL_PISTOL_DESCRIPTION": "Erschieße a<style=cIsUtility>Silberkugel</style>für<style=cIsDamage>800 % Schaden</style>. <style=cIsUtility>Kopfschüsse</style>handeln<style=cIsDamage>2x Schaden</style>. Tötet<style=cIsUtility>Setzen Sie alle Ihre Abklingzeiten zurück</style>.",
        "ROB_DANTE_BODY_SPECIAL_PISTOL_SCEPTER_NAME": "Goldene Waffe",
        "ROB_DANTE_BODY_SPECIAL_PISTOL_SCEPTER_DESCRIPTION": "Erschieße a<style=cIsUtility>Silberkugel</style>für<style=cIsDamage>800 % Schaden</style>. <style=cIsUtility>Kopfschüsse</style>handeln<style=cIsDamage>2x Schaden</style>. Tötet<style=cIsUtility>Setzen Sie alle Ihre Abklingzeiten zurück</style>.\n<color=#d299ff>ZEPTER: Verursacht 9000 % Schaden.</color>",
        "ROB_DANTE_BODY_SPECIAL_HOLYCROSS_NAME": "Heilige Flamme",
        "ROB_DANTE_BODY_SPECIAL_HOLYCROSS_DESCRIPTION": "Rufen Sie die Macht an<color=#FF0033>Vorsehung</color>, entfesseln a<style=cIsUtility>gewaltige Flamme</style>für<style=cIsDamage>300 % Schaden pro Tick</style>. Endet mit a<style=cIsDamage>4000 % Schaden</style>Supernova.",
