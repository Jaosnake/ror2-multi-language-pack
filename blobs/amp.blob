		{
			//IL_007f: Unknown result type (might be due to invalid IL or missing references)
			//IL_0084: Unknown result type (might be due to invalid IL or missing references)
			//IL_0101: Unknown result type (might be due to invalid IL or missing references)
			//IL_00aa: Unknown result type (might be due to invalid IL or missing references)
			//IL_00af: Unknown result type (might be due to invalid IL or missing references)
			//IL_0200: Unknown result type (might be due to invalid IL or missing references)
			//IL_0205: Unknown result type (might be due to invalid IL or missing references)
			//IL_021f: Unknown result type (might be due to invalid IL or missing references)
			//IL_0224: Unknown result type (might be due to invalid IL or missing references)
			characterEnabled = Config.CharacterEnableConfig(bodyName);
			if (characterEnabled.Value)
			{
				InitializeUnlockables();
				bodyPrefab = Prefabs.CreatePrefab(bodyName + "Body", "mdl" + bodyName, bodyInfo);
				if (isAmp)
				{
					bodyPrefab.GetComponent<EntityStateMachine>().mainStateType = new SerializableEntityStateType(typeof(AmpMain));
				}
				if (isNemAmp)
				{
					bodyPrefab.GetComponent<EntityStateMachine>().mainStateType = new SerializableEntityStateType(typeof(NemAmpMain));
				}
				Prefabs.SetupCharacterModel(bodyPrefab, customRendererInfos, mainRendererIndex);
				displayPrefab = Prefabs.CreateDisplayPrefab(bodyName + "Display", bodyPrefab, bodyInfo);
				Prefabs.RegisterNewSurvivor(bodyPrefab, displayPrefab, Color.grey, bodyName.ToUpper(), characterUnlockableDef, 101f);
				InitializeHitboxes();
				InitializeSkills();
				InitializeSkins();
				InitializeItemDisplays();
				InitializeDoppelganger();
				if (isAmp)
				{
					bodyPrefab.AddComponent<AmpLightningController>();
					PlayMenuSound playMenuSound = displayPrefab.AddComponent<PlayMenuSound>();
					playMenuSound.soundString = "PlayLobbyEntrance";
				}
				if (isNemAmp)
				{
					bodyPrefab.AddComponent<NemAmpLightningTracker>();
					bodyPrefab.AddComponent<StackDamageController>();
					bodyPrefab.AddComponent<NemAmpBuffVFXController>();
					bodyPrefab.AddComponent<NemAmpLightningTetherController>();
					bodyPrefab.AddComponent<NemLightningColorController>();
					bodyPrefab.AddComponent<DashCrosshairController>();
					bodyPrefab.AddComponent<DashPrimaryActiveVFXController>();
					CharacterDeathBehavior component = bodyPrefab.GetComponent<CharacterDeathBehavior>();
					EntityStateMachine component2 = bodyPrefab.GetComponent<EntityStateMachine>();
					component.deathState = new SerializableEntityStateType(typeof(NemDeathState));
					component.deathStateMachine = component2;
					component2.initialStateType = new SerializableEntityStateType(typeof(NemSpawnState));
					PlayMenuSound playMenuSound2 = displayPrefab.AddComponent<PlayMenuSound>();
					playMenuSound2.soundString = "Play_item_use_lighningArm";
				}
				isAmp = false;
				isNemAmp = false;
			}
		}

		internal virtual void InitializeUnlockables()
		{
		}

		internal virtual void InitializeSkills()
		{
		}

		internal virtual void InitializeHitboxes()
		{
		}

		internal virtual void InitializeSkins()
		{
		}

		internal virtual void InitializeDoppelganger()
		{
			if (isAmp)
			{
				Prefabs.CreateGenericDoppelganger(instance.bodyPrefab, bodyName + "MonsterMaster", "Merc");
			}
			else if (isNemAmp)
			{
				Prefabs.CreateGenericDoppelganger(instance.bodyPrefab, bodyName + "MonsterMaster", "Mage");
			}
			else
			{
				Prefabs.CreateGenericDoppelganger(instance.bodyPrefab, bodyName + "MonsterMaster", "Merc");
			}
		}

		public virtual void InitializeItemDisplays()
		{
			CharacterModel componentInChildren = bodyPrefab.GetComponentInChildren<CharacterModel>();
			ItemDisplayRuleSet val = ScriptableObject.CreateInstance<ItemDisplayRuleSet>();
			((Object)val).name = "idrs" + bodyName;
			componentInChildren.itemDisplayRuleSet = val;
			if (itemDisplays != null)
			{
				ContentManager.onContentPacksAssigned += SetItemDisplays;
			}
		}

		public void SetItemDisplays(ReadOnlyArray<ReadOnlyContentPack> obj)
		{
			CharacterModel componentInChildren = bodyPrefab.GetComponentInChildren<CharacterModel>();
			itemDisplays.SetItemDisplays(componentInChildren.itemDisplayRuleSet);
		}
	}
}
