			}
			InspiringDroneMinionBehavior inspiringDroneMinionBehavior = (Object.op_Implicit((Object)(object)report.victimMaster) ? ((Component)report.victimMaster).GetComponent<InspiringDroneMinionBehavior>() : null);
			if (Object.op_Implicit((Object)(object)inspiringDroneMinionBehavior) && Object.op_Implicit((Object)(object)inspiringDroneMinionBehavior.OwnerBody))
