		private static AssetBundle assetBundle => CharacterBase<TeslaTrooperSurvivor>.instance.assetBundle;

		[MethodImpl(MethodImplOptions.NoInlining | MethodImplOptions.NoOptimization)]
		public void Init()
		{
			//IL_0042: Unknown result type (might be due to invalid IL or missing references)
			//IL_004c: Expected O, but got Unknown
			SurvivorCatalog.SetSurvivorDefs_Driver += SurvivorCatalog_SetSurvivorDefs_Driver;
			Language.Add("HABIBI_TESLA_BODY_DRIVER_GUN_NAME", "Tesla Gauntlet");
			Language.Add("HABIBI_TESLA_BODY_DRIVER_GUN_DESCRIPTION", "2000 volts coming up.");
			if (GeneralConfig.Debug.Value)
			{
				CharacterBody.Update += new hook_Update(CharacterBody_Update);
			}
		}

		private void SurvivorCatalog_SetSurvivorDefs_Driver(GameObject driverBody)
		{
			driverBody.AddComponent<TeslaTrackerComponent>();
			driverBody.AddComponent<DriverTeslaTrackerComponentZap>();
			driverBody.AddComponent<TeslaTowerControllerControllerGuest>();
			Log.Debug("found driver. adding tracker");
			DoDriverCompat();
		}

		private void CharacterBody_Update(orig_Update orig, CharacterBody self)
		{
			orig.Invoke(self);
			DriverController val = default(DriverController);
			if (Input.GetKeyDown((KeyCode)104) && ((Component)self).TryGetComponent<DriverController>(ref val))
			{
				val.PickUpWeapon(DriverWeaponCatalog.GetWeaponFromIndex((int)teslaGunIndex), -1f, false);
			}
		}

		private void DoDriverCompat()
		{
			TeslaDriverWeapon teslaDriverWeapon = new TeslaDriverWeapon();
			((BaseWeapon)teslaDriverWeapon).Init();
			teslaGunIndex = ((BaseWeapon)teslaDriverWeapon).weaponDef.index;
			InitConfig();
			Content.AddEntityState(typeof(DriverZap));
			Content.AddEntityState(typeof(DriverAimBigZap));
			Content.AddEntityState(typeof(DriverBigZap));
			Language.Add("HABIBI_TESLA_BODY_PRIMARY_ZAP_DRIVER_DESCRIPTION", "Zap targeted units with 3 bolts of electricity for " + Tokens.DamageText($"3x{(float)Driver_M1_Damage * 100f}% damage") + ". " + Tokens.UtilityText("Charges allies") + ".");
		}

		private void InitConfig()
		{
			string section = "2-1. Tesla Mod Compats";
			Driver_M1_Damage = Config.BindAndOptions(section, "Driver_M1_Damage", 2f, 0f, 20f, "each lightning bolt");
		}
	}
