		}

		internal static string Lee(string desc, string altDesc, bool isColoured)
		{
			//IL_0071: Unknown result type (might be due to invalid IL or missing references)
			//IL_002d: Unknown result type (might be due to invalid IL or missing references)
			if (Config.loreMode.Value)
			{
				if (!isColoured)
				{
					return altDesc;
				}
				return "<color=#" + ColorUtility.ToHtmlStringRGB(StaticValues.bodyColor) + ">" + altDesc + "</color>";
			}
			if (!isColoured)
			{
				return desc;
			}
			return "<color=#" + ColorUtility.ToHtmlStringRGB(StaticValues.bodyColor) + ">" + desc + "</color>";
		}

