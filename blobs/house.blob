namespace HouseMod.Modules.Survivors
{
	public static class House
	{
		internal static GameObject characterPrefab;

		internal static GameObject displayPrefab;

		internal static ConfigEntry<bool> characterEnabled;

		public const string bodyName = "JavangleHouse";

		public const string bodyNameToken = "JAVANGLE_HOUSE_BODY_NAME";

		public static int bodyRendererIndex;

		internal static ItemDisplayRuleSet itemDisplayRuleSet;

		internal static List<KeyAssetRuleGroup> itemDisplayRules;

		internal static UnlockableDef characterUnlockableDef;

		internal static UnlockableDef masterySkinUnlockableDef;

		internal static void CreateCharacter()
		{
			//IL_0046: Unknown result type (might be due to invalid IL or missing references)
			//IL_004b: Unknown result type (might be due to invalid IL or missing references)
			//IL_0061: Unknown result type (might be due to invalid IL or missing references)
			//IL_0066: Unknown result type (might be due to invalid IL or missing references)
			//IL_00eb: Unknown result type (might be due to invalid IL or missing references)
			//IL_00f0: Unknown result type (might be due to invalid IL or missing references)
			//IL_0109: Unknown result type (might be due to invalid IL or missing references)
			//IL_010e: Unknown result type (might be due to invalid IL or missing references)
			//IL_011d: Unknown result type (might be due to invalid IL or missing references)
			//IL_026f: Unknown result type (might be due to invalid IL or missing references)
			bool flag = true;
			CreateUnlockables();
			characterPrefab = Prefabs.CreatePrefab("JavangleHouse", "mdlHouse", new BodyInfo
			{
				armor = 0f,
				armorGrowth = 0f,
				bodyName = "JavangleHouse",
				bodyNameToken = "JAVANGLE_HOUSE_BODY_NAME",
				bodyColor = Color.green,
				characterPortrait = Assets.LoadCharacterIcon(),
				crosshair = Addressables.LoadAssetAsync<GameObject>((object)"RoR2/DLC1/Railgunner/BlankCrosshair.prefab").WaitForCompletion(),
				damage = 12f,
				healthGrowth = 33f,
				healthRegen = 1.5f,
				jumpCount = 1,
				maxHealth = 110f,
				subtitleNameToken = "JAVANGLE_HOUSE_BODY_SUBTITLE",
				podPrefab = LegacyResourcesAPI.Load<GameObject>("Prefabs/NetworkedObjects/SurvivorPod")
			});
			characterPrefab.AddComponent<HouseController>();
			characterPrefab.GetComponent<CharacterDeathBehavior>().deathState = new SerializableEntityStateType(typeof(HouseDeathState));
			characterPrefab.GetComponent<EntityStateMachine>().mainStateType = new SerializableEntityStateType(typeof(HouseMain));
			Material material = Assets.CreateMaterial("HouseMat", 10f, Color.white);
			Material material2 = Assets.CreateMaterial("HouseMatShiny", 10f);
			Material material3 = Assets.CreateMaterial("HouseRouletteMat", 10f);
			Material material4 = Assets.CreateMaterial("HouseRouletteMatShiny", 10f);
			bodyRendererIndex = 1;
			Prefabs.SetupCharacterModel(characterPrefab, new CustomRendererInfo[8]
			{
				new CustomRendererInfo
				{
					childName = "HouseMesh",
					material = material
				},
				new CustomRendererInfo
				{
					childName = "CoatMesh",
					material = material
				},
				new CustomRendererInfo
				{
					childName = "GoldMesh",
					material = material2
				},
				new CustomRendererInfo
				{
					childName = "HatMesh",
					material = material
				},
				new CustomRendererInfo
				{
					childName = "RevolverMesh",
					material = material3
				},
				new CustomRendererInfo
				{
					childName = "RevolverGoldMesh",
					material = material4
				},
				new CustomRendererInfo
				{
					childName = "TieMesh",
					material = material
				},
				new CustomRendererInfo
				{
					childName = "CoinMesh",
					material = material2
				}
			}, bodyRendererIndex);
			characterPrefab.AddComponent<HousePassiveManager>();
			displayPrefab = Prefabs.CreateDisplayPrefab("HouseDisplay", characterPrefab);
			Prefabs.RegisterNewSurvivor(characterPrefab, displayPrefab, Color.green, "HOUSE", characterUnlockableDef);
			CreateHitboxes();
			CreateSkills();
			CreateSkins();
			CreateDoppelganger();
		}

		private static void CreateUnlockables()
		{
		}

		private static void CreateDoppelganger()
		{
			Prefabs.CreateGenericDoppelganger(characterPrefab, "HouseMonsterMaster", "Merc");
		}

		private static void CreateHitboxes()
		{
			ChildLocator componentInChildren = characterPrefab.GetComponentInChildren<ChildLocator>();
			GameObject gameObject = ((Component)componentInChildren).gameObject;
			Transform hitboxTransform = componentInChildren.FindChild("CardHitbox");
			Prefabs.SetupHitbox(gameObject, hitboxTransform, "CardSwipe");
		}

