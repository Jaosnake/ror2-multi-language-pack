{
    "FR": {
        "ROB_HUNK_BODY_NAME": "HUNK",
        "ROB_HUNK_BODY_DESCRIPTION": "HUNK est un infiltré d'élite qui transporte un vaste arsenal d'armes obtenues via OSP (On-Site Procurement).<color=#CCD3E0>Original mod by rob</i>",
        "ROB_HUNK_BODY_SUBTITLE": "Le Faucheur",
        "ROB_HUNK_BODY_OUTRO_FLAVOR": "..et ainsi il partit, tout va bien.",
        "ROB_HUNK_BODY_OUTRO_FAILURE": "..et ainsi il disparut, unité humaine maintenant neutralisée.",
        "ROB_HUNK_BODY_DEFAULT_SKIN_NAME": "Par défaut",
        "ROB_HUNK_BODY_CLASSIC_SKIN_NAME": "RE2make",
        "ROB_HUNK_BODY_TOFU_SKIN_NAME": "Tofu",
        "ROB_HUNK_BODY_SUPER_SKIN_NAME": "<color=#FFFF00>Early Supporter</color>",
        "ROB_HUNK_BODY_LIGHTWEIGHT_SKIN_NAME": "Léger",
        "ROB_HUNK_BODY_GUERRILLA_SKIN_NAME": "Troupier",
        "ROB_HUNK_BODY_ROOKIE_SKIN_NAME": "Recrue",
        "ROB_HUNK_BODY_SWAT_SKIN_NAME": "Pacificateur",
        "ROB_HUNK_BODY_LEON_SKIN_NAME": "Specialist",
        "ROB_HUNK_BODY_LEONSHIRT_SKIN_NAME": "Specialist EX",
        "ROB_HUNK_BODY_ENFORCER_SKIN_NAME": "Bulldozer",
        "ROB_HUNK_BODY_WESKER_SKIN_NAME": "Mastermind",
        "ROB_HUNK_BODY_DOOM_SKIN_NAME": "Slayer",
        "ROB_HUNK_BODY_COMMANDO_SKIN_NAME": "Commando",
        "ROB_HUNK_BODY_JACKET_SKIN_NAME": "Veste",
        "ROB_HUNK_BODY_PPASSIVE_NAME": "OSP (On-Site Procurement)",
        "ROB_HUNK_BODY_PPASSIVE_DESCRIPTION": "HUNK peut collecter des <color=#FFFF00>U.C. Keycards</color> pour ouvrir des <style=cIsDamage>mallettes d'armes</style> et étendre son arsenal.",
        "ROB_HUNK_BODY_PPASSIVE2_NAME": "Soldat Oublié",
        "ROB_HUNK_BODY_PPASSIVE2_DESCRIPTION": "Le premier <style=cIsHealth>boss</style> à mourir à chaque Étape laisse tomber un <style=cIsDamage>paquet de ravitaillement</style> contenant une arme ou un accessoire.",
        "ROB_HUNK_BODY_PASSIVE_NAME": "Combat Obscur",
        "ROB_HUNK_BODY_PASSIVE_DESCRIPTION": "Commencez avec une <style=cIsDamage>LE 5</style> et une <style=cIsDamage>arme secondaire</style>. Vous pouvez <style=cIsDamage>fouiller</style> <style=cIsUtility>les coffres</style> pour trouver des munitions.",
        "ROB_HUNK_BODY_PASSIVE2_NAME": "Effroi Imminent",
        "ROB_HUNK_BODY_PASSIVE2_DESCRIPTION": "Commencez avec un <style=cIsDamage>arsenal complet</style>, <style=cIsHealth>MAIS</style> vous ne pouvez plus <style=cIsHealth>obtenir de munitions supplémentaires</style>.",
        "ROB_HUNK_BODY_RANDOMPASSIVE_NAME": "New Game+",
        "ROB_HUNK_BODY_RANDOMPASSIVE_DESCRIPTION": "Commencez avec une <style=cIsDamage>LE 5</style> et une <style=cIsDamage>arme secondaire</style>. Vous pouvez <style=cIsDamage>fouiller</style> <style=cIsUtility>les coffres</style> pour trouver des munitions. <style=cIsHealth>Tout le contenu des mallettes d'armes est aléatoire.</style>",
        "ROB_HUNK_BODY_SHOTGUNPASSIVE_NAME": "Autorité Suprême",
        "ROB_HUNK_BODY_SHOTGUNPASSIVE_DESCRIPTION": "Commencez avec une <style=cIsDamage>W-870</style> et une <style=cIsDamage>arme secondaire</style>. Vous pouvez <style=cIsDamage>fouiller</style> <style=cIsUtility>les coffres</style> pour trouver des munitions.",
        "ROB_HUNK_BODY_SMGPASSIVE_NAME": "Mercenaire Suprême",
        "ROB_HUNK_BODY_SMGPASSIVE_DESCRIPTION": "Commencez <style=cIsHealth>SEULEMENT</style> avec une <style=cIsDamage>LE 5 entièrement améliorée</style>. Vous pouvez <style=cIsDamage>fouiller</style> <style=cIsUtility>les coffres</style> pour trouver des munitions. La <style=cIsDamage>Spéciale</style> est remplacée par <color=#C80202>Mode Chaos</color>.",
        "ROB_HUNK_BODY_WPASSIVE_NAME": "Saturation Globale Complète",
        "ROB_HUNK_BODY_WPASSIVE_DESCRIPTION": "Commencez <style=cIsHealth>SEULEMENT</style> avec une <style=cIsDamage>arme secondaire</style>. Vous pouvez <style=cIsDamage>fouiller</style> <style=cIsUtility>les coffres</style> pour trouver des munitions. L'<style=cIsDamage>Utilitaire</style> est remplacé par <color=#C80202>Uroboros</color>.",
        "ROB_HUNK_BODY_FLAMERPASSIVE_NAME": "Pyromanie",
        "ROB_HUNK_BODY_FLAMERPASSIVE_DESCRIPTION": "Commencez <style=cIsHealth>SEULEMENT</style> avec un <style=cIsDamage>Lance-flammes Chimique</style>. Vous pouvez <style=cIsDamage>fouiller</style> <style=cIsUtility>les coffres</style> pour trouver des munitions. <style=cIsHealth>Seulement UNE mallette d'armes apparaît par Étape.</style>",
        "ROB_HUNK_BODY_PRIMARY_KNIFE_NAME": "Couteau de Combat",
        "ROB_HUNK_BODY_PRIMARY_KNIFE_DESCRIPTION": "<style=cIsUtility>Tirez.</style> <style=cIsDamage>Tranchez</style> les combattants proches pour <style=cIsDamage>200% de dégâts</style>, infligeant <style=cIsHealth>Mutilé</style>.",
        "ROB_HUNK_BODY_PRIMARY_CQC_NAME": "CQC (Combat de Proximité)",
        "ROB_HUNK_BODY_PRIMARY_CQC_DESCRIPTION": "<style=cIsUtility>Tirez.</style> <style=cIsDamage>Donnez deux coups de pied</style> pour <style=cIsDamage>200% et 250% de dégâts</style>. Si le <style=cIsUtility>deuxième coup de pied</style> touche, enchaînez avec une <style=cIsDamage>Contre-attaque</style>.",
        "ROB_HUNK_BODY_PRIMARY_RELOAD_NAME": "Recharger",
        "ROB_HUNK_BODY_RELOAD_DESCRIPTION": "Rechargez votre arme actuelle.",
        "ROB_HUNK_BODY_SECONDARY_AIM_NAME": "Viser Ferme",
        "ROB_HUNK_BODY_SECONDARY_AIM_DESCRIPTION": "Visez, <style=cIsUtility>exposant les points faibles ennemis</style>. <style=cIsDamage>Utiliser le primaire en visant tire votre arme équipée.</style>",
        "ROB_HUNK_BODY_UTILITY_DODGE_NAME": "Quickstep",
        "ROB_HUNK_BODY_UTILITY_DODGE_DESCRIPTION": "<style=cIsUtility>Avancez</style> d'une courte distance. Si utilisé de manière préventive pour <style=cIsUtility>éviter une attaque</style>, effectuez une <style=cIsDamage>Esquive Parfaite</style>.",
        "ROB_HUNK_BODY_UTILITY_DODGE_SCEPTER_NAME": "Uroboros",
        "ROB_HUNK_BODY_UTILITY_DODGE_SCEPTER_DESCRIPTION": "<style=cIsUtility>Avancez</style> d'une courte distance. Si utilisé de manière préventive pour <style=cIsUtility>éviter une attaque</style>, effectuez une <style=cIsDamage>Esquive Parfaite</style>. Le pouvoir d'Uroboros coule en vous.",
        "ROB_HUNK_BODY_UTILITY_PARRY_NAME": "Parade",
        "ROB_HUNK_BODY_UTILITY_PARRY_DESCRIPTION": "<style=cIsUtility>Bloquez</style> une attaque, <style=cIsDamage>annulant</style> les dégâts et <style=cIsUtility>remboursant le temps de recharge</style>. Si utilisé de manière préventive, effectuez une <style=cIsDamage>Parade Parfaite</style>.",
        "ROB_HUNK_BODY_UTILITY_BASH_NAME": "Coup d'épaule",
        "ROB_HUNK_BODY_UTILITY_BASH_DESCRIPTION": "<style=cIsUtility>Frappez</style> les ennemis proches avec l'épaule, <style=cIsUtility>les étourdissant</style> pour <style=cIsDamage>400% de dégâts</style>. Si utilisé de manière préventive pour <style=cIsUtility>annuler une attaque</style>, effectuez une <style=cIsDamage>Déflexion Parfaite</style>.",
        "ROB_HUNK_BODY_SPECIAL_SWAP_NAME": "Légion",
        "ROB_HUNK_BODY_SPECIAL_SWAP_DESCRIPTION": "<style=cIsUtility>Échangez</style> pour une <style=cIsDamage>arme différente</style>. Appuyez pour échanger vers <style=cIsUtility>votre dernière arme utilisée</style>.",
        "ROB_HUNK_BODY_SPECIAL_MAYHEM_NAME": "Mode Chaos",
        "ROB_HUNK_BODY_SPECIAL_MAYHEM_DESCRIPTION": "Entrez en <style=cIsDamage>Mode Chaos</style>, augmentant considérablement les performances de l'arme.",
        "ROB_HUNK_BODY_CONFIRM_NAME": "Confirmer",
        "ROB_HUNK_BODY_CONFIRM_DESCRIPTION": "Procéder avec la compétence actuelle.",
        "ROB_HUNK_BODY_CANCEL_NAME": "Annuler",
        "ROB_HUNK_BODY_CANCEL_DESCRIPTION": "Annuler la compétence actuelle.",
        "ROB_HUNK_BODY_KNIFE_DEFAULT_NAME": "Couteau de Combat",
        "ROB_HUNK_BODY_KNIFE_DEFAULT_DESCRIPTION": "Un couteau militaire standard. Certainement utile dans les moments difficiles.",
        "ROB_HUNK_BODY_KNIFE_INFINITE_NAME": "Couteau de Combat EX",
        "ROB_HUNK_BODY_KNIFE_INFINITE_DESCRIPTION": "Un couteau militaire traité spécialement qui a été durci à un degré incroyable. On dit qu'il est fait pour durer vraiment.",
        "ROB_HUNK_BODY_KNIFE_HIDDEN_NAME": "Lame Cachée",
        "ROB_HUNK_BODY_KNIFE_HIDDEN_DESCRIPTION": "Une lame rétractable discrète cachée dans la manche. Idéale pour les opérations furtives.",
        "ROB_HUNK_BODY_KNIFE_WESKER_NAME": "Couteau Personnalisé",
        "ROB_HUNK_BODY_KNIFE_WESKER_DESCRIPTION": "Une lame cruelle au bord dentelé pour aider à lacérer vos adversaires.",
        "ROB_HUNK_BODY_KNIFE_MACHETE_NAME": "Machette",
        "ROB_HUNK_BODY_KNIFE_MACHETE_DESCRIPTION": "Une lame énorme principalement destinée aux tactiques de guérilla.",
        "ROB_HUNK_BODY_KNIFE_RE4_NAME": "Couteau Principal",
        "ROB_HUNK_BODY_KNIFE_RE4_DESCRIPTION": "Un couteau forgé avec des possibilités infinies.",
        "ROB_HUNK_BODY_KNIFE_BLOODY_NAME": "Lame Ensanglantée",
        "ROB_HUNK_BODY_KNIFE_BLOODY_DESCRIPTION": "Une lame ensanglantée au bord dentelé qui a déjà lacéré de nombreux adversaires.",
        "ROB_HUNK_BODY_KNIFE_HOTDOGGER_NAME": "HOT DOGGER",
        "ROB_HUNK_BODY_KNIFE_HOTDOGGER_DESCRIPTION": "Comme le nom l'indique, ce couteau anti-bioweapon développé par Umbrella est utilisé par ceux qui aiment se mettre en valeur.",
        "ROB_HUNK_BODY_KNIFE_STUNROD_NAME": "B",
        "ROB_HUNK_BODY_KNIFE_STUNROD_DESCRIPTION": "AVERTISSEMENT : N'étourdir pas vraiment.",
        "ROB_HUNK_BODY_KNIFE_KITCHEN_NAME": "Couteau de Cuisine",
        "ROB_HUNK_BODY_KNIFE_KITCHEN_DESCRIPTION": "Un couteau fait pour cuisiner. Sa lame s'écaille facilement.",
        "ROB_HUNK_BODY_SHOOT_SMG_NAME": "Tirer",
        "ROB_HUNK_BODY_SHOOT_SMG_DESCRIPTION": "Tire pour <style=cIsDamage>110% de dégâts</style>. <style=cIsUtility>25% de bonus en tir à la tête.</style>",
        "ROB_HUNK_BODY_SHOOT_M19_NAME": "Tirer",
        "ROB_HUNK_BODY_SHOOT_M19_DESCRIPTION": "Tire pour <style=cIsDamage>500% de dégâts</style>. <style=cIsUtility>100% de bonus en tir à la tête.</style>",
        "ROB_HUNK_BODY_SHOOT_SG09_NAME": "Tirer",
