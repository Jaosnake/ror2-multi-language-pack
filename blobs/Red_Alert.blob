		public class DriverDeployEnter : DeployEnter
		{
			protected override void PlayCannonAnimations(Animator animator)
			{
			}

			protected override void PlayEnterAnimation()
			{
				((EntityState)this).PlayCrossfade("FullBody, Override", "Heal", "Action.playbackRate", duration, 0.05f);
			}

			protected override void SetNextState()
			{
				_complete = true;
				DriverDeployIrradiate obj = new DriverDeployIrradiate
				{
					aimRequest = aimRequest,
					fromEnter = true
				};
				((BaseSkillState)obj).activatorSkillSlot = ((BaseSkillState)this).activatorSkillSlot;
				DriverDeployIrradiate nextState = obj;
				((EntityState)this).outer.SetNextState((EntityState)(object)nextState);
			}
		}

		public class DriverDeployIrradiate : DeployIrradiate
		{
			private DriverWeaponDef cachedWeaponDef;

			private DriverController iDrive;

			public override void OnEnter()
			{
				base.OnEnter();
				if (((EntityState)this).gameObject.TryGetComponent<DriverController>(ref iDrive))
				{
					iDrive.ConsumeAmmo(4f, true);
					DriverController obj = iDrive;
					cachedWeaponDef = ((obj != null) ? obj.weaponDef : null);
				}
			}

			protected override void PlayPumpAnimation()
			{
				((EntityState)this).PlayAnimation("FullBody, Override", "HealLoop", "Action.playbackRate", duration, 0.05f);
			}

			protected override void UpdateCannonSpin()
			{
			}

			public override void FixedUpdate()
			{
				base.FixedUpdate();
				if (Object.op_Implicit((Object)(object)iDrive) && (Object)(object)cachedWeaponDef != (Object)(object)iDrive.weaponDef)
				{
					((EntityState)this).PlayAnimation("FullBody, Override", "BufferEmpty");
					((EntityState)this).outer.SetNextStateToMain();
				}
			}

			protected override void SetNextState()
			{
				_complete = true;
				DriverDeployIrradiate obj = new DriverDeployIrradiate
				{
					aimRequest = aimRequest,
					fromEnter = true
				};
				((BaseSkillState)obj).activatorSkillSlot = ((BaseSkillState)this).activatorSkillSlot;
				DriverDeployIrradiate nextState = obj;
				((EntityState)this).outer.SetNextState((EntityState)(object)nextState);
			}
		}

		private ushort desolatorGunIndex;

		private static ConfigEntry<float> Driver_M1_Damage;

		private static AssetBundle assetBundle => CharacterBase<DesolatorSurvivor>.instance.assetBundle;

		[MethodImpl(MethodImplOptions.NoInlining | MethodImplOptions.NoOptimization)]
		public void Init()
		{
			//IL_0013: Unknown result type (might be due to invalid IL or missing references)
			//IL_001d: Expected O, but got Unknown
			if (GeneralConfig.Debug.Value)
			{
				CharacterBody.Update += new hook_Update(CharacterBody_Update);
			}
			SurvivorCatalog.SetSurvivorDefs_Driver += SurvivorCatalog_SetSurvivorDefs_Driver;
		}

		private void CharacterBody_Update(orig_Update orig, CharacterBody self)
		{
			orig.Invoke(self);
			DriverController val = default(DriverController);
			if (Input.GetKeyDown((KeyCode)106) && ((Component)self).TryGetComponent<DriverController>(ref val))
			{
				val.PickUpWeapon(DriverWeaponCatalog.GetWeaponFromIndex((int)desolatorGunIndex), -1f, false);
			}
		}

		private void SurvivorCatalog_SetSurvivorDefs_Driver(GameObject driverBody)
		{
			DoDriverCompat();
		}

		private void DoDriverCompat()
		{
			InitConfig();
			Language.Add("HABIBI_DESOLATOR_BODY_DRIVER_GUN_NAME", "Rad Cannon");
			Language.Add("HABIBI_DESOLATOR_BODY_DRIVER_GUN_DESCRIPTION", "Make it glow.");
			Language.Add("HABIBI_DESOLATOR_BODY_PRIMARY_BEAM_DRIVER_DESCRIPTION", "Shoot an enemy with a beam of radiation for " + Tokens.DamageValueText(Driver_M1_Damage) + " and deal " + Tokens.DamageText($"{Mathf.FloorToInt((float)RadBeam.RadPrimaryStacks * RadBeam.RadDamageMultiplier * DesolatorSurvivor.TotalDotDamage * 100f)}% <style=cIsHealing>Radiation</style> damage") + " over " + Tokens.UtilityText($"{DesolatorSurvivor.DotDuration} seconds"));
			Language.Add("HABIBI_DESOLATOR_BODY_SPECIAL_DEPLOY_DESCRIPTION", "Shoot an enemy with a beam of radiation for " + Tokens.DamageValueText(Driver_M1_Damage) + " and deal " + Tokens.DamageText($"{Mathf.FloorToInt((float)RadBeam.RadPrimaryStacks * RadBeam.RadDamageMultiplier * DesolatorSurvivor.TotalDotDamage * 100f)}% <style=cIsHealing>Radiation</style> damage") + " over " + Tokens.UtilityText($"{DesolatorSurvivor.DotDuration} seconds"));
			DesolatorDriverWeapon desolatorDriverWeapon = new DesolatorDriverWeapon();
			((BaseWeapon)desolatorDriverWeapon).Init();
			desolatorGunIndex = ((BaseWeapon)desolatorDriverWeapon).weaponDef.index;
			Content.AddEntityState(typeof(DriverDeployIrradiate));
			Content.AddEntityState(typeof(DriverDeployEnter));
			Content.AddEntityState(typeof(DriverRadBeam));
		}

		private void InitConfig()
		{
			string section = "2-2. Deso Mod Compats";
			Driver_M1_Damage = Config.BindAndOptions(section, "Driver_M1_Damage", 3f, 0f, 20f);
		}
	}
