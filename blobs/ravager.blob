				val.alphaCurve = AnimationCurve.EaseInOut(0f, 1f, 0.5f, 1f);
				val.animateShaderAlpha = true;
				RavagerOverlayTracker ravagerOverlayTracker = ((Component)modelTransform).gameObject.AddComponent<RavagerOverlayTracker>();
				ravagerOverlayTracker.body = characterBody;
				ravagerOverlayTracker.penis = this;
				ravagerOverlayTracker.overlay = val;
				ravagerOverlayTracker.modelTransform = modelTransform;
			}
		}

