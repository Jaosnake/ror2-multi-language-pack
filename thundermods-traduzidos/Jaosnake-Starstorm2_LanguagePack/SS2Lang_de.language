    "SS2_ACHIEVEMENT_CYBORG_MASTERY_DESC": "Schlagen Sie als Cyborg das Spiel oder vernichten Sie es auf Monsoon oder härter.",
    "SS2_ACHIEVEMENT_CYBORG_GRANDMASTERY_NAME": "Cyborg: Große Meisterschaft",
    "SS2_ACHIEVEMENT_CYBORG_GRANDMASTERY_DESC": "Schlagen Sie als Cyborg das Spiel oder vernichten Sie es auf Typhoon oder härter.",
    "SS2_ACHIEVEMENT_CHIRR_NAME": "Prinzip der kompetitiven Exklusion",
    "SS2_ACHIEVEMENT_CHIRR_DESC": "Töte eine Empyrean-Elite.",
    "SS2_ACHIEVEMENT_CHIRR_MASTERY_NAME": "Chirr: Meisterschaft",
    "SS2_ACHIEVEMENT_CHIRR_MASTERY_DESC": "Schlagen Sie als Chirr das Spiel oder vernichten Sie es auf Monsun oder härter.",
    "SS2_ACHIEVEMENT_CHIRR_GRANDMASTERY_NAME": "Chirr: Große Meisterschaft",
