        "ROB_HUNK_BODY_JACKET_SKIN_NAME": "Giacca",
        "ROB_HUNK_BODY_PPASSIVE_NAME": "OSP (Approvvigionamento in loco)",
        "ROB_HUNK_BODY_PPASSIVE_DESCRIPTION": "HUNK può raccogliere <color=#FFFF00>U.C. Keycards</color> per aprire <style=cIsDamage>casse di armi</style> ed espandere il suo arsenale.",
        "ROB_HUNK_BODY_PPASSIVE2_NAME": "Soldato dimenticato",
        "ROB_HUNK_BODY_PPASSIVE2_DESCRIPTION": "Il primo <style=cIsHealth>boss</style> a morire in ogni livello rilascia un <style=cIsDamage>pacchetto di rifornimenti</style> contenente un'arma o un accessorio.",
        "ROB_HUNK_BODY_PASSIVE_NAME": "Lotta all'ombra",
        "ROB_HUNK_BODY_PASSIVE_DESCRIPTION": "Inizia con un <style=cIsDamage>LE 5</style> e un <style=cIsDamage>arma secondaria</style>. Puoi <style=cIsDamage>scavenge</style> <style=cIsUtility>chests</style> per le munizioni.",
        "ROB_HUNK_BODY_PASSIVE2_NAME": "Terrore imminente",
        "ROB_HUNK_BODY_PASSIVE2_DESCRIPTION": "Inizia con un <style=cIsDamage>arsenale completo</style>, <style=cIsHealth>BUT</style> non potrai più <style=cIsHealth>ottenere munizioni aggiuntive</style>.",
        "ROB_HUNK_BODY_RANDOMPASSIVE_NAME": "Nuovo gioco+",
        "ROB_HUNK_BODY_RANDOMPASSIVE_DESCRIPTION": "Inizia con un <style=cIsDamage>LE 5</style> e un <style=cIsDamage>arma secondaria</style>. Puoi <style=cIsDamage>scavenge</style> <style=cIsUtility>chests</style> per le munizioni. <style=cIsHealth>Tutti i contenuti della custodia delle armi sono casuali.</style>",
        "ROB_HUNK_BODY_SHOTGUNPASSIVE_NAME": "Autorità Suprema",
        "ROB_HUNK_BODY_SHOTGUNPASSIVE_DESCRIPTION": "Inizia con un <style=cIsDamage>W-870</style> e un <style=cIsDamage>arma secondaria</style>. Puoi <style=cIsDamage>scavenge</style> <style=cIsUtility>chests</style> per le munizioni.",
        "ROB_HUNK_BODY_SMGPASSIVE_NAME": "Mercenario Supremo",
        "ROB_HUNK_BODY_SMGPASSIVE_DESCRIPTION": "Inizia <style=cIsHealth>ONLY</style> con un <style=cIsDamage>LE 5</style> completamente aggiornato. Puoi <style=cIsDamage>scavenge</style> <style=cIsUtility>chests</style> per le munizioni. <style=cIsDamage>Special</style> è sostituito da</style>0__Modalità caos</style>1__.",
        "ROB_HUNK_BODY_WPASSIVE_NAME": "Saturazione globale completa",
        "ROB_HUNK_BODY_WPASSIVE_DESCRIPTION": "Inizia <style=cIsHealth>ONLY</style> con un <style=cIsDamage>arma secondaria</style>. Puoi <style=cIsDamage>scavenge</style> <style=cIsUtility>chests</style> per le munizioni. <style=cIsDamage>Utility</style> è sostituito da</style>0__Uroboros</style>1__.",
        "ROB_HUNK_BODY_FLAMERPASSIVE_NAME": "Piromania",
        "ROB_HUNK_BODY_FLAMERPASSIVE_DESCRIPTION": "Inizia <style=cIsHealth>ONLY</style> con un <style=cIsDamage>Lanciafiamme chimico</style>. Puoi <style=cIsDamage>scavenge</style> <style=cIsUtility>chests</style> per le munizioni. <style=cIsHealth> Viene generata solo UNA custodia per armi per fase.</style>",
        "ROB_HUNK_BODY_PRIMARY_KNIFE_NAME": "Coltello da combattimento",
        "ROB_HUNK_BODY_PRIMARY_KNIFE_DESCRIPTION": "<style=cIsUtility>Draw.</style> <style=cIsDamage>Cut</style> combattenti vicini per <style=cIsDamage>200% di danno</style>, infliggendo <style=cIsHealth>Mangled</style>.",
        "ROB_HUNK_BODY_PRIMARY_CQC_NAME": "CQC (combattimento ravvicinato)",
        "ROB_HUNK_BODY_PRIMARY_CQC_DESCRIPTION": "<style=cIsUtility>Estrai.</style> <style=cIsDamage>Calci due volte</style> per <style=cIsDamage>200% e 250% di danno</style>. Se il <style=cIsUtility>secondo calcio</style> va a segno, segui un <style=cIsDamage>Contrattacco</style>.",
        "ROB_HUNK_BODY_PRIMARY_RELOAD_NAME": "Ricaricare",
        "ROB_HUNK_BODY_RELOAD_DESCRIPTION": "Ricarica la tua arma attuale.",
        "ROB_HUNK_BODY_SECONDARY_AIM_NAME": "Mira costantemente",
        "ROB_HUNK_BODY_SECONDARY_AIM_DESCRIPTION": "Mira, <style=cIsUtility>esponendo i punti deboli del nemico</style>. <style=cIsDamage>Utilizzare il primario mentre si mira spara con l'arma equipaggiata.</style>",
        "ROB_HUNK_BODY_UTILITY_DODGE_NAME": "Quickstep",
        "ROB_HUNK_BODY_UTILITY_DODGE_DESCRIPTION": "<style=cIsUtility>Advance</style> a breve distanza. Se utilizzato preventivamente per <style=cIsUtility>evitare un attacco</style>, esegui una <style=cIsDamage>Schivata perfetta</style>.",
        "ROB_HUNK_BODY_UTILITY_DODGE_SCEPTER_NAME": "Uroboros",
        "ROB_HUNK_BODY_UTILITY_DODGE_SCEPTER_DESCRIPTION": "<style=cIsUtility>Advance</style> a breve distanza. Se utilizzato preventivamente per <style=cIsUtility>evitare un attacco</style>, esegui una <style=cIsDamage>Schivata perfetta</style>. Il potere di Uroboros scorre attraverso di te.",
        "ROB_HUNK_BODY_UTILITY_PARRY_NAME": "Parare",
        "ROB_HUNK_BODY_UTILITY_PARRY_DESCRIPTION": "<style=cIsUtility>Blocca</style> un attacco, <style=cIsDamage>annullando</style> il danno e <style=cIsUtility>rimborsando il tempo di recupero</style>. Se usato preventivamente, esegui una <style=cIsDamage>Para perfetta</style>.",
        "ROB_HUNK_BODY_UTILITY_BASH_NAME": "Colpo di spalla",
        "ROB_HUNK_BODY_UTILITY_BASH_DESCRIPTION": "<style=cIsUtility>Colpisci</style> i nemici vicini con la spalla, <style=cIsUtility>stordindoli</style> per <style=cIsDamage>400% di danno</style>. Se utilizzato preventivamente per <style=cIsUtility>annullare un attacco</style>, esegui una <style=cIsDamage>Deviazione perfetta</style>.",
        "ROB_HUNK_BODY_SPECIAL_SWAP_NAME": "Legione",
        "ROB_HUNK_BODY_SPECIAL_SWAP_DESCRIPTION": "<style=cIsUtility>Scambia</style> con un <style=cIsDamage>arma diversa</style>. Tocca per passare alla tua <style=cIsUtility>ultima arma utilizzata</style>.",
        "ROB_HUNK_BODY_SPECIAL_MAYHEM_NAME": "Modalità caos",
        "ROB_HUNK_BODY_SPECIAL_MAYHEM_DESCRIPTION": "Entra nella <style=cIsDamage>Modalità caos</style>, aumentando drasticamente le prestazioni dell'arma.",
        "ROB_HUNK_BODY_CONFIRM_NAME": "Confermare",
        "ROB_HUNK_BODY_CONFIRM_DESCRIPTION": "Procedi con l'abilità attuale.",
        "ROB_HUNK_BODY_CANCEL_NAME": "Cancellare",
        "ROB_HUNK_BODY_CANCEL_DESCRIPTION": "Annulla l'abilità attuale.",
