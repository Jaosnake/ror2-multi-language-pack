{
    "de": {
        "BOG_DEPUTY_BODY_NAME": "Der Stellvertreter",
        "BOG_DEPUTY_BODY_DESCRIPTION": "Die Deputy ist eine hyperaggressive Geschwindigkeitsdämonin, die mit ihren Zwillingsrevolvern und tödlichen Tritten für Gerechtigkeit sorgt.",
