{
    "pt-BR": {
        "ROB_DANTE_BODY_NAME": "<color=#B70027>Dante</color>",
        "ROB_NERO_BODY_NAME": "<color=#2150AF>Nero</color>",
        "ROB_VERGIL_BODY_NAME": "<color=#32D2FF>Vergil</color>",
        "ROB_DANTE_BODY_DESCRIPTION": "<color=#B70027>Dante</color> é um lendário caçador de demônios que luta com um par de pistolas e uma espada.<color=#CCD3E0>",
        "ROB_DANTE_BODY_SUBTITLE": "Lendário Caçador de Demônios",
        "ROB_DANTE_BODY_LORE": "Sabe, eu devia pesquisar melhor meus trabalhos antes de aceitá-los.\n\nUm cara entra na minha loja falando de monstros que precisam ser mortos. Bem sério e formal, provavelmente militar. Uma escopeta no lugar do braço esquerdo. Deve estar falando sério.\n\nEle joga uma bolsa de dinheiro e uma passagem de navio na mesa. Isso vai me deixar numa boa por meses!\n\nMas tenho que manter a calma, bancar o difícil.\n\n'Trabalho longo significa pagamento longo.'\n\n'Acredito que isso vai mudar sua ideia.'\n\nUma foto cai na mesa. Mostra um homem preso em... vidro? Não dá pra ver o rosto dele, mas esse pingente eu reconheceria em qualquer lugar.\n\nEsse cara fez o dever de casa. Acho que vou ter que entrar nesse navio.\n\n'Fechado.'\n\nAgora tenho que cruzar o planeta limpando a sujeira.\n\nSemanas de busca, matança, sobrevivência.\n\nMas preciso encontrar <color=#32D2FF>ele</color>.\n\nTrabalho é trabalho, né?\n\n<color=#B70027>Let's rock.</color>",
        "ROB_DANTE_BODY_OUTRO_FLAVOR": "..e então ele partiu.",
        "ROB_DANTE_BODY_OUTRO_FAILURE": "..e então ele desapareceu.",
        "ROB_DANTE_BODY_DEFAULT_SKIN_NAME": "<color=#B70027>Default</color>",
        "ROB_DANTE_BODY_MASTERY_SKIN_NAME": "<color=#B70027>Classic</color>",
        "ROB_DANTE_BODY_TYPHOON_SKIN_NAME": "<color=#B70027>idk</color>",
        "ROB_DANTE_BODY_PRESTIGE_SKIN_NAME": "<color=#B70027>Prestige</color>",
        "ROB_DANTE_BODY_DMC2_SKIN_NAME": "<color=#B70027>Veteran</color>",
        "ROB_DANTE_BODY_DMC_SKIN_NAME": "<color=#B70027>El Donte</color>",
        "ROB_DANTE_BODY_SUPER_SKIN_NAME": "<color=#B70027>Super</color>",
        "ROB_DANTE_BODY_VERGIL_SKIN_NAME": "<color=#32D2FF>Vergil</color>",
        "ROB_DANTE_BODY_VERGILEX_SKIN_NAME": "<color=#32D2FF>Vergil EX</color>",
        "ROB_DANTE_BODY_MINECRAFT_SKIN_NAME": "<color=#B70027>Minecraft</color>",
        "ROB_DANTE_BODY_PASSIVE_NAME": "<color=#B70027>Filho de Sparda</color>",
        "ROB_DANTE_BODY_PASSIVE_DESCRIPTION": "<color=#B70027>Dante</color> tem acesso a diversas <style=cIsDamage>habilidades únicas</style>. <style=cIsUtility>Passe o mouse para mais informações.</style>",
        "ROB_DANTE_BODY_CONFIRM_NAME": "Confirmar",
        "ROB_DANTE_BODY_CONFIRM_DESCRIPTION": "Prosseguir com a habilidade atual.",
        "ROB_DANTE_BODY_CANCEL_NAME": "Cancelar",
        "ROB_DANTE_BODY_CANCEL_DESCRIPTION": "Cancelar a habilidade atual.",
        "ROB_DANTE_BODY_PRIMARY_NAME": "<color=#B70027>Ebony & Ivory</color>",
        "ROB_DANTE_BODY_PRIMARY_DESCRIPTION": "Atire rapidamente causando <style=cIsDamage>120% de dano</style>. Pare de atirar por <style=cIsUtility>1 segundo</style> para preparar um <style=cIsDamage>tiro carregado</style> que causa <style=cIsDamage>350% de dano</style>.",
        "ROB_NERO_BODY_PRIMARY_NAME": "<color=#2150AF>Blue Rose</color>",
        "ROB_NERO_BODY_PRIMARY_DESCRIPTION": "Atire duas vezes, causando <style=cIsDamage>200% de dano</style> e <style=cIsDamage>350% de dano</style>. Segure por <style=cIsUtility>1 segundo</style> para preparar um <style=cIsDamage>tiro carregado</style>.",
        "ROB_VERGIL_BODY_PRIMARY_NAME": "<color=#32D2FF>Summon Swords</color>",
        "ROB_VERGIL_BODY_PRIMARY_DESCRIPTION": "Dispare espadas espectrais causando <style=cIsDamage>200% de dano</style>.",
        "ROB_DANTE_BODY_MELEE_NAME": "<color=#B70027>Lock & Load</color>",
        "ROB_DANTE_BODY_MELEE_DESCRIPTION": "Prepare sua <style=cIsUtility>arma empunhada</style>. <style=cIsDamage>Ataque primário</style> torna-se <style=cIsDamage>ataques corpo a corpo</style>, e ataques inimigos são <style=cIsUtility>defletidos</style> enquanto empunhada.",
        "ROB_DANTE_BODY_UTILITY_NAME": "<color=#B70027>Trick</color>",
        "ROB_DANTE_BODY_UTILITY_DESCRIPTION": "<style=cIsUtility>Deslize</style> em uma direção, ficando brevemente <style=cIsUtility>invulnerável</style>. <style=cIsUtility>Ataques corpo a corpo recarregam esta habilidade instantaneamente.</style>",
        "ROB_DANTE_BODY_SPECIAL_DEVILTRIGGER_NAME": "<color=#A556FF>Devil Trigger</color>",
        "ROB_DANTE_BODY_SPECIAL_DEVILTRIGGER_DESCRIPTION": "<color=#B70027>Hellbent.</color> Ative o <color=#A556FF>Devil Trigger</color>, drenando sua barra para ganhar <style=cIsUtility>armadura</style>, <style=cIsHealing>regeneração</style> e <style=cIsDamage>dano</style> temporários. <style=cIsUtility>Ataques corpo a corpo preenchem a barra.</style>",
        "ROB_DANTE_BODY_SPECIAL_DEVILTRIGGER_SCEPTER_NAME": "Perfect Devil Trigger",
        "ROB_DANTE_BODY_SPECIAL_DEVILTRIGGER_SCEPTER_DESCRIPTION": "<color=#B70027>Hellbent.</color> Ative o <color=#A556FF>Devil Trigger</color>, drenando sua barra para ganhar <style=cIsUtility>armadura</style>, <style=cIsHealing>regeneração</style> e <style=cIsDamage>dano</style> temporários. <style=cIsUtility>Ataques corpo a corpo preenchem a barra.</style>\n<color=#d299ff>SCEPTER: Devaste seus inimigos com espadas invocadas enquanto ativo.</color>",
        "ROB_DANTE_BODY_SPECIAL_SDT_NAME": "<color=#B70027>Sin Devil Trigger</color>",
        "ROB_DANTE_BODY_SPECIAL_SDT_DESCRIPTION": "<style=cIsUtility>Segure</style> para transferir a barra para a barra de <color=#B70027>Sin Devil Trigger</color>. <style=cIsUtility>Segure</style> quando cheia para liberar sua <style=cIsDamage>verdadeira forma demoníaca</style> por um curto período.",
        "ROB_DANTE_BODY_SPECIAL_SDT_SCEPTER_NAME": "<color=#B70027>Perfect Sin Devil Trigger</color>",
        "ROB_DANTE_BODY_SPECIAL_SDT_SCEPTER_DESCRIPTION": "<style=cIsUtility>Segure</style> para transferir a barra para a barra de <color=#B70027>Sin Devil Trigger</color>. <style=cIsUtility>Segure</style> quando cheia para liberar sua <style=cIsDamage>verdadeira forma demoníaca</style> por um curto período.\n<color=#d299ff>SCEPTER: Devaste seus inimigos com espadas invocadas enquanto ativo.</color>",
        "ROB_DANTE_BODY_SPECIAL_PISTOL_NAME": "Silver Bullet",
        "ROB_DANTE_BODY_SPECIAL_PISTOL_DESCRIPTION": "Atire uma <style=cIsUtility>bala de prata</style> causando <style=cIsDamage>800% de dano</style>. <style=cIsUtility>Acertos de cabeça</style> causam <style=cIsDamage>2x dano</style>. Mortes <style=cIsUtility>reiniciam todos os seus tempos de recarga</style>.",
        "ROB_DANTE_BODY_SPECIAL_PISTOL_SCEPTER_NAME": "Golden Gun",
        "ROB_DANTE_BODY_SPECIAL_PISTOL_SCEPTER_DESCRIPTION": "Atire uma <style=cIsUtility>bala de prata</style> causando <style=cIsDamage>800% de dano</style>. <style=cIsUtility>Acertos de cabeça</style> causam <style=cIsDamage>2x dano</style>. Mortes <style=cIsUtility>reiniciam todos os seus tempos de recarga</style>.\n<color=#d299ff>SCEPTER: Causa 9.000% de dano.</color>",
        "ROB_DANTE_BODY_SPECIAL_HOLYCROSS_NAME": "Sacred Flame",
        "ROB_DANTE_BODY_SPECIAL_HOLYCROSS_DESCRIPTION": "Invoque o poder de <color=#FF0033>Providence</color>, liberando uma <style=cIsUtility>chama massiva</style> que causa <style=cIsDamage>300% de dano por tick</style>. Termina com uma supernová de <style=cIsDamage>4.000% de dano</style>.",
        "ROB_DANTE_BODY_LOADOUT_SKILL_MISC": "Passiva",
