			text2 = text2 + "< ! > Pistol is a powerful anti air, with its low cooldown and high damage." + Environment.NewLine + Environment.NewLine;
			text2 = text2 + "< ! > Roll has a lingering armor buff that helps to use it aggressively." + Environment.NewLine + Environment.NewLine;
			text2 = text2 + "< ! > Bomb can be used to wipe crowds with ease." + Environment.NewLine + Environment.NewLine;
