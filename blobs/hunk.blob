				ammoPickupInteractable = PrefabAPI.InstantiateClone(Addressables.LoadAssetAsync<GameObject>((object)"RoR2/Base/Barrel1/Barrel1.prefab").WaitForCompletion(), "HunkAmmoPickupInteractable", true);
				Object.Destroy((Object)(object)ammoPickupInteractable.GetComponent<BarrelInteraction>());
				Object.Destroy((Object)(object)ammoPickupInteractable.GetComponent<Highlight>());
