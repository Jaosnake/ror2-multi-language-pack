				text = "ROB_NEMESIS_BODY_";
				LanguageAPI.Add(text + "PASSIVE_NAME", "Ultimate Lifeform");
				LanguageAPI.Add(text + "PASSIVE_DESCRIPTION", "<style=cIsDamage>Dealing damage</style> stores <style=cIsHealth>Biomass</style>, boosting your <style=cIsDamage>damage</style> when full. Jumps can be <style=cIsDamage>charged</style> for <style=cIsUtility>mighty leaps</style>.");
				LanguageAPI.Add(text + "PASSIVE2_NAME", "Biological Weaponry");
				LanguageAPI.Add(text + "PASSIVE2_DESCRIPTION", "The Nemesis T-Type can <style=cIsHealth>mutate</style> by consuming <style=cIsDamage>persons of interest</style>, gaining <style=cIsDamage>new and upgraded abilities</style>.");
				LanguageAPI.Add(text + "PASSIVE22_NAME", "Muscle Mass Boost");
				LanguageAPI.Add(text + "PASSIVE22_DESCRIPTION", "<style=cIsUtility>Melee attacks</style> deal <style=cIsDamage>20%</style> more damage, <style=isHealth>BUT allies can take damage</style>.");
				LanguageAPI.Add(text + "MELEE_NAME", "Brutal Assault");
				LanguageAPI.Add(text + "MELEE_DESCRIPTION", "Punch for <style=cIsDamage>350% damage</style>. Use while <style=cIsUtility>standing still</style> to stomp for <style=cIsDamage>800% damage</style>. Use while <style=cIsUtility>sprinting</style> to tackle for <style=cIsDamage>600% damage</style>.");
				LanguageAPI.Add(text + "GRAB_NAME", "Deadly Reach");
				LanguageAPI.Add(text + "GRAB_DESCRIPTION", "Grab an enemy. Use Primary to consume them and heal 10% max health, or Secondary to charge a throw for up to 2400% damage.");
				LanguageAPI.Add(text + "DASH_NAME", "Biohazard Rush");
				LanguageAPI.Add(text + "DASH_DESCRIPTION", "Use while <style=cIsUtility>airborne</style> to airdash <style=cIsDamage>once</style>.");
				LanguageAPI.Add(text + "ULTIMATE_NAME", "Critical Mass");
				LanguageAPI.Add(text + "ULTIMATE_DESCRIPTION", "Hold to slowly consume <style=cIsHealth>Biomass</style>, restoring up to <style=cIsHealing>100% max health</style>.");
				LanguageAPI.Add(text + "DEFAULT_SKIN_NAME", "Default");
				LanguageAPI.Add(text + "CLASSIC_SKIN_NAME", "Classic");
				LanguageAPI.Add(text + "VENOM_SKIN_NAME", "Symbiote");
				LanguageAPI.Add(text + "SUPER_SKIN_NAME", "<color=#FFFF00>Early Supporter</color>");
				LanguageAPI.Add(text + "MAHORAGA_SKIN_NAME", "Big Raga The Opp Stoppa");
				LanguageAPI.Add(text + "MINOS_SKIN_NAME", "King of Men");
				text = "ROB_HUNK_";
				LanguageAPI.Add(text + "ITEM_EFFECT_TITLE", "Bonus Effect");
				LanguageAPI.Add(text + "ITEM_EFFECT_BACKUPMAG", "Gain <color=#00FF66>Fake Ammo</color> after a successful reload.");
				LanguageAPI.Add(text + "ITEM_EFFECT_BANDOLIER", "Ammo packs refill your magazine with <color=#00FF66>Fake Ammo</color>.");
				LanguageAPI.Add(text + "ITEM_EFFECT_ALIENHEAD", "Gain <style=cIsUtility>more ammo</style> when picking any up.");
				LanguageAPI.Add(text + "ITEM_EFFECT_BRAINSTALKS", "While active, firing your gun <style=cIsUtility>consumes no ammo</style>.");
				LanguageAPI.Add(text + "ITEM_EFFECT_LYSATECELL", "Gain <color=#00FF66>Fake Ammo</color> when equipping a weapon.");
				LanguageAPI.Add(text + "ITEM_EFFECT_PURITY", "Double your <style=cIsUtility>magazine size</style>. Ammo consumption is unchanged.");
				LanguageAPI.Add(text + "ITEM_EFFECT_LUMINOUSSHOT", "Gain a stack after aiming for <style=cIsUtility>1 second</style>. <style=cIsHealth>Lose all stacks when you shoot or stop aiming.</style>");
				text = "ROB_NEMESIS_";
				LanguageAPI.Add(text + "ITEM_EFFECT_TITLE", "Bonus Effect");
				LanguageAPI.Add(text + "ITEM_EFFECT_BANDOLIER", "Ammo packs restore <style=cIsHealth>10% Biomass</style>.");
				LanguageAPI.Add(text + "ITEM_EFFECT_ALIENHEAD", "Boost <style=cIsHealth>Biomass</style> gained when <style=cIsDamage>consuming</style> enemies.");
				LanguageAPI.Add(text + "ITEM_EFFECT_BRAINSTALKS", "While active, <style=cIsHealth>Biomass</style> is <style=cIsUtility>unlimited</style>.");
				LanguageAPI.Add(text + "ITEM_EFFECT_PURITY", "Boost <style=cIsHealth>Biomass</style> gained <style=cIsDamage>on hit</style>.");
				text = "ROB";
				LanguageAPI.Add("ROB_HUNK_JETPACK_NAME", "Experimental Jump Pack");
				LanguageAPI.Add("ROB_HUNK_JETPACK_DESC", "An Umbrella-made tool that allows you to boost yourself in any direction by pressing jump while midair.");
				LanguageAPI.Add("ROB_HUNK_SURVIVALKIT_NAME", "Emergency Survival Kit");
				LanguageAPI.Add("ROB_HUNK_SURVIVALKIT_DESC", "A survival kit that boosts both your ability to rummage for ammo and the effectiveness of your knife.");
				LanguageAPI.Add("ROB_HUNK_TRANSCEIVER_NAME", "Worn Transceiver");
				LanguageAPI.Add("ROB_HUNK_TRANSCEIVER_DESC", "Calls in a squadmate to help you on your operation.");
				LanguageAPI.Add("ROB_HUNK_INFROCKET_NAME", "ATM-4");
				LanguageAPI.Add("ROB_HUNK_INFROCKET_DESC", "A rocket launcher with <style=cIsHealing>infinite ammo</style>. Reward for the <color=#FFFF00>Early Supporter</color> achievement.");
				LanguageAPI.Add("ROB_HUNK_SPADE_KEYCARD_NAME", "U.C. Keycard (Spade)");
				LanguageAPI.Add("ROB_HUNK_CLUB_KEYCARD_NAME", "U.C. Keycard (Club)");
				LanguageAPI.Add("ROB_HUNK_HEART_KEYCARD_NAME", "U.C. Keycard (Heart)");
				LanguageAPI.Add("ROB_HUNK_DIAMOND_KEYCARD_NAME", "U.C. Keycard (Diamond)");
				LanguageAPI.Add("ROB_HUNK_GOLD_KEYCARD_NAME", "U.C. Keycard (Star)");
				LanguageAPI.Add("ROB_HUNK_MASTER_KEYCARD_NAME", "U.C. Keycard (Master)");
				LanguageAPI.Add("ROB_HUNK_KEYCARD_DESC", "Used to open <color=#C80202>Umbrella Corporation</color> <style=cIsUtility>weapon cases</style>.");
				LanguageAPI.Add("ROB_HUNK_KEYCARD_MASTER_DESC", "Used to open <color=#C80202>Umbrella Corporation</color> <style=cIsUtility>weapon cases</style>. Opens <style=cIsHealing>all cases</style>, and turns other keycards into <style=cIsUtility>scrap</style>.");
				LanguageAPI.Add("ROB_HUNK_WRISTBAND_NAME", "I.D. Wristband");
				LanguageAPI.Add("ROB_HUNK_WRISTBAND_DESC", "An electronic key for use in <color=#C80202>Umbrella Corporation</color> facilities. Used to open a <style=cIsUtility>special weapon case</style>.");
				LanguageAPI.Add("ROB_HUNK_TYPEWRITER_NAME", "Typewriter");
				LanguageAPI.Add("ROB_HUNK_TYPEWRITER_DESC", "Gain <style=cIsUtility>2</style> additional <color=#C80202>Umbrella Corporation</color> <style=cIsUtility>weapon cases</style> per stage.");
				LanguageAPI.Add("ROB_HUNK_CRYSTALSKULL_NAME", "Crystal Skull");
				LanguageAPI.Add("ROB_HUNK_CRYSTALSKULL_DESC", "A rare treasure. Can be turned into any <style=cIsUtility>Cauldron</style> to receive one item.");
				LanguageAPI.Add("ROB_HUNK_STARSBADGE_NAME", "S.T.A.R.S. Badge");
				LanguageAPI.Add("ROB_HUNK_STARSBADGE2_NAME", "USB Dongle Key");
				if (Config.disableNemesis.Value)
				{
					LanguageAPI.Add("ROB_HUNK_STARSBADGE_DESC", "<color=#F20443>STOP PICKING THIS UP STOP PICKING THIS UP STOP PICKING THIS UP</color>");
					LanguageAPI.Add("ROB_HUNK_STARSBADGE_DESCFULL", "<color=#F20443>STOP PICKING THIS UP STOP PICKING THIS UP STOP PICKING THIS UP</color>");
					LanguageAPI.Add("ROB_HUNK_STARSBADGE2_DESC", "You are the coolest awesomest epic friend I've ever seen. :)");
					LanguageAPI.Add("ROB_HUNK_STARSBADGE2_DESCFULL", "Each stage, a special <color=#F20443>S.T.A.R.S.</color> box spawns that can only be opened using this badge.");
				}
