					((Renderer)val2).sharedMaterial = val3;
					val2.widthMultiplier = width;
				}
			}
			Content.CreateAndAddEffectDef(val);
			return val;
		}

		private static GameObject CreateZapConeProjectile()
		{
			//IL_0055: Unknown result type (might be due to invalid IL or missing references)
			//IL_0062: Unknown result type (might be due to invalid IL or missing references)
			GameObject val = PrefabAPI.InstantiateClone(LegacyResourcesAPI.Load<GameObject>("Prefabs/Projectiles/LoaderZapCone"), "TeslaLoaderZapCone");
			ProjectileProximityBeamController component = val.GetComponent<ProjectileProximityBeamController>();
			component.attackFireCount = ZapPunch.OrbCasts;
			component.attackRange = ZapPunch.OrbDistance;
			component.maxAngleFilter = 50f;
			component.procCoefficient = ZapPunch.ProcCoefficient;
			component.damageCoefficient = 1f;
			component.lightningType = (LightningType)8;
			ModdedDamageTypeHolderComponent val2 = val.AddComponent<ModdedDamageTypeHolderComponent>();
			val2.Add(TeslaDamageTypes.Conductive);
			Object.DestroyImmediate((Object)(object)((Component)val.transform.Find("Effect")).GetComponent<ShakeEmitter>());
			TeslaZapConeEffect = CreateTeslaZapConeEffect(val);
			Object.Destroy((Object)(object)((Component)val.transform.Find("Effect/Distortion, 3D")).gameObject);
			Object.Destroy((Object)(object)((Component)val.transform.Find("Effect/RadialMesh")).gameObject);
			Object.Destroy((Object)(object)((Component)val.transform.Find("Effect/Flash")).gameObject);
			Content.AddProjectilePrefab(val);
			return val;
		}

