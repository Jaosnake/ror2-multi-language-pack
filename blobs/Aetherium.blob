				if (!Object.op_Implicit((Object)(object)val2))
				{
					val2 = ((Component)body).gameObject.AddComponent<DeathRewards>();
				}
				val2.characterBody = body;
				val2.goldReward = component.GoldReward;
				val2.expReward = component.ExpReward;
			}
		}
	}
