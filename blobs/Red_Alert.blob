		private static AssetBundle _assetBundle;

		public static void Init(AssetBundle assetBundle)
		{
			_assetBundle = assetBundle;
			CreateGarrison();
			CreateGarrisonHealthBar();
			WheewBoyMakeATerrorDrone();
			RunSpeedEffect = assetBundle.LoadAsset<GameObject>("fxRunSpeedLines").DebugClone(network: true);
			Content.CreateAndAddEffectDef(RunSpeedEffect);
			blastEffect = Asset.AddAsyncAsset<GameObject>("RoR2/Base/LemurianBruiser/OmniExplosionVFXLemurianBruiserFireballImpact.prefab", (Action<GameObject>)null);
			CreateMolotov();
			CreateTerrorDroneTargetViewer();
			_assetBundle.LoadAssetAsync<EntityStateConfiguration>("escConscriptJumpOnEnemy", (Action<EntityStateConfiguration>)delegate(EntityStateConfiguration resultESC)
			{
				Content.AddEntityStateConfiguration(resultESC);
			});
		}

