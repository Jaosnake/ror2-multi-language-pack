        "ROB_HUNK_BODY_LEON_SKIN_NAME": "Uzman",
        "ROB_HUNK_BODY_LEONSHIRT_SKIN_NAME": "Uzman EX",
        "ROB_HUNK_BODY_ENFORCER_SKIN_NAME": "Buldozer",
        "ROB_HUNK_BODY_WESKER_SKIN_NAME": "Beyni",
        "ROB_HUNK_BODY_DOOM_SKIN_NAME": "Avcı",
        "ROB_HUNK_BODY_COMMANDO_SKIN_NAME": "Komando",
        "ROB_HUNK_BODY_JACKET_SKIN_NAME": "Ceket",
        "ROB_HUNK_BODY_PPASSIVE_NAME": "OSP (Yerinde Tedarik)",
        "ROB_HUNK_BODY_PPASSIVE_DESCRIPTION": "HUNK, <color=#FFFF00>U.C. toplayabilir. <style=cIsDamage>silah kasalarını</style> açmak ve cephaneliğini genişletmek için anahtar kartları</color>.",
        "ROB_HUNK_BODY_PPASSIVE2_NAME": "Unutulmuş Asker",
        "ROB_HUNK_BODY_PPASSIVE2_DESCRIPTION": "Her Aşamada ölen ilk <style=cIsHealth>boss</style>, içinde silah veya aksesuar bulunan bir <style=cIsDamage>tedarik paketi</style> düşürür.",
        "ROB_HUNK_BODY_PASSIVE_NAME": "Gölge Dövüşü",
        "ROB_HUNK_BODY_PASSIVE_DESCRIPTION": "Bir <style=cIsDamage>LE 5</style> ve bir <style=cIsDamage>ikincil silah</style> ile başlayın. Cephane için <style=cIsDamage>scavenge</style> <style=cIsUtility>sandık</style> yapabilirsiniz.",
        "ROB_HUNK_BODY_PASSIVE2_NAME": "Yaklaşan Dehşet",
        "ROB_HUNK_BODY_PASSIVE2_DESCRIPTION": "<style=cIsDamage>tam cephanelik</style> ile başlayın, <style=cIsHealth>BUT</style> artık <style=cIsHealth>ek cephane</style> elde edemezsiniz.",
        "ROB_HUNK_BODY_RANDOMPASSIVE_NAME": "Yeni Oyun+",
        "ROB_HUNK_BODY_RANDOMPASSIVE_DESCRIPTION": "Bir <style=cIsDamage>LE 5</style> ve bir <style=cIsDamage>ikincil silah</style> ile başlayın. Cephane için <style=cIsDamage>scavenge</style> <style=cIsUtility>sandık</style> yapabilirsiniz. <style=cIsHealth>Tüm silah kutusu içerikleri rastgeledir.</style>",
        "ROB_HUNK_BODY_SHOTGUNPASSIVE_NAME": "Yüksek Otorite",
        "ROB_HUNK_BODY_SHOTGUNPASSIVE_DESCRIPTION": "Bir <style=cIsDamage>W-870</style> ve bir <style=cIsDamage>ikincil silah</style> ile başlayın. Cephane için <style=cIsDamage>scavenge</style> <style=cIsUtility>sandık</style> yapabilirsiniz.",
        "ROB_HUNK_BODY_SMGPASSIVE_NAME": "Yüce Paralı Asker",
        "ROB_HUNK_BODY_SMGPASSIVE_DESCRIPTION": "<style=cIsHealth>ONLY</style>'yi <style=cIsDamage>tamamen yükseltilmiş LE 5</style> ile başlatın. Cephane için <style=cIsDamage>scavenge</style> <style=cIsUtility>sandık</style> yapabilirsiniz. <style=cIsDamage>Special</style>,</style>0__Kaos Modu</style>1__ ile değiştirildi.",
        "ROB_HUNK_BODY_WPASSIVE_NAME": "Küresel Doygunluğu Tamamla",
        "ROB_HUNK_BODY_WPASSIVE_DESCRIPTION": "<style=cIsHealth>ONLY</style>'i <style=cIsDamage>ikincil silah</style> ile başlatın. Cephane için <style=cIsDamage>scavenge</style> <style=cIsUtility>sandık</style> yapabilirsiniz. <style=cIsDamage>Utility</style>,</style>0__Uroboros</style>1__ ile değiştirildi.",
        "ROB_HUNK_BODY_FLAMERPASSIVE_NAME": "Piromani",
        "ROB_HUNK_BODY_FLAMERPASSIVE_DESCRIPTION": "<style=cIsHealth>ONLY</style>'yi <style=cIsDamage>Kimyasal Alev Atıcı</style> ile başlatın. Cephane için <style=cIsDamage>scavenge</style> <style=cIsUtility>sandık</style> yapabilirsiniz. <style=cIsHealth>Aşama başına yalnızca BİR silah kasası ortaya çıkar.</style>",
        "ROB_HUNK_BODY_PRIMARY_KNIFE_NAME": "Savaş Bıçağı",
        "ROB_HUNK_BODY_PRIMARY_KNIFE_DESCRIPTION": "<style=cIsUtility>Çekil.</style> <style=cIsDamage>Kes</style> yakındaki savaşçılar <style=cIsDamage>%200 hasar</style>, <style=cIsHealth>Mangled</style> uygulayarak.",
        "ROB_HUNK_BODY_PRIMARY_CQC_NAME": "CQC (Yakın Mesafe Savaşı)",
        "ROB_HUNK_BODY_PRIMARY_CQC_DESCRIPTION": "<style=cIsUtility>Çekil.</style> <style=cIsDamage>İki kez vur</style> <style=cIsDamage>%200 ve %250 hasar</style> için. <style=cIsUtility>ikinci vuruş</style> bağlanırsa, <style=cIsDamage>Karşı saldırı</style> ile devam edin.",
        "ROB_HUNK_BODY_PRIMARY_RELOAD_NAME": "Yeniden yükle",
        "ROB_HUNK_BODY_RELOAD_DESCRIPTION": "Mevcut silahınızı yeniden yükleyin.",
        "ROB_HUNK_BODY_SECONDARY_AIM_NAME": "Sürekli Hedefleyin",
        "ROB_HUNK_BODY_SECONDARY_AIM_DESCRIPTION": "Nişan alın, <style=cIsUtility>düşmanın zayıf noktalarını ortaya çıkarın</style>. <style=cIsDamage>Nişan alırken birincil kullanmak, donanımlı silahınızı ateşler.</style>",
        "ROB_HUNK_BODY_UTILITY_DODGE_NAME": "Hızlı adım",
        "ROB_HUNK_BODY_UTILITY_DODGE_DESCRIPTION": "<style=cIsUtility>İlerleme</style> kısa bir mesafe. <style=cIsUtility>bir saldırıyı önlemek</style> için önleyici olarak kullanılırsa, <style=cIsDamage>Perfect Dodge</style> gerçekleştirin.",
        "ROB_HUNK_BODY_UTILITY_DODGE_SCEPTER_NAME": "Uroboros",
        "ROB_HUNK_BODY_UTILITY_DODGE_SCEPTER_DESCRIPTION": "<style=cIsUtility>İlerleme</style> kısa bir mesafe. <style=cIsUtility>bir saldırıyı önlemek</style> için önleyici olarak kullanılırsa, <style=cIsDamage>Perfect Dodge</style> gerçekleştirin. Uroboros'un gücü senin içinden akıyor.",
        "ROB_HUNK_BODY_UTILITY_PARRY_NAME": "Savuşturma",
        "ROB_HUNK_BODY_UTILITY_PARRY_DESCRIPTION": "<style=cIsUtility>Block</style> bir saldırı, <style=cIsDamage>hasarı geçersiz kılma</style> ve <style=cIsUtility>bekleme süresini geri ödeme</style>. Önceden kullanılırsa, <style=cIsDamage>Perfect Parry</style> gerçekleştirin.",
        "ROB_HUNK_BODY_UTILITY_BASH_NAME": "Omuz Darbesi",
        "ROB_HUNK_BODY_UTILITY_BASH_DESCRIPTION": "<style=cIsUtility>Yakındaki düşmanlara omuzunuzla vurun</style>, <style=cIsUtility>onları sersemletir</style> <style=cIsDamage>%400 hasar</style>. <style=cIsUtility>bir saldırıyı iptal etmek</style> için önleyici olarak kullanılırsa, <style=cIsDamage>Mükemmel Saptırma</style> gerçekleştirin.",
        "ROB_HUNK_BODY_SPECIAL_SWAP_NAME": "Lejyon",
        "ROB_HUNK_BODY_SPECIAL_SWAP_DESCRIPTION": "<style=cIsUtility></style>'i <style=cIsDamage>farklı bir silahla</style> ile değiştirin. <style=cIsUtility>son kullanılan silahınız</style> ile değiştirmek için dokunun.",
        "ROB_HUNK_BODY_SPECIAL_MAYHEM_NAME": "Kaos Modu",
        "ROB_HUNK_BODY_SPECIAL_MAYHEM_DESCRIPTION": "Silah performansını büyük ölçüde artıran <style=cIsDamage>Kaos Modu</style>'e girin.",
        "ROB_HUNK_BODY_CONFIRM_NAME": "Onaylamak",
        "ROB_HUNK_BODY_CONFIRM_DESCRIPTION": "Mevcut yeteneğinizle devam edin.",
        "ROB_HUNK_BODY_CANCEL_NAME": "İptal etmek",
        "ROB_HUNK_BODY_CANCEL_DESCRIPTION": "Mevcut yeteneği iptal et.",
        "ROB_HUNK_BODY_KNIFE_DEFAULT_NAME": "Savaş Bıçağı",
        "ROB_HUNK_BODY_KNIFE_DEFAULT_DESCRIPTION": "Standart bir askeri bıçak. Kesinlikle dar noktalarda faydalıdır.",
        "ROB_HUNK_BODY_KNIFE_INFINITE_NAME": "Savaş Bıçağı EX",
        "ROB_HUNK_BODY_KNIFE_INFINITE_DESCRIPTION": "İnanılmaz derecede sertleştirilmiş, özel olarak işlenmiş bir askeri bıçak. Gerçekten uzun süre dayanacak şekilde yapıldığı söyleniyor.",
        "ROB_HUNK_BODY_KNIFE_HIDDEN_NAME": "Gizli Bıçak",
        "ROB_HUNK_BODY_KNIFE_HIDDEN_DESCRIPTION": "Manşonun içine gizlenmiş düşük profilli, geri çekilebilir bir bıçak. Gizli operasyonlar için idealdir.",
        "ROB_HUNK_BODY_KNIFE_WESKER_NAME": "Özel Bıçak",
        "ROB_HUNK_BODY_KNIFE_WESKER_DESCRIPTION": "Rakiplerinizi parçalamaya yardımcı olacak tırtıklı kenarlı acımasız bir bıçak.",
        "ROB_HUNK_BODY_KNIFE_MACHETE_NAME": "Pala",
