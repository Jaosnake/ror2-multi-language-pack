        "SS2_KEYWORD_LIFTOFF": "<style=cKeywordName>Liftoff</style><style=cSub>Havadayken, yardımcı programınızı Liftoff ile değiştirir:\n<color=#D78326>heat</color>'yi havada <style=cIsUtility>hover</style>'ye tüketin.",
        "SS2_ITEM_SCRAPFROMCHEST_LORE": "???",
        "SS2_EQUIP_GREATERWARBANNER_DESC": "<style=cIsHealing>50% Sağlık yenilenmesi</style>, <style=cIsDamage>20% kritik vuruş şansı</style>, ve <style=cIsUtility>50% bekleme süresi azaltma</style> sağlayan daha büyük bir savaş bayrağı yerleştirin. Aynı anda yalnızca bir sancak etkin olabilir.",
        "SS2_ACHIEVEMENT_ERRATICGADET_NAME": "Lord of Lightning",
        "SS2_NEMMANDO_PRIMARY_BLADE_DESCRIPTION": "<style=cIsDamage>Gouging.</style> <style=cIsUtility>Agile.</style> <style=cIsDamage>{0}% hasar için düşmanları dilimleyin</style>.",
