			//IL_0005: Unknown result type (might be due to invalid IL or missing references)
			return (InterruptPriority)2;
		}
	}
	internal class BaseShotSkill : BaseSkillState
	{
		public int CardNo = 0;

		public float potency = 1f;

		public float baseDuration = 0.6f;

		public float duration = 1f;

		public float baseFireTime = 0.05f;

		public float fireTime = 0.2f;

		public bool hasActivated = false;

		public GameObject shootMuzzleVFX = FirePistol2.muzzleEffectPrefab;

		public string shootMuzzleSFX = "Bullet_Blank";

		public string muzzleString = "Muzzle";

		public string animationString = "ShootGun";

		public ChildLocator childLocator;

		public HousePassiveManager passiveManager;

		public override void OnEnter()
		{
			((BaseState)this).OnEnter();
			fireTime = baseFireTime / ((BaseState)this).attackSpeedStat;
			duration = baseDuration / ((BaseState)this).attackSpeedStat;
			((EntityState)this).PlayAnimation("Gesture, Override", animationString, "Shoot.playbackRate", 2.5f * duration, 0f);
			((BaseState)this).StartAimMode(duration + 0.5f, false);
			childLocator = ((Component)((EntityState)this).GetModelTransform()).GetComponent<ChildLocator>();
			passiveManager = ((EntityState)this).GetComponent<HousePassiveManager>();
			if (!Object.op_Implicit((Object)(object)childLocator))
			{
				Debug.LogError((object)"[House Error] Shot skill could not find ChildLocator");
			}
			else if (!Object.op_Implicit((Object)(object)passiveManager))
			{
				Debug.LogError((object)"[House Error] Shot skill could not find PassiveManager");
			}
			else if (!((EntityState)this).characterBody.isPlayerControlled)
			{
				potency *= 0.3f;
			}
		}

		public override void OnExit()
		{
			((EntityState)this).OnExit();
		}

		public override void FixedUpdate()
		{
			((EntityState)this).FixedUpdate();
			if (((EntityState)this).fixedAge >= fireTime)
			{
				Fire();
			}
			if (((EntityState)this).fixedAge >= duration)
			{
				((EntityState)this).outer.SetNextStateToMain();
			}
		}

		private void Debugger()
		{
		}

		protected void Fire()
		{
			if (!hasActivated)
			{
				hasActivated = true;
				if (((EntityState)this).isAuthority && Object.op_Implicit((Object)(object)shootMuzzleVFX))
				{
					EffectManager.SimpleMuzzleFlash(shootMuzzleVFX, ((EntityState)this).gameObject, muzzleString, false);
				}
				Util.PlaySound(shootMuzzleSFX, ((EntityState)this).gameObject);
				OnShoot();
			}
		}

		public virtual void OnShoot()
		{
		}

		public override void OnSerialize(NetworkWriter writer)
		{
			((BaseSkillState)this).OnSerialize(writer);
			writer.Write((double)potency);
			writer.Write((double)baseDuration);
			writer.Write((double)baseFireTime);
		}

		public override void OnDeserialize(NetworkReader reader)
		{
			((BaseSkillState)this).OnDeserialize(reader);
			potency = (float)reader.ReadDouble();
			baseDuration = (float)reader.ReadDouble();
			baseFireTime = (float)reader.ReadDouble();
		}

		public override InterruptPriority GetMinimumInterruptPriority()
		{
			//IL_0002: Unknown result type (might be due to invalid IL or missing references)
			//IL_0005: Unknown result type (might be due to invalid IL or missing references)
			return (InterruptPriority)2;
		}
	}
