{
    "la": {
        "ROB_HENRY_BODY_NAME": "Henry",
        "ROB_HENRY_BODY_DESCRIPTION": "Henricus est pugnator peritus qui lato armorum apparatu utitur ut hostes prosternat.<color=#CCD3E0>\n\n< ! > Gladius est utilis in plurimis rebus; Caestus Pugiles meliores sunt ad hostes validiores contundendos.\n\n< ! > Pistola potens est contra hostes aereos, cum brevi mora et magno damno.\n\n< ! > Volutatio munimentum armaturae paulisper relinquit et impetum audaciorem adiuvat.\n\n< ! > Bomba turbas hostium facile delere potest.</color>",
        "ROB_HENRY_BODY_SUBTITLE": "Electus",
        "ROB_HENRY_BODY_LORE": "Historia exempli",
        "ROB_HENRY_BODY_OUTRO_FLAVOR": "..atque ita discessit, novam personam quaerens.",
        "ROB_HENRY_BODY_OUTRO_FAILURE": "..atque ita evanuit, in perpetuum tabula rasa.",
        "ROB_HENRY_BODY_DEFAULT_SKIN_NAME": "Defalta",
        "ROB_HENRY_BODY_MASTERY_SKIN_NAME": "Alterna",
        "ROB_HENRY_BODY_TYPHOON_SKIN_NAME": "V1",
        "ROB_HENRY_BODY_DANTE_SKIN_NAME": "Dante",
        "ROB_HENRY_BODY_VERGIL_SKIN_NAME": "Vergil",
        "ROB_HENRY_BODY_SAMURAI_SKIN_NAME": "Samurai",
        "ROB_HENRY_BODY_SOLDIER_SKIN_NAME": "Champion",
        "ROB_HENRY_BODY_ZOMBIE_SKIN_NAME": "Zombie",
        "ROB_HENRY_BODY_SKELETON_SKIN_NAME": "Skeleton",
        "ROB_HENRY_BODY_PASSIVE_NAME": "Passivum Henrici",
        "ROB_HENRY_BODY_PASSIVE_DESCRIPTION": "Textus exempli.",
        "ROB_HENRY_BODY_PRIMARY_SLASH_NAME": "Gladius",
        "ROB_HENRY_BODY_PRIMARY_SLASH_DESCRIPTION": "<style=cIsUtility>Agilis.</style> Ante te caede pro <style=cIsDamage>280% damno</style>.",
        "ROB_HENRY_BODY_PRIMARY_PUNCH_NAME": "Caestus Pugiles",
        "ROB_HENRY_BODY_PRIMARY_PUNCH_DESCRIPTION": "<style=cIsUtility>Agilis.</style> Celeriter pugna pro <style=cIsDamage>240% damno</style>. <style=cIsUtility>Armaturam ignorat.</style>",
        "ROB_HENRY_BODY_PRIMARY_GUN_NAME": "Pistola",
        "ROB_HENRY_BODY_PRIMARY_GUN_DESCRIPTION": "<style=cIsUtility>Agilis.</style> Parva pistola iacula pro <style=cIsDamage>90% damno</style>.",
        "ROB_HENRY_BODY_SECONDARY_GUN_NAME": "Sclopetum Manuarium",
        "ROB_HENRY_BODY_SECONDARY_GUN_DESCRIPTION": "<style=cIsUtility>Agilis.</style> Sclopeto manuari iacula pro <style=cIsDamage>420% damno</style>.",
        "ROB_HENRY_BODY_SECONDARY_STINGER_NAME": "Stinger",
        "ROB_HENRY_BODY_SECONDARY_STINGER_DESCRIPTION": "<style=cIsUtility>Agilis.</style> In hostem impetum fac pro <style=cIsDamage>450% damno</style>.",
        "ROB_HENRY_BODY_SECONDARY_UZI_NAME": "Uzi",
        "ROB_HENRY_BODY_SECONDARY_UZI_DESCRIPTION": "Uzi iacula pro <style=cIsDamage>75% damno</style>.",
        "ROB_HENRY_BODY_UTILITY_ROLL_NAME": "Volutatio",
        "ROB_HENRY_BODY_UTILITY_ROLL_DESCRIPTION": "Breve spatium volve, accipiens <style=cIsUtility>300 armaturam</style>. <style=cIsUtility>Dum volveris feriri non potes.</style>",
        "ROB_HENRY_BODY_UTILITY_SHOTGUN_NAME": "Shotgun",
        "ROB_HENRY_BODY_UTILITY_SHOTGUN_DESCRIPTION": "Shotgun iacula pro <style=cIsDamage>14x140% damno</style>, te vi retroacta propellens.",
        "ROB_HENRY_BODY_SPECIAL_BOMB_NAME": "Bomba",
        "ROB_HENRY_BODY_SPECIAL_BOMB_DESCRIPTION": "Bombam iace pro <style=cIsDamage>1600% damno</style>.",
        "ROB_HENRY_BODY_SPECIAL_SCEPBOMB_NAME": "Plures Bombae!",
        "ROB_HENRY_BODY_SPECIAL_SCEPBOMB_DESCRIPTION": "Bombam iace pro <style=cIsDamage>1600% damno</style>.\n<color=#d299ff>SCEPTER: Usque ad 4 bombas tenere potes. Mora dimidiatur.</color>",
        "ROB_HENRY_BODY_SPECIAL_BAZOOKA_NAME": "Bazooka",
        "ROB_HENRY_BODY_SPECIAL_BAZOOKA_DESCRIPTION": "Rachetas para et iacula pro <style=cIsDamage>600%-1600% damno</style>.",
        "ROB_HENRY_BODY_PRIMARY_BAZOOKA_NAME": "Ignis",
        "ROB_HENRY_BODY_PRIMARY_BAZOOKA_DESCRIPTION": "Rachetam para et iacula pro <style=cIsDamage>600%-1600% damno</style>.",
        "ROB_HENRY_BODY_PRIMARY_BAZOOKAOUT_NAME": "Abrogare",
        "ROB_HENRY_BODY_PRIMARY_BAZOOKAOUT_DESCRIPTION": "Repone tuam <style=cIsDamage>bazooka</style>.",
        "ROB_HENRY_BODY_SPECIAL_SCEPBAZOOKA_NAME": "Armageddon",
        "ROB_HENRY_BODY_SPECIAL_SCEPBAZOOKA_DESCRIPTION": "Rachetas para et iacula pro <style=cIsDamage>600%-1600% damno</style>.\n<color=#d299ff>SCEPTER: Duas Bazookas simul tenere potes.</color>",
        "ROB_HENRY_BODY_PRIMARY_SCEPBAZOOKA_NAME": "Ignis",
        "ROB_HENRY_BODY_PRIMARY_SCEPBAZOOKA_DESCRIPTION": "Rachetam para et iacula pro <style=cIsDamage>600%-1600% damno</style>.\n<color=#d299ff>SCEPTER: Duas Bazookas simul tenere potes.</color>",
        "ROB_HENRY_BODY_SPECIAL_FRENZY_NAME": "Rampage",
        "ROB_HENRY_BODY_SPECIAL_FRENZY_DESCRIPTION": "<style=cIsHealth>Fury</style> ictibus collige. Utere cum plene oneratum est ut in <style=cIsDamage>furorem</style> ingrediaris per <style=cIsUtility>10 secundas</style>. <style=cIsHealth>Celerius oneratur cum valetudo minor est.</style>",
        "ROB_HENRY_BODY_SPECIAL_SCEPFRENZY_NAME": "Super Saiyan",
        "ROB_HENRY_BODY_SPECIAL_SCEPFRENZY_DESCRIPTION": "<style=cIsHealth>Fury</style> ictibus collige. Utere cum plene oneratum est ut in <style=cIsDamage>furorem</style> ingrediaris per <style=cIsUtility>10 secundas</style>. <style=cIsHealth>Celerius oneratur cum valetudo minor est.</style>\n<color=#d299ff>SCEPTER: Boni statuum valde augentur. Duratio augetur.</color>",
        "ACHIEVEMENT_ROB_HENRY_BODY_UNLOCKABLE_ACHIEVEMENT_ID_NAME": "Prelude",
        "ACHIEVEMENT_ROB_HENRY_BODY_UNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "Ut Henry, Titanic Plains intra.",
        "ACHIEVEMENT_ROB_HENRY_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_ID_NAME": "Henry: Mastery",
        "ACHIEVEMENT_ROB_HENRY_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "Ut Henry, ludum vince aut te oblitera in Monsoon.",
        "ACHIEVEMENT_ROB_HENRY_BODY_TYPHOONUNLOCKABLE_ACHIEVEMENT_ID_NAME": "Henry: Grand Mastery",
        "ACHIEVEMENT_ROB_HENRY_BODY_TYPHOONUNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "Ut Henry, ludum vince aut te oblitera in Typhoon aut Eclipse.\n<color=#8888>(Computat quamlibet difficultatem Typhoon vel altiorem)</color>",
        "ROB_HENRY_BODY_DANTEUNLOCKABLE_ACHIEVEMENT_NAME": "Henry: Jackpot",
