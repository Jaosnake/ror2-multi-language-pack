		public class InteractionPrompt : MonoBehaviour
		{
			public GameObject panel;

			public GameObject nearImage;

			public GameObject pressImage;

			public TextMeshProUGUI text;

			public TextMeshProUGUI costText;

			public GameObject insufficient;

			private float activeTimer;

			private bool active;

			private MPEventSystemLocator eventSystemLocator;

			private PurchaseInteraction purchase;

			private void Awake()
			{
				panel.SetActive(false);
				panel.SetActive(true);
				nearImage.SetActive(true);
				pressImage.SetActive(false);
				((TMP_Text)costText).text = "";
			}

			private void Start()
			{
				purchase = ((Component)this).GetComponentInParent<PurchaseInteraction>();
				if (!MainPlugin.riskUIInstalled)
				{
					((TMP_Text)text).font = HunkAssets.hgFont;
				}
				eventSystemLocator = ((Component)Hunk.HUDinstance).GetComponentInChildren<MPEventSystemLocator>();
			}

			private void FixedUpdate()
			{
				activeTimer -= Time.fixedDeltaTime;
				if (Object.op_Implicit((Object)(object)purchase) && !purchase.CanBeAffordedByInteractor(((Component)Helpers.getLocalPlayer.body).GetComponent<Interactor>()))
				{
					insufficient.SetActive(true);
					nearImage.SetActive(false);
					pressImage.SetActive(false);
					activeTimer = 0f;
					active = true;
					return;
				}
				insufficient.SetActive(false);
				if (activeTimer <= 0f && active)
				{
					active = false;
					nearImage.SetActive(true);
					pressImage.SetActive(false);
				}
				if (Object.op_Implicit((Object)(object)eventSystemLocator))
				{
					((TMP_Text)text).text = string.Format(CultureInfo.InvariantCulture, "{0}", Glyphs.GetGlyphString(eventSystemLocator, "Interact"));
				}
				else
				{
					eventSystemLocator = ((Component)Hunk.HUDinstance).GetComponentInChildren<MPEventSystemLocator>();
				}
			}

			public void Show()
			{
			}

			public void ShowClose()
			{
				nearImage.SetActive(false);
				pressImage.SetActive(true);
				active = true;
				activeTimer = 0.1f;
			}

			public void Hide()
			{
			}
		}
