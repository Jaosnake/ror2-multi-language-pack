				damageInfo.procCoefficient = 0f;
				damageInfo.rejected = true;
			}
			else
			{
				self.body.AddTimedBuff(Prefabs.laserCD, 0.05f);
			}
		}
		if (Object.op_Implicit((Object)(object)((Component)self).GetComponent<Behaviour>()))
		{
			damageInfo.damage *= 0.8f;
		}
		if (Object.op_Implicit((Object)(object)damageInfo.attacker))
		{
			if (Object.op_Implicit((Object)(object)damageInfo.attacker.GetComponent<Behaviour>()) && damageInfo.procCoefficient > 0f)
			{
				damageInfo.damageType |= DamageTypeCombo.op_Implicit((DamageType)128);
			}
			if (self.body.HasBuff(Prefabs.masterDmgBuff) && Object.op_Implicit((Object)(object)damageInfo.attacker.GetComponent<MasterMarkBehaviour>()))
			{
				damageInfo.damage *= 1.2f;
			}
		}
		orig.Invoke(self, damageInfo);
	}
