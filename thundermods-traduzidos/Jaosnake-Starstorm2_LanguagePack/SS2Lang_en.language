                    "SS2_ITEM_DETRITIVETREMATODE_NAME":  "Detritive Trematode",
                    "SS2_MULE_NAME":  "MULE (SS2 BETA. VERY ROUGH PROTOTYPE)",
                    "SS2_BIGBROTHER_BODY_SUBTITLE":  "Revitalized Destroyer",
