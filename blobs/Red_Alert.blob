	public static class ChronoItems
	{
		public static ItemDef chronoSicknessItemDef;

		public static void Init()
		{
			//IL_007c: Unknown result type (might be due to invalid IL or missing references)
			chronoSicknessItemDef = ScriptableObject.CreateInstance<ItemDef>();
			((Object)chronoSicknessItemDef).name = "ChronoSickness";
			chronoSicknessItemDef.nameToken = "HABIBI_CHRONO_ITEM_SICKNESS_NAME";
			chronoSicknessItemDef.descriptionToken = "HABIBI_CHRONO_ITEM_SICKNESS_DESCRIPTION";
			chronoSicknessItemDef.pickupToken = "HABIBI_CHRONO_ITEM_SICKNESS_PICKUP";
			chronoSicknessItemDef.loreToken = "HABIBI_CHRONO_ITEM_SICKNESS_LORE";
			chronoSicknessItemDef.canRemove = false;
			chronoSicknessItemDef.hidden = true;
			chronoSicknessItemDef.tier = (ItemTier)5;
			chronoSicknessItemDef.deprecatedTier = (ItemTier)5;
			Content.AddItemDef(chronoSicknessItemDef);
		}
	}
	public static class ChronoStates
	{
		public static void Init()
		{
			Content.AddEntityState(typeof(ChronoCharacterMain));
			Content.AddEntityState(typeof(ChronoSprintState));
			Content.AddEntityState(typeof(ChronoSprintStateEpic));
			Content.AddEntityState(typeof(WindDownState));
			Content.AddEntityState(typeof(PhaseState));
			Content.AddEntityState(typeof(ChronoShoot));
			Content.AddEntityState(typeof(ChronoBombPlace));
			Content.AddEntityState(typeof(ChronoBombThrow));
			Content.AddEntityState(typeof(AimChronosphere1));
			Content.AddEntityState(typeof(AimChronosphere2));
			Content.AddEntityState(typeof(PlaceChronosphere2));
			Content.AddEntityState(typeof(AimFreezoSphere));
			Content.AddEntityState(typeof(PlaceFreezoSphere));
