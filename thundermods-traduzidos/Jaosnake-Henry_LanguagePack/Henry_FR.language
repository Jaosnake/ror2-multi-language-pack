{
    "FR": {
        "ROB_HENRY_BODY_NAME": "Henri",
        "ROB_HENRY_BODY_DESCRIPTION": "Henry est un combattant talentueux qui utilise un vaste arsenal d'armes pour abattre ses ennemis.<color=#CCD3E0>",
        "ROB_HENRY_BODY_SUBTITLE": "L'Élu",
        "ROB_HENRY_BODY_LORE": "exemple d'histoire",
        "ROB_HENRY_BODY_OUTRO_FLAVOR": "..et ainsi il partit, à la recherche d'une nouvelle identité.",
        "ROB_HENRY_BODY_OUTRO_FAILURE": "..et ainsi il disparut, à jamais une page blanche.",
        "ROB_HENRY_BODY_DEFAULT_SKIN_NAME": "Par défaut",
        "ROB_HENRY_BODY_MASTERY_SKIN_NAME": "Alternatif",
        "ROB_HENRY_BODY_TYPHOON_SKIN_NAME": "V1",
        "ROB_HENRY_BODY_DANTE_SKIN_NAME": "Dante",
        "ROB_HENRY_BODY_VERGIL_SKIN_NAME": "Vergil",
        "ROB_HENRY_BODY_SAMURAI_SKIN_NAME": "Samurai",
        "ROB_HENRY_BODY_SOLDIER_SKIN_NAME": "Champion",
        "ROB_HENRY_BODY_ZOMBIE_SKIN_NAME": "Zombie",
        "ROB_HENRY_BODY_SKELETON_SKIN_NAME": "Squelette",
        "ROB_HENRY_BODY_PASSIVE_NAME": "Passif d'Henry",
        "ROB_HENRY_BODY_PASSIVE_DESCRIPTION": "Texte d'exemple.",
        "ROB_HENRY_BODY_PRIMARY_SLASH_NAME": "Épée",
        "ROB_HENRY_BODY_PRIMARY_SLASH_DESCRIPTION": "<style=cIsUtility>Agile.</style> Balancez-vous vers l'avant pour <style=cIsDamage>280 % de dégâts</style>.",
        "ROB_HENRY_BODY_PRIMARY_PUNCH_NAME": "Gants de Boxe",
        "ROB_HENRY_BODY_PRIMARY_PUNCH_DESCRIPTION": "<style=cIsUtility>Agile.</style> Frappe rapidement pour <style=cIsDamage>240% de dégâts</style>. <style=cIsUtility>Ignore l’armure.</style>",
        "ROB_HENRY_BODY_PRIMARY_GUN_NAME": "Pistolet",
        "ROB_HENRY_BODY_PRIMARY_GUN_DESCRIPTION": "<style=cIsUtility>Agile.</style> Tire avec un petit pistolet pour <style=cIsDamage>90% de dégâts</style>.",
        "ROB_HENRY_BODY_SECONDARY_GUN_NAME": "Pistolet",
        "ROB_HENRY_BODY_SECONDARY_GUN_DESCRIPTION": "<style=cIsUtility>Agile.</style> Tirez avec une arme de poing pour <style=cIsDamage>420 % de dégâts</style>.",
        "ROB_HENRY_BODY_SECONDARY_STINGER_NAME": "Stinger",
        "ROB_HENRY_BODY_SECONDARY_STINGER_DESCRIPTION": "<style=cIsUtility>Agile.</style> Fonce sur un ennemi pour <style=cIsDamage>450% de dégâts</style>.",
        "ROB_HENRY_BODY_SECONDARY_UZI_NAME": "Uzi",
        "ROB_HENRY_BODY_SECONDARY_UZI_DESCRIPTION": "Tire avec un uzi pour <style=cIsDamage>75% de dégâts</style>.",
        "ROB_HENRY_BODY_UTILITY_ROLL_NAME": "Roulade",
        "ROB_HENRY_BODY_UTILITY_ROLL_DESCRIPTION": "Roule sur une courte distance, gagnant <style=cIsUtility>300 d'armure</style>. <style=cIsUtility>Vous ne pouvez pas être touché pendant la roulade.</style>",
        "ROB_HENRY_BODY_UTILITY_SHOTGUN_NAME": "Shotgun",
        "ROB_HENRY_BODY_UTILITY_SHOTGUN_DESCRIPTION": "Tire avec un <style=cIsUtility>shotgun</style> pour <style=cIsDamage>14x140% de dégâts</style>, en te propulsant avec le recul.",
        "ROB_HENRY_BODY_SPECIAL_BOMB_NAME": "Bombe",
        "ROB_HENRY_BODY_SPECIAL_BOMB_DESCRIPTION": "Lance une bombe pour <style=cIsDamage>1600% de dégâts</style>.",
        "ROB_HENRY_BODY_SPECIAL_SCEPBOMB_NAME": "Plus de Bombes !",
        "ROB_HENRY_BODY_SPECIAL_SCEPBOMB_DESCRIPTION": "Lance une bombe pour <style=cIsDamage>1600% de dégâts</style>.\n<color=#d299ff>SCEPTER : garde jusqu’à 4 bombes. Le temps de recharge est réduit de moitié.</color>",
        "ROB_HENRY_BODY_SPECIAL_BAZOOKA_NAME": "Bazooka",
        "ROB_HENRY_BODY_SPECIAL_BAZOOKA_DESCRIPTION": "Charge et tire des roquettes pour <style=cIsDamage>600%-1600% de dégâts</style>.",
        "ROB_HENRY_BODY_PRIMARY_BAZOOKA_NAME": "Tirer",
        "ROB_HENRY_BODY_PRIMARY_BAZOOKA_DESCRIPTION": "Charge et tire une roquette pour <style=cIsDamage>600%-1600% de dégâts</style>.",
        "ROB_HENRY_BODY_PRIMARY_BAZOOKAOUT_NAME": "Annuler",
        "ROB_HENRY_BODY_PRIMARY_BAZOOKAOUT_DESCRIPTION": "Range ton <style=cIsDamage>bazooka</style>.",
        "ROB_HENRY_BODY_SPECIAL_SCEPBAZOOKA_NAME": "Armageddon",
        "ROB_HENRY_BODY_SPECIAL_SCEPBAZOOKA_DESCRIPTION": "Charge et tire des roquettes pour <style=cIsDamage>600%-1600% de dégâts</style>.\n<color=#d299ff>SCEPTER : porte deux Bazookas à la fois.</color>",
        "ROB_HENRY_BODY_PRIMARY_SCEPBAZOOKA_NAME": "Tirer",
        "ROB_HENRY_BODY_PRIMARY_SCEPBAZOOKA_DESCRIPTION": "Charge et tire une roquette pour <style=cIsDamage>600%-1600% de dégâts</style>.\n<color=#d299ff>SCEPTER : porte deux Bazookas à la fois.</color>",
        "ROB_HENRY_BODY_SPECIAL_FRENZY_NAME": "Rampage",
        "ROB_HENRY_BODY_SPECIAL_FRENZY_DESCRIPTION": "Accumule de la <style=cIsHealth>Fury</style> en touchant. Utilise-la une fois chargée pour entrer en <style=cIsDamage>frénésie</style> pendant <style=cIsUtility>10 secondes</style>. <style=cIsHealth>Se charge plus vite à faible santé.</style>",
        "ROB_HENRY_BODY_SPECIAL_SCEPFRENZY_NAME": "Super Saiyan",
        "ROB_HENRY_BODY_SPECIAL_SCEPFRENZY_DESCRIPTION": "Accumule de la <style=cIsHealth>Fury</style> en touchant. Utilise-la une fois chargée pour entrer en <style=cIsDamage>frénésie</style> pendant <style=cIsUtility>10 secondes</style>. <style=cIsHealth>Se charge plus vite à faible santé.</style>\n<color=#d299ff>SCEPTER : bonus de stats massivement augmentés. Durée augmentée.</color>",
        "ACHIEVEMENT_ROB_HENRY_BODY_UNLOCKABLE_ACHIEVEMENT_ID_NAME": "Prelude",
        "ACHIEVEMENT_ROB_HENRY_BODY_UNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "Entre dans les Plaines titanesques.",
        "ACHIEVEMENT_ROB_HENRY_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_ID_NAME": "Henry: Mastery",
        "ACHIEVEMENT_ROB_HENRY_BODY_MASTERYUNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "En tant qu’Henry, termine le jeu ou oblitère-toi en Mousson.",
        "ACHIEVEMENT_ROB_HENRY_BODY_TYPHOONUNLOCKABLE_ACHIEVEMENT_ID_NAME": "Henry: Grand Mastery",
        "ACHIEVEMENT_ROB_HENRY_BODY_TYPHOONUNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "En tant qu’Henry, termine le jeu ou oblitère-toi en Typhon ou Eclipse.\n<color=#8888>(Compte toute difficulté Typhon ou supérieure)</color>",
        "ROB_HENRY_BODY_DANTEUNLOCKABLE_ACHIEVEMENT_NAME": "Henry: Jackpot",
        "ROB_HENRY_BODY_DANTEUNLOCKABLE_ACHIEVEMENT_DESC": "As Henry, defeat a Twisted Scavenger on Monsoon.",
        "ROB_HENRY_BODY_DANTEUNLOCKABLE_UNLOCKABLE_NAME": "Henry: Jackpot",
        "ROB_HENRY_BODY_VERGILUNLOCKABLE_ACHIEVEMENT_NAME": "Henry: 200% Motivated",
        "ROB_HENRY_BODY_VERGILUNLOCKABLE_ACHIEVEMENT_DESC": "As Henry, defeat the King of Nothing with no items.",
        "ROB_HENRY_BODY_VERGILUNLOCKABLE_UNLOCKABLE_NAME": "Henry: 200% Motivated",
        "ACHIEVEMENT_ROB_HENRY_MASTERYACHIEVEMENT_NAME": "Henry: Mastery",
        "ACHIEVEMENT_ROB_HENRY_MASTERYACHIEVEMENT_DESCRIPTION": "En tant qu'Henry, terminez le jeu ou effacez la mousson.",
        "ROB_MRGREEN_BODY_NAME": "Mr. Green",
        "ROB_MRGREEN_BODY_DESCRIPTION": "Mr. Green<color=#CCD3E0>\n\n< ! > Sword is a good all-rounder while Boxing Gloves are better for laying a beatdown on more powerful foes.\n\n< ! > Pistol is a powerful anti air, with its low cooldown and high damage.\n\n< ! > Roll has a lingering armor buff that helps to use it aggressively.\n\n< ! > Bomb can be used to wipe crowds with ease.</color>",
        "ROB_MRGREEN_BODY_SUBTITLE": "Le",
        "ROB_MRGREEN_BODY_LORE": "histoire d’exemple partie 2",
        "ROB_MRGREEN_BODY_OUTRO_FLAVOR": "..and so he left, bottom text.",
        "ROB_MRGREEN_BODY_DEFAULT_SKIN_NAME": "Par défaut",
        "ROB_MRGREEN_BODY_PASSIVE_NAME": "Passif de Mr. Green",
        "ROB_MRGREEN_BODY_PASSIVE_DESCRIPTION": "Texte d’exemple.",
        "ROB_MRGREEN_BODY_PRIMARY_PUNCH_NAME": "Martial Arts",
        "ROB_MRGREEN_BODY_PRIMARY_PUNCH_DESCRIPTION": "Effectue un combo rapide de coups de poing et de pied pour <style=cIsDamage>90% de dégâts</style>.",
        "ROB_MRGREEN_BODY_SECONDARY_CLONETHROW_NAME": "Lancer de Clone",
        "ROB_MRGREEN_BODY_SECONDARY_CLONETHROW_DESCRIPTION": "Invoque un clone et lance-le vers l’avant, attrapant les ennemis proches et les écrasant au sol pour <style=cIsDamage>420% de dégâts</style>.",
        "ROB_MRGREEN_BODY_UTILITY_DASH_NAME": "People's Elbow",
        "ROB_MRGREEN_BODY_UTILITY_DASH_DESCRIPTION": "Fonce sur une courte distance. Au contact d’un <style=cIsUtility>clone</style>, bondis en l’air et retombe avec un puissant <style=cIsUtility>coup de coude</style> pour <style=cIsDamage>800% de dégâts</style>.",
        "ROB_MRGREEN_BODY_SPECIAL_RES_NAME": "Resurrection",
        "ROB_MRGREEN_BODY_SPECIAL_RES_DESCRIPTION": "Ressuscite tous les clones tombés.",
        "ROB_NEMRY_BODY_NAME": "Nemesis Henry",
        "ROB_NEMRY_BODY_DESCRIPTION": "Nemesis Henry is a volatile swordsman who wields a special blade that stores energy to boost its attacks. He has no cooldowns, but must manage his energy well.<color=#CCD3E0>\n\n< ! > Sword Mode is used to build up energy while Gun Mode is used to spend energy for powerful attacks.\n\n< ! > Swordmaster can be charged up for more damage.\n\n< ! > Flash Step is a powerful aggressive tool that helps to build up energy.\n\n< ! > Use Hydra Bite to stay healthy and Hyper Beam to unleash a ton of damage.</color>",
        "ROB_NEMRY_BODY_SUBTITLE": "Le Déchu",
        "ROB_NEMRY_BODY_LORE": "histoire d’exemple",
        "ROB_NEMRY_BODY_OUTRO_FLAVOR": "..and so he left, having blown up the moon for no discernible reason.",
        "ROB_NEMRY_BODY_OUTRO_FAILURE": "..he tried so hard, and got so far. But in the end it doesn't even matter.",
        "ROB_NEMRY_BODY_DEFAULT_SKIN_NAME": "Nemesis",
        "ROB_NEMRY_BODY_MASTERY_SKIN_NAME": "Captive #001",
        "ROB_NEMRY_BODY_TYPHOON_SKIN_NAME": "FLLFFL",
        "ROB_NEMRY_BODY_PASSIVE_NAME": "Gunblade acide",
        "ROB_NEMRY_BODY_PASSIVE_DESCRIPTION": "Nemesis Henry manie une arme spéciale qui peut alterner entre Sword Mode et Gun Mode. Ses compétences n’ont pas de recharge normale et utilisent le système d’<style=cIsHealing>Énergie</style> de son épée.",
        "ROB_NEMRY_BODY_PRIMARY_SPEAR_NAME": "Empaler",
        "ROB_NEMRY_BODY_PRIMARY_SPEAR_DESCRIPTION": "<style=cIsUtility>Agile.</style> Transperce vers l’avant pour <style=cIsDamage>160% dégâts</style>. <style=cIsDamage>beaucoup de <style=cIsHealing>50%</style> Soigne 50% des dégâts infligés.</style>.",
        "ROB_WEAPON_SWAP_SKILL": "Weapon Swap",
        "ROB_NEMRY_BODY_PRIMARY_SWORD_NAME": "Sword Mode",
        "ROB_NEMRY_BODY_PRIMARY_SWORD_DESCRIPTION": "Swing your blade forward for <style=cIsDamage>280% damage</style>. Generate <style=cIsHealing>20% Energy</style> on hit.",
        "ROB_NEMRY_BODY_PRIMARY_GUN_NAME": "Gun Mode",
        "ROB_NEMRY_BODY_PRIMARY_GUN_DESCRIPTION": "<style=cIsHealing>2.5% Energy.</style> Fire a piercing <style=cIsHealing>Energy</style> shot for <style=cIsDamage>240% damage</style>.",
        "ROB_NEMRY_BODY_PRIMARY_SWORDCSS_NAME": "Sword Mode / Gun Mode",
        "ROB_NEMRY_BODY_PRIMARY_SWORDCSS_DESCRIPTION": "Swing your blade forward for <style=cIsDamage>280% damage</style>. Generate <style=cIsHealing>20% Energy</style> on hit.\n<style=cIsHealing>2.5% Energy.</style> Fire a piercing <style=cIsHealing>Energy</style> shot for <style=cIsDamage>240% damage</style>.",
        "ROB_NEMRY_BODY_SECONDARY_BLAST_NAME": "Null Blast",
        "ROB_NEMRY_BODY_SECONDARY_BLAST_DESCRIPTION": "<style=cIsUtility>Agile.</style> Lance une masse d’énergie mystérieuse pour <style=cIsDamage>200% dégâts</style>.",
        "ROB_NEMRY_BODY_SECONDARY_CHARGE_NAME": "Swordmaster",
        "ROB_NEMRY_BODY_SECONDARY_CHARGE_DESCRIPTION": "<style=cIsHealing>10% Énergie.</style> Fonce sur un ennemi proche pour <style=cIsDamage>700% dégâts</style>.",
        "ROB_NEMRY_BODY_SECONDARY_TORRENT_NAME": "Gunslinger",
        "ROB_NEMRY_BODY_SECONDARY_TORRENT_DESCRIPTION": "<style=cIsHealing>5% Énergie.</style> Tire une rafale d’ Énergie.",
        "ROB_NEMRY_BODY_SECONDARY_CHARGECSS_NAME": "Swordmaster / Gunslinger",
        "ROB_NEMRY_BODY_SECONDARY_CHARGECSS_DESCRIPTION": "<style=cIsHealing>10% Énergie.</style> Fonce sur un ennemi proche pour <style=cIsDamage>700% dégâts</style>.\n<style=cIsHealing>5% Énergie.</style> Tire une rafale d’ Énergie.",
        "ROB_NEMRY_BODY_UTILITY_DODGESLASH_NAME": "Entaille rapide",
        "ROB_NEMRY_BODY_UTILITY_DODGESLASH_DESCRIPTION": "Fais un salto arrière et tranche les ennemis proches pour <style=cIsDamage>300% dégâts</style>.",
        "ROB_NEMRY_BODY_UTILITY_BLINK_NAME": "Flash Step",
        "ROB_NEMRY_BODY_UTILITY_BLINK_DESCRIPTION": "<style=cIsHealing>5% Énergie.</style> Fonce sur un ennemi proche pour",
        "ROB_NEMRY_BODY_UTILITY_BURST_NAME": "Décharge d’énergie",
        "ROB_NEMRY_BODY_UTILITY_BURST_DESCRIPTION": "<style=cIsHealing>10% Énergie.</style> Libère une décharge d’énergie et te propulse avec le recul pour <style=cIsDamage>400% dégâts</style>.",
        "ROB_NEMRY_BODY_UTILITY_BLINKCSS_NAME": "Flash Step / Décharge d’énergie",
        "ROB_NEMRY_BODY_UTILITY_BLINKCSS_DESCRIPTION": "<style=cIsHealing>5% Énergie.</style> Fonce sur un ennemi proche pour\n<style=cIsHealing>10% Énergie.</style> Libère une décharge d’énergie et te propulse avec le recul pour <style=cIsDamage>400% dégâts</style>.",
        "ROB_NEMRY_BODY_SPECIAL_STAB_NAME": "Hydra Bite",
        "ROB_NEMRY_BODY_SPECIAL_STAB_DESCRIPTION": "<style=cIsHealing>100% Énergie.</style> Plonge ta lame dans un ennemi pour <style=cIsDamage>2800% dégâts</style>. <style=cIsHealing>Soigne 50% des dégâts infligés.</style>",
        "ROB_NEMRY_BODY_SPECIAL_BEAM_NAME": "Hyper Beam",
        "ROB_NEMRY_BODY_SPECIAL_BEAM_DESCRIPTION": "<style=cIsHealing>100% Énergie.</style> Charge une puissante salve de lasers pour <style=cIsDamage>10x540% dégâts</style>.",
        "ROB_NEMRY_BODY_SPECIAL_STABCSS_NAME": "Hydra Bite / Hyper Beam",
        "ROB_NEMRY_BODY_SPECIAL_STABCSS_DESCRIPTION": "<style=cIsHealing>100% Énergie.</style> Plonge ta lame dans un ennemi pour <style=cIsDamage>2800% dégâts</style>. <style=cIsHealing>Soigne 50% des dégâts infligés.</style>\n<style=cIsHealing>100% Énergie.</style> Charge une puissante salve de lasers pour <style=cIsDamage>beaucoup de dégâts</style>.",
        "ROB_NEMRY_BODY_UNLOCKABLE_ACHIEVEMENT_NAME": "???",
        "ROB_NEMRY_BODY_UNLOCKABLE_ACHIEVEMENT_DESC": "Vaincs le Vestige d’Henry.",
