				if (!((FixedTimeStamp)(ref expirationTimeStamp)).hasPassed)
				{
					List<string> list = forbiddenStages;
					Scene activeScene = SceneManager.GetActiveScene();
					if (!list.Contains(((Scene)(ref activeScene)).name))
					{
						((BaseServerAchievement)this).Grant();
					}
				}
				Reset();
			}

			private void OnStageStart(Stage stage)
			{
				//IL_0007: Unknown result type (might be due to invalid IL or missing references)
				//IL_000c: Unknown result type (might be due to invalid IL or missing references)
				List<string> list = forbiddenStages;
				Scene activeScene = SceneManager.GetActiveScene();
				if (!list.Contains(((Scene)(ref activeScene)).name))
				{
					BeginStageTimer();
				}
			}

			private void OnRunStart(Run run)
			{
				BeginStageTimer();
			}

			private void Reset()
			{
				//IL_0002: Unknown result type (might be due to invalid IL or missing references)
				//IL_0007: Unknown result type (might be due to invalid IL or missing references)
				expirationTimeStamp = FixedTimeStamp.negativeInfinity;
			}
		}

		private static readonly float window = 180f;

