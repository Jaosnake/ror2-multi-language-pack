        "HABIBI_CHRONO_MASTERY_SKIN_NAME": "Alternativo",
        "HABIBI_CHRONO_PASSIVE_SPRINT_NAME": "Já Estou Lá",
        "HABIBI_CHRONO_PASSIVE_SPRINT_DESCRIPTION": "Em vez de correr, você salta no tempo de um lugar para outro, após o qual fica <style=cIsUtility>desabilitado</style> por um curto período baseado na distância.",
