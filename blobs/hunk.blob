			internal void CreateCharacter()
			{
				//IL_003c: Unknown result type (might be due to invalid IL or missing references)
				//IL_0046: Unknown result type (might be due to invalid IL or missing references)
				instance = this;
				characterPrefab = CreateBodyPrefab(isPlayer: true);
				enemyPrefab = CreateBodyPrefab(isPlayer: false);
				displayPrefab = Prefabs.CreateDisplayPrefab("NemesisDisplay", characterPrefab);
				Transform transform = displayPrefab.transform;
				transform.localScale *= 0.35f;
				displayPrefab.AddComponent<NemesisCSS>();
				((Component)displayPrefab.GetComponentInChildren<CharacterModel>()).gameObject.AddComponent<ModelSkinController>().skins = characterPrefab.GetComponentInChildren<ModelSkinController>().skins.ToArray();
				if (Config.playableNemesis.Value)
				{
					survivorDef = Prefabs.RegisterNewSurvivor(characterPrefab, displayPrefab, "NEMESIS");
				}
				enemyMaster = CreateMaster(enemyPrefab, "RobNemesisMaster");
				umbraMaster = CreateMaster(characterPrefab, "RobNemesisMonsterMaster");
				CreateSpawnCard();
				CreateMutations();
				Hook();
			}

