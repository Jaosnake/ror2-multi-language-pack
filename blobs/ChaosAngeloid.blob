	{
		if (overlay != null)
		{
			overlay.duration = 0f;
		}
		if (NetworkServer.active && Object.op_Implicit((Object)(object)body))
		{
			body.RemoveBuff(Prefabs.masterMarkBuff);
		}
	}
}
