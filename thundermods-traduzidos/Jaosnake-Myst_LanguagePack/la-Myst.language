        "JAVANGLE_MYST_MAGICITE_FIREBALL_NAME": "Globus Ignis",
        "JAVANGLE_MYST_MAGICITE_FIREBALL_DESCRIPTION": "Globum ignis sequacem ad metam emittit qui in ictu explodit, damnum faciens et hostes in area effectus <style=cIsDamage>accendens</style>.",
        "JAVANGLE_MYST_MAGICITE_CALL_LIGHTNING_NAME": "Voca Fulgur",
        "JAVANGLE_MYST_MAGICITE_CALL_LIGHTNING_DESCRIPTION": "Ictum fulguris in metam tuam evoca, damnum faciens et hostes aerios e caelo deiciens.",
        "JAVANGLE_MYST_MAGICITE_CONE_OF_FROST_NAME": "Conus Gelu",
        "JAVANGLE_MYST_MAGICITE_CONE_OF_FROST_DESCRIPTION": "Conum venti gelantis evoca ut damnum facias et hostes ante te <style=cIsDamage>glacies</style>.",
        "JAVANGLE_MYST_MAGICITE_FORTIFY_NAME": "Firma",
        "JAVANGLE_MYST_MAGICITE_FORTIFY_DESCRIPTION": "Post breve canale: auxilium <style=cIsUtility>armaturae</style> potens tibi et socio destinato donat.",
        "JAVANGLE_MYST_MAGICITE_MEND_WOUNDS_NAME": "Sana Vulnera",
        "JAVANGLE_MYST_MAGICITE_MEND_WOUNDS_DESCRIPTION": "Post breve canale: te et socium destinatum pro <style=cIsHealing>50% Valetudinis Maximae</style> sanat.",
        "JAVANGLE_MYST_MAGICITE_MAGNET_NAME": "Magnes",
        "JAVANGLE_MYST_MAGICITE_MAGNET_DESCRIPTION": "Campum magneticum evoca ad hostes in area lata circum metam trahendos.",
        "JAVANGLE_MYST_MAGICITE_HASTE_NAME": "Festinatio",
        "JAVANGLE_MYST_MAGICITE_HASTE_DESCRIPTION": "Post breve canale: Celeritatem Motus et Celeritatem Impetus tibi et socio destinato donat.",
        "JAVANGLE_MYST_MAGICITE_MAGIC_MISSILE_NAME": "Missile Magicum",
        "JAVANGLE_MYST_MAGICITE_MAGIC_MISSILE_DESCRIPTION": "Nimbum missilium magicorum sequacium iace quae metas petunt. Plus MP plura missilia iaculata efficit.",
        "JAVANGLE_MYST_MAGICITE_ECLIPSE_GATE_NAME": "Porta Eclipsis",
        "JAVANGLE_MYST_MAGICITE_ECLIPSE_GATE_DESCRIPTION": "Fragmentum potentiae umbralis evocat ad damnum metae secundum MP defectum faciendum.",
        "JAVANGLE_MYST_MAGICITE_ULTIMA_NAME": "Ultima",
        "JAVANGLE_MYST_MAGICITE_ULTIMA_DESCRIPTION": "Post breve canale: omnem Potentiam Magicam restantem impendit ad vorticem ingentem energiae creandum qui damnum incredibile omnibus hostibus in area lata post longam moram facit.",
        "JAVANGLE_MYST_MAGICITE_FATED_CIRCLE_NAME": "Circulus Fatalis",
        "JAVANGLE_MYST_MAGICITE_FATED_CIRCLE_DESCRIPTION": "Impetus rotans qui hostes stupefacit et trahit, sequentibus explosionibus ignis quae eos repellunt, grave damnum faciens.",
        "JAVANGLE_MYST_MAGICITE_EXPLOSION_NAME": "Displosio",
        "JAVANGLE_MYST_MAGICITE_EXPLOSION_DESCRIPTION": "<style=cIsUtility>(Finitores differunt secundum Myst in terra vel in aere sit)</style>. Positionem tene et Orbes Lucis evoca qui circum te orbitant, damnum faciens et hostes propinquos stupefaciens.",
        "JAVANGLE_MYST_MAGICITE_CHALLENGING_SHOUT_NAME": "Clamor Provocans",
        "JAVANGLE_MYST_MAGICITE_CHALLENGING_SHOUT_DESCRIPTION": "Clamorem imperantem emitte qui hostes debilitat et ad te trahit.",
        "JAVANGLE_MYST_MAGICITE_BLADE_DANCE_NAME": "Saltatio Gladii",
        "JAVANGLE_MYST_MAGICITE_BLADE_DANCE_DESCRIPTION": "Serenata artistica ictuum caedentium quae utentem propellit et damnum celeriter facit.",
        "JAVANGLE_MYST_MAGICITE_JUDGEMENT_CUT_NAME": "Caesura Iudicii",
        "JAVANGLE_MYST_MAGICITE_JUDGEMENT_CUT_DESCRIPTION": "Intangibilis fias et pluries in area effectus ferias, plures ictus cum celeritate impetus altiore consequens.",
        "JAVANGLE_MYST_MAGICITE_SHILLELAGH_NAME": "Shillelagh",
        "JAVANGLE_MYST_MAGICITE_SHILLELAGH_DESCRIPTION": "Cum in <style=cIsUtility>Recharga Magica</style>: grave damnum facit et Potentiam Magicam restituit. Sed aliter, mediocris.",
        "JAVANGLE_MYST_MAGICITE_BLASTING_ZONE_NAME": "Zona Displosiva",
        "JAVANGLE_MYST_MAGICITE_BLASTING_ZONE_DESCRIPTION": "Columnam giganteam vis evoca ut Gladium Vorpalem involvat, antequam laminam vibras ut eam in hostes ante te percutias, damnum incredibile in area lata faciens.",
        "JAVANGLE_MYST_MAGICITE_BERSERK_FORM_NAME": "Forma Berserci",
        "JAVANGLE_MYST_MAGICITE_BERSERK_FORM_DESCRIPTION": "Myst furit, Celeritatem Motus et Altitudinem Saltus auctas obtinens, necnon motus in impetus focatos.",
        "JAVANGLE_MYST_MAGICITE_JUDGEMENT_CUT_END_NAME": "Caesura Iudicii Finalis",
        "JAVANGLE_MYST_MAGICITE_JUDGEMENT_CUT_END_DESCRIPTION": "Gladium Vorpalem in vaginam mitte, energiam cumulans antequam nimbum caesurarum fulguris celeritate liberat quae damnum incredibile post moram faciunt.",
        "JAVANGLE_MYST_MAGICITE_POWER_WORD_KILL_NAME": "Verbum Potens Necis",
        "JAVANGLE_MYST_MAGICITE_POWER_WORD_KILL_DESCRIPTION": "Post breve canale: metam <style=cIsDamage>statim</style> eliminat.",
