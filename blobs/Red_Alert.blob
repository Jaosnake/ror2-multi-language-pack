		public override void OnArrival()
		{
			if (Object.op_Implicit((Object)(object)base.target) && Object.op_Implicit((Object)(object)buffToApply))
			{
				if (bufftime == -1f)
				{
					base.target.healthComponent.body.AddBuff(buffToApply);
				}
				else
				{
					base.target.healthComponent.body.AddTimedBuff(buffToApply, bufftime);
				}
			}
		}
	}
	public enum ModdedLightningType
	{
		Ukulele,
		Tesla,
		BFG,
		Loader,
		MageLightning,
		Nod,
		NodMage,
		NodMageThick
	}
	public class PseudoLightningOrb : LightningOrb
	{
		public ModdedLightningType moddedLightningType;

		public override void Begin()
		{
			//IL_00bc: Unknown result type (might be due to invalid IL or missing references)
			//IL_00c1: Unknown result type (might be due to invalid IL or missing references)
			//IL_00c3: Unknown result type (might be due to invalid IL or missing references)
			//IL_00cd: Unknown result type (might be due to invalid IL or missing references)
			//IL_00da: Expected O, but got Unknown
			if (base.speed <= 0f)
			{
				((Orb)this).duration = 0.0001f;
			}
			else
			{
				((Orb)this).duration = ((Orb)this).distanceToTarget / base.speed;
			}
			GameObject val = null;
			switch (moddedLightningType)
			{
			case ModdedLightningType.Ukulele:
				val = LegacyResourcesAPI.Load<GameObject>("Prefabs/Effects/OrbEffects/LightningOrbEffect");
				break;
			case ModdedLightningType.Tesla:
				val = LegacyResourcesAPI.Load<GameObject>("Prefabs/Effects/OrbEffects/TeslaOrbEffect");
				break;
			case ModdedLightningType.BFG:
				val = LegacyResourcesAPI.Load<GameObject>("Prefabs/Effects/OrbEffects/BeamSphereOrbEffect");
				break;
			case ModdedLightningType.Loader:
				val = LegacyResourcesAPI.Load<GameObject>("Prefabs/Effects/OrbEffects/LoaderLightningOrbEffect");
				break;
			case ModdedLightningType.MageLightning:
				val = LegacyResourcesAPI.Load<GameObject>("Prefabs/Effects/OrbEffects/MageLightningOrbEffect");
				break;
			case ModdedLightningType.Nod:
				val = TeslaAssets.TeslaLightningOrbEffectRed;
				break;
			case ModdedLightningType.NodMage:
				val = TeslaAssets.TeslaMageLightningOrbEffectRed;
				break;
			case ModdedLightningType.NodMageThick:
				val = TeslaAssets.TeslaMageLightningOrbEffectRedThick;
				break;
			}
			base.isElectric = true;
			EffectData val2 = new EffectData
			{
				origin = ((Orb)this).origin,
				genericFloat = ((Orb)this).duration
			};
			val2.SetHurtBoxReference(((Orb)this).target);
			EffectManager.SpawnEffect(val, val2, true);
		}
	}
}
