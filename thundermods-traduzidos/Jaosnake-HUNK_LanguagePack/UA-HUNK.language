        "ROB_HUNK_BODY_COMMANDO_SKIN_NAME": "Commando",
        "ROB_HUNK_BODY_JACKET_SKIN_NAME": "Піджак",
        "ROB_HUNK_BODY_PPASSIVE_NAME": "OSP (закупівля на місці)",
        "ROB_HUNK_BODY_PPASSIVE_DESCRIPTION": "HUNK може отримати <color=#FFFF00>U.C. Keycards</color>, щоб відкрити <style=cIsDamage>чохли зі зброєю</style> і розширити свій арсенал.",
        "ROB_HUNK_BODY_PPASSIVE2_NAME": "Забутий солдат",
        "ROB_HUNK_BODY_PPASSIVE2_DESCRIPTION": "Перший <style=cIsHealth>бос</style>, який помре на кожному етапі, видає <style=cIsDamage>пакет із припасами</style>, який містить зброю чи аксесуар.",
        "ROB_HUNK_BODY_PASSIVE_NAME": "Shadow Fight",
        "ROB_HUNK_BODY_PASSIVE_DESCRIPTION": "Почніть із <style=cIsDamage>LE 5</style> та <style=cIsDamage>допоміжної зброї</style>. Ви можете <style=cIsDamage>збирати</style> <style=cIsUtility>скрині</style> для патронів.",
        "ROB_HUNK_BODY_PASSIVE2_NAME": "Неминучий жах",
        "ROB_HUNK_BODY_PASSIVE2_DESCRIPTION": "Почніть із <style=cIsDamage>повного арсеналу</style>, <style=cIsHealth>АЛЕ</style> ви більше не можете <style=cIsHealth>отримати додаткові боєприпаси</style>.",
        "ROB_HUNK_BODY_RANDOMPASSIVE_NAME": "Нова гра+",
        "ROB_HUNK_BODY_RANDOMPASSIVE_DESCRIPTION": "Почніть із <style=cIsDamage>LE 5</style> та <style=cIsDamage>допоміжної зброї</style>. Ви можете <style=cIsDamage>збирати</style> <style=cIsUtility>скрині</style> для патронів. <style=cIsHealth>Увесь вміст футляра для зброї є випадковим.</style>",
        "ROB_HUNK_BODY_SHOTGUNPASSIVE_NAME": "Вища влада",
        "ROB_HUNK_BODY_SHOTGUNPASSIVE_DESCRIPTION": "Почніть із <style=cIsDamage>W-870</style> та <style=cIsDamage>другорядної зброї</style>. Ви можете <style=cIsDamage>збирати</style> <style=cIsUtility>скрині</style> для патронів.",
        "ROB_HUNK_BODY_SMGPASSIVE_NAME": "Верховний найманець",
        "ROB_HUNK_BODY_SMGPASSIVE_DESCRIPTION": "Почніть <style=cIsHealth>ЛИШЕ</style> з <style=cIsDamage>повністю оновленого LE 5</style>. Ви можете <style=cIsDamage>збирати</style> <style=cIsUtility>скрині</style> для патронів. <style=cIsDamage>Special</style> замінено на</style>0__Chaos Mode</style>1__.",
        "ROB_HUNK_BODY_WPASSIVE_NAME": "Повне глобальне насичення",
        "ROB_HUNK_BODY_WPASSIVE_DESCRIPTION": "Почніть <style=cIsHealth>ЛИШЕ</style> з <style=cIsDamage>допоміжної зброї</style>. Ви можете <style=cIsDamage>збирати</style> <style=cIsUtility>скрині</style> для патронів. <style=cIsDamage>Утиліта</style> замінено на</style>0__Uroboros</style>1__.",
        "ROB_HUNK_BODY_FLAMERPASSIVE_NAME": "Піроманія",
        "ROB_HUNK_BODY_FLAMERPASSIVE_DESCRIPTION": "Почніть <style=cIsHealth>ЛИШЕ</style> з <style=cIsDamage>хімічного вогнемета</style>. Ви можете <style=cIsDamage>збирати</style> <style=cIsUtility>скрині</style> для патронів. <style=cIsHealth>Тільки ОДИН чохол для зброї з’являється на етапі.</style>",
        "ROB_HUNK_BODY_PRIMARY_KNIFE_NAME": "Бойовий ніж",
        "ROB_HUNK_BODY_PRIMARY_KNIFE_DESCRIPTION": "<style=cIsUtility>Намалюйте.</style> <style=cIsDamage>Ріжте</style> сусідніх бойовиків, завдаючи <style=cIsDamage>200% шкоди</style>, завдаючи <style=cIsHealth>Понівечений</style>.",
        "ROB_HUNK_BODY_PRIMARY_CQC_NAME": "CQC (близький бій)",
        "ROB_HUNK_BODY_PRIMARY_CQC_DESCRIPTION": "<style=cIsUtility>Ничия.</style> <style=cIsDamage>Удар двічі</style> для <style=cIsDamage>200% і 250% шкоди</style>. Якщо <style=cIsUtility>другий удар</style> підключається, продовжуйте <style=cIsDamage>Контратака</style>.",
        "ROB_HUNK_BODY_PRIMARY_RELOAD_NAME": "Перезавантажити",
        "ROB_HUNK_BODY_RELOAD_DESCRIPTION": "Перезарядіть поточну зброю.",
        "ROB_HUNK_BODY_SECONDARY_AIM_NAME": "Неухильно цільтесь",
        "ROB_HUNK_BODY_SECONDARY_AIM_DESCRIPTION": "Прицілюйтеся, <style=cIsUtility>виявляючи слабкі місця ворога</style>. <style=cIsDamage>Використання основного під час прицілювання веде вогонь із вашої спорядженої зброї.</style>",
        "ROB_HUNK_BODY_UTILITY_DODGE_NAME": "Квікстеп",
        "ROB_HUNK_BODY_UTILITY_DODGE_DESCRIPTION": "<style=cIsUtility>Advance</style> на коротку відстань. Якщо використовується запобіжно, щоб <style=cIsUtility>уникнути атаки</style>, виконайте <style=cIsDamage>Ідеальне ухилення</style>.",
        "ROB_HUNK_BODY_UTILITY_DODGE_SCEPTER_NAME": "Уроборос",
        "ROB_HUNK_BODY_UTILITY_DODGE_SCEPTER_DESCRIPTION": "<style=cIsUtility>Advance</style> на коротку відстань. Якщо використовується запобіжно, щоб <style=cIsUtility>уникнути атаки</style>, виконайте <style=cIsDamage>Ідеальне ухилення</style>. Сила Уробороса тече через вас.",
        "ROB_HUNK_BODY_UTILITY_PARRY_NAME": "Паррі",
        "ROB_HUNK_BODY_UTILITY_PARRY_DESCRIPTION": "<style=cIsUtility>Блокувати</style> атаку, <style=cIsDamage>анулювати</style> пошкодження та <style=cIsUtility>відшкодовувати час відновлення</style>. Якщо використовується запобіжно, виконайте <style=cIsDamage>Ідеальне парування</style>.",
        "ROB_HUNK_BODY_UTILITY_BASH_NAME": "Удар плечем",
        "ROB_HUNK_BODY_UTILITY_BASH_DESCRIPTION": "<style=cIsUtility>Бийте плечем</style> ворогів поблизу, <style=cIsUtility>приголомшуючи їх</style>, завдаючи <style=cIsDamage>400% шкоди</style>. Якщо використовується запобіжно, щоб <style=cIsUtility>скасувати атаку</style>, виконайте <style=cIsDamage>Ідеальне відхилення</style>.",
        "ROB_HUNK_BODY_SPECIAL_SWAP_NAME": "Легіон",
        "ROB_HUNK_BODY_SPECIAL_SWAP_DESCRIPTION": "<style=cIsUtility>Поміняйте</style> на <style=cIsDamage>іншу зброю</style>. Торкніться, щоб змінити на свою <style=cIsUtility>останню використану зброю</style>.",
        "ROB_HUNK_BODY_SPECIAL_MAYHEM_NAME": "Режим хаосу",
        "ROB_HUNK_BODY_SPECIAL_MAYHEM_DESCRIPTION": "Увійдіть у режим <style=cIsDamage>Chaos Mode</style>, різко підвищивши продуктивність зброї.",
        "ROB_HUNK_BODY_CONFIRM_NAME": "Підтвердити",
        "ROB_HUNK_BODY_CONFIRM_DESCRIPTION": "Продовжити з поточною здатністю.",
        "ROB_HUNK_BODY_CANCEL_NAME": "Скасувати",
        "ROB_HUNK_BODY_CANCEL_DESCRIPTION": "Скасувати поточну здатність.",
        "ROB_HUNK_BODY_KNIFE_DEFAULT_NAME": "Бойовий ніж",
        "ROB_HUNK_BODY_KNIFE_DEFAULT_DESCRIPTION": "Звичайний військовий ніж. Безумовно, корисний у вузьких місцях.",
        "ROB_HUNK_BODY_KNIFE_INFINITE_NAME": "Бойовий ніж EX",
        "ROB_HUNK_BODY_KNIFE_INFINITE_DESCRIPTION": "Спеціально оброблений військовий ніж загартований до неймовірної міри. Кажуть, що це справді довговічне.",
        "ROB_HUNK_BODY_KNIFE_HIDDEN_NAME": "Прихований клинок",
        "ROB_HUNK_BODY_KNIFE_HIDDEN_DESCRIPTION": "Низькопрофільний висувний клинок, захований у втулці. Ідеально підходить для стелс-операцій.",
        "ROB_HUNK_BODY_KNIFE_WESKER_NAME": "Ніж на замовлення",
        "ROB_HUNK_BODY_KNIFE_WESKER_DESCRIPTION": "Жорстоке лезо із зазубреним краєм допоможе розірвати супротивників.",
        "ROB_HUNK_BODY_KNIFE_MACHETE_NAME": "Мачете",
        "ROB_HUNK_BODY_KNIFE_MACHETE_DESCRIPTION": "Величезний клинок, призначений насамперед для партизанської тактики.",
        "ROB_HUNK_BODY_KNIFE_RE4_NAME": "Первинний ніж",
